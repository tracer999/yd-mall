<%- layout('user/mypage/layout') %>

<!-- 상단 요약 정보 -->
<div class="bg-white rounded-lg shadow p-6 mb-8 border border-gray-100">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
            <div class="w-16 h-16 bg-gray-200 rounded-full flex items-center justify-center text-2xl">
                👤
            </div>
            <div>
                <h3 class="text-lg font-semibold text-gray-800">안녕하세요, <span class="text-green-600"><%= user.name %></span>님!</h3>
                <p class="text-gray-500 text-sm mt-1"><%= user.email %></p>
            </div>
        </div>
        <div class="flex gap-8 text-center">
            <div>
                <div class="text-sm text-gray-500 mb-1">보유 포인트</div>
                <a href="/mypage/points" class="text-xl font-bold text-gray-800 hover:text-green-600">
                    <%= (pointsBalance || 0).toLocaleString() %> P
                </a>
            </div>
            <div>
                <div class="text-sm text-gray-500 mb-1">쿠폰</div>
                <a href="/mypage/coupons" class="text-xl font-bold text-gray-800 hover:text-green-600">
                    <%= couponCount || 0 %> 장
                </a>
            </div>
        </div>
    </div>
</div>

<!-- 주문 현황 -->
<div class="bg-white rounded-lg shadow p-6 mb-8 border border-gray-100">
    <h3 class="text-lg font-bold text-gray-800 mb-6">진행 중인 주문</h3>
    <div class="grid grid-cols-5 gap-2 text-center">
        <div class="group cursor-pointer">
            <div class="text-3xl font-bold text-gray-800 mb-2 group-hover:text-green-600 transition-colors"><%= stats.PENDING || 0 %></div>
            <div class="text-sm text-gray-500">입금대기</div>
        </div>
        <div class="group cursor-pointer">
            <div class="text-3xl font-bold text-gray-800 mb-2 group-hover:text-green-600 transition-colors"><%= stats.PAID || 0 %></div>
            <div class="text-sm text-gray-500">결제완료</div>
        </div>
        <div class="group cursor-pointer">
            <div class="text-3xl font-bold text-gray-800 mb-2 group-hover:text-green-600 transition-colors"><%= stats.PREPARING || 0 %></div>
            <div class="text-sm text-gray-500">배송준비</div>
        </div>
        <div class="group cursor-pointer">
            <div class="text-3xl font-bold text-gray-800 mb-2 group-hover:text-green-600 transition-colors"><%= stats.SHIPPED || 0 %></div>
            <div class="text-sm text-gray-500">배송중</div>
        </div>
        <div class="group cursor-pointer">
            <div class="text-3xl font-bold text-gray-800 mb-2 group-hover:text-green-600 transition-colors"><%= stats.DELIVERED || 0 %></div>
            <div class="text-sm text-gray-500">배송완료</div>
        </div>
    </div>
</div>

<!-- 최근 활동 -->
<div class="bg-white rounded-lg shadow overflow-hidden border border-gray-100 mb-8">
    <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
        <h3 class="text-lg font-bold text-gray-800">최근 활동</h3>
        <a href="/mypage/activities" class="text-sm text-gray-500 hover:text-green-600 font-medium">전체보기 ></a>
    </div>
    <% if (recentActivities.length === 0) { %>
        <div class="p-8 text-center text-gray-500 text-sm">
            최근 활동 내역이 없습니다.
        </div>
    <% } else { %>
        <div class="divide-y divide-gray-100">
            <% recentActivities.forEach(activity => { %>
                <% 
                    const activityLink = activity.type === 'review' 
                        ? '/products/' + activity.product_id + '#review' 
                        : '/inquiries/' + activity.id; 
                %>
                <div class="px-6 py-4 hover:bg-gray-50 transition cursor-pointer" onclick="location.href='<%= activityLink %>'">
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-xs font-semibold px-2 py-0.5 rounded <%= activity.type === 'review' ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800' %>"><%= activity.type === 'review' ? '리뷰' : '문의' %></span>
                        <span class="text-xs text-gray-400"><%= new Date(activity.created_at).toLocaleDateString() %></span>
                    </div>
                    <p class="text-gray-700 text-sm truncate"><%= activity.content %></p>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<!-- 최근 주문 내역 -->
<div class="bg-white rounded-lg shadow overflow-hidden border border-gray-100">
    <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
        <h3 class="text-lg font-bold text-gray-800">최근 주문 내역</h3>
        <a href="/mypage/orders" class="text-sm text-gray-500 hover:text-green-600 font-medium">전체보기 ></a>
    </div>
    <% if (recentOrders.length === 0) { %>
        <div class="p-12 text-center text-gray-500">
            최근 주문 내역이 없습니다.
        </div>
    <% } else { %>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-white text-gray-500 text-xs uppercase border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-3 font-medium">주문번호 / 일자</th>
                        <th class="px-6 py-3 font-medium">결제금액</th>
                        <th class="px-6 py-3 font-medium">상태</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% recentOrders.forEach(order => { %>
                        <tr class="hover:bg-gray-50 transition-colors cursor-pointer" onclick="location.href='/mypage/orders/<%= order.id %>'">
                            <td class="px-6 py-4">
                                <div class="font-medium text-gray-900">
                                    <a href="/mypage/orders/<%= order.id %>" class="hover:text-green-600 hover:underline" onclick="event.stopPropagation()">
                                        <%= order.id %>
                                    </a>
                                </div>
                                <div class="text-sm text-gray-500"><%= new Date(order.created_at).toLocaleDateString() %></div>
                            </td>
                            <td class="px-6 py-4 text-gray-900 font-medium">
                                <%= Number(order.total_amount).toLocaleString() %>원
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-full
                                    <%= order.status === 'PENDING' ? 'bg-yellow-100 text-yellow-800' :
                                       order.status === 'PAID' ? 'bg-blue-100 text-blue-800' :
                                       order.status === 'DELIVERED' ? 'bg-green-100 text-green-800' :
                                       order.status === 'CANCELLED' ? 'bg-red-100 text-red-800' :
                                       'bg-gray-100 text-gray-800' %>">
                                    <%= order.status %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>