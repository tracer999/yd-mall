<div class="p-6">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800">주문 상세 정보</h1>
        <a href="/admin/orders" class="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 transition">목록으로</a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Column -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Order Items -->
            <div class="bg-white rounded-xl shadow overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 font-bold text-gray-800">주문 상품</div>
                <div class="divide-y divide-gray-100">
                    <% items.forEach(item => { %>
                        <div class="p-6 flex gap-4 items-center">
                            <div class="w-16 h-16 bg-gray-100 rounded overflow-hidden flex-shrink-0">
                                <% if (item.thumbnail_image) { %>
                                    <img src="<%= item.thumbnail_image %>" class="w-full h-full object-cover">
                                <% } else { %>
                                    <div class="w-full h-full flex items-center justify-center text-gray-400 text-xs">No Image</div>
                                <% } %>
                            </div>
                            <div class="flex-1">
                                <div class="font-medium text-gray-900"><%= item.product_name %></div>
                                <div class="text-sm text-gray-500">
                                    <%= Number(item.product_price).toLocaleString() %>원 / <%= item.quantity %>개
                                </div>
                            </div>
                            <div class="font-bold text-gray-900">
                                <%= Number(item.total_price).toLocaleString() %>원
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Payment Info -->
            <div class="bg-white rounded-xl shadow overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 font-bold text-gray-800">결제 정보</div>
                <div class="p-6 space-y-2">
                    <div class="flex justify-between">
                        <span class="text-gray-600">상품 합계</span>
                        <span><%= Number(order.subtotal_amount).toLocaleString() %>원</span>
                    </div>
                    <% if (order.coupon_discount > 0) { %>
                        <div class="flex justify-between text-red-600">
                            <span>쿠폰 할인</span>
                            <span>-<%= Number(order.coupon_discount).toLocaleString() %>원</span>
                        </div>
                    <% } %>
                    <% if (order.point_used > 0) { %>
                        <div class="flex justify-between text-red-600">
                            <span>포인트 사용</span>
                            <span>-<%= Number(order.point_used).toLocaleString() %>원</span>
                        </div>
                    <% } %>
                    <div class="flex justify-between pt-2 border-t font-bold text-lg">
                        <span>총 결제금액</span>
                        <span class="text-blue-600"><%= Number(order.total_amount).toLocaleString() %>원</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="space-y-6">
            <!-- Status & Action -->
            <div class="bg-white rounded-xl shadow overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 font-bold text-gray-800">주문 상태</div>
                <div class="p-6">
                    <form action="/admin/orders/<%= order.id %>/status" method="POST">
                        <label class="block text-sm font-medium text-gray-700 mb-2">상태 변경</label>
                        <div class="flex gap-2">
                            <select name="status" class="flex-1 border-gray-300 rounded focus:ring-blue-500 focus:border-blue-500">
                                <% const statuses = ['PENDING', 'PAID', 'PREPARING', 'SHIPPED', 'DELIVERED', 'CANCELLED', 'REFUNDED']; %>
                                <% const statusLabels = { 'PENDING': '입금대기', 'PAID': '결제완료', 'PREPARING': '배송준비', 'SHIPPED': '배송중', 'DELIVERED': '배송완료', 'CANCELLED': '취소', 'REFUNDED': '환불' }; %>
                                <% statuses.forEach(st => { %>
                                    <option value="<%= st %>" <%= order.status === st ? 'selected' : '' %>>
                                        <%= statusLabels[st] || st %>
                                    </option>
                                <% }) %>
                            </select>
                            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition">변경</button>
                        </div>
                    </form>
                    
                    <% if (order.status !== 'CANCELLED' && order.status !== 'REFUNDED') { %>
                        <div class="mt-6 pt-6 border-t border-gray-100">
                            <form action="/admin/orders/<%= order.id %>/cancel" method="POST" onsubmit="return confirm('주문을 취소하고 재고를 복구하시겠습니까?');">
                                <label class="block text-sm font-bold text-red-600 mb-2">주문 취소 (재고 복구)</label>
                                <div class="mb-2">
                                    <select onchange="const input = this.form.querySelector('input[name=cancel_reason]'); if(this.value) input.value = this.value; else { input.value = ''; input.focus(); }" class="w-full border-gray-300 rounded text-sm focus:ring-red-500 focus:border-red-500">
                                        <option value="">사유 선택 (직접 입력)</option>
                                        <option value="단순변심">단순변심</option>
                                        <option value="주문실수">주문실수</option>
                                        <option value="배송지연">배송지연</option>
                                        <option value="재고부족">재고부족</option>
                                        <option value="서비스불만">서비스불만</option>
                                    </select>
                                </div>
                                <div class="flex gap-2">
                                    <input type="text" name="cancel_reason" placeholder="취소 사유를 입력하세요" class="flex-1 border-gray-300 rounded text-sm focus:ring-red-500 focus:border-red-500" required>
                                    <button type="submit" class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 transition text-sm font-medium whitespace-nowrap">주문 취소</button>
                                </div>
                                <p class="text-xs text-gray-500 mt-1">* 주문을 취소하면 상품 재고가 자동으로 복구됩니다.</p>
                            </form>
                        </div>
                    <% } %>

                    <% if (order.cancel_reason) { %>
                        <div class="mt-4 p-3 bg-red-50 text-red-700 text-sm rounded">
                            <strong>취소 사유:</strong> <%= order.cancel_reason %>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Delivery Info -->
            <div class="bg-white rounded-xl shadow overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 font-bold text-gray-800">배송 정보 (송장)</div>
                <div class="p-6">
                    <form action="/admin/orders/<%= order.id %>/tracking" method="POST">
                        <div class="mb-3">
                            <label class="block text-sm font-medium text-gray-700 mb-1">택배사</label>
                            <select name="courier_company" class="w-full border-gray-300 rounded text-sm focus:ring-blue-500 focus:border-blue-500">
                                <option value="">선택하세요</option>
                                <% const couriers = ['CJ대한통운', '우체국택배', '한진택배', '롯데택배', '로젠택배']; %>
                                <% couriers.forEach(c => { %>
                                    <option value="<%= c %>" <%= (shipment && shipment.courier_company === c) ? 'selected' : '' %>><%= c %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="block text-sm font-medium text-gray-700 mb-1">송장번호</label>
                            <input type="text" name="tracking_number" value="<%= shipment ? shipment.tracking_number : '' %>" class="w-full border-gray-300 rounded text-sm focus:ring-blue-500 focus:border-blue-500" placeholder="숫자만 입력">
                        </div>
                        <button type="submit" class="w-full bg-green-600 text-white py-2 rounded hover:bg-green-700 transition text-sm font-medium">운송장 저장</button>
                    </form>
                </div>
            </div>

            <!-- Buyer & Receiver -->
            <div class="bg-white rounded-xl shadow overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 font-bold text-gray-800">주문자 / 배송지</div>
                <div class="p-6 space-y-4">
                    <div>
                        <h4 class="text-sm font-bold text-gray-700 mb-1">
                            주문자
                            <% if (order.user_id) { %>
                                <a href="/admin/orders?user_id=<%= order.user_id %>" class="ml-2 text-xs text-blue-600 hover:underline font-normal">해당 회원의 주문 내역 보기</a>
                            <% } %>
                        </h4>
                        <p class="text-gray-600"><%= order.buyer_name %> (<%= order.buyer_phone %>)</p>
                        <p class="text-gray-500 text-sm"><%= order.buyer_email %></p>
                    </div>
                    <hr>
                    <div>
                        <h4 class="text-sm font-bold text-gray-700 mb-1">받는 분</h4>
                        <p class="text-gray-600"><%= order.receiver_name %> (<%= order.receiver_phone %>)</p>
                        <p class="text-gray-600 text-sm mt-1">
                            (<%= order.receiver_zipcode %>) <%= order.receiver_address %> <%= order.receiver_detailed_address %>
                        </p>
                        <% if (order.shipping_message) { %>
                            <p class="text-gray-500 text-sm mt-2 bg-gray-50 p-2 rounded">
                                " <%= order.shipping_message %> "
                            </p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>