<%- layout('layouts/main_layout') %>

<div class="max-w-4xl mx-auto px-4 py-10">
    <div class="mb-6">
        <a href="/boards/<%= type %>" class="text-gray-500 hover:text-gray-900 transition">&larr; 목록으로</a>
    </div>

    <div class="bg-white rounded-xl shadow p-8 border border-gray-100">
        <h1 class="text-2xl font-bold text-gray-900 mb-4"><%= post.title %></h1>
        <div class="flex justify-between text-sm text-gray-500 border-b border-gray-100 pb-4 mb-6">
            <span><%= new Date(post.created_at).toLocaleString() %></span>
            <span>조회 <%= post.view_count %></span>
        </div>
        <div class="prose max-w-none text-gray-700 leading-relaxed">
            <%- post.content %>
        </div>
    </div>
</div>