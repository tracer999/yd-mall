{
  "name": "dev_mall",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon",
    "start": "node app.js",
    "start:prod": "cross-env NODE_ENV=production node app.js",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/style.css",
    "watch:css": "tailwindcss -i ./public/css/input.css -o ./public/css/style.css --watch",
    "dev:all": "concurrently \"npm run watch:css\" \"cross-env NODE_ENV=development npm run dev\"",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:start:dev": "pm2 start ecosystem.config.cjs --env development",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --env production --update-env",
    "pm2:restart:dev": "pm2 restart ecosystem.config.cjs --env development --update-env",
    "init:db": "node scripts/init_db.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.19.0",
    "marked": "^17.0.1",
    "multer": "^2.0.2",
    "mysql2": "^3.16.3",
    "nodemailer": "^8.0.0",
    "openai": "^6.18.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-kakao": "^1.0.1",
    "passport-local": "^1.0.0",
    "passport-naver-v2": "^2.0.8",
    "png-to-ico": "^3.0.1",
    "redis": "^5.10.0",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.34.5",
    "sitemap": "^9.0.1",
    "tinymce": "^8.4.0",
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.11",
    "tailwindcss": "^4.1.18"
  }
}
