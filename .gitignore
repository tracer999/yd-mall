# ===== yd-mall (Express / Node.js) =====

# 의존성
node_modules/

# 환경 변수 — 비공개 저장소이므로 추적함 (루트 .gitignore의 .env 무시를 여기서 해제)
!.env
!.env.development
!.env.production
# 단, 개인용 로컬 오버라이드는 추적하지 않음
.env.local
.env.*.local

# 로그
logs/
*.log
npm-debug.log*

# 빌드 캐시 / 임시
.cache/
tmp/

# 작업용 임시 스크립트 (_verify_tmp.sh, _dbcheck_tmp.js 등)
_*_tmp.*
_*tmp*.sh
_*tmp*.js

# PM2 런타임
.pm2/

# OS / 에디터
.DS_Store
*.swp

# 루트의 작업용 임시 스크립트 전부 무시 (_c2.sh, _m1_tmp.sh 등)
/_*

# Playwright MCP 산출물(스냅샷·스크린샷)
/.playwright-mcp/

# 업로드 이미지 — 런타임 산출물이라 추적하지 않는다.
# 이미 추적 중인 기존 파일은 그대로 둔다: 인덱스에서 빼면 배포 서버의
# `git reset --hard origin/main` 이 서버 디스크의 이미지까지 지운다.
/public/uploads/
