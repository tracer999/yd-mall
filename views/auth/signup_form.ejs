<%
/*
 * 자체 회원가입 (이메일 + 비밀번호).
 * 상세정보·약관 블록은 소셜 가입 후 추가정보 화면(auth/signup_finish.ejs)과 같은 partial 을 쓴다.
 */
const v = locals.values || {};
const err = locals.errors || {};
const hasErrors = Object.keys(err).length > 0;
const inputClass = (field) => `appearance-none block w-full px-3 py-2 border rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm ${err[field] ? 'border-red-400 bg-red-50' : 'border-gray-300'}`;
%>
<div class="bg-gray-50 py-10 px-4 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-lg text-center">
    <h2 class="text-3xl font-extrabold text-gray-900">회원가입</h2>
    <p class="mt-2 text-sm text-gray-600">주문·배송에 필요한 정보를 한 번에 입력해주세요.</p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-lg">
    <!-- 간편 가입 -->
    <div class="bg-white py-6 px-4 shadow sm:rounded-lg sm:px-10">
      <%- include('./_social_buttons', { providers: providers, ctaPrefix: '회원가입' }) %>
      <p class="mt-3 text-center text-xs text-gray-500">간편 가입 후에도 주문·배송 정보를 한 번 입력받습니다.</p>
    </div>

    <div class="relative my-6">
      <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
      <div class="relative flex justify-center"><span class="bg-gray-50 px-3 text-xs text-gray-400">또는 이메일로 가입</span></div>
    </div>

    <!-- 이메일 가입폼 -->
    <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
      <% if (hasErrors) { %>
        <div class="rounded-md bg-red-50 border border-red-200 p-4 mb-6">
          <p class="text-sm font-medium text-red-800">입력값을 확인해주세요.</p>
        </div>
      <% } %>

      <form id="signup-form" class="space-y-6" action="/auth/signup" method="POST" novalidate>
        <!-- 계정 -->
        <div class="space-y-4">
          <h3 class="text-sm font-bold text-gray-900 border-l-4 border-green-600 pl-2">로그인 계정</h3>
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700">비밀번호 <span class="text-red-500">*</span></label>
            <input id="password" name="password" type="password" autocomplete="new-password" required
                   class="mt-1 <%= inputClass('password') %>" />
            <% if (err.password) { %><p class="mt-1 text-xs text-red-500"><%= err.password %></p><% } %>
            <p class="mt-1 text-xs text-gray-500">8자 이상, 영문과 숫자를 모두 포함해주세요.</p>
          </div>
          <div>
            <label for="password_confirm" class="block text-sm font-medium text-gray-700">비밀번호 확인 <span class="text-red-500">*</span></label>
            <input id="password_confirm" name="password_confirm" type="password" autocomplete="new-password" required
                   class="mt-1 <%= inputClass('password_confirm') %>" />
            <% if (err.password_confirm) { %><p class="mt-1 text-xs text-red-500"><%= err.password_confirm %></p><% } %>
          </div>
          <p class="text-xs text-gray-500">아이디로 사용할 이메일은 아래 기본 정보에서 입력합니다.</p>
        </div>

        <div class="pt-6 mt-6 border-t border-gray-100">
          <%- include('./_profile_fields', { values: v, errors: err, needsEmail: true }) %>
        </div>

        <%- include('./_terms_agreement', { values: v, errors: err, termsContent: termsContent, privacyContent: privacyContent }) %>

        <button type="submit"
                class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors">
          가입하기
        </button>
      </form>
    </div>

    <p class="mt-6 text-center text-sm text-gray-600">
      이미 회원이신가요?
      <a href="/auth/login" class="font-semibold text-green-700 hover:text-green-800 underline underline-offset-2">로그인</a>
    </p>
  </div>
</div>
