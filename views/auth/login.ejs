<% const v = locals.values || {}; %>
<div class="flex justify-center bg-gray-50 pt-10 md:pt-20 pb-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full bg-white px-8 py-10 rounded-2xl shadow-xl">
    <div class="text-center">
      <% if (typeof siteSettings !== 'undefined' && siteSettings.logo_image) { %>
        <img src="<%= siteSettings.logo_image %>" alt="<%= siteSettings.company_name || '와이디몰' %>" class="h-10 mx-auto mb-4">
      <% } %>
      <h2 class="text-3xl font-extrabold text-gray-900">로그인</h2>
      <p class="mt-3 text-base font-semibold text-gray-700">건강한 하루의 시작, 와이디몰</p>
    </div>

    <% if (locals.errorMessage) { %>
      <div class="mt-6 rounded-md bg-red-50 border border-red-200 p-3">
        <p class="text-sm text-red-700"><%= errorMessage %></p>
      </div>
    <% } %>

    <!-- 이메일 로그인 -->
    <form class="mt-8 space-y-4" action="/auth/login" method="POST">
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700">이메일</label>
        <input id="email" name="email" type="email" autocomplete="email" required value="<%= v.email || '' %>"
               class="mt-1 appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
               placeholder="example@email.com" />
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-gray-700">비밀번호</label>
        <input id="password" name="password" type="password" autocomplete="current-password" required
               class="mt-1 appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm" />
      </div>
      <button type="submit"
              class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors">
        로그인
      </button>
    </form>

    <p class="mt-4 text-center text-sm text-gray-600">
      아직 회원이 아니신가요?
      <a href="/auth/signup" class="font-semibold text-green-700 hover:text-green-800 underline underline-offset-2">이메일로 회원가입</a>
    </p>

    <!-- 소셜 로그인 -->
    <div class="relative my-7">
      <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
      <div class="relative flex justify-center"><span class="bg-white px-3 text-xs text-gray-400">간편 로그인</span></div>
    </div>

    <%- include('./_social_buttons', { providers: providers, ctaPrefix: '로그인' }) %>

    <p class="mt-6 text-center text-xs text-gray-400">
      소셜 계정으로 처음 로그인하면 주문·배송에 필요한 정보를 한 번 더 입력받습니다.
    </p>
  </div>
</div>
