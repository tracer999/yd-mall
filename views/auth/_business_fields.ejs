<%
/*
 * 사업자 정보 입력 블록 (설계 §3.2).
 *
 * 두 경로가 이 파일 하나를 공유한다:
 *   - 사업자 회원가입   : /auth/signup?type=biz
 *   - 사업자 전환 신청  : /b2b/apply   (이미 가입한 일반회원)
 * name 속성이 services/b2b/businessProfileService.normalizeBusinessInput 과 1:1 로 맞아야 한다.
 *
 * ⚠️ 이 블록을 쓰는 form 은 enctype="multipart/form-data" 여야 한다(등록증 첨부).
 */
const b = locals.bizValues || {};
const bErr = locals.bizErrors || {};
const bizInput = (field) => `appearance-none block w-full px-3 py-2 border rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm ${bErr[field] ? 'border-red-400 bg-red-50' : 'border-gray-300'}`;
const requireLicense = locals.requireLicense !== false;
%>

<div class="space-y-4">
  <h3 class="text-sm font-bold text-gray-900 border-l-4 border-blue-600 pl-2">사업자 정보</h3>
  <p class="text-xs text-gray-500">
    입력하신 내용은 첨부하신 사업자등록증과 대조해 확인합니다. 승인 후 기업 전용가를 이용하실 수 있습니다.
  </p>

  <div>
    <label for="company_name" class="block text-sm font-medium text-gray-700">상호 <span class="text-red-500">*</span></label>
    <input id="company_name" name="company_name" type="text" value="<%= b.company_name || '' %>"
           class="mt-1 <%= bizInput('company_name') %>" placeholder="(주)와이디유통" />
    <% if (bErr.company_name) { %><p class="mt-1 text-xs text-red-500"><%= bErr.company_name %></p><% } %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="business_number" class="block text-sm font-medium text-gray-700">사업자등록번호 <span class="text-red-500">*</span></label>
      <input id="business_number" name="business_number" type="text" inputmode="numeric"
             value="<%= b.business_number || '' %>" class="mt-1 <%= bizInput('business_number') %>"
             placeholder="000-00-00000" maxlength="12" />
      <% if (bErr.business_number) { %><p class="mt-1 text-xs text-red-500"><%= bErr.business_number %></p><% } %>
    </div>
    <div>
      <label for="representative_name" class="block text-sm font-medium text-gray-700">대표자명 <span class="text-red-500">*</span></label>
      <input id="representative_name" name="representative_name" type="text" value="<%= b.representative_name || '' %>"
             class="mt-1 <%= bizInput('representative_name') %>" />
      <% if (bErr.representative_name) { %><p class="mt-1 text-xs text-red-500"><%= bErr.representative_name %></p><% } %>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="business_type" class="block text-sm font-medium text-gray-700">업태 <span class="text-red-500">*</span></label>
      <input id="business_type" name="business_type" type="text" value="<%= b.business_type || '' %>"
             class="mt-1 <%= bizInput('business_type') %>" placeholder="도매 및 소매업" />
      <% if (bErr.business_type) { %><p class="mt-1 text-xs text-red-500"><%= bErr.business_type %></p><% } %>
    </div>
    <div>
      <label for="business_category" class="block text-sm font-medium text-gray-700">종목 <span class="text-red-500">*</span></label>
      <input id="business_category" name="business_category" type="text" value="<%= b.business_category || '' %>"
             class="mt-1 <%= bizInput('business_category') %>" placeholder="건강기능식품" />
      <% if (bErr.business_category) { %><p class="mt-1 text-xs text-red-500"><%= bErr.business_category %></p><% } %>
    </div>
  </div>

  <div>
    <label for="company_address" class="block text-sm font-medium text-gray-700">사업장 주소</label>
    <div class="mt-1 flex gap-2">
      <input id="company_zipcode" name="company_zipcode" type="text" readonly value="<%= b.company_zipcode || '' %>"
             class="w-32 <%= bizInput('company_zipcode') %> bg-gray-50" placeholder="우편번호" />
      <button type="button" onclick="findCompanyAddress()"
              class="shrink-0 px-4 py-2 text-sm font-medium rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">
        주소 찾기
      </button>
    </div>
    <input id="company_address" name="company_address" type="text" readonly value="<%= b.company_address || '' %>"
           class="mt-2 <%= bizInput('company_address') %> bg-gray-50" placeholder="기본 주소" />
    <input id="company_detailed_address" name="company_detailed_address" type="text" value="<%= b.company_detailed_address || '' %>"
           class="mt-2 <%= bizInput('company_detailed_address') %>" placeholder="상세 주소" />
  </div>

  <div>
    <label for="tax_invoice_email" class="block text-sm font-medium text-gray-700">세금계산서 수신 이메일 <span class="text-red-500">*</span></label>
    <input id="tax_invoice_email" name="tax_invoice_email" type="email" value="<%= b.tax_invoice_email || '' %>"
           class="mt-1 <%= bizInput('tax_invoice_email') %>" placeholder="tax@company.co.kr" />
    <% if (bErr.tax_invoice_email) { %><p class="mt-1 text-xs text-red-500"><%= bErr.tax_invoice_email %></p><% } %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="manager_name" class="block text-sm font-medium text-gray-700">담당자명 <span class="text-red-500">*</span></label>
      <input id="manager_name" name="manager_name" type="text" value="<%= b.manager_name || '' %>"
             class="mt-1 <%= bizInput('manager_name') %>" />
      <% if (bErr.manager_name) { %><p class="mt-1 text-xs text-red-500"><%= bErr.manager_name %></p><% } %>
    </div>
    <div>
      <label for="manager_phone" class="block text-sm font-medium text-gray-700">담당자 연락처 <span class="text-red-500">*</span></label>
      <input id="manager_phone" name="manager_phone" type="tel" inputmode="numeric" value="<%= b.manager_phone || '' %>"
             class="mt-1 <%= bizInput('manager_phone') %>" placeholder="숫자만 입력" />
      <% if (bErr.manager_phone) { %><p class="mt-1 text-xs text-red-500"><%= bErr.manager_phone %></p><% } %>
    </div>
  </div>

  <div>
    <label for="license_file" class="block text-sm font-medium text-gray-700">
      사업자등록증 사본 <% if (requireLicense) { %><span class="text-red-500">*</span><% } %>
    </label>
    <input id="license_file" name="license_file" type="file" accept="image/*,application/pdf"
           class="mt-1 block w-full text-sm text-gray-600 file:mr-3 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
    <% if (bErr.license_file) { %><p class="mt-1 text-xs text-red-500"><%= bErr.license_file %></p><% } %>
    <p class="mt-1 text-xs text-gray-500">
      이미지 또는 PDF, 10MB 이하.
      <% if (!requireLicense) { %>다시 올리지 않으면 기존 파일이 유지됩니다.<% } %>
    </p>
  </div>
</div>

<script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
<script>
  function findCompanyAddress() {
    new daum.Postcode({
      oncomplete: function (data) {
        document.getElementById('company_zipcode').value = data.zonecode;
        document.getElementById('company_address').value = data.roadAddress || data.jibunAddress;
        document.getElementById('company_detailed_address').focus();
      }
    }).open();
  }
</script>
