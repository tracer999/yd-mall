<div class="mb-6 flex justify-between items-center">
  <div>
    <p class="text-sm text-gray-500">선택한 버전의 전체 내용을 확인합니다.</p>
  </div>
  <a href="/admin/policies" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">목록으로</a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-4">
  <div class="flex flex-wrap gap-4 items-center justify-between">
    <div class="space-y-1 text-sm text-gray-700">
      <p><span class="font-medium">종류:</span>
        <% if (policy.type === 'TERMS') { %>
          이용약관
        <% } else { %>
          개인정보 처리방침
        <% } %>
      </p>
      <p><span class="font-medium">버전:</span> <%= policy.version %></p>
      <p><span class="font-medium">시행일:</span> <%= new Date(policy.effective_date).toLocaleDateString() %></p>
      <p><span class="font-medium">작성일:</span> <%= new Date(policy.created_at).toLocaleDateString() %></p>
    </div>
    <div class="space-x-2">
      <a href="/admin/policies/<%= policy.id %>/edit" class="inline-flex items-center justify-center h-[50px] px-6 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정하기</a>
    </div>
  </div>

  <div class="border-t border-gray-200 pt-4">
    <h3 class="text-sm font-semibold text-gray-700 mb-2">내용</h3>
    <div class="prose max-w-none text-sm text-gray-800">
      <%- policy.content %>
    </div>
  </div>
</div>
