<div class="mb-6 flex justify-between items-center">
    <div>
        <p class="text-sm text-gray-500">이용약관 및 개인정보 처리방침의 버전을 관리합니다.</p>
    </div>
    <a href="/admin/policies/create"
        class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 no-underline gap-2 whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd"
                d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"
                clip-rule="evenodd" />
        </svg>
        새 버전 등록
    </a>
</div>

<div class="bg-gray-50 border-b border-gray-200 px-1 mb-6">
    <nav class="-mb-px flex space-x-8" aria-label="Tabs">
        <button onclick="switchTab('terms')" id="tab-terms" type="button"
            class="whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm border-blue-500 text-blue-600 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 focus:ring-blue-500">
            이용약관
        </button>
        <button onclick="switchTab('privacy')" id="tab-privacy" type="button"
            class="whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 focus:ring-blue-500">
            개인정보 처리방침
        </button>
    </nav>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">

    <!-- TERMS LIST -->
    <div id="content-terms" class="p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">이용약관 버전 목록</h3>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">버전
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">시행일
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">작성일
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">관리
                        </th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <% if (termsVersions && termsVersions.length> 0) { %>
                        <% termsVersions.forEach(version=> { %>
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                    <%= version.version %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <%= new Date(version.effective_date).toLocaleDateString() %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if (version.is_active) { %>
                                        <span
                                            class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                            시행 중
                                        </span>
                                        <% } else { %>
                                            <span
                                                class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
                                                종료
                                            </span>
                                            <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <%= new Date(version.created_at).toLocaleDateString() %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <div class="flex flex-wrap items-center justify-end gap-2">
                                        <a href="/admin/policies/<%= version.id %>" class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 border border-indigo-200 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 no-underline">보기</a>
                                        <a href="/admin/policies/<%= version.id %>/edit" class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정</a>
                                        <% if (!version.is_active) { %>
                                        <form action="/admin/policies/<%= version.id %>/active" method="POST" class="inline">
                                            <input type="hidden" name="type" value="TERMS">
                                            <button type="submit" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 border border-green-200 bg-green-50 text-green-700 hover:bg-green-100" onclick="return confirm('이 버전을 즉시 시행하시겠습니까?')">시행하기</button>
                                        </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="px-6 py-4 text-center text-sm text-gray-500">등록된 버전이
                                            없습니다.</td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- PRIVACY LIST -->
    <div id="content-privacy" class="p-6 hidden">
        <h3 class="text-lg font-medium text-gray-900 mb-4">개인정보 처리방침 버전 목록</h3>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">버전
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">시행일
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">작성일
                        </th>
                        <th scope="col"
                            class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">관리
                        </th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <% if (privacyVersions && privacyVersions.length> 0) { %>
                        <% privacyVersions.forEach(version=> { %>
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                    <%= version.version %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <%= new Date(version.effective_date).toLocaleDateString() %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <% if (version.is_active) { %>
                                        <span
                                            class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                            시행 중
                                        </span>
                                        <% } else { %>
                                            <span
                                                class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
                                                종료
                                            </span>
                                            <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <%= new Date(version.created_at).toLocaleDateString() %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <div class="flex flex-wrap items-center justify-end gap-2">
                                        <a href="/admin/policies/<%= version.id %>" class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 border border-indigo-200 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 no-underline">보기</a>
                                        <a href="/admin/policies/<%= version.id %>/edit" class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정</a>
                                        <% if (!version.is_active) { %>
                                        <form action="/admin/policies/<%= version.id %>/active" method="POST" class="inline">
                                            <input type="hidden" name="type" value="PRIVACY">
                                            <button type="submit" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 border border-green-200 bg-green-50 text-green-700 hover:bg-green-100" onclick="return confirm('이 버전을 즉시 시행하시겠습니까?')">시행하기</button>
                                        </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="px-6 py-4 text-center text-sm text-gray-500">등록된 버전이
                                            없습니다.</td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    const tabActiveClass = 'whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm border-blue-500 text-blue-600 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 focus:ring-blue-500';
    const tabInactiveClass = 'whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 focus:ring-blue-500';

    function switchTab(tab) {
        const termsBtn = document.getElementById('tab-terms');
        const privacyBtn = document.getElementById('tab-privacy');
        const termsContent = document.getElementById('content-terms');
        const privacyContent = document.getElementById('content-privacy');

        if (tab === 'terms') {
            termsBtn.className = tabActiveClass;
            privacyBtn.className = tabInactiveClass;
            termsContent.classList.remove('hidden');
            privacyContent.classList.add('hidden');
        } else {
            privacyBtn.className = tabActiveClass;
            termsBtn.className = tabInactiveClass;
            privacyContent.classList.remove('hidden');
            termsContent.classList.add('hidden');
        }
    }
</script>