<div class="mb-6">
  <p class="text-sm text-gray-500">선택한 버전의 내용과 메타 정보를 수정합니다. 활성/비활성 전환은 목록 화면의 "시행하기" 버튼으로 관리합니다.</p>
</div>

<form action="/admin/policies/<%= policy.id %>/edit" method="POST" class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">약관 종류</label>
      <input type="text" value="<%= policy.type === 'TERMS' ? '이용약관' : '개인정보 처리방침' %>" disabled
             class="bg-gray-50 text-gray-600">
    </div>
    <div>
      <label for="version" class="block text-sm font-medium text-gray-700 mb-1">버전 명</label>
      <input type="text" name="version" id="version" value="<%= policy.version %>" required>
    </div>
    <div>
      <label for="effective_date" class="block text-sm font-medium text-gray-700 mb-1">시행일</label>
      <input type="date" name="effective_date" id="effective_date" value="<%= policy.effective_date.toISOString().split('T')[0] %>" required>
    </div>
    <div class="flex items-center pt-6 text-sm text-gray-600">
      <% if (policy.is_active) { %>
        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800 mr-2">현재 시행 중</span>
        <span>시행 상태 변경은 목록 화면에서 "시행하기" 버튼으로 관리합니다.</span>
      <% } else { %>
        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800 mr-2">종료 상태</span>
        <span>이 버전을 시행하려면 목록 화면에서 "시행하기"를 눌러주세요.</span>
      <% } %>
    </div>
  </div>

  <div class="mb-6">
    <label for="content" class="block text-sm font-medium text-gray-700 mb-1">약관 내용</label>
    <textarea name="content" id="content" rows="20"><%- policy.content %></textarea>
  </div>

  <div class="flex justify-end gap-3">
    <a href="/admin/policies" class="inline-flex items-center justify-center h-[50px] px-6 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline min-w-[120px]">취소</a>
    <button type="submit" class="inline-flex items-center justify-center h-[50px] px-6 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 min-w-[120px]">저장하기</button>
  </div>
</form>

<script src="https://cdn.tiny.cloud/1/<%= tinymceKey %>/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
<script>
  tinymce.init({
    selector: '#content',
    branding: false,
    plugins: 'anchor autolink charmap codesample code emoticons image link lists media searchreplace table visualblocks wordcount',
    toolbar: 'undo redo | blocks fontfamily fontsize | bold italic underline strikethrough | link image media table | align lineheight | numlist bullist indent outdent | emoticons charmap | code removeformat',
  });
</script>
