<%
  /*
   * 아울렛 카테고리 관리
   *
   * 저장소는 categories 테이블이고 type = 'OUTLET' 로 구분된다(별도 테이블 아님).
   * 그래서 여기 보이는 목록은 이미 type 스코프가 걸린 결과다 — 일반 카테고리는 절대 나타나지 않는다.
   */
  const _items = categories || [];
  const byParent = new Map();
  _items.forEach((c) => {
    const key = c.parent_id || 0;
    if (!byParent.has(key)) byParent.set(key, []);
    byParent.get(key).push(c);
  });
  const roots = byParent.get(0) || [];
%>

<div class="w-full">

  <div class="mb-6">
    <a href="/admin/outlet" class="text-sm text-gray-500 hover:text-gray-700 no-underline">
      <i class="bi bi-arrow-left mr-1"></i> 아울렛 관리
    </a>
    <h1 class="mt-2 text-2xl font-bold text-gray-900"><%= title %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= subtitle %></p>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <%# ── 등록 ─────────────────────────────────────────── %>
  <div class="mb-6 bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-base font-bold text-gray-900 mb-4">카테고리 등록</h2>
    <form method="POST" action="/admin/outlet/categories/add" class="flex flex-wrap items-end gap-3">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-semibold text-gray-600 mb-1.5">카테고리명</label>
        <input type="text" name="name" required maxlength="50" placeholder="예: 시즌오프 의류"
               class="w-full h-[38px] px-3 rounded-md border border-gray-200 text-sm">
      </div>
      <div class="w-48">
        <label class="block text-xs font-semibold text-gray-600 mb-1.5">상위 카테고리</label>
        <select name="parent_id" class="w-full h-[38px] px-3 rounded-md border border-gray-200 text-sm">
          <option value="">최상위</option>
          <% _items.filter(c => c.depth < maxDepth).forEach(function (c) { %>
            <option value="<%= c.id %>"><%= '　'.repeat(Math.max(c.depth - 1, 0)) %><%= c.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="w-24">
        <label class="block text-xs font-semibold text-gray-600 mb-1.5">순서</label>
        <input type="number" name="display_order" value="0"
               class="w-full h-[38px] px-3 rounded-md border border-gray-200 text-sm">
      </div>
      <button type="submit" class="h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
        추가
      </button>
    </form>
    <p class="mt-3 text-xs text-gray-500">최대 <%= maxDepth %>뎁스까지 만들 수 있습니다.</p>
  </div>

  <%# ── 목록 ─────────────────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
            <th class="px-4 py-2.5">카테고리</th>
            <th class="px-4 py-2.5 w-24 text-center">상품</th>
            <th class="px-4 py-2.5 w-20 text-center">순서</th>
            <th class="px-4 py-2.5 w-20 text-center">활성</th>
            <th class="px-4 py-2.5 w-40 text-center">관리</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (_items.length === 0) { %>
            <tr><td colspan="5" class="px-6 py-16 text-center text-gray-500">
              <p class="mb-2">아울렛 카테고리가 없습니다.</p>
              <p class="text-xs text-gray-400">
                할인 사유(시즌오프·리퍼브 등)와는 별개입니다. 여기는 <strong>상품 분류</strong>입니다.
                예: 의류 / 신발 / 가방 / 가전
              </p>
            </td></tr>
          <% } %>
          <% _items.forEach(function (c) { %>
            <tr class="<%= c.is_active ? '' : 'bg-gray-50/60' %>">
              <td class="px-4 py-3">
                <form method="POST" action="/admin/outlet/categories/<%= c.id %>/edit" class="flex items-center gap-2"
                      id="catForm<%= c.id %>">
                  <span class="text-gray-300 text-xs" style="padding-left: <%= (c.depth - 1) * 16 %>px">
                    <%= c.depth > 1 ? '└' : '' %>
                  </span>
                  <input type="text" name="name" value="<%= c.name %>" maxlength="50"
                         class="flex-1 h-[32px] px-2 rounded border border-transparent hover:border-gray-200 focus:border-indigo-400 text-sm">
                  <select name="parent_id" class="h-[32px] px-2 rounded border border-gray-200 text-xs w-32">
                    <option value="">최상위</option>
                    <% _items.filter(p => p.id !== c.id && p.depth < maxDepth).forEach(function (p) { %>
                      <option value="<%= p.id %>" <%= c.parent_id === p.id ? 'selected' : '' %>><%= p.name %></option>
                    <% }); %>
                  </select>
                </form>
              </td>
              <td class="px-4 py-3 text-center text-gray-600"><%= c.product_count %></td>
              <td class="px-4 py-3 text-center">
                <input type="number" name="display_order" value="<%= c.display_order %>" form="catForm<%= c.id %>"
                       class="w-16 h-[32px] px-2 rounded border border-gray-200 text-sm text-center">
              </td>
              <td class="px-4 py-3 text-center">
                <select name="is_active" form="catForm<%= c.id %>"
                        class="h-[32px] px-2 rounded border border-gray-200 text-xs">
                  <option value="1" <%= c.is_active ? 'selected' : '' %>>활성</option>
                  <option value="0" <%= !c.is_active ? 'selected' : '' %>>비활성</option>
                </select>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1.5">
                  <button type="submit" form="catForm<%= c.id %>"
                          class="text-xs px-2 py-1 rounded border border-gray-200 text-gray-700 hover:bg-gray-50">저장</button>
                  <form method="POST" action="/admin/outlet/categories/<%= c.id %>/delete"
                        onsubmit="return confirm('카테고리 &quot;<%= c.name %>&quot; 을(를) 삭제합니다.\n연결된 아울렛 상품은 미분류로 남습니다.');">
                    <button type="submit" class="text-xs px-2 py-1 rounded border border-red-200 text-red-600 hover:bg-red-50">삭제</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <p class="mt-6 text-xs text-gray-400 leading-relaxed">
    <strong>카테고리와 할인 사유는 다릅니다.</strong>
    카테고리는 <em>무슨 상품인가</em>(의류·신발·가전), 할인 사유는 <em>왜 싼가</em>(시즌오프·리퍼브)입니다.
    고객은 두 축으로 함께 탐색합니다.
    하위 카테고리가 있는 카테고리는 삭제할 수 없습니다 — 하위가 조용히 최상위로 올라가는 것을 막기 위함입니다.
  </p>
</div>
