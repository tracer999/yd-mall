<%
  /*
   * 아울렛 상품 등록·수정 (add/edit 공용)
   *
   * 이 폼의 핵심은 '할인 사유'다. 사유에 따라 요구하는 정보가 달라진다:
   *   리퍼브·전시·포장훼손 → 상태 등급 필수, B·C 등급이면 하자 고지 필수
   *   임박상품            → 유통기한 필수
   * 검증은 서버(outletService.validate)가 하고, 여기서는 같은 규칙을 미리 안내만 한다.
   *
   * 가격 입력란이 없는 건 의도다. 아울렛은 진열만 하고 가격은 상품이 갖는다.
   */
  const isEdit = Boolean(item && item.id);
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');
  const gradeRequired = JSON.stringify(gradeRequiredTypes);
  const defectRequired = JSON.stringify(defectRequiredGrades);
%>

<div class="w-full">

  <div class="mb-6">
    <a href="/admin/outlet" class="text-sm text-gray-500 hover:text-gray-700 no-underline">
      <i class="bi bi-arrow-left mr-1"></i> 아울렛 관리
    </a>
    <h1 class="mt-2 text-2xl font-bold text-gray-900"><%= title %></h1>
  </div>

  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <form method="POST" action="<%= isEdit ? `/admin/outlet/${item.id}/edit` : '/admin/outlet/add' %>"
        class="space-y-6" id="outletForm">

    <%# ── 상품 선택 ────────────────────────────────────── %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-base font-bold text-gray-900 mb-4">상품</h2>

      <% if (isEdit || (item && item.product_id)) { %>
        <input type="hidden" name="product_id" value="<%= item.product_id %>">
        <div class="flex items-center gap-4 p-4 rounded-lg bg-gray-50 border border-gray-200">
          <% if (item.main_image) { %>
            <img src="<%= item.main_image %>" alt="" class="w-16 h-16 rounded object-cover bg-white">
          <% } %>
          <div class="flex-1">
            <p class="font-medium text-gray-900"><%= item.name %></p>
            <div class="mt-1 flex items-baseline gap-2 text-sm">
              <span class="font-semibold text-gray-900"><%= won(item.price) %>원</span>
              <% if (item.original_price > item.price) { %>
                <span class="text-gray-400 line-through text-xs"><%= won(item.original_price) %>원</span>
              <% } %>
              <span class="font-bold text-red-600"><%= item.discount_rate || 0 %>%</span>
            </div>
            <% if ((item.discount_rate || 0) < setting.min_discount_rate) { %>
              <p class="mt-1.5 text-xs text-red-600">
                <i class="bi bi-exclamation-triangle-fill"></i>
                최소 할인율(<%= setting.min_discount_rate %>%)에 미달합니다.
                <a href="/admin/products" class="underline">상품 관리</a>에서 가격을 먼저 조정하세요.
              </p>
            <% } %>
          </div>
          <% if (isEdit) { %>
            <span class="text-xs text-gray-400">상품은 변경할 수 없습니다.<br>다른 상품이면 새로 등록하세요.</span>
          <% } %>
        </div>
      <% } else { %>
        <input type="hidden" name="product_id" id="productId" value="">
        <div class="relative">
          <input type="text" id="productSearch" placeholder="상품명 또는 상품코드로 검색"
                 autocomplete="off"
                 class="w-full h-[42px] px-3 rounded-md border border-gray-200 text-sm">
          <div id="searchResults" class="hidden absolute z-20 mt-1 w-full max-h-80 overflow-y-auto bg-white rounded-lg border border-gray-200 shadow-lg"></div>
        </div>
        <div id="selectedProduct" class="hidden mt-4 p-4 rounded-lg bg-indigo-50 border border-indigo-200"></div>
        <p class="mt-2 text-xs text-gray-500">
          최소 할인율 <strong><%= setting.min_discount_rate %>%</strong> 이상인 상품만 아울렛에 등록할 수 있습니다.
        </p>
      <% } %>
    </div>

    <%# ── 할인 사유 ────────────────────────────────────── %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-base font-bold text-gray-900 mb-1">할인 사유</h2>
      <p class="text-sm text-gray-500 mb-4">
        <strong>왜 이 상품이 싼지</strong>를 고객에게 알려주는 정보입니다. 아울렛의 존재 이유이자 필수 항목입니다.
      </p>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-2 mb-5">
        <% outletTypes.forEach(function (t) { %>
          <label class="flex items-start gap-2 p-3 rounded-lg border cursor-pointer transition
                        <%= (item && item.outlet_type) === t.code ? 'border-indigo-400 bg-indigo-50' : 'border-gray-200 hover:bg-gray-50' %>">
            <input type="radio" name="outlet_type" value="<%= t.code %>" required
                   <%= (item && item.outlet_type) === t.code ? 'checked' : '' %>
                   class="mt-0.5 border-gray-300 text-indigo-600 outlet-type-radio">
            <span>
              <span class="block text-sm font-medium text-gray-800"><%= t.label %></span>
              <span class="block text-[11px] text-gray-400 mt-0.5"><%= t.hint %></span>
            </span>
          </label>
        <% }); %>
      </div>

      <div class="mb-5">
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">고객 노출 문구</label>
        <input type="text" name="outlet_reason" maxlength="255"
               value="<%= (item && item.outlet_reason) || '' %>"
               placeholder="예: 25FW 시즌 이월 — 제품은 새 상품입니다"
               class="w-full h-[38px] px-3 rounded-md border border-gray-200 text-sm">
        <p class="mt-1.5 text-xs text-gray-500">상품 목록·상세의 사유 배지 옆에 표시됩니다. 비우면 사유 이름만 나옵니다.</p>
      </div>

      <%# 유통기한 — 임박상품 전용 %>
      <div id="expiryField" class="mb-5 hidden">
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">유통기한 <span class="text-red-500">*</span></label>
        <input type="date" name="expiry_at" id="expiryAt"
               value="<%= (item && item.expiry_at) ? toDateInput(item.expiry_at) : '' %>"
               class="h-[38px] px-3 rounded-md border border-gray-200 text-sm">
        <p class="mt-1.5 text-xs text-gray-500">고객 화면에 그대로 표시됩니다. 임박상품은 기한 고지가 법적으로도 필요합니다.</p>
      </div>
    </div>

    <%# ── 상태 고지 — 리퍼브·전시·훼손 전용 ─────────────── %>
    <div id="conditionBlock" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hidden">
      <h2 class="text-base font-bold text-gray-900 mb-1">상품 상태 고지</h2>
      <p class="text-sm text-red-600 mb-4">
        <i class="bi bi-exclamation-triangle-fill"></i>
        리퍼브·전시·포장훼손 상품을 <strong>일반 이월상품처럼 보여주면 교환·반품 분쟁이 발생합니다.</strong>
        상태를 정확히 고지하세요.
      </p>

      <div class="mb-5">
        <label class="block text-sm font-semibold text-gray-700 mb-2">상태 등급 <span class="text-red-500">*</span></label>
        <div class="space-y-2">
          <% conditionGrades.forEach(function (g) { %>
            <label class="flex items-center gap-2 p-2.5 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="radio" name="condition_grade" value="<%= g.code %>"
                     <%= (item && item.condition_grade) === g.code ? 'checked' : '' %>
                     class="border-gray-300 text-indigo-600 grade-radio">
              <span class="text-sm text-gray-800"><%= g.label %></span>
            </label>
          <% }); %>
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">
          하자 고지 <span id="defectRequiredMark" class="text-red-500 hidden">*</span>
        </label>
        <textarea name="defect_description" rows="3" id="defectDescription"
                  placeholder="예: 우측 하단 3cm 스크래치. 기능 이상 없음. 박스 모서리 눌림."
                  class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm"><%= (item && item.defect_description) || '' %></textarea>
        <p class="mt-1.5 text-xs text-gray-500">
          <strong>B·C 등급은 필수입니다.</strong> 상품 상세의 구매 버튼 위에 눈에 띄게 표시됩니다.
        </p>
      </div>
    </div>

    <%# ── 진열 설정 ────────────────────────────────────── %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-base font-bold text-gray-900 mb-4">진열</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">아울렛 카테고리</label>
          <select name="outlet_category_id" class="w-full h-[38px] px-3 rounded-md border border-gray-200 text-sm">
            <option value="">미분류</option>
            <% categories.forEach(function (c) { %>
              <option value="<%= c.id %>" <%= (item && item.outlet_category_id) === c.id ? 'selected' : '' %>>
                <%= '　'.repeat(Math.max(c.depth - 1, 0)) %><%= c.name %>
              </option>
            <% }); %>
          </select>
          <% if (!categories.length) { %>
            <p class="mt-1.5 text-xs text-amber-600">
              아울렛 카테고리가 없습니다. <a href="/admin/outlet/categories" class="underline">카테고리 관리</a>에서 먼저 만드세요.
            </p>
          <% } %>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">정렬 순서</label>
          <input type="number" name="sort_order" value="<%= (item && item.sort_order) || 0 %>"
                 class="h-[38px] w-32 px-3 rounded-md border border-gray-200 text-sm">
          <p class="mt-1.5 text-xs text-gray-500">작을수록 앞에 나옵니다.</p>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">판매 시작</label>
          <input type="datetime-local" name="started_at"
                 value="<%= (item && item.started_at) ? toLocalInput(item.started_at) : '' %>"
                 class="h-[38px] w-full px-3 rounded-md border border-gray-200 text-sm">
          <p class="mt-1.5 text-xs text-gray-500">비우면 즉시 시작</p>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">판매 종료</label>
          <input type="datetime-local" name="ended_at"
                 value="<%= (item && item.ended_at) ? toLocalInput(item.ended_at) : '' %>"
                 class="h-[38px] w-full px-3 rounded-md border border-gray-200 text-sm">
          <p class="mt-1.5 text-xs text-gray-500">비우면 재고 소진까지 무기한</p>
        </div>
      </div>

      <div class="mt-5 pt-5 border-t border-gray-100">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="is_visible" value="1"
                 <%= (!item || item.is_visible) ? 'checked' : '' %>
                 class="rounded border-gray-300 text-indigo-600">
          <span class="text-sm font-medium text-gray-700">고객 화면에 노출</span>
        </label>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <button type="submit" class="h-[42px] px-6 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
        <%= isEdit ? '수정' : '아울렛에 등록' %>
      </button>
      <a href="/admin/outlet" class="h-[42px] inline-flex items-center px-5 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">
        취소
      </a>
    </div>
  </form>
</div>

<script>
(function () {
  var GRADE_REQUIRED_TYPES = <%- gradeRequired %>;
  var DEFECT_REQUIRED_GRADES = <%- defectRequired %>;

  var conditionBlock = document.getElementById('conditionBlock');
  var expiryField = document.getElementById('expiryField');
  var expiryAt = document.getElementById('expiryAt');
  var defectMark = document.getElementById('defectRequiredMark');
  var defectDesc = document.getElementById('defectDescription');

  // 사유에 따라 요구하는 정보가 달라진다. 서버 검증과 같은 규칙을 화면에서 미리 보여준다.
  function syncType() {
    var checked = document.querySelector('.outlet-type-radio:checked');
    var type = checked ? checked.value : '';

    var needsGrade = GRADE_REQUIRED_TYPES.indexOf(type) !== -1;
    conditionBlock.classList.toggle('hidden', !needsGrade);
    document.querySelectorAll('.grade-radio').forEach(function (r) { r.required = needsGrade; });

    var isExpiry = type === 'EXPIRY_SOON';
    expiryField.classList.toggle('hidden', !isExpiry);
    if (expiryAt) expiryAt.required = isExpiry;

    // 라디오 카드 시각 표시
    document.querySelectorAll('.outlet-type-radio').forEach(function (r) {
      var card = r.closest('label');
      card.classList.toggle('border-indigo-400', r.checked);
      card.classList.toggle('bg-indigo-50', r.checked);
      card.classList.toggle('border-gray-200', !r.checked);
    });

    syncGrade();
  }

  function syncGrade() {
    var checked = document.querySelector('.grade-radio:checked');
    var grade = checked ? checked.value : '';
    var required = DEFECT_REQUIRED_GRADES.indexOf(grade) !== -1;
    if (defectMark) defectMark.classList.toggle('hidden', !required);
    if (defectDesc) defectDesc.required = required;
  }

  document.querySelectorAll('.outlet-type-radio').forEach(function (r) {
    r.addEventListener('change', syncType);
  });
  document.querySelectorAll('.grade-radio').forEach(function (r) {
    r.addEventListener('change', syncGrade);
  });
  syncType();

  // ── 상품 검색 (등록 시에만) ─────────────────────────
  var search = document.getElementById('productSearch');
  if (!search) return;

  var results = document.getElementById('searchResults');
  var productId = document.getElementById('productId');
  var selected = document.getElementById('selectedProduct');
  var timer = null;

  var won = function (n) { return Number(n || 0).toLocaleString('ko-KR'); };
  var esc = function (s) {
    var d = document.createElement('div');
    d.textContent = s == null ? '' : String(s);
    return d.innerHTML;
  };

  search.addEventListener('input', function () {
    clearTimeout(timer);
    var q = search.value.trim();
    if (q.length < 2) { results.classList.add('hidden'); return; }

    timer = setTimeout(function () {
      fetch('/admin/outlet/product-search?q=' + encodeURIComponent(q))
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var list = data.products || [];
          if (!list.length) {
            results.innerHTML = '<div class="px-4 py-6 text-center text-sm text-gray-400">검색 결과가 없습니다.</div>';
            results.classList.remove('hidden');
            return;
          }

          results.innerHTML = list.map(function (p) {
            // 담을 수 없는 상품도 보여주되 이유를 밝힌다 — 안 보여주면 "왜 안 뜨지?" 가 된다.
            var reason = p.already_in_outlet ? '이미 아울렛에 있음'
                       : (!p.eligible ? '할인율 ' + (p.discount_rate || 0) + '% — 최소 ' + data.minDiscountRate + '% 필요'
                       : '');
            return ''
              + '<button type="button" class="w-full flex items-center gap-3 px-3 py-2.5 text-left hover:bg-gray-50 border-b border-gray-50 '
              + (p.eligible ? '' : 'opacity-50 cursor-not-allowed') + '" '
              + (p.eligible ? 'data-pick=\'' + esc(JSON.stringify({id:p.id,name:p.name,price:p.price,original_price:p.original_price,discount_rate:p.discount_rate,main_image:p.main_image})) + '\'' : 'disabled')
              + '>'
              + (p.main_image ? '<img src="' + esc(p.main_image) + '" class="w-10 h-10 rounded object-cover bg-gray-100">'
                              : '<div class="w-10 h-10 rounded bg-gray-100"></div>')
              + '<span class="flex-1 min-w-0">'
              +   '<span class="block text-sm text-gray-900 truncate">' + esc(p.name) + '</span>'
              +   '<span class="block text-xs text-gray-500">' + won(p.price) + '원 · 할인 ' + (p.discount_rate || 0) + '% · 재고 ' + p.stock + '</span>'
              +   (reason ? '<span class="block text-[11px] text-red-500 mt-0.5">' + esc(reason) + '</span>' : '')
              + '</span>'
              + '</button>';
          }).join('');
          results.classList.remove('hidden');
        });
    }, 250);
  });

  results.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-pick]');
    if (!btn) return;
    var p = JSON.parse(btn.getAttribute('data-pick'));

    productId.value = p.id;
    search.value = '';
    results.classList.add('hidden');

    selected.innerHTML = ''
      + '<div class="flex items-center gap-4">'
      +   (p.main_image ? '<img src="' + esc(p.main_image) + '" class="w-16 h-16 rounded object-cover bg-white">' : '')
      +   '<div class="flex-1">'
      +     '<p class="font-medium text-gray-900">' + esc(p.name) + '</p>'
      +     '<div class="mt-1 flex items-baseline gap-2 text-sm">'
      +       '<span class="font-semibold text-gray-900">' + won(p.price) + '원</span>'
      +       (p.original_price > p.price ? '<span class="text-gray-400 line-through text-xs">' + won(p.original_price) + '원</span>' : '')
      +       '<span class="font-bold text-red-600">' + (p.discount_rate || 0) + '%</span>'
      +     '</div>'
      +   '</div>'
      +   '<button type="button" id="clearProduct" class="text-xs text-gray-500 hover:text-gray-700">변경</button>'
      + '</div>';
    selected.classList.remove('hidden');
  });

  selected.addEventListener('click', function (e) {
    if (e.target.id !== 'clearProduct') return;
    productId.value = '';
    selected.classList.add('hidden');
    search.focus();
  });

  document.getElementById('outletForm').addEventListener('submit', function (e) {
    if (!productId.value) {
      e.preventDefault();
      alert('상품을 선택하세요.');
    }
  });

  document.addEventListener('click', function (e) {
    if (!results.contains(e.target) && e.target !== search) results.classList.add('hidden');
  });
})();
</script>
