<%
  /*
   * 아울렛 관리 — 상품 목록 + 몰 설정
   *
   * 이 화면이 답해야 하는 질문 두 개:
   *   1. 지금 아울렛이 고객에게 보이는가? (GNB 게이트 — 상품 수가 임계치를 넘었는가)
   *   2. 하자 고지가 빠진 상품이 있는가? (리퍼브·전시·훼손인데 설명이 없으면 분쟁이 난다)
   */
  const _items = items || [];
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');

  const TYPE_CLS = {
    SEASON_OFF:     'bg-blue-50 text-blue-700',
    DISCONTINUED:   'bg-gray-100 text-gray-600',
    OVERSTOCK:      'bg-amber-50 text-amber-700',
    DISPLAY:        'bg-purple-50 text-purple-700',
    REFURBISHED:    'bg-teal-50 text-teal-700',
    PACKAGE_DAMAGE: 'bg-orange-50 text-orange-700',
    EXPIRY_SOON:    'bg-red-50 text-red-700',
  };
  const GRADE_CLS = { A: 'bg-green-50 text-green-700', B: 'bg-amber-50 text-amber-700', C: 'bg-red-50 text-red-700' };
%>

<div class="w-full">

  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= title %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= subtitle %></p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/admin/outlet/categories"
         class="inline-flex items-center h-[38px] px-4 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">
        <i class="bi bi-diagram-3 mr-1.5"></i> 카테고리
      </a>
      <a href="/admin/outlet/add"
         class="inline-flex items-center h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 no-underline">
        <i class="bi bi-plus-lg mr-1.5"></i> 아울렛 상품 등록
      </a>
    </div>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <%# ── GNB 노출 상태 — 아울렛의 가장 중요한 운영 지표 ─────────────── %>
  <div class="mb-6 rounded-xl border <%= gateOk ? 'border-green-200 bg-green-50/50' : 'border-amber-200 bg-amber-50/50' %> p-4">
    <div class="flex items-start gap-3">
      <i class="bi <%= gateOk ? 'bi-eye-fill text-green-600' : 'bi-eye-slash-fill text-amber-600' %> text-lg mt-0.5"></i>
      <div class="flex-1">
        <p class="text-sm font-semibold <%= gateOk ? 'text-green-900' : 'text-amber-900' %>">
          <% if (gateOk) { %>
            아울렛이 고객 메뉴(GNB)에 노출되고 있습니다 — 판매중 <%= liveCount %>개
          <% } else { %>
            아울렛이 고객 메뉴(GNB)에서 숨겨져 있습니다 — 판매중 <%= liveCount %>개 / 최소 <%= setting.min_product_count %>개 필요
          <% } %>
        </p>
        <p class="mt-1 text-xs <%= gateOk ? 'text-green-700' : 'text-amber-700' %>">
          <% if (gateOk) { %>
            판매중 상품이 최소 노출 수(<%= setting.min_product_count %>개) 이상이라 메뉴가 자동으로 켜졌습니다.
          <% } else { %>
            빈 메뉴를 막기 위해 상품이 부족하면 메뉴가 자동으로 숨습니다.
            <strong><%= Math.max(setting.min_product_count - liveCount, 0) %>개</strong>를 더 등록하면 노출됩니다.
            (기준값은 아래 설정에서 바꿀 수 있습니다.)
          <% } %>
        </p>
      </div>
    </div>
  </div>

  <%# ── 필터 ──────────────────────────────────────────── %>
  <form method="GET" action="/admin/outlet" class="mb-5 flex flex-wrap items-center gap-2">
    <input type="text" name="q" value="<%= filters.q %>" placeholder="상품명·상품코드 검색"
           class="h-[38px] px-3 rounded-md border border-gray-200 text-sm w-64">
    <select name="type" class="h-[38px] px-3 rounded-md border border-gray-200 text-sm">
      <option value="">전체 할인 사유</option>
      <% outletTypes.forEach(function (t) { %>
        <option value="<%= t.code %>" <%= filters.type === t.code ? 'selected' : '' %>><%= t.label %></option>
      <% }); %>
    </select>
    <select name="category_id" class="h-[38px] px-3 rounded-md border border-gray-200 text-sm">
      <option value="">전체 카테고리</option>
      <% categories.forEach(function (c) { %>
        <option value="<%= c.id %>" <%= Number(filters.categoryId) === c.id ? 'selected' : '' %>>
          <%= '　'.repeat(Math.max(c.depth - 1, 0)) %><%= c.name %>
        </option>
      <% }); %>
    </select>
    <button type="submit" class="h-[38px] px-4 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50">
      검색
    </button>
    <% if (filters.q || filters.type || filters.categoryId) { %>
      <a href="/admin/outlet" class="h-[38px] inline-flex items-center px-3 text-sm text-gray-500 hover:text-gray-700 no-underline">초기화</a>
    <% } %>
    <span class="ml-auto text-sm text-gray-500">전체 <strong class="text-gray-900"><%= total %></strong>개</span>
  </form>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
            <th class="px-4 py-2.5 w-16">이미지</th>
            <th class="px-4 py-2.5">상품</th>
            <th class="px-4 py-2.5 w-28">할인 사유</th>
            <th class="px-4 py-2.5 w-24">카테고리</th>
            <th class="px-4 py-2.5 w-36">가격</th>
            <th class="px-4 py-2.5 w-20 text-center">재고</th>
            <th class="px-4 py-2.5 w-24">상태 고지</th>
            <th class="px-4 py-2.5 w-20 text-center">노출</th>
            <th class="px-4 py-2.5 w-28 text-center">관리</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (_items.length === 0) { %>
            <tr><td colspan="9" class="px-6 py-16 text-center text-gray-500">
              <% if (filters.q || filters.type || filters.categoryId) { %>
                조건에 맞는 아울렛 상품이 없습니다.
              <% } else { %>
                <p class="mb-2">등록된 아울렛 상품이 없습니다.</p>
                <p class="text-xs text-gray-400">
                  아울렛은 <strong>할인 사유가 있는 상품</strong>을 담는 곳입니다.
                  단순히 할인율이 높은 상품이 아니라, 이월·리퍼브·전시·임박처럼 <strong>왜 싼지가 상품 자체에 있는</strong> 상품을 등록하세요.
                </p>
              <% } %>
            </td></tr>
          <% } %>
          <% _items.forEach(function (it) { %>
            <tr class="<%= it.is_visible ? '' : 'bg-gray-50/60' %>">
              <td class="px-4 py-3">
                <% if (it.main_image) { %>
                  <img src="<%= it.main_image %>" alt="" class="w-12 h-12 rounded object-cover bg-gray-100">
                <% } else { %>
                  <div class="w-12 h-12 rounded bg-gray-100 flex items-center justify-center text-gray-300"><i class="bi bi-image"></i></div>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <a href="/admin/outlet/<%= it.id %>/edit" class="font-medium text-gray-900 hover:text-indigo-600 no-underline">
                  <%= it.name %>
                </a>
                <% if (it.outlet_reason) { %>
                  <div class="text-xs text-gray-500 mt-0.5"><%= it.outlet_reason %></div>
                <% } %>
                <% if (it.product_code) { %>
                  <div class="text-[11px] text-gray-400 mt-0.5"><%= it.product_code %></div>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <span class="text-[10px] font-bold px-1.5 py-0.5 rounded <%= TYPE_CLS[it.outlet_type] || 'bg-gray-100 text-gray-600' %>">
                  <%= it.typeLabel %>
                </span>
                <% if (it.outlet_type === 'EXPIRY_SOON' && it.expiry_at) { %>
                  <div class="text-[11px] text-red-600 mt-1">~ <%= new Date(it.expiry_at).toLocaleDateString('ko-KR') %></div>
                <% } %>
              </td>
              <td class="px-4 py-3 text-xs text-gray-600">
                <%= it.category_name || '<span class="text-gray-300">미분류</span>' %>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-baseline gap-1.5">
                  <span class="font-semibold text-gray-900"><%= won(it.price) %>원</span>
                  <% if (it.discount_rate > 0) { %>
                    <span class="text-xs font-bold text-red-600"><%= it.discount_rate %>%</span>
                  <% } %>
                </div>
                <% if (it.original_price > it.price) { %>
                  <div class="text-xs text-gray-400 line-through"><%= won(it.original_price) %>원</div>
                <% } %>
              </td>
              <td class="px-4 py-3 text-center">
                <span class="<%= it.stock > 0 ? 'text-gray-700' : 'text-red-500 font-semibold' %>"><%= it.stock %></span>
              </td>
              <td class="px-4 py-3">
                <% if (it.condition_grade) { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded <%= GRADE_CLS[it.condition_grade] %>">
                    <%= it.condition_grade %>급
                  </span>
                <% } %>
                <% if (it.needsGrade && !it.defect_description) { %>
                  <div class="text-[11px] text-red-600 mt-1 font-semibold" title="하자 고지 없이 노출하면 교환·반품 분쟁이 발생합니다">
                    <i class="bi bi-exclamation-triangle-fill"></i> 고지 없음
                  </div>
                <% } %>
              </td>
              <td class="px-4 py-3 text-center">
                <% if (it.is_visible) { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-green-50 text-green-700">노출</span>
                <% } else { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-gray-100 text-gray-500">숨김</span>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1.5">
                  <a href="/admin/outlet/<%= it.id %>/edit"
                     class="text-xs px-2 py-1 rounded border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">수정</a>
                  <form method="POST" action="/admin/outlet/<%= it.id %>/delete"
                        onsubmit="return confirm('아울렛에서 이 상품을 내립니다. 상품 자체는 삭제되지 않습니다.');">
                    <button type="submit" class="text-xs px-2 py-1 rounded border border-red-200 text-red-600 hover:bg-red-50">내리기</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <%# ── 페이지네이션 ──────────────────────────────────── %>
  <% if (totalPages > 1) { %>
    <div class="mt-5 flex items-center justify-center gap-1">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="?page=<%= i %><%= filters.q ? '&q=' + encodeURIComponent(filters.q) : '' %><%= filters.type ? '&type=' + filters.type : '' %><%= filters.categoryId ? '&category_id=' + filters.categoryId : '' %>"
           class="w-8 h-8 inline-flex items-center justify-center text-sm rounded no-underline <%= i === page ? 'bg-indigo-600 text-white font-semibold' : 'text-gray-600 hover:bg-gray-100' %>">
          <%= i %>
        </a>
      <% } %>
    </div>
  <% } %>

  <%# ── 몰 설정 ──────────────────────────────────────── %>
  <div class="mt-10 bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-bold text-gray-900 mb-1">아울렛 운영 설정</h2>
    <p class="text-sm text-gray-500 mb-5">이 몰에서 아울렛을 어떻게 운영할지 정합니다.</p>

    <form method="POST" action="/admin/outlet/settings" class="space-y-6">

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">사용할 할인 사유</label>
        <p class="text-xs text-gray-500 mb-3">
          이 몰에서 발생하지 않는 사유는 꺼두세요. 등록 폼에 나타나지 않습니다.
          (예: 건강식품몰은 시즌 이월이 없고 유통기한 임박만 있습니다)
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
          <% outletTypes.forEach(function (t) { %>
            <label class="flex items-start gap-2 p-2.5 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="allowed_types" value="<%= t.code %>"
                     <%= setting.allowedTypes.includes(t.code) ? 'checked' : '' %>
                     class="mt-0.5 rounded border-gray-300 text-indigo-600">
              <span>
                <span class="block text-sm font-medium text-gray-800"><%= t.label %></span>
                <span class="block text-[11px] text-gray-400 mt-0.5"><%= t.hint %></span>
              </span>
            </label>
          <% }); %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">최소 할인율 (%)</label>
          <input type="number" name="min_discount_rate" value="<%= setting.min_discount_rate %>" min="0" max="99"
                 class="h-[38px] w-32 px-3 rounded-md border border-gray-200 text-sm">
          <p class="mt-1.5 text-xs text-gray-500">
            이 할인율에 못 미치는 상품은 아울렛에 등록할 수 없습니다. 허위 할인을 막습니다.
          </p>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">GNB 노출 최소 상품 수</label>
          <input type="number" name="min_product_count" value="<%= setting.min_product_count %>" min="0"
                 class="h-[38px] w-32 px-3 rounded-md border border-gray-200 text-sm">
          <p class="mt-1.5 text-xs text-gray-500">
            판매중 아울렛 상품이 이 수에 못 미치면 <strong>고객 메뉴에서 자동으로 숨습니다.</strong>
            빈 메뉴를 막기 위한 장치입니다. 0 으로 두면 항상 노출됩니다.
          </p>
        </div>
      </div>

      <div>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="show_in_normal_list" value="1"
                 <%= setting.show_in_normal_list ? 'checked' : '' %>
                 class="rounded border-gray-300 text-indigo-600">
          <span class="text-sm text-gray-700">아울렛 상품을 일반 상품 목록에도 함께 노출</span>
        </label>
        <p class="mt-1.5 ml-6 text-xs text-gray-500">
          끄면 아울렛 상품은 아울렛 안에서만 보입니다. 신상품·브랜드 이미지를 보호하려면 끄세요.
        </p>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">아울렛 공통 고지</label>
        <textarea name="notice_html" rows="3" data-rich
                  placeholder="예: 아울렛 상품은 단순 변심 반품 시 왕복 배송비가 부과됩니다."
                  class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm"><%= setting.notice_html || '' %></textarea>
        <p class="mt-1.5 text-xs text-gray-500">아울렛 목록·상세 상단에 표시됩니다. 교환·반품 조건이 일반 상품과 다르면 반드시 적으세요.</p>
      </div>

      <div class="pt-2">
        <button type="submit" class="h-[38px] px-5 text-sm font-semibold rounded-md bg-gray-900 text-white hover:bg-gray-800">
          설정 저장
        </button>
      </div>
    </form>
  </div>

  <p class="mt-6 text-xs text-gray-400 leading-relaxed">
    <strong>아울렛 vs 쇼핑특가.</strong> 쇼핑특가는 <em>기간</em>이 끝나면 정상가로 돌아갑니다.
    아울렛은 <em>상품 자체에 할인 사유</em>가 있어 재고가 소진될 때까지 계속 쌉니다.
    단순 기간 할인 상품은 아울렛이 아니라 쇼핑특가에 등록하세요.
  </p>
</div>

<%- include('../../partials/admin/tinymce', { selector: 'textarea[data-rich]', height: 240 }) %>
