<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
  <div class="flex items-center gap-4">
    <img src="<%= user.picture || 'https://via.placeholder.com/64' %>" alt="프로필 이미지"
      class="h-14 w-14 rounded-full border border-gray-200 object-cover">
    <div>
      <div class="flex items-center gap-2 mb-1">
        <p class="text-2xl font-bold text-gray-900">
          <%= user.name || '이름 없음' %>
        </p>
        <% if (!user.is_active && user.withdrawn_at) { %>
          <span
            class="px-2 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-700">탈퇴</span>
          <% } else if (user.is_active) { %>
          <span
            class="px-2 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">활성</span>
          <% } else { %>
            <span
              class="px-2 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-200 text-gray-700">비활성</span>
            <% } %>
              <% if (user.kakao_id) { %>
                <span
                  class="px-2 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Kakao</span>
                <% } else if (user.google_id) { %>
                  <span
                    class="px-2 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Google</span>
                  <% } else { %>
                    <span
                      class="px-2 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">Email</span>
                    <% } %>
      </div>
      <p class="text-sm text-gray-500">회원 ID <span class="font-mono">
          <%= user.id %>
        </span></p>
      <p class="text-sm text-gray-500 mt-0.5">
        <%= user.email %>
      </p>
    </div>
  </div>
  <div class="flex gap-2 justify-end">
    <a href="/admin/users"
      class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">
      목록으로 돌아가기
    </a>
  </div>
</div>

<% if (typeof message !== 'undefined' && message) { %>
  <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-900 break-all"><%= message %></div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800"><%= error %></div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- 좌측: 기본/연락처 정보 -->
  <div class="lg:col-span-2 space-y-6">
    <% if (!user.is_active && user.withdrawn_at) { %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-5">
      <h3 class="text-sm font-semibold text-red-800 mb-3">
        <i class="bi bi-person-x-fill mr-1"></i> 탈퇴 회원 정보
      </h3>
      <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3 text-sm">
        <div>
          <dt class="text-red-400">탈퇴일</dt>
          <dd class="font-medium text-red-800"><%= user.withdrawn_at ? new Date(user.withdrawn_at).toISOString().replace('T', ' ').slice(0, 19) : '-' %></dd>
        </div>
        <div>
          <dt class="text-red-400">탈퇴 사유</dt>
          <dd class="font-medium text-red-800"><%= user.withdraw_reason || '미입력' %></dd>
        </div>
      </dl>
    </div>
    <% } %>
    <div class="bg-white shadow-sm rounded-xl p-6 border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-gray-700">기본 정보</h3>
        <span class="text-xs text-gray-400">고객 문의로 들어온 오기입을 여기서 고칩니다</span>
      </div>

      <% const bd = user.birthdate ? new Date(user.birthdate).toISOString().split('T')[0] : ''; %>
      <form action="/admin/users/<%= user.id %>/edit" method="POST" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4 text-sm">
          <div>
            <label class="block text-gray-500 mb-1">이름</label>
            <input type="text" name="name" value="<%= user.name || '' %>" maxlength="50" required
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
          <div>
            <label class="block text-gray-500 mb-1">이메일 <span class="text-gray-300">(로그인 아이디 — 변경 불가)</span></label>
            <input type="text" value="<%= user.email || '' %>" disabled
                   class="w-full px-3 py-2 rounded-md border border-gray-100 bg-gray-50 text-sm text-gray-400">
          </div>
          <div>
            <label class="block text-gray-500 mb-1">전화번호</label>
            <input type="text" name="phone" value="<%= user.phone || '' %>" maxlength="20"
                   placeholder="010-0000-0000" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
          <div>
            <label class="block text-gray-500 mb-1">생년월일</label>
            <input type="date" name="birthdate" value="<%= bd %>"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
          <div>
            <label class="block text-gray-500 mb-1">성별</label>
            <select name="gender" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
              <option value="" <%= !user.gender ? 'selected' : '' %>>선택 안 함</option>
              <option value="M" <%= user.gender === 'M' ? 'selected' : '' %>>남성</option>
              <option value="F" <%= user.gender === 'F' ? 'selected' : '' %>>여성</option>
            </select>
          </div>
          <div>
            <label class="block text-gray-500 mb-1">우편번호</label>
            <input type="text" name="zipcode" value="<%= user.zipcode || '' %>" maxlength="10"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
          <div class="md:col-span-2">
            <label class="block text-gray-500 mb-1">주소</label>
            <input type="text" name="address" value="<%= user.address || '' %>" maxlength="255"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
          <div class="md:col-span-2">
            <label class="block text-gray-500 mb-1">상세 주소</label>
            <input type="text" name="detailed_address" value="<%= user.detailed_address || '' %>" maxlength="255"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
          <div>
            <label class="block text-gray-500 mb-1">기본 수령인</label>
            <input type="text" name="receiver_name" value="<%= user.receiver_name || '' %>" maxlength="50"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
          <div>
            <label class="block text-gray-500 mb-1">보조 연락처</label>
            <input type="text" name="phone_sub" value="<%= user.phone_sub || '' %>" maxlength="20"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
          <div class="md:col-span-2">
            <label class="block text-gray-500 mb-1">기본 배송 요청사항</label>
            <input type="text" name="delivery_request" value="<%= user.delivery_request || '' %>" maxlength="255"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
        </div>

        <label class="inline-flex items-center gap-2 text-sm text-gray-700">
          <input type="checkbox" name="marketing_agreed" value="1" <%= user.marketing_agreed ? 'checked' : '' %>
                 class="w-4 h-4 rounded border-gray-300">
          마케팅 정보 수신 동의
        </label>

        <div class="pt-2 flex items-center gap-2">
          <button type="submit"
                  class="inline-flex items-center justify-center h-[38px] px-5 text-sm font-medium rounded-md bg-blue-600 text-white hover:bg-blue-700">
            정보 저장
          </button>
          <span class="text-xs text-gray-400">포인트 잔액은 포인트 관리에서 이력을 남기며 조정합니다.</span>
        </div>
      </form>

      <div class="mt-5 pt-5 border-t border-gray-100">
        <h4 class="text-sm font-semibold text-gray-700 mb-1">비밀번호 초기화</h4>
        <% if (!user.password_hash) { %>
          <p class="text-xs text-gray-500">
            소셜 로그인 전용 계정이라 비밀번호가 없습니다.
            가입에 쓴 소셜 계정(<%= user.kakao_id ? '카카오' : (user.google_id ? '구글' : '소셜') %>)으로 로그인하도록 안내하세요.
          </p>
        <% } else { %>
          <p class="text-xs text-gray-500 mb-2">
            임시 비밀번호를 새로 만들어 회원 메일로 보냅니다. 발송에 실패해도 화면에 표시되니 전화로 안내할 수 있습니다.
          </p>
          <form action="/admin/users/<%= user.id %>/reset-password" method="POST"
                onsubmit="return confirm('임시 비밀번호를 발급할까요? 기존 비밀번호는 즉시 쓸 수 없게 됩니다.');">
            <button type="submit"
                    class="inline-flex items-center gap-1 h-[34px] px-3 text-xs font-medium rounded-md border border-amber-300 bg-amber-50 text-amber-800 hover:bg-amber-100">
              <i class="bi bi-key"></i> 임시 비밀번호 발급
            </button>
          </form>
        <% } %>
      </div>
    </div>

    <div class="bg-white shadow-sm rounded-xl p-6 border border-gray-100">
      <h3 class="text-sm font-semibold text-gray-700 mb-4">약관 동의 정보</h3>
      <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3 text-sm text-gray-700">
        <div>
          <dt class="text-gray-500">이용약관 버전</dt>
          <dd class="font-medium">
            <%= user.terms_version || '-' %>
          </dd>
        </div>
        <div>
          <dt class="text-gray-500">개인정보 처리방침 버전</dt>
          <dd class="font-medium">
            <%= user.privacy_version || '-' %>
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- 우측: 계정 상태 카드 -->
  <div class="space-y-6">
    <div class="bg-white shadow-sm rounded-xl p-6 border border-gray-100">
      <h3 class="text-sm font-semibold text-gray-700 mb-4">계정 상태</h3>
      <dl class="space-y-3 text-sm text-gray-700">
        <div class="flex items-center justify-between">
          <dt class="text-gray-500">활성 여부</dt>
          <dd>
            <% if (user.is_active) { %>
              <span
                class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">활성</span>
              <% } else { %>
                <span
                  class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-200 text-gray-700">비활성</span>
                <% } %>
          </dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-gray-500">마케팅 동의</dt>
          <dd>
            <% if (user.marketing_agreed) { %>
              <span
                class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">동의</span>
              <% } else { %>
                <span
                  class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">미동의</span>
                <% } %>
          </dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-gray-500">가입일</dt>
          <dd class="font-medium">
            <%= user.created_at ? user.created_at.toISOString().split('T')[0] : '-' %>
          </dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-gray-500">최근 로그인</dt>
          <dd class="font-medium">
            <%= user.last_login ? user.last_login.toISOString().split('T')[0] : '-' %>
          </dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-gray-500">보유 포인트</dt>
          <dd class="font-semibold text-indigo-600">
            <%= (user.points_balance || 0).toLocaleString() %>P
          </dd>
        </div>
      </dl>
    </div>

  </div>
</div>

<!-- 발급된 쿠폰 및 사용 내역 -->
<div class="mt-8 bg-white shadow-sm rounded-xl p-6 border border-gray-100">
  <h3 class="text-sm font-semibold text-gray-700 mb-4">발급된 쿠폰 및 사용 내역</h3>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">쿠폰명</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">할인액</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">지급일</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">지급유형</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">사용일</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">주문번호</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if (!issuedCoupons || issuedCoupons.length===0) { %>
          <tr>
            <td colspan="6" class="px-4 py-6 text-center text-sm text-gray-500">발급된 쿠폰이 없습니다.</td>
          </tr>
          <% } else { %>
            <% issuedCoupons.forEach(function(c) { %>
              <tr>
                <td class="px-4 py-3 text-sm text-gray-900">
                  <%= c.coupon_name || c.coupon_code || '-' %>
                </td>
                <td class="px-4 py-3 text-sm text-right text-gray-900">
                  <%= (c.discount_amount || 0).toLocaleString() %>원
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">
                  <%= c.issued_at ? new Date(c.issued_at).toLocaleString('ko-KR') : '-' %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">
                  <%= c.issued_by==='AUTO' ? '자동' : c.issued_by==='ADMIN' ? '관리자' : '코드' %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">
                  <%= c.used_at ? new Date(c.used_at).toLocaleString('ko-KR') : '-' %>
                </td>
                <td class="px-4 py-3 text-sm">
                  <% if (c.order_id && c.order_number) { %>
                    <a href="/admin/sales/<%= c.order_id %>" class="text-blue-600 hover:underline">
                      <%= c.order_number %>
                    </a>
                    <% } else { %>
                      <%= c.order_number || '-' %>
                        <% } %>
                </td>
              </tr>
              <% }); %>
                <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- 포인트 내역 -->
<div class="mt-6 bg-white shadow-sm rounded-xl p-6 border border-gray-100">
  <h3 class="text-sm font-semibold text-gray-700 mb-4">포인트 내역</h3>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">일시</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">유형</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">금액</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">설명</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if (!pointTransactions || pointTransactions.length===0) { %>
          <tr>
            <td colspan="4" class="px-4 py-6 text-center text-sm text-gray-500">포인트 내역이 없습니다.</td>
          </tr>
          <% } else { %>
            <% pointTransactions.forEach(function(pt) { %>
              <tr>
                <td class="px-4 py-3 text-sm text-gray-500">
                  <%= pt.created_at ? new Date(pt.created_at).toLocaleString('ko-KR') : '-' %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-700">
                  <%= pt.transaction_type==='PURCHASE_ACCUMULATE' ? '구매적립' : pt.transaction_type==='PURCHASE_USE'
                    ? '구매사용' : pt.transaction_type==='ADMIN_GRANT' ? '관리자지급' : '관리자차감' %>
                </td>
                <td
                  class="px-4 py-3 text-sm text-right font-medium <%= pt.amount >= 0 ? 'text-green-600' : 'text-red-600' %>">
                  <%= pt.amount>= 0 ? '+' : '' %><%= pt.amount.toLocaleString() %>P
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">
                  <%= pt.description || '-' %>
                </td>
              </tr>
              <% }); %>
                <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- 주문 내역 및 주문 금액 합계 -->
<% const orderStatusLabels={ PENDING: '대기' , PAID: '결제완료' , PREPARING: '배송준비' , SHIPPED: '배송중' , DELIVERED: '배송완료' ,
  CANCELLED: '취소' , REFUNDED: '환불' }; %>
  <div class="mt-6 bg-white shadow-sm rounded-xl p-6 border border-gray-100">
    <h3 class="text-sm font-semibold text-gray-700 mb-4">주문 내역</h3>
    <div class="mb-4 flex items-center justify-between flex-wrap gap-2">
      <span class="text-sm text-gray-600">결제완료 기준 주문 금액 합계</span>
      <span class="text-lg font-bold text-indigo-600">
        <%= (totalOrderAmount || 0).toLocaleString() %>원
      </span>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">주문번호</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">주문일시</th>
            <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">결제금액</th>
            <th class="px-4 py-2 text-center text-xs font-medium text-gray-500 uppercase">상태</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if (!userOrders || userOrders.length===0) { %>
            <tr>
              <td colspan="4" class="px-4 py-6 text-center text-sm text-gray-500">주문 내역이 없습니다.</td>
            </tr>
            <% } else { %>
              <% userOrders.forEach(function(o) { %>
                <tr>
                  <td class="px-4 py-3 text-sm">
                    <a href="/admin/sales/<%= o.id %>" class="text-blue-600 hover:underline font-medium">
                      <%= o.order_number %>
                    </a>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-500">
                    <%= o.created_at ? new Date(o.created_at).toLocaleString('ko-KR') : '-' %>
                  </td>
                  <td class="px-4 py-3 text-sm text-right text-gray-900">
                    <%= (o.total_amount || 0).toLocaleString() %>원
                  </td>
                  <td class="px-4 py-3 text-sm text-center">
                    <span
                      class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium <%= o.status === 'PAID' ? 'bg-green-100 text-green-800' : o.status === 'CANCELLED' || o.status === 'REFUNDED' ? 'bg-gray-100 text-gray-700' : 'bg-blue-100 text-blue-800' %>">
                      <%= orderStatusLabels[o.status] || o.status %>
                    </span>
                  </td>
                </tr>
                <% }); %>
                  <% } %>
        </tbody>
      </table>
    </div>
  </div>