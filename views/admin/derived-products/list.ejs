<div class="w-full py-2">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-xl font-bold text-gray-900">세트·기획상품</h1>
            <p class="text-sm text-gray-500 mt-1">기본상품(단일·옵션)을 조합해 만드는 파생상품입니다. 재고는 구성 SKU 에서 파생됩니다.</p>
        </div>
        <a href="/admin/derived-products/new" class="px-4 py-2 rounded-lg bg-gray-900 text-white text-sm font-semibold hover:bg-gray-700 no-underline">+ 새로 만들기</a>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50">
                <tr class="text-left text-gray-500">
                    <th class="px-4 py-3 font-medium">유형</th>
                    <th class="px-4 py-3 font-medium">상품명</th>
                    <th class="px-4 py-3 font-medium text-center w-20">구성</th>
                    <th class="px-4 py-3 font-medium text-center w-24">가용수량</th>
                    <th class="px-4 py-3 font-medium text-right w-28">판매가</th>
                    <th class="px-4 py-3 font-medium text-center w-16">상태</th>
                    <th class="px-4 py-3 font-medium text-right w-56">관리</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% if (!products.length) { %>
                    <tr><td colspan="7" class="px-4 py-10 text-center text-gray-400">등록된 세트·기획상품이 없습니다. [새로 만들기] 로 추가하세요.</td></tr>
                <% } %>
                <% products.forEach(function(p){ %>
                <tr>
                    <td class="px-4 py-3"><span class="px-2 py-0.5 rounded text-xs bg-teal-50 text-teal-700 border border-teal-200"><%= p.type_label %></span></td>
                    <td class="px-4 py-3 text-gray-800 font-medium"><%= p.name %></td>
                    <td class="px-4 py-3 text-center text-gray-600"><%= p.component_count %>종</td>
                    <td class="px-4 py-3 text-center <%= p.available_qty > 0 ? 'text-gray-700' : 'text-red-600' %>"><%= p.available_qty %></td>
                    <td class="px-4 py-3 text-right text-gray-800"><%= Number(p.price).toLocaleString() %>원</td>
                    <td class="px-4 py-3 text-center">
                        <span class="px-2 py-0.5 rounded-full text-xs <%= p.status === 'ON' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' %>"><%= p.status %></span>
                    </td>
                    <td class="px-4 py-3 text-right whitespace-nowrap">
                        <a href="/admin/derived-products/<%= p.id %>/compose" class="text-teal-700 hover:underline">구성 관리</a>
                        <span class="text-gray-300 mx-1">|</span>
                        <a href="/admin/products/edit/<%= p.id %>" class="text-gray-600 hover:underline">기본정보</a>
                        <span class="text-gray-300 mx-1">|</span>
                        <form action="/admin/derived-products/<%= p.id %>/delete" method="post" class="inline" onsubmit="return confirm('이 세트·기획상품을 삭제할까요? (구성 정보도 함께 삭제)');">
                            <button type="submit" class="text-red-500 hover:underline">삭제</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
