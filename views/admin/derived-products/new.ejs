<div class="w-full">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl font-bold text-gray-900">새 세트·기획상품</h1>
        <a href="/admin/derived-products" class="text-sm text-gray-500 hover:text-gray-800">← 목록</a>
    </div>

    <% if (typeof query !== 'undefined' && query && query.error === 'name') { %>
        <div class="mb-4 p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">상품명을 입력하세요.</div>
    <% } %>

    <form action="/admin/derived-products/new" method="post" class="bg-white border border-gray-200 rounded-xl p-6 space-y-5">
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">상품명</label>
            <input type="text" name="name" required maxlength="100" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="예: 헤어케어 3종 세트">
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">유형</label>
            <select name="type" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                <% types.forEach(function(t){ %>
                    <option value="<%= t %>" <%= t === 'SET' ? 'selected' : '' %>><%= typeLabel[t] || t %></option>
                <% }) %>
            </select>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">판매가 (원)</label>
            <input type="number" name="price" min="0" value="0" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
            <p class="text-xs text-gray-400 mt-1">세트 판매가입니다. 재고는 다음 단계에서 지정하는 구성 SKU 에서 파생됩니다.</p>
        </div>
        <div class="pt-2">
            <button type="submit" class="px-5 py-2.5 rounded-xl bg-gray-900 text-white font-semibold hover:bg-gray-700">만들고 구성하기 →</button>
        </div>
    </form>
</div>
