<%
  const _kw = typeof keyword !== 'undefined' ? keyword : '';
  const _f  = typeof filters !== 'undefined' ? filters : { status:'', visibility:'', stock:'', categoryId:null, brandId:null };
  const _cats   = typeof filterCategories !== 'undefined' ? filterCategories : [];
  const _brands = typeof filterBrands !== 'undefined' ? filterBrands : [];
  const _selCat   = typeof selectedCategory !== 'undefined' ? selectedCategory : null;
  const _selBrand = typeof selectedBrand   !== 'undefined' ? selectedBrand   : null;
  const _hasFilter = !!(_kw || _f.status || _f.visibility || _f.stock || _f.categoryId || _f.brandId);

  /* 페이지네이션·개수변경 링크가 필터를 잃지 않도록 현재 필터를 전부 실어 나른다. */
  const _qs = (extra) => {
    const params = new URLSearchParams();
    if (_kw) params.set('keyword', _kw);
    if (_f.status) params.set('status', _f.status);
    if (_f.visibility) params.set('visibility', _f.visibility);
    if (_f.stock) params.set('stock', _f.stock);
    if (_f.categoryId) params.set('categoryId', _f.categoryId);
    if (_f.brandId) params.set('brandId', _f.brandId);
    params.set('perPage', pagination.perPage);
    if (extra) Object.entries(extra).forEach(([k, v]) => params.set(k, v));
    return params.toString();
  };

  /* 카테고리 365개·브랜드 1354개는 select 로 못 쓴다 → 선택 레이어에서 검색해 고른다. */
  const toJs = (v) => JSON.stringify(v)
    .replace(/</g, '\\u003c')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029');

  /* 같은 이름의 카테고리가 여러 부모 밑에 있다(예: 티셔츠 = 여성패션/남성패션).
     이름만 보여주면 고를 수 없으므로 "여성패션 > 티셔츠" 전체 경로를 함께 넘긴다. */
  const _catById = new Map(_cats.map(c => [c.id, c]));
  const _catPath = (c) => {
    const names = [c.name];
    let cur = c.parent_id, guard = 0;
    while (cur && guard++ < 10) {
      const parent = _catById.get(cur);
      if (!parent) break;
      names.unshift(parent.name);
      cur = parent.parent_id;
    }
    return names.join(' > ');
  };

  const STATUS_LABELS = { ON:'판매중', OFF:'판매중지', SOLD_OUT:'품절', COMING_SOON:'출시예정', RESTOCK:'재입고예정' };
  const VIS_LABELS = { PUBLIC:'전체공개', HIDDEN:'숨김', MEMBER_ONLY:'회원전용' };
%>
<form action="/admin/products" method="GET" class="mb-4 rounded-lg border border-gray-200 bg-white p-4">
    <input type="hidden" name="perPage" value="<%= pagination.perPage %>">
    <input type="hidden" name="categoryId" id="filter-category-id" value="<%= _f.categoryId || '' %>">
    <input type="hidden" name="brandId" id="filter-brand-id" value="<%= _f.brandId || '' %>">

    <div class="flex flex-wrap items-end gap-3">
        <div class="flex-1 min-w-[220px]">
            <label class="block mb-1 text-xs font-medium text-gray-500">검색어</label>
            <input type="text" name="keyword" value="<%= _kw %>" placeholder="상품명, 브랜드, 카테고리"
                class="w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md bg-white focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500">
        </div>

        <div class="w-36">
            <label class="block mb-1 text-xs font-medium text-gray-500">재고 여부</label>
            <select name="stock" class="w-full h-[38px] px-2 text-sm border border-gray-300 rounded-md bg-white">
                <option value="">전체</option>
                <option value="in"  <%= _f.stock === 'in'  ? 'selected' : '' %>>재고 있음</option>
                <option value="out" <%= _f.stock === 'out' ? 'selected' : '' %>>재고 없음</option>
            </select>
        </div>

        <div class="w-36">
            <label class="block mb-1 text-xs font-medium text-gray-500">상태</label>
            <select name="status" class="w-full h-[38px] px-2 text-sm border border-gray-300 rounded-md bg-white">
                <option value="">전체</option>
                <% Object.entries(STATUS_LABELS).forEach(([v, label]) => { %>
                    <option value="<%= v %>" <%= _f.status === v ? 'selected' : '' %>><%= label %></option>
                <% }) %>
            </select>
        </div>

        <div class="w-36">
            <label class="block mb-1 text-xs font-medium text-gray-500">노출 여부</label>
            <select name="visibility" class="w-full h-[38px] px-2 text-sm border border-gray-300 rounded-md bg-white">
                <option value="">전체</option>
                <% Object.entries(VIS_LABELS).forEach(([v, label]) => { %>
                    <option value="<%= v %>" <%= _f.visibility === v ? 'selected' : '' %>><%= label %></option>
                <% }) %>
            </select>
        </div>

        <div class="w-52">
            <label class="block mb-1 text-xs font-medium text-gray-500">카테고리</label>
            <div class="flex items-center gap-1">
                <button type="button" onclick="openPickerModal('category')" id="filter-category-btn"
                    class="flex-1 h-[38px] px-3 text-sm text-left truncate border border-gray-300 rounded-md bg-white hover:bg-gray-50">
                    <%= _selCat ? _catPath(_selCat) : '전체' %>
                </button>
                <button type="button" onclick="clearPicker('category')" title="선택 해제"
                    class="h-[38px] px-2 text-sm text-gray-400 hover:text-gray-700 <%= _f.categoryId ? '' : 'hidden' %>" id="filter-category-clear">✕</button>
            </div>
        </div>

        <div class="w-52">
            <label class="block mb-1 text-xs font-medium text-gray-500">브랜드</label>
            <div class="flex items-center gap-1">
                <button type="button" onclick="openPickerModal('brand')" id="filter-brand-btn"
                    class="flex-1 h-[38px] px-3 text-sm text-left truncate border border-gray-300 rounded-md bg-white hover:bg-gray-50">
                    <%= _selBrand ? _selBrand.name : '전체' %>
                </button>
                <button type="button" onclick="clearPicker('brand')" title="선택 해제"
                    class="h-[38px] px-2 text-sm text-gray-400 hover:text-gray-700 <%= _f.brandId ? '' : 'hidden' %>" id="filter-brand-clear">✕</button>
            </div>
        </div>

        <div class="flex items-center gap-2">
            <button type="submit" class="inline-flex items-center justify-center h-[38px] px-5 text-sm font-medium rounded-md bg-gray-700 text-white hover:bg-gray-800 transition-colors">검색</button>
            <% if (_hasFilter) { %>
                <a href="/admin/products?perPage=<%= pagination.perPage %>"
                   class="inline-flex items-center justify-center h-[38px] px-3 text-sm rounded-md border border-gray-300 bg-white text-gray-600 hover:bg-gray-50 no-underline">초기화</a>
            <% } %>
        </div>
    </div>
</form>
<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 sm:gap-0">
    <div class="flex items-center gap-4">
        <p class="text-sm text-gray-500">총 <span class="font-semibold text-gray-800"><%= pagination.total %></span>개 상품
            <% if (_kw) { %><span class="text-blue-600">(「<%= _kw %>」 검색 결과)</span><% } %>
        </p>
        <select onchange="changePerPage(this.value)"
            class="text-sm border border-gray-300 rounded-md px-2 py-1 bg-white focus:outline-none focus:ring-1 focus:ring-blue-500">
            <% [10, 20, 30, 50].forEach(n => { %>
                <option value="<%= n %>" <%= pagination.perPage === n ? 'selected' : '' %>><%= n %>개씩 보기</option>
            <% }) %>
        </select>
    </div>
    <div class="flex flex-wrap gap-2 w-full sm:w-auto justify-start sm:justify-end">
        <a href="/admin/products/add"
            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 no-underline gap-1 uppercase tracking-widest">
            <i class="bi bi-plus-lg me-1"></i> 상품 등록
        </a>
    </div>
</div>

<div class="bg-white overflow-hidden shadow-sm sm:rounded-lg">
    <form action="/admin/products/status/update" method="POST" id="bulk-action-form">
        <div class="mb-4 flex flex-wrap gap-2 items-center">
            <span class="text-sm text-gray-600 mr-2">선택한 상품을:</span>
            <button type="submit" name="status" value="ON" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 bg-green-600 text-white hover:bg-green-700">판매중 처리</button>
            <button type="submit" name="status" value="SOLD_OUT" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500 bg-yellow-500 text-white hover:bg-yellow-600">품절 처리</button>
            <button type="submit" name="status" value="OFF" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 bg-red-600 text-white hover:bg-red-700">판매중지 처리</button>
            <%# Shopify 미사용 시 동기화 버튼 숨김 (A3). 서버측 POST /admin/products/shopify-sync 는
                isShopifySyncEnabled() 가드가 409 로 거부하므로 이중 방어다. %>
            <% if (typeof shopifyEnabled !== 'undefined' && shopifyEnabled) { %>
                <div class="border-l border-gray-300 h-6 mx-1"></div>
                <button type="button" id="shopify-sync-btn" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 bg-indigo-600 text-white hover:bg-indigo-700 gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/></svg>
                    Shopify 동기화
                </button>
            <% } %>
        </div>

        <%# 판매 시작일 일괄 지정 — 임포트 상품은 판매시작일이 비어 있어(=신상품 아님) 운영이 여기서 채운다.
            같은 폼의 체크박스를 재사용하고 formaction 으로 전송 대상만 바꾼다. %>
        <div class="mb-4 flex flex-wrap gap-2 items-center border-t border-gray-200 pt-3">
            <span class="text-sm text-gray-600 mr-2">선택한 상품의 판매 시작일을:</span>
            <input type="date" name="sale_start_date"
                class="h-[38px] rounded-md border-gray-300 text-sm shadow-sm focus:border-blue-300 focus:ring focus:ring-blue-200 focus:ring-opacity-50">
            <button type="submit" formaction="/admin/products/sale-start-date/bulk"
                class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700">
                판매 시작일 지정
            </button>
            <span class="text-xs text-gray-500">비워두고 누르면 미지정으로 되돌립니다(신상품에서 제외).</span>
        </div>

        <% if (typeof shopifyEnabled !== 'undefined' && shopifyEnabled) { %>
            <div id="shopify-sync-status" class="hidden mb-3 px-4 py-2 rounded-md text-sm"></div>
        <% } %>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-3 py-3 text-left w-8">
                            <input type="checkbox" id="select-all" class="rounded border-gray-300 text-blue-600 shadow-sm focus:border-blue-300 focus:ring focus:ring-blue-200 focus:ring-opacity-50">
                        </th>
                        <th scope="col" class="px-3 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-16">이미지</th>
                        <th scope="col" class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상품명 / 카테고리</th>
                        <th scope="col" class="px-3 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-14">재고</th>
                        <th scope="col" class="px-3 py-4 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-24">정가</th>
                        <th scope="col" class="px-3 py-4 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-24">판매가</th>
                        <th scope="col" class="px-3 py-4 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-28">판매시작일</th>
                        <th scope="col" class="px-3 py-4 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-20">상태</th>
                        <th scope="col" class="px-3 py-4 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-24">노출관리</th>
                        <th scope="col" class="px-3 py-4 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-20">관리</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <% products.forEach(p => { %>
                        <tr class="hover:bg-gray-50">
                            <td class="px-3 py-4 whitespace-nowrap">
                                <input type="checkbox" name="product_ids[]" value="<%= p.id %>" class="product-checkbox rounded border-gray-300 text-blue-600 shadow-sm focus:border-blue-300 focus:ring focus:ring-blue-200 focus:ring-opacity-50">
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap">
                                <% if(p.main_image) { %>
                                    <img src="<%= p.main_image %>" alt="thumb" class="h-10 w-10 rounded object-cover">
                                <% } else { %>
                                    <div class="h-10 w-10 rounded bg-gray-100 flex items-center justify-center">
                                        <i class="bi bi-image text-gray-400"></i>
                                    </div>
                                <% } %>
                            </td>
                            <td class="px-3 py-3">
                                <div class="text-sm font-medium text-gray-900">
                                    <a href="/admin/products/detail/<%= p.id %>" class="hover:text-blue-600 hover:underline">
                                        <%= p.name %>
                                    </a>
                                </div>
                                <div class="text-sm text-gray-500"><%= p.provider %></div>
                                <div class="mt-1 flex gap-1">
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
                                        <%= p.category_name || '미지정' %>
                                    </span>
                                    <% if(p.brand_category_name) { %>
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-indigo-100 text-indigo-800">
                                            <%= p.brand_category_name %>
                                        </span>
                                    <% } %>
                                </div>
                                <% if (p.distribution_badge || p.product_badge) { %>
                                    <div class="mt-1 flex gap-1">
                                        <% if (p.distribution_badge === 'ONLINE_ONLY') { %>
                                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">온라인판매가능</span>
                                        <% } /* 오프라인전용 뱃지 미사용으로 주석처리: else if (p.distribution_badge === 'OFFLINE_ONLY') */ %>
                                        <% const _bl = p.product_badge ? p.product_badge.split(',') : [];
                                           const _bm = { BEST: ['bg-red-100','text-red-800','BEST'], NEW: ['bg-blue-100','text-blue-800','NEW'], RECOMMEND: ['bg-amber-100','text-amber-800','추천'], DEADLINE_SALE: ['bg-rose-100','text-rose-700','기간임박'], GREENHUB_SPECIAL: ['bg-green-100','text-green-800','특가'] };
                                           _bl.forEach(b => { const m = _bm[b]; if (m) { %>
                                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= m[0] %> <%= m[1] %>"><%= m[2] %></span>
                                        <% } }) %>
                                    </div>
                                <% } %>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-500">
                                <%= p.stock.toLocaleString() %>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-400 text-right">
                                <% if (p.original_price && p.original_price > p.price) { %>
                                    <span class="line-through"><%= p.original_price.toLocaleString() %>원</span>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap text-sm text-gray-900 text-right font-medium">
                                <%= (p.price || 0).toLocaleString() %>원
                                <% if (p.discount_rate > 0) { %>
                                    <div class="text-[10px] text-red-500"><%= p.discount_rate %>%↓</div>
                                <% } %>
                            </td>
                            <%# 판매시작일 + 신상품 여부. 판정 규칙은 services/catalog/newArrival 한 곳에만 있다. %>
                            <td class="px-3 py-4 whitespace-nowrap text-center text-sm">
                                <% if (p.sale_start_date) { %>
                                    <div class="text-gray-700"><%= new Date(p.sale_start_date).toISOString().slice(0,10) %></div>
                                <% } else { %>
                                    <div class="text-gray-400">미지정</div>
                                <% } %>
                                <% if (typeof isNewProduct === 'function' && isNewProduct(p)) { %>
                                    <span class="mt-1 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">신상품</span>
                                <% } %>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap text-center">
                                <% if(p.status === 'ON') { %>
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">판매중</span>
                                <% } else if(p.status === 'SOLD_OUT') { %>
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">품절</span>
                                <% } else if(p.status === 'COMING_SOON') { %>
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">예정</span>
                                <% } else if(p.status === 'RESTOCK') { %>
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-cyan-100 text-cyan-800">재입고예정</span>
                                <% } else { %>
                                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">숨김</span>
                                <% } %>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap text-center">
                                <select class="visibility-select text-xs border rounded-md px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500
                                    <%= p.visibility === 'HIDDEN' ? 'bg-gray-200 text-gray-600 border-gray-300' : p.visibility === 'MEMBER_ONLY' ? 'bg-blue-50 text-blue-700 border-blue-200' : 'bg-green-50 text-green-700 border-green-200' %>"
                                    data-product-id="<%= p.id %>">
                                    <option value="PUBLIC" <%= (!p.visibility || p.visibility === 'PUBLIC') ? 'selected' : '' %>>노출</option>
                                    <option value="HIDDEN" <%= p.visibility === 'HIDDEN' ? 'selected' : '' %>>노출중지</option>
                                    <option value="MEMBER_ONLY" <%= p.visibility === 'MEMBER_ONLY' ? 'selected' : '' %>>로그인전용</option>
                                </select>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap text-center text-sm font-medium">
                                <div class="flex flex-col items-center gap-1">
                                    <a href="/admin/products/edit/<%= p.id %>" class="inline-flex items-center justify-center w-full h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정</a>
                                    <form action="/admin/products/delete" method="POST" class="w-full" onsubmit="return confirm('「<%= p.name %>」 상품을 삭제하시겠습니까?\n삭제 후 복구할 수 없습니다.');">
                                        <input type="hidden" name="id" value="<%= p.id %>">
                                        <button type="submit" class="inline-flex items-center justify-center w-full h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 border border-red-200 bg-red-50 text-red-700 hover:bg-red-100">삭제</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                    <% if(products.length === 0) { %>
                        <tr>
                            <td colspan="9" class="px-6 py-10 text-center text-gray-500">등록된 상품이 없습니다.<%= _kw ? ' (검색 결과 없음)' : '' %></td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </form>

    <% if (pagination.totalPages > 1) { %>
    <div class="px-6 py-4 flex items-center justify-between border-t border-gray-200">
        <p class="text-sm text-gray-500">
            <%= (pagination.page - 1) * pagination.perPage + 1 %>-<%= Math.min(pagination.page * pagination.perPage, pagination.total) %> / 총 <%= pagination.total %>개
        </p>
        <%
            const _pgUrl = (p) => `/admin/products?${_qs({ page: p })}`;
        %>
        <nav class="flex items-center gap-1">
            <% if (pagination.page > 1) { %>
                <a href="<%= _pgUrl(pagination.page - 1) %>"
                   class="px-3 py-1.5 text-sm rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">이전</a>
            <% } %>
            <%
                const maxShow = 5;
                let startPage = Math.max(1, pagination.page - Math.floor(maxShow / 2));
                let endPage = Math.min(pagination.totalPages, startPage + maxShow - 1);
                if (endPage - startPage + 1 < maxShow) startPage = Math.max(1, endPage - maxShow + 1);
            %>
            <% if (startPage > 1) { %>
                <a href="<%= _pgUrl(1) %>"
                   class="px-3 py-1.5 text-sm rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">1</a>
                <% if (startPage > 2) { %><span class="px-1 text-gray-400">...</span><% } %>
            <% } %>
            <% for (let i = startPage; i <= endPage; i++) { %>
                <a href="<%= _pgUrl(i) %>"
                   class="px-3 py-1.5 text-sm rounded-md border no-underline
                   <%= i === pagination.page ? 'bg-blue-600 text-white border-blue-600' : 'border-gray-300 bg-white text-gray-700 hover:bg-gray-50' %>"><%= i %></a>
            <% } %>
            <% if (endPage < pagination.totalPages) { %>
                <% if (endPage < pagination.totalPages - 1) { %><span class="px-1 text-gray-400">...</span><% } %>
                <a href="<%= _pgUrl(pagination.totalPages) %>"
                   class="px-3 py-1.5 text-sm rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline"><%= pagination.totalPages %></a>
            <% } %>
            <% if (pagination.page < pagination.totalPages) { %>
                <a href="<%= _pgUrl(pagination.page + 1) %>"
                   class="px-3 py-1.5 text-sm rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">다음</a>
            <% } %>
        </nav>
    </div>
    <% } %>

    <script>
        document.getElementById('select-all').addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('.product-checkbox');
            checkboxes.forEach(cb => cb.checked = this.checked);
        });

        document.getElementById('bulk-action-form').addEventListener('submit', function(e) {
            const checked = document.querySelectorAll('.product-checkbox:checked');
            if(checked.length === 0) {
                e.preventDefault();
                alert('선택된 상품이 없습니다.');
                return;
            }
            if(!confirm(`선택한 ${checked.length}개 상품의 상태를 변경하시겠습니까?`)) {
                e.preventDefault();
            }
        });

        // Shopify 일괄 동기화 — Shopify 미사용 시 버튼이 렌더되지 않는다(A3).
        // 가드가 없으면 null.addEventListener 로 이 스크립트 블록 전체가 죽는다.
        const shopifySyncBtn = document.getElementById('shopify-sync-btn');
        if (shopifySyncBtn) shopifySyncBtn.addEventListener('click', async function() {
            const checked = document.querySelectorAll('.product-checkbox:checked');
            if (checked.length === 0) {
                alert('동기화할 상품을 먼저 선택하세요.');
                return;
            }
            if (!confirm(`선택한 ${checked.length}개 상품을 Shopify에 동기화하시겠습니까?\n(신규 상품은 생성, 기존 상품은 업데이트됩니다)`)) return;

            const productIds = Array.from(checked).map(cb => parseInt(cb.value));
            const btn = this;
            const statusEl = document.getElementById('shopify-sync-status');

            btn.disabled = true;
            btn.innerHTML = '<svg class="animate-spin h-4 w-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> 동기화 중...';
            statusEl.className = 'mb-3 px-4 py-2 rounded-md text-sm bg-blue-50 text-blue-700 border border-blue-200';
            statusEl.textContent = `${productIds.length}개 상품 동기화 중...`;

            try {
                const res = await fetch('/admin/products/shopify-sync', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productIds })
                });
                const data = await res.json();
                if (data.success) {
                    statusEl.className = 'mb-3 px-4 py-2 rounded-md text-sm bg-green-50 text-green-700 border border-green-200';
                    statusEl.textContent = data.message;
                } else {
                    statusEl.className = 'mb-3 px-4 py-2 rounded-md text-sm bg-red-50 text-red-700 border border-red-200';
                    statusEl.textContent = '동기화 실패: ' + (data.message || '오류가 발생했습니다.');
                }
            } catch (err) {
                statusEl.className = 'mb-3 px-4 py-2 rounded-md text-sm bg-red-50 text-red-700 border border-red-200';
                statusEl.textContent = '네트워크 오류: ' + err.message;
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/></svg> Shopify 동기화';
            }
        });

        // 노출관리 AJAX 변경
        document.querySelectorAll('.visibility-select').forEach(sel => {
            sel.addEventListener('change', async function() {
                const pid = this.dataset.productId;
                const value = this.value;
                try {
                    const res = await fetch('/admin/products/visibility', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId: pid, visibility: value })
                    });
                    const data = await res.json();
                    if (data.success) {
                        this.className = 'visibility-select text-xs border rounded-md px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500 ' +
                            (value === 'HIDDEN' ? 'bg-gray-200 text-gray-600 border-gray-300' :
                             value === 'MEMBER_ONLY' ? 'bg-blue-50 text-blue-700 border-blue-200' :
                             'bg-green-50 text-green-700 border-green-200');
                    } else {
                        alert('변경 실패: ' + (data.message || '오류'));
                    }
                } catch (err) {
                    alert('네트워크 오류');
                }
            });
        });
    </script>
</div>

<%# ── 카테고리/브랜드 선택 레이어 ──────────────────────────────
    항목이 각각 수백~1천 개라 select 박스로는 못 쓴다. 레이어에서 검색해 고른다.
    한 번에 그리는 항목 수를 제한한다(브랜드 1354개를 전부 그리면 DOM 이 무겁다). %>
<div id="pickerModal" class="fixed inset-0 z-50 hidden" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/40" onclick="closePickerModal()"></div>
    <div class="relative mx-auto mt-24 w-full max-w-lg rounded-lg bg-white shadow-xl">
        <div class="flex items-center justify-between border-b border-gray-200 px-5 py-3">
            <h3 class="text-base font-semibold text-gray-900" id="picker-title">선택</h3>
            <button type="button" onclick="closePickerModal()" class="text-gray-400 hover:text-gray-700">✕</button>
        </div>
        <div class="p-5">
            <input type="text" id="picker-search" placeholder="이름으로 검색"
                class="mb-3 w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500">
            <p id="picker-count" class="mb-2 text-xs text-gray-400"></p>
            <ul id="picker-list" class="max-h-80 overflow-y-auto divide-y divide-gray-100 border border-gray-100 rounded-md"></ul>
        </div>
        <div class="flex justify-end gap-2 border-t border-gray-200 px-5 py-3">
            <button type="button" onclick="pickItem(null)" class="h-[36px] px-3 text-sm rounded-md border border-gray-300 bg-white text-gray-600 hover:bg-gray-50">전체(선택 해제)</button>
            <button type="button" onclick="closePickerModal()" class="h-[36px] px-4 text-sm rounded-md bg-gray-700 text-white hover:bg-gray-800">닫기</button>
        </div>
    </div>
</div>

<script>
    /* perPage 는 URL 에 이미 있을 수 있다. 새로 append 하면 중복 키가 되어 서버가 기본값으로 되돌린다. */
    function changePerPage(value) {
        const url = new URL(location.href);
        url.searchParams.set('perPage', value);
        url.searchParams.set('page', 1);
        location.href = url.pathname + '?' + url.searchParams.toString();
    }

    const PICKER_DATA = {
        category: <%- toJs(_cats.map(c => ({ id: c.id, name: c.name, depth: c.depth, path: _catPath(c) }))) %>,
        brand: <%- toJs(_brands.map(b => ({ id: b.id, name: b.name, depth: 1 }))) %>,
    };
    const PICKER_TITLE = { category: '카테고리 선택', brand: '브랜드 선택' };
    const PICKER_MAX = 200;  // 한 번에 그릴 최대 항목 수
    let pickerKind = 'category';

    function openPickerModal(kind) {
        pickerKind = kind;
        document.getElementById('picker-title').textContent = PICKER_TITLE[kind];
        const search = document.getElementById('picker-search');
        search.value = '';
        renderPickerList('');
        document.getElementById('pickerModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        search.focus();
    }

    function closePickerModal() {
        document.getElementById('pickerModal').classList.add('hidden');
        document.body.style.overflow = '';
    }

    function renderPickerList(query) {
        const q = (query || '').trim().toLowerCase();
        const all = PICKER_DATA[pickerKind] || [];
        const matched = q ? all.filter(x => (x.path || x.name).toLowerCase().includes(q)) : all;
        const shown = matched.slice(0, PICKER_MAX);
        const searching = q.length > 0;

        const countEl = document.getElementById('picker-count');
        countEl.textContent = matched.length > shown.length
            ? `${matched.length}개 중 ${shown.length}개 표시 — 검색으로 좁혀주세요`
            : `${matched.length}개`;

        const list = document.getElementById('picker-list');
        list.innerHTML = '';
        const frag = document.createDocumentFragment();
        shown.forEach(item => {
            const li = document.createElement('li');
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'block w-full px-3 py-2 text-left text-sm text-gray-700 hover:bg-blue-50';
            if (searching && item.path) {
                // 검색 중에는 동명 항목을 구분해야 하므로 경로를 그대로 보여준다.
                btn.textContent = item.path;
            } else {
                btn.style.paddingLeft = (12 + (item.depth - 1) * 16) + 'px';
                btn.textContent = (item.depth > 1 ? '└ ' : '') + item.name;
            }
            btn.onclick = () => pickItem(item);
            li.appendChild(btn);
            frag.appendChild(li);
        });
        if (shown.length === 0) {
            const li = document.createElement('li');
            li.className = 'px-3 py-6 text-center text-sm text-gray-400';
            li.textContent = '검색 결과가 없습니다.';
            frag.appendChild(li);
        }
        list.appendChild(frag);
    }

    /* 선택하면 hidden 값과 버튼 라벨만 바꾼다. 실제 필터링은 폼 제출(GET) 로 서버가 한다. */
    function pickItem(item) {
        const idInput = document.getElementById(`filter-${pickerKind}-id`);
        const btn = document.getElementById(`filter-${pickerKind}-btn`);
        const clear = document.getElementById(`filter-${pickerKind}-clear`);
        idInput.value = item ? item.id : '';
        btn.textContent = item ? (item.path || item.name) : '전체';
        clear.classList.toggle('hidden', !item);
        closePickerModal();
    }

    function clearPicker(kind) {
        pickerKind = kind;
        pickItem(null);
    }

    document.getElementById('picker-search').addEventListener('input', (e) => renderPickerList(e.target.value));
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !document.getElementById('pickerModal').classList.contains('hidden')) closePickerModal();
    });
</script>
