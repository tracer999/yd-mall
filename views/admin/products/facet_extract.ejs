<%# 관리자 — 상품 속성 자동 추출 + 검수
    설계: docs/사이트개선/카테고리_브랜드_상품필터_설계.md §9, §10(Phase 8) %>
<div class="w-full">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl font-bold text-gray-900">상품 속성 추출·검수</h1>
        <div class="flex items-center gap-3 text-sm">
            <a href="/admin/products/facets" class="text-gray-500 hover:text-gray-800">카테고리 필터 설정</a>
            <a href="/admin/products" class="text-gray-500 hover:text-gray-800">← 상품 목록</a>
        </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 text-amber-800 text-sm rounded-lg p-3 mb-6 leading-relaxed">
        상품명·옵션값·공급처 원본에서 <b>색상·소재 같은 속성을 자동으로 뽑아</b> 검수 대기로 넣습니다.<br>
        <b>자동 추출은 틀릴 수 있어 바로 반영되지 않습니다.</b> 아래에서 <b>승인</b>해야 고객 화면 필터에 걸립니다.
    </div>

    <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="bg-white border border-gray-200 rounded-xl p-4">
            <div class="text-xs text-gray-500 mb-1">승인되어 필터에 걸린 값</div>
            <div class="text-2xl font-bold text-green-600"><%= Number(stat.approved || 0).toLocaleString() %></div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-4">
            <div class="text-xs text-gray-500 mb-1">검수 대기</div>
            <div class="text-2xl font-bold text-amber-600"><%= Number(stat.waiting || 0).toLocaleString() %></div>
        </div>
    </div>

    <!-- 추출 실행 -->
    <div class="bg-white border border-gray-200 rounded-xl p-5 mb-6">
        <div class="text-sm font-medium text-gray-700 mb-2">1. 추출 실행</div>
        <div class="flex flex-wrap items-center gap-2">
            <select id="catSelect" class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
                <option value="">전체 카테고리</option>
                <% categories.forEach(function (c) { %>
                    <option value="<%= c.id %>"><%= c.name %></option>
                <% }) %>
            </select>
            <button type="button" id="runBtn"
                class="px-4 py-2 rounded-lg bg-gray-900 text-white text-sm font-semibold hover:bg-gray-700">추출 실행</button>
            <span id="runMsg" class="text-sm text-gray-500"></span>
        </div>
        <p class="text-xs text-gray-400 mt-2">한 번에 최대 2,000개 상품을 훑습니다. 이미 승인된 값은 덮어쓰지 않습니다.</p>
    </div>

    <!-- 검수 -->
    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
        <div class="flex items-center justify-between px-5 py-3 border-b bg-gray-50">
            <div class="text-sm font-medium text-gray-700">2. 검수 (<%= pending.length %>종)</div>
            <div class="flex items-center gap-2">
                <label class="text-xs text-gray-500 flex items-center gap-1 cursor-pointer">
                    <input type="checkbox" id="checkAll"> 전체 선택
                </label>
                <button type="button" data-action="approve"
                    class="review-btn px-3 py-1.5 rounded-lg bg-green-600 text-white text-xs font-semibold hover:bg-green-700">승인</button>
                <button type="button" data-action="reject"
                    class="review-btn px-3 py-1.5 rounded-lg bg-white border border-gray-300 text-gray-600 text-xs font-semibold hover:bg-gray-50">반려</button>
            </div>
        </div>

        <% if (!pending.length) { %>
            <div class="px-5 py-10 text-center text-sm text-gray-400">
                검수 대기 중인 값이 없습니다. 위에서 추출을 실행해 보세요.
            </div>
        <% } else { %>
        <table class="w-full text-sm">
            <thead>
                <tr class="text-left text-gray-500 border-b">
                    <th class="py-2 pl-5 w-10"></th>
                    <th class="py-2 pr-3">속성</th>
                    <th class="py-2 pr-3">값</th>
                    <th class="py-2 pr-3 w-24 text-right">상품 수</th>
                    <th class="py-2 pr-5">예시 상품</th>
                </tr>
            </thead>
            <tbody>
                <% pending.forEach(function (r) { %>
                <tr class="pend-row border-b last:border-0" data-name="<%= r.attr_name %>" data-value="<%= r.attr_value %>">
                    <td class="py-2 pl-5"><input type="checkbox" class="p-chk"></td>
                    <td class="py-2 pr-3 text-gray-500"><%= r.attr_name %></td>
                    <td class="py-2 pr-3 font-medium text-gray-800"><%= r.attr_value %></td>
                    <td class="py-2 pr-3 text-right tabular-nums"><%= Number(r.cnt).toLocaleString() %></td>
                    <td class="py-2 pr-5 text-gray-500 truncate max-w-xs">
                        <a href="/admin/products/edit/<%= r.sample_id %>" target="_blank" rel="noopener"
                           class="hover:underline"><%= r.sample_name %></a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
    <div class="mt-3"><span id="reviewMsg" class="text-sm"></span></div>
</div>

<script>
(function () {
    var runBtn = document.getElementById('runBtn');
    var runMsg = document.getElementById('runMsg');

    runBtn.addEventListener('click', async function () {
        runBtn.disabled = true;
        runMsg.textContent = '추출 중... (상품 수에 따라 시간이 걸립니다)';
        runMsg.className = 'text-sm text-gray-500';
        try {
            var resp = await fetch('/admin/products/facet-extract/run', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ categoryId: document.getElementById('catSelect').value || null }),
            });
            var d = await resp.json();
            if (!d.ok) throw new Error(d.message || '실패');
            runMsg.textContent = '상품 ' + d.scanned + '건 검사 → ' + d.matched + '건에서 발견, '
                + d.inserted + '개 값을 검수 대기로 넣었습니다.';
            runMsg.className = 'text-sm text-green-600';
            if (d.inserted > 0) setTimeout(function () { location.reload(); }, 1200);
        } catch (e) {
            runMsg.textContent = '오류: ' + e.message;
            runMsg.className = 'text-sm text-red-600';
        } finally { runBtn.disabled = false; }
    });

    var checkAll = document.getElementById('checkAll');
    if (checkAll) {
        checkAll.addEventListener('change', function () {
            [].slice.call(document.querySelectorAll('.p-chk')).forEach(function (c) { c.checked = checkAll.checked; });
        });
    }

    [].slice.call(document.querySelectorAll('.review-btn')).forEach(function (btn) {
        btn.addEventListener('click', async function () {
            var action = btn.dataset.action;
            var pairs = [].slice.call(document.querySelectorAll('.pend-row'))
                .filter(function (r) { return r.querySelector('.p-chk').checked; })
                .map(function (r) { return { attr_name: r.dataset.name, attr_value: r.dataset.value }; });
            var msg = document.getElementById('reviewMsg');
            if (!pairs.length) {
                msg.textContent = '선택된 항목이 없습니다.'; msg.className = 'text-sm text-gray-500'; return;
            }
            if (action === 'reject' && !confirm(pairs.length + '종을 반려(삭제)합니다. 계속할까요?')) return;
            msg.textContent = '처리 중...'; msg.className = 'text-sm text-gray-500';
            try {
                var resp = await fetch('/admin/products/facet-extract/review', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: action, pairs: pairs }),
                });
                var d = await resp.json();
                if (!d.ok) throw new Error(d.message || '실패');
                msg.textContent = action === 'reject'
                    ? (d.deleted + '개 값을 반려했습니다.')
                    : (d.updated + '개 값을 승인했습니다. 고객 화면 필터에 반영됩니다.');
                msg.className = 'text-sm text-green-600';
                setTimeout(function () { location.reload(); }, 1000);
            } catch (e) {
                msg.textContent = '오류: ' + e.message; msg.className = 'text-sm text-red-600';
            }
        });
    });
})();
</script>
