<div class="flex justify-center">
    <div class="w-full">
        <div class="bg-white overflow-hidden shadow-sm rounded-lg">
            <div class="px-6 py-4 bg-white border-b border-gray-200">
                <h5 class="text-lg font-bold text-gray-800">
                    <%= title %>
                </h5>
            </div>

            <script src="https://cdn.tiny.cloud/1/<%= process.env.TINYMCE_KEY %>/tinymce/5/tinymce.min.js"
                referrerpolicy="origin"></script>

            <div class="p-6 bg-white">
                <form action="<%= product ? '/admin/products/edit' : '/admin/products/add' %>" method="POST"
                    enctype="multipart/form-data">
                    <% if(product) { %>
                        <input type="hidden" name="id" value="<%= product.id %>">
                        <input type="hidden" name="old_image" value="<%= product.main_image %>">
                        <input type="hidden" name="old_thumbnail" value="<%= product.thumbnail_image %>">
                        <input type="hidden" name="old_video" value="<%= product.video_url %>">
                        <% } %>

                            <%#
                              URL 로 상품 가져오기 — 등록 화면 전용.
                              외부 상품 상세 페이지의 구조화 데이터(JSON-LD/OpenGraph)를 읽어 폼을 채운다.
                              **저장은 하지 않는다.** 값을 확인하고 [저장] 을 눌러야 상품이 만들어진다.
                              페이지가 JS 로 그리는 값은 읽을 수 없어, 가져오지 못한 칸은 비어 있는 채로 남는다.
                            %>
                            <% if (!product) { %>
                                <div class="mb-6 rounded-lg border border-blue-200 bg-blue-50/60 p-4">
                                    <label class="block text-sm font-bold text-gray-800 mb-1">URL 로 상품 가져오기</label>
                                    <p class="text-xs text-gray-500 mb-2">
                                        다른 쇼핑몰의 <strong>상품 상세 페이지 URL</strong> 을 넣으면 상품명·가격·이미지·설명을 읽어 아래 폼을 채웁니다.
                                        읽을 수 있는 항목만 채워지며, 저장 전까지 상품은 만들어지지 않습니다.
                                    </p>
                                    <div class="flex gap-2">
                                        <input type="url" id="import-url" placeholder="https://..." autocomplete="off"
                                            class="flex-1 min-w-0 text-sm border-gray-300 rounded-md">
                                        <button type="button" id="import-url-btn"
                                            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-semibold rounded-md bg-blue-600 text-white hover:bg-blue-700 whitespace-nowrap">가져오기</button>
                                    </div>
                                    <p id="import-status" class="mt-2 text-xs hidden"></p>

                                    <%# 가져오기가 내려받아 저장한 이미지 경로. 파일을 직접 올리면 그쪽이 우선한다(서버에서 판정). %>
                                    <div id="imported-images"></div>
                                </div>
                            <% } %>

                            <!-- 기본 정보 -->
                            <h6 class="text-base font-semibold text-gray-700 border-b pb-2 mb-4">기본 정보</h6>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">상품명<span
                                            class="text-red-500">*</span></label>
                                    <input type="text" name="name" required value="<%= product ? product.name : '' %>">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">상품코드</label>
                                    <input type="text" name="product_code"
                                        value="<%= product && product.product_code ? product.product_code : '' %>"
                                        placeholder="예: GH-001">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">상품 URL (슬러그)</label>
                                    <input type="text" name="slug" value="<%= product ? product.slug : '' %>">
                                    <p class="text-xs text-gray-500 mt-1">비워두면 상품명을 기반으로 자동 생성되며, 동일한 값이 있으면 `-1`, `-2`가
                                        붙습니다.</p>
                                    <p class="text-xs text-gray-500 mt-0.5">미리보기: <span id="slug-preview"
                                            class="font-mono text-blue-700"></span></p>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">카테고리</label>

                                    <%# 제출용 원본 select — 숨기고 종속 셀렉트가 값을 채운다(기존 JS 호환) %>
                                    <select name="category_id" id="category_id_select" class="hidden">
                                        <option value="">선택하세요</option>
                                        <% (productCategories || []).forEach(c=> { %>
                                            <option value="<%= c.id %>" <%=product && product.category_id===c.id
                                                ? 'selected' : '' %>><%= c.name %></option>
                                        <% }) %>
                                    </select>

                                    <%# 단계별(뎁스) 종속 셀렉트박스 — 1단계 고르면 2단계가, 2단계 고르면 3단계가 채워진다 %>
                                    <div id="cat-cascade" class="flex flex-col sm:flex-row gap-2">
                                        <select id="cat-lv-1" class="cat-lv w-full text-sm" data-lv="1"><option value="">1단계 선택</option></select>
                                        <select id="cat-lv-2" class="cat-lv w-full text-sm" data-lv="2" disabled><option value="">2단계</option></select>
                                        <select id="cat-lv-3" class="cat-lv w-full text-sm" data-lv="3" disabled><option value="">3단계</option></select>
                                    </div>

                                    <input type="text" name="new_category_name" id="new_category_name"
                                        class="mt-1.5 w-full text-sm"
                                        placeholder="＋ 목록에 없으면 경로로 입력 (예: 여성신발>부츠/워커>미들부츠)">
                                    <p class="text-xs text-gray-500 mt-1">
                                        기존 카테고리는 위 단계별 선택으로 고릅니다. 없으면 아래 칸에
                                        <b>대>중>소</b> 경로(구분자 <code>&gt;</code>)로 입력하면 <b>단계별로 자동 생성</b>됩니다(최대 3단계).
                                    </p>
                                    <script id="cat-tree-data" type="application/json"><%- JSON.stringify((productCategories || []).map(function(c){ return { id: c.id, name: c.name, parent_id: c.parent_id, depth: c.depth }; })) %></script>

                                    <!-- 네이버 카테고리 리소스 검색 — 선택하면 위 "직접 입력"칸을 채운다(taxonomyResolver 경로 재사용) -->
                                    <div class="mt-2 relative" id="naver-cat-widget">
                                        <input type="text" id="naver_cat_search" autocomplete="off"
                                            class="w-full text-sm border-dashed"
                                            placeholder="🔎 네이버 카테고리에서 찾기 (예: 홍삼)"
                                            value="<%= product && product.naver_category_path ? product.naver_category_path : '' %>">
                                        <input type="hidden" name="naver_category_id" id="naver_category_id"
                                            value="<%= product && product.naver_category_id ? product.naver_category_id : '' %>">
                                        <div id="naver_cat_results"
                                            class="hidden absolute z-20 mt-1 w-full max-h-60 overflow-auto bg-white border rounded-md shadow-lg text-sm"></div>
                                        <% if (product && product.naver_category_id) { %>
                                            <p class="text-[11px] mt-1 flex items-center gap-2">
                                                <span class="<%= product.naver_category_inactive ? 'text-amber-600' : 'text-emerald-600' %>">
                                                    지정됨 · ID <%= product.naver_category_id %><%
                                                    %><% if (!product.naver_category_path) { %> (수집 목록에 없는 분류)<% } %><%
                                                    %><% if (product.naver_category_inactive) { %> · 네이버에서 비활성<% } %>
                                                </span>
                                                <button type="button" id="naver_cat_clear"
                                                    class="text-gray-400 hover:text-red-500 underline">지정 해제</button>
                                            </p>
                                        <% } %>
                                        <p class="text-[11px] text-gray-400 mt-1">
                                            네이버 스마트스토어 분류를 근거로 몰 카테고리를 만듭니다. 선택 시 네이버 카테고리 ID 도 상품에 함께 저장됩니다.
                                        </p>
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">브랜드</label>
                                    <select name="brand_category_id">
                                        <option value="">브랜드 선택</option>
                                        <% (brands || []).forEach(b=> { %>
                                            <option value="<%= b.id %>" <%=product && String(product.brand_category_id
                                                || '' )===String(b.id) ? 'selected' : '' %>>
                                                <%= b.name %>
                                            </option>
                                            <% }) %>
                                    </select>
                                    <input type="text" name="new_brand_name" id="new_brand_name"
                                        class="mt-1.5 w-full text-sm"
                                        placeholder="＋ 목록에 없으면 브랜드명 직접 입력">
                                    <p class="text-xs text-gray-500 mt-1">위 목록에서 못 고른 경우에만 입력하세요. 비슷한 브랜드가
                                        있으면 자동으로 연결하고, 없으면 새로 만들어 저장합니다.</p>
                                    <input type="hidden" name="provider"
                                        value="<%= product ? (product.provider || '') : '' %>">
                                </div>
                                <%# 상품 속성 — 고객 목록의 필터(facet) 값이 된다.
                                    카테고리마다 항목이 달라서 카테고리를 고치면 다시 그린다.
                                    설계: docs/사이트개선/카테고리_브랜드_상품필터_설계.md §9 %>
                                <div class="md:col-span-2">
                                    <div class="flex items-center justify-between mb-1">
                                        <label class="block text-sm font-medium text-gray-700">
                                            상품 속성
                                            <span class="text-xs font-normal text-gray-400">— 고객 목록의 필터로 쓰입니다</span>
                                        </label>
                                        <a href="/admin/products/facets" target="_blank" rel="noopener"
                                           class="text-xs text-gray-400 hover:text-gray-600">카테고리별 필터 설정 →</a>
                                    </div>
                                    <div id="facet-attrs"
                                         class="border border-gray-300 rounded-md p-3 text-sm text-gray-500"
                                         data-product-id="<%= product ? product.id : '' %>">
                                        카테고리를 선택하면 입력할 속성이 나타납니다.
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">판매 상태</label>
                                    <select name="status">
                                        <option value="ON" <%=product && product.status==='ON' ? 'selected' : '' %>>판매중
                                        </option>
                                        <option value="SOLD_OUT" <%=product && product.status==='SOLD_OUT' ? 'selected'
                                            : '' %>>품절</option>
                                        <option value="OFF" <%=product && product.status==='OFF' ? 'selected' : '' %>
                                            >중지(판매중단)</option>
                                        <option value="COMING_SOON" <%=product && product.status==='COMING_SOON'
                                            ? 'selected' : '' %>>판매예정</option>
                                        <option value="RESTOCK" <%=product && product.status==='RESTOCK'
                                            ? 'selected' : '' %>>재입고예정</option>
                                    </select>
                                </div>
                                <%
                                    /* 판매 시작일 — 신상품 판정 앵커.
                                       신규 등록은 오늘로 프리필한다. 비워두면 신상품에서 조용히 빠지기 때문이다.
                                       DATE 컬럼은 로컬(KST) 자정 Date 로 올라온다. toISOString 은 하루 밀리므로 로컬 기준으로 찍는다. */
                                    const _ymd = (v) => {
                                        const d = new Date(v);
                                        if (isNaN(d)) return '';
                                        const p = (n) => String(n).padStart(2, '0');
                                        return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())}`;
                                    };
                                    const _todayStr = _ymd(new Date());
                                    const _saleStart = (product && product.sale_start_date)
                                        ? _ymd(product.sale_start_date)
                                        : (product ? '' : _todayStr);
                                    const _newDays = (typeof newProductDays !== 'undefined' && newProductDays) ? newProductDays : 100;
                                %>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">판매 시작일</label>
                                    <input type="date" name="sale_start_date" value="<%= _saleStart %>"
                                        class="w-full border border-gray-300 rounded-md px-3 py-2">
                                    <p class="mt-1 text-xs text-gray-500">
                                        이 날짜로부터 <strong><%= _newDays %>일간</strong> 신상품으로 자동 노출됩니다.
                                        비워두면 신상품에 포함되지 않습니다.
                                    </p>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">노출 설정</label>
                                    <select name="visibility">
                                        <option value="PUBLIC" <%= (!product || !product.visibility || product.visibility === 'PUBLIC') ? 'selected' : '' %>>노출 (기본)</option>
                                        <option value="HIDDEN" <%= product && product.visibility === 'HIDDEN' ? 'selected' : '' %>>노출중지 (프론트 전체 숨김)</option>
                                        <option value="MEMBER_ONLY" <%= product && product.visibility === 'MEMBER_ONLY' ? 'selected' : '' %>>로그인전용 (로그인 회원만 노출)</option>
                                    </select>
                                </div>
                                <%#
                                  재고는 SKU 가 원천이다. 등록 시에만 초기 재고를 받아 기본 SKU 를
                                  만들고, 수정 화면에서는 입력칸을 두지 않는다 — 여기서 저장하면
                                  옵션·SKU 화면에서 고친 재고를 덮어쓰기 때문이다.
                                %>
                                <% if (!product) { %>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">재고 수량</label>
                                        <input type="number" name="stock" value="0">
                                        <p class="mt-1 text-xs text-gray-400">등록 후에는 [옵션·SKU 관리] 화면에서 관리합니다.</p>
                                    </div>
                                <% } else { %>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">재고 수량</label>
                                        <div class="flex items-center gap-2">
                                            <span class="text-sm font-semibold text-gray-900"><%= Number(product.stock || 0).toLocaleString() %>개</span>
                                            <a href="/admin/products/options/<%= product.id %>"
                                               class="text-xs px-2 py-1 rounded border border-indigo-300 bg-indigo-50 text-indigo-700 hover:bg-indigo-100">옵션·SKU 에서 수정</a>
                                        </div>
                                        <p class="mt-1 text-xs text-gray-400">재고는 SKU 기준으로 관리합니다.</p>
                                    </div>
                                <% } %>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">유통채널 구분</label>
                                    <div class="space-y-2 border border-gray-300 rounded-md p-3">
                                        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                            <input type="radio" name="distribution_badge" value=""
                                                class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300"
                                                <%=!product || !product.distribution_badge ? 'checked' : '' %>>
                                            <span>미선택 (뱃지 미노출)</span>
                                        </label>
                                        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                            <input type="radio" name="distribution_badge" value="ONLINE_ONLY"
                                                class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300"
                                                <%=product && product.distribution_badge==='ONLINE_ONLY' ? 'checked'
                                                : '' %>>
                                            <span>온라인판매가능</span>
                                        </label>
                                        <!-- 오프라인판매전용 — 기능 미사용으로 주석처리
                                        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                            <input type="radio" name="distribution_badge" value="OFFLINE_ONLY"
                                                class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300"
                                                disabled>
                                            <span>오프라인판매전용</span>
                                        </label>
                                        -->
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">상품구분 (복수 선택 가능)</label>
                                    <% const _badges = (product && product.product_badge) ? product.product_badge.split(',') : []; %>
                                    <div class="space-y-2 border border-gray-300 rounded-md p-3">
                                        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                            <input type="checkbox" name="product_badge" value="BEST"
                                                class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
                                                <%= _badges.includes('BEST') ? 'checked' : '' %>>
                                            <span>BEST</span>
                                        </label>
                                        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                            <input type="checkbox" name="product_badge" value="NEW"
                                                class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
                                                <%= _badges.includes('NEW') ? 'checked' : '' %>>
                                            <span>NEW <span class="text-xs text-gray-500">— 기간이 지나도 신상품에 강제 노출</span></span>
                                        </label>
                                        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                            <input type="checkbox" name="product_badge" value="RECOMMEND"
                                                class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
                                                <%= _badges.includes('RECOMMEND') ? 'checked' : '' %>>
                                            <span>추천</span>
                                        </label>
                                        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                            <input type="checkbox" name="product_badge" value="DEADLINE_SALE"
                                                class="h-4 w-4 text-red-600 focus:ring-red-500 border-gray-300 rounded"
                                                <%= _badges.includes('DEADLINE_SALE') ? 'checked' : '' %>>
                                            <span class="text-red-600 font-medium">기간임박할인</span>
                                        </label>
                                        <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                            <input type="checkbox" name="product_badge" value="GREENHUB_SPECIAL"
                                                class="h-4 w-4 text-green-600 focus:ring-green-500 border-gray-300 rounded"
                                                <%= _badges.includes('GREENHUB_SPECIAL') ? 'checked' : '' %>>
                                            <span class="text-green-700 font-medium">와이디몰특가</span>
                                        </label>
                                    </div>
                                </div>
                                <div id="badgeExpireDateWrap" class="<%= _badges.includes('DEADLINE_SALE') ? '' : 'hidden' %>">
                                    <label class="block text-sm font-medium text-gray-700 mb-1">기간임박할인 만료일</label>
                                    <input type="date" name="badge_expire_date"
                                        value="<%= (product && product.badge_expire_date) ? _ymd(product.badge_expire_date) : '' %>"
                                        class="w-full border border-gray-300 rounded-md p-2 text-sm focus:ring-blue-500 focus:border-blue-500">
                                    <p class="text-xs text-gray-500 mt-1">만료일이 지나면 자동으로 품절(SOLD_OUT) 처리됩니다.</p>
                                </div>
                                <script>
                                    document.querySelectorAll('input[name="product_badge"]').forEach(cb => {
                                        cb.addEventListener('change', () => {
                                            const deadlineChecked = document.querySelector('input[name="product_badge"][value="DEADLINE_SALE"]').checked;
                                            document.getElementById('badgeExpireDateWrap').classList.toggle('hidden', !deadlineChecked);
                                        });
                                    });
                                </script>
                            </div>

                            <!-- 함께 보면 좋은 상품 -->
                            <div class="bg-gray-50 p-4 rounded-lg mb-8">
                                <h6 class="text-base font-semibold text-gray-700 border-b pb-2 mb-4">함께 보면 좋은 상품 <span class="text-xs font-normal text-gray-400">(최대 8개, 양방향 자동 연결)</span></h6>
                                <div class="mb-3">
                                    <div class="flex gap-2">
                                        <input type="text" id="rec-search-input" placeholder="상품명 또는 상품코드로 검색"
                                            class="flex-1 border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500">
                                        <button type="button" onclick="searchRecommendation()" class="px-4 py-2 bg-gray-700 text-white text-sm rounded-md hover:bg-gray-800">검색</button>
                                    </div>
                                    <div id="rec-search-results" class="mt-2 hidden border border-gray-200 rounded-md bg-white max-h-48 overflow-y-auto"></div>
                                </div>
                                <div id="rec-list" class="space-y-2">
                                    <p class="text-sm text-gray-400 py-2 text-center" id="rec-empty">로딩 중...</p>
                                </div>
                                <p class="text-xs text-gray-400 mt-2">등록된 추천 상품: <span id="rec-count">0</span>/8개</p>
                            </div>
                            <div id="rec-hidden-inputs"></div>
                            <script>
                            (function() {
                                const IS_EDIT = <%= product ? 'true' : 'false' %>;
                                const PID = '<%= product ? product.id : 0 %>';
                                const listEl = document.getElementById('rec-list');
                                const countEl = document.getElementById('rec-count');
                                const searchInput = document.getElementById('rec-search-input');
                                const resultsEl = document.getElementById('rec-search-results');
                                const hiddenInputs = document.getElementById('rec-hidden-inputs');

                                // 신규 등록용: 로컬 추천 목록
                                let localRecs = [];

                                async function loadRecs() {
                                    if (IS_EDIT) {
                                        const res = await fetch('/admin/products/recommendations/' + PID);
                                        const data = await res.json();
                                        renderRecs(data.recommendations || []);
                                    } else {
                                        renderRecs(localRecs);
                                    }
                                }

                                function renderRecs(recs) {
                                    countEl.textContent = recs.length;
                                    if (recs.length === 0) {
                                        listEl.innerHTML = '<p class="text-sm text-gray-400 py-2 text-center">등록된 추천 상품이 없습니다.</p>';
                                        hiddenInputs.innerHTML = '';
                                        return;
                                    }
                                    listEl.innerHTML = recs.map((r, i) => `
                                        <div class="flex items-center gap-2 bg-white border border-gray-200 rounded-md px-3 py-2">
                                            <span class="text-xs text-gray-400 w-5 text-center">${i + 1}</span>
                                            ${r.main_image ? `<img src="${r.main_image}" class="w-8 h-8 rounded object-cover">` : '<div class="w-8 h-8 rounded bg-gray-100"></div>'}
                                            <span class="text-sm text-gray-800 flex-1 truncate">${r.name}</span>
                                            <span class="text-[10px] text-gray-400">${r.product_code || ''}</span>
                                            <button type="button" onclick="moveRec(${i}, -1)" class="text-gray-400 hover:text-gray-700 text-xs px-1" ${i === 0 ? 'disabled' : ''}>↑</button>
                                            <button type="button" onclick="moveRec(${i}, 1)" class="text-gray-400 hover:text-gray-700 text-xs px-1" ${i === recs.length - 1 ? 'disabled' : ''}>↓</button>
                                            <button type="button" onclick="removeRec('${r.id}')" class="text-red-400 hover:text-red-600 text-xs px-1">×</button>
                                        </div>
                                    `).join('');
                                    window._recIds = recs.map(r => r.id);
                                    // 신규 등록용 hidden inputs
                                    if (!IS_EDIT) {
                                        hiddenInputs.innerHTML = recs.map(r => `<input type="hidden" name="recommendation_ids" value="${r.id}">`).join('');
                                    }
                                }

                                window.searchRecommendation = async function() {
                                    const q = searchInput.value.trim();
                                    if (!q) return;
                                    const res = await fetch('/admin/products/recommendations/search?q=' + encodeURIComponent(q) + '&excludeId=' + PID);
                                    const data = await res.json();
                                    if (data.products.length === 0) {
                                        resultsEl.innerHTML = '<p class="text-sm text-gray-400 p-3">검색 결과가 없습니다.</p>';
                                    } else {
                                        resultsEl.innerHTML = data.products.map(p => `
                                            <div class="flex items-center gap-2 px-3 py-2 hover:bg-gray-50 cursor-pointer border-b border-gray-100 last:border-0" onclick="addRec('${p.id}', '${p.name.replace(/'/g,"\\'")}', '${p.main_image||''}', '${p.product_code||''}')">
                                                ${p.main_image ? `<img src="${p.main_image}" class="w-8 h-8 rounded object-cover">` : '<div class="w-8 h-8 rounded bg-gray-100"></div>'}
                                                <span class="text-sm text-gray-800 flex-1 truncate">${p.name}</span>
                                                <span class="text-[10px] text-gray-400">${p.product_code || ''}</span>
                                                <span class="text-[10px] px-1.5 py-0.5 rounded ${p.status === 'ON' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}">${p.status}</span>
                                            </div>
                                        `).join('');
                                    }
                                    resultsEl.classList.remove('hidden');
                                };

                                searchInput.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); searchRecommendation(); } });

                                window.addRec = async function(relatedId, name, image, code) {
                                    if (IS_EDIT) {
                                        await fetch('/admin/products/recommendations/add', {
                                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify({ productId: PID, relatedId })
                                        });
                                    } else {
                                        if (localRecs.length >= 8) { alert('최대 8개까지 등록 가능합니다.'); return; }
                                        if (localRecs.find(r => String(r.id) === String(relatedId))) { alert('이미 등록된 상품입니다.'); return; }
                                        localRecs.push({ id: relatedId, name: name, main_image: image, product_code: code });
                                    }
                                    resultsEl.classList.add('hidden');
                                    searchInput.value = '';
                                    loadRecs();
                                };

                                window.removeRec = async function(relatedId) {
                                    if (!confirm('추천 상품을 삭제하시겠습니까?' + (IS_EDIT ? ' (양방향 삭제)' : ''))) return;
                                    if (IS_EDIT) {
                                        await fetch('/admin/products/recommendations/remove', {
                                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify({ productId: PID, relatedId })
                                        });
                                    } else {
                                        localRecs = localRecs.filter(r => String(r.id) !== String(relatedId));
                                    }
                                    loadRecs();
                                };

                                window.moveRec = async function(idx, dir) {
                                    if (IS_EDIT) {
                                        const ids = [...window._recIds];
                                        const target = idx + dir;
                                        if (target < 0 || target >= ids.length) return;
                                        [ids[idx], ids[target]] = [ids[target], ids[idx]];
                                        await fetch('/admin/products/recommendations/reorder', {
                                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify({ productId: PID, order: ids })
                                        });
                                    } else {
                                        const target = idx + dir;
                                        if (target < 0 || target >= localRecs.length) return;
                                        [localRecs[idx], localRecs[target]] = [localRecs[target], localRecs[idx]];
                                    }
                                    loadRecs();
                                };

                                document.addEventListener('click', e => {
                                    if (!resultsEl.contains(e.target) && e.target !== searchInput) resultsEl.classList.add('hidden');
                                });

                                loadRecs();
                            })();
                            </script>

                            <!-- 가격 정보 -->
                            <div class="bg-gray-50 p-4 rounded-lg mb-8">
                                <h6 class="text-base font-semibold text-gray-700 border-b pb-2 mb-4">가격 설정</h6>

                                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                    <div>
                                        <label class="block text-xs font-bold text-gray-900 mb-1">판매가 (필수)<span
                                                class="text-red-500">*</span></label>
                                        <input type="text" name="price" id="price"
                                            class="price-input text-right font-bold ring-1 ring-blue-500 border-blue-500"
                                            required value="<%= product ? product.price : '' %>">
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-500 mb-1">정가 (선택, 취소선 표시용)</label>
                                        <input type="text" name="original_price" id="original_price"
                                            class="price-input text-right"
                                            value="<%= product ? (product.original_price || '') : '' %>">
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-500 mb-1">할인율 % (선택)</label>
                                        <input type="number" name="discount_rate" id="discount_rate" min="0" max="100"
                                            class="w-full px-3 py-2 text-right text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500"
                                            value="<%= product ? (product.discount_rate || 0) : 0 %>">
                                    </div>
                                </div>
                                <p class="text-xs text-gray-500 mt-3">* 정가를 판매가보다 높게 입력하면 상품 목록·상세에서 정가에 취소선이 표시됩니다. 할인율은 상품 이미지의 SALE 뱃지에 사용됩니다.</p>

                                <!-- 원가(관리자 참고용, 미노출) -->
                                <input type="hidden" name="purchase_price"
                                    value="<%= product ? product.purchase_price : 0 %>">
                            </div>

                            <!-- B2B(사업자) 판매 -->
                            <%
                            /*
                             * 사업자 고객에게 다른 가격으로 팔 때만 켠다. 꺼 두면(기본) 이 상품은
                             * 지금까지와 똑같이 일반 판매가로만 팔린다.
                             * 값은 product_b2b_setting 에 저장된다(controllers/admin/productController).
                             */
                            const _b2bSet = locals.b2bSetting || null;
                            const _b2bOn = !!(_b2bSet && _b2bSet.is_b2b_sale);
                            const _b2bRate = _b2bSet ? Number(_b2bSet.discount_rate) : 0;
                            const _b2bMoq = _b2bSet ? Number(_b2bSet.min_order_qty) : 1;
                            %>
                            <div class="bg-gray-50 p-4 rounded-lg mb-8">
                                <h6 class="text-base font-semibold text-gray-700 border-b pb-2 mb-4">B2B(사업자) 판매</h6>

                                <label class="flex items-center gap-2 text-sm font-medium text-gray-900 cursor-pointer">
                                    <input type="checkbox" name="is_b2b_sale" id="is_b2b_sale" value="1" <%= _b2bOn ? 'checked' : '' %>
                                           onchange="document.getElementById('b2bFields').style.display = this.checked ? '' : 'none';"
                                           class="rounded border-gray-300">
                                    이 상품을 사업자 고객에게도 판매 (기업 전용가 적용)
                                </label>
                                <p class="text-xs text-gray-500 mt-2">
                                    체크하지 않으면 사업자 고객에게도 <strong>일반 판매가</strong>로 팔립니다. 일반 고객 화면은 어느 쪽이든 바뀌지 않습니다.
                                </p>

                                <div id="b2bFields" style="<%= _b2bOn ? '' : 'display:none' %>" class="mt-4 pt-4 border-t border-gray-200">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <div>
                                            <label class="block text-xs font-bold text-gray-900 mb-1">B2B 할인율 (%)</label>
                                            <input type="number" name="b2b_discount_rate" id="b2b_discount_rate"
                                                   min="0" max="99" step="0.01" value="<%= _b2bRate %>"
                                                   class="w-full px-3 py-2 text-right text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500">
                                            <p class="text-xs text-gray-500 mt-1" id="b2bPricePreview"></p>
                                        </div>
                                        <div>
                                            <label class="block text-xs font-bold text-gray-900 mb-1">최소 주문수량</label>
                                            <input type="number" name="b2b_min_order_qty" min="1" value="<%= _b2bMoq %>"
                                                   class="w-full px-3 py-2 text-right text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500">
                                            <p class="text-xs text-gray-500 mt-1">1 이면 1개부터 주문 가능</p>
                                        </div>
                                    </div>
                                    <p class="text-xs text-gray-500 mt-3">
                                        * 거래처마다 <strong>추가 할인</strong>을 더 줄 수 있습니다(B2B 관리 &gt; 거래처 할인). 두 할인율은 <strong>단순 합산</strong>됩니다.<br>
                                        * <strong>과세 구분</strong>(세금계산서/계산서)은 상품이 아니라 <strong>거래처</strong>에 정합니다 — B2B 관리 &gt; 기업회원 승인.<br>
                                        * 수량별 단가·납기 같은 조건은 <strong>견적 단계에서 협의</strong>합니다.
                                    </p>
                                </div>
                            </div>
                            <script>
                            (function () {
                                // 할인율을 입력하면 실제 적용가를 바로 보여 준다 — 저장 후에야 아는 일이 없게.
                                const rate = document.getElementById('b2b_discount_rate');
                                const price = document.getElementById('price');
                                const out = document.getElementById('b2bPricePreview');
                                if (!rate || !price || !out) return;
                                function preview() {
                                    const p = parseInt(String(price.value).replace(/[^0-9]/g, ''), 10) || 0;
                                    const r = parseFloat(rate.value) || 0;
                                    out.textContent = (p > 0 && r > 0)
                                        ? '적용가 ' + Math.floor(p * (1 - r / 100)).toLocaleString() + '원'
                                        : '할인율 0 이면 일반 판매가와 같습니다';
                                }
                                rate.addEventListener('input', preview);
                                price.addEventListener('input', preview);
                                preview();
                            })();
                            </script>

                            <!-- 상세 정보 -->
                            <h6 class="text-base font-semibold text-gray-700 border-b pb-2 mb-4 mt-8">상세 정보 및 이미지</h6>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">대표 이미지</label>
                                    <div class="flex gap-2 mb-2 items-center">
                                        <input type="file" name="main_image" id="main_image"
                                            class="flex-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
                                            accept="image/*">
                                        <button type="button" id="paste-main-btn"
                                            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-100 whitespace-nowrap">붙여넣기</button>
                                    </div>
                                    <div id="main-image-preview" class="mt-2">
                                        <% if(product && product.main_image) { %>
                                            <div class="text-sm text-gray-500">현재: <%= product.main_image %>
                                            </div>
                                            <img src="<%= product.main_image %>"
                                                class="mt-2 h-24 w-auto rounded border border-gray-200">
                                            <% } %>
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">썸네일 이미지</label>
                                    <div class="flex gap-2 mb-2 items-center">
                                        <input type="file" name="thumbnail_image" id="thumbnail_image"
                                            class="flex-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100"
                                            accept="image/*">
                                        <button type="button" id="paste-thumbnail-btn"
                                            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-100 whitespace-nowrap">붙여넣기</button>
                                    </div>
                                    <div id="thumbnail-preview" class="mt-2">
                                        <% if(product && product.thumbnail_image) { %>
                                            <div class="text-sm text-gray-500">현재: <%= product.thumbnail_image %>
                                            </div>
                                            <img src="<%= product.thumbnail_image %>"
                                                class="mt-2 h-24 w-auto rounded border border-gray-200">
                                            <% } %>
                                    </div>
                                </div>
                            </div>
                            <!-- 추가 이미지 (최대 10개) -->
                            <div class="mb-6">
                                <label class="block text-sm font-medium text-gray-700 mb-1">추가 이미지 (최대 10개)</label>
                                <input type="file" name="sub_images" id="sub_images" multiple
                                    class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100"
                                    accept="image/*">
                                <p class="text-xs text-gray-500 mt-1">* 여러 파일을 한 번에 선택할 수 있습니다.</p>

                                <div id="sub-images-preview" class="mt-2 grid grid-cols-5 gap-2">
                                    <% if(product && product.images && product.images.length> 0) { %>
                                        <% product.images.forEach(img=> { %>
                                            <div class="relative group">
                                                <img src="<%= img.image_url %>"
                                                    class="h-20 w-auto rounded border border-gray-200 object-cover">
                                                <div class="absolute top-0 right-0 bg-red-500 text-white rounded-full p-1 cursor-pointer opacity-0 group-hover:opacity-100 transition"
                                                    onclick="deleteImage('<%= img.id %>', this)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none"
                                                        viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                                    </svg>
                                                </div>
                                                <input type="hidden" name="existing_image_ids[]" value="<%= img.id %>">
                                            </div>
                                            <% }) %>
                                                <% } %>
                                </div>
                            </div>

                            <div class="mb-6 p-4 bg-gray-50 rounded-lg">
                                <label class="block text-sm font-medium text-gray-700 mb-2">동영상 설정</label>
                                <div class="flex gap-4 mb-3">
                                    <label class="inline-flex items-center">
                                        <input type="radio" name="video_type" value="FILE" class="form-radio"
                                            <%=(!product || product.video_type==='FILE' ) ? 'checked' : '' %>
                                        onclick="toggleVideoInput('FILE')">
                                        <span class="ml-2">파일 업로드</span>
                                    </label>
                                    <label class="inline-flex items-center">
                                        <input type="radio" name="video_type" value="YOUTUBE" class="form-radio"
                                            <%=(product && product.video_type==='YOUTUBE' ) ? 'checked' : '' %>
                                        onclick="toggleVideoInput('YOUTUBE')">
                                        <span class="ml-2">유튜브 링크</span>
                                    </label>
                                </div>
                                <div id="video-file-input"
                                    class="<%= (product && product.video_type === 'YOUTUBE') ? 'hidden' : '' %>">
                                    <input type="file" name="video_file" accept="video/*"
                                        class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-gray-200 file:text-gray-700 hover:file:bg-gray-300">
                                    <% if(product && product.video_type==='FILE' && product.video_url) { %>
                                        <p class="mt-1 text-sm text-gray-500">현재 파일: <%=
                                                product.video_url.split('/').pop() %>
                                        </p>
                                        <% } %>
                                </div>
                                <div id="video-url-input"
                                    class="<%= (!product || product.video_type === 'FILE') ? 'hidden' : '' %>">
                                    <input type="url" name="video_url" placeholder="https://www.youtube.com/watch?v=..."
                                        value="<%= (product && product.video_type === 'YOUTUBE') ? product.video_url : '' %>">
                                </div>
                            </div>

                            <div class="mb-6">
                                <label class="block text-sm font-medium text-gray-700 mb-1">상품 기본설명 (요약)</label>
                                <textarea id="short_description" name="short_description"
                                    rows="5"><%= product ? product.short_description : '' %></textarea>
                                <p class="text-xs text-gray-500 mt-1">상세설명 상단에 노출되는 3~4줄 요약 설명입니다.</p>
                            </div>

                            <div class="mb-6">
                                <label class="block text-sm font-medium text-gray-700 mb-1">상품 상세 설명</label>
                                <textarea id="description" name="description"
                                    rows="10"><%= product ? product.description : '' %></textarea>
                            </div>

                            <!-- AI 추천 설정 -->
                            <div class="mb-6 p-4 bg-purple-50 rounded-lg border border-purple-100">
                                <div class="flex justify-between items-center mb-4">
                                    <h6 class="text-base font-semibold text-purple-800">AI 추천 설정</h6>
                                    <label class="inline-flex items-center cursor-pointer">
                                        <span class="mr-3 text-sm font-medium text-gray-700">AI 추천 사용</span>
                                        <div class="relative">
                                            <input type="checkbox" name="is_ai_recommendation" id="is_ai_recommendation"
                                                class="sr-only" <%=(product && product.is_ai_recommendation) ? 'checked'
                                                : '' %> onchange="toggleAIContent()">
                                            <div class="block bg-gray-300 w-10 h-6 rounded-full checkbox-bg"></div>
                                            <div
                                                class="dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition">
                                            </div>
                                        </div>
                                    </label>
                                    <style>
                                        input:checked~.checkbox-bg {
                                            background-color: #7c3aed;
                                        }

                                        input:checked~.dot {
                                            transform: translateX(100%);
                                        }
                                    </style>
                                </div>

                                <% const aiUsable = (typeof aiStatus !== 'undefined' && aiStatus) ? aiStatus.usable : true; %>
                                <% const aiMessage = (typeof aiStatus !== 'undefined' && aiStatus) ? (aiStatus.message || '') : ''; %>
                                <div id="ai-content-area"
                                    class="<%= (product && product.is_ai_recommendation) ? '' : 'hidden' %>">
                                    <% if (!aiUsable) { %>
                                    <div class="mb-2 flex items-start gap-2 rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800">
                                        <i class="bi bi-exclamation-triangle-fill mt-0.5"></i>
                                        <span><%= aiMessage %></span>
                                    </div>
                                    <% } %>
                                    <div class="flex justify-end mb-2">
                                        <button type="button" id="generate-ai-btn"
                                            <%= aiUsable ? '' : 'aria-disabled="true"' %>
                                            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 <%= aiUsable ? 'bg-purple-600 text-white hover:bg-purple-700' : 'bg-gray-300 text-gray-500 cursor-not-allowed' %>">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none"
                                                viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M13 10V3L4 14h7v7l9-11h-7z" />
                                            </svg>
                                            AI 추천 생성
                                        </button>
                                    </div>
                                    <textarea name="ai_recommendation_content" id="ai_recommendation_content" rows="4"
                                        class="focus:border-purple-500 focus:ring-purple-500"
                                        placeholder="AI가 작성한 추천 문구가 여기에 표시됩니다."><%= product ? product.ai_recommendation_content : '' %></textarea>
                                </div>
                            </div>

                            <div class="flex justify-end gap-3 mt-8">
                                <% if (product) { %>
                                    <a href="/admin/products/options/<%= product.id %>"
                                        class="inline-flex items-center justify-center h-[50px] px-6 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 border border-indigo-300 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 no-underline min-w-[120px] mr-auto">옵션·SKU 관리</a>
                                <% } %>
                                <a href="/admin/products"
                                    class="inline-flex items-center justify-center h-[50px] px-6 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline min-w-[120px]">취소</a>
                                <button type="submit"
                                    class="inline-flex items-center justify-center h-[50px] px-6 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 min-w-[120px]">
                                    <%= product ? '수정하기' : '상품 등록' %>
                                </button>
                            </div>
                </form>

                <% if(product) { %>
                    <div class="mt-8 pt-6 border-t border-gray-200 flex justify-end">
                        <form action="/admin/products/delete" method="POST" onsubmit="return confirm('정말 삭제하시겠습니까?');">
                            <input type="hidden" name="id" value="<%= product.id %>">
                            <button type="submit"
                                class="inline-flex items-center justify-center h-[50px] px-6 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 border border-red-200 bg-red-50 text-red-700 hover:bg-red-100 min-w-[120px]">상품
                                삭제</button>
                        </form>
                    </div>
                    <% } %>
            </div>
        </div>
    </div>
</div>

<script>
    // Price Formatting and Calculation Logic
    const priceInputs = document.querySelectorAll('.price-input');
    const originalPriceInput = document.getElementById('original_price');
    const discountRateInput = document.getElementById('discount_rate');
    const priceInput = document.getElementById('price');

    // Slug Preview Logic
    const productUrlBase = "<%= typeof productUrlBase !== 'undefined' ? productUrlBase : '' %>";
    const nameInput = document.querySelector('input[name="name"]');
    const slugInput = document.querySelector('input[name="slug"]');
    const slugPreviewEl = document.getElementById('slug-preview');

    function slugifyClient(text) {
        if (!text) return '';
        let slug = text.toString().toLowerCase();
        slug = slug
            .replace(/[^0-9a-zA-Z가-힣\s-]/g, ' ')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .replace(/^-+|-+$/g, '');
        return slug;
    }

    function updateSlugPreview() {
        if (!slugPreviewEl) return;
        const rawSlug = slugInput && slugInput.value.trim();
        const baseText = rawSlug || (nameInput ? nameInput.value.trim() : '');
        const slug = slugifyClient(baseText);

        if (!slug) {
            slugPreviewEl.textContent = '상품명을 입력하면 URL이 생성됩니다.';
        } else {
            slugPreviewEl.textContent = productUrlBase + slug;
        }
    }

    if (nameInput) {
        nameInput.addEventListener('input', updateSlugPreview);
    }
    if (slugInput) {
        slugInput.addEventListener('input', updateSlugPreview);
    }
    updateSlugPreview();

    // Format number with commas
    function formatNumber(num) {
        if (!num && num !== 0) return '';
        return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
    }

    // Remove commas for calculation
    function unformatNumber(str) {
        if (!str) return 0;
        return parseInt(str.toString().replace(/,/g, '')) || 0;
    }

    // Apply formatting on load
    priceInputs.forEach(input => {
        input.value = formatNumber(input.value);

        input.addEventListener('input', (e) => {
            let val = unformatNumber(e.target.value);
            e.target.value = formatNumber(val);
        });
    });

    // Toggle Video Input
    window.toggleVideoInput = function (type) {
        const fileInput = document.getElementById('video-file-input');
        const urlInput = document.getElementById('video-url-input');
        if (type === 'FILE') {
            fileInput.classList.remove('hidden');
            urlInput.classList.add('hidden');
        } else {
            fileInput.classList.add('hidden');
            urlInput.classList.remove('hidden');
        }
    }

    // Toggle AI Content
    window.toggleAIContent = function () {
        const checkbox = document.getElementById('is_ai_recommendation');
        const contentArea = document.getElementById('ai-content-area');
        if (checkbox.checked) {
            contentArea.classList.remove('hidden');
        } else {
            contentArea.classList.add('hidden');
        }
    }

    // Setup Paste Handler function
    function setupPasteHandler(btnId, inputId, previewId) {
        const btn = document.getElementById(btnId);
        const input = document.getElementById(inputId);
        const preview = document.getElementById(previewId);

        if (!btn || !input || !preview) return;

        btn.addEventListener('click', async () => {
            try {
                const items = await navigator.clipboard.read();
                for (const item of items) {
                    if (!item.types.includes('image/png') && !item.types.includes('image/jpeg')) continue;

                    const blob = await item.getType(item.types[0]);
                    const file = new File([blob], "pasted_image.png", { type: "image/png" });

                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(file);
                    input.files = dataTransfer.files;

                    const reader = new FileReader();
                    reader.onload = (e) => {
                        preview.innerHTML = `<div class="text-sm text-green-600">붙여넣기 성공!</div><img src="${e.target.result}" class="mt-2 h-24 w-auto rounded border border-green-200">`;
                    };
                    reader.readAsDataURL(blob);
                    break;
                }
            } catch (err) {
                console.error(err);
                alert('클립보드에서 이미지를 읽을 수 없습니다. (권한 허용 필요)');
            }
        });
    }

    // Initialize Paste Handlers
    setupPasteHandler('paste-main-btn', 'main_image', 'main-image-preview');
    setupPasteHandler('paste-thumbnail-btn', 'thumbnail_image', 'thumbnail-preview');

    // Delete sub image
    window.deleteImage = function (id, el) {
        if (!confirm('이미지를 삭제하시겠습니까? (저장 후 반영됩니다)')) return;

        // Mark for deletion visually
        const container = el.parentElement;
        container.style.opacity = '0.3';

        // Add hidden input for deletion
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'delete_image_ids[]';
        input.value = id;
        document.querySelector('form').appendChild(input);

        // Remove from existing_image_ids list
        const hiddenId = container.querySelector('input[name="existing_image_ids[]"]');
        if (hiddenId) hiddenId.disabled = true;
    }

    // Sub Images Preview
    // Sub Images Preview & Accumulation
    const subImagesInput = document.getElementById('sub_images');
    const subImagesDataTransfer = new DataTransfer();

    if (subImagesInput) {
        subImagesInput.addEventListener('change', function (e) {
            const previewContainer = document.getElementById('sub-images-preview');

            // Add new files to DataTransfer
            if (this.files) {
                Array.from(this.files).forEach(file => {
                    // Check for duplicates (optional, but good UX)
                    let isDuplicate = false;
                    for (let i = 0; i < subImagesDataTransfer.items.length; i++) {
                        if (subImagesDataTransfer.files[i].name === file.name &&
                            subImagesDataTransfer.files[i].size === file.size) {
                            isDuplicate = true;
                            break;
                        }
                    }

                    if (!isDuplicate) {
                        subImagesDataTransfer.items.add(file);

                        // Create preview
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            const div = document.createElement('div');
                            div.className = 'relative group';

                            // Store file name/size as data attributes to identify for deletion
                            div.dataset.fileName = file.name;
                            div.dataset.fileSize = file.size;

                            div.innerHTML = `
                                <img src="${e.target.result}" class="h-20 w-auto rounded border border-gray-200 object-cover">
                                <div class="absolute top-0 right-0 bg-red-500 text-white rounded-full p-1 cursor-pointer opacity-0 group-hover:opacity-100 transition"
                                     onclick="removeNewImage(this)">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                </div>
                            `;
                            previewContainer.appendChild(div);
                        }
                        reader.readAsDataURL(file);
                    }
                });
            }

            // Update input files
            subImagesInput.files = subImagesDataTransfer.files;
        });
    }

    // Remove newly added image
    window.removeNewImage = function (el) {
        const container = el.parentElement;
        const fileName = container.dataset.fileName;
        const fileSize = container.dataset.fileSize;

        // Remove from DataTransfer
        const newDataTransfer = new DataTransfer();
        for (let i = 0; i < subImagesDataTransfer.files.length; i++) {
            const file = subImagesDataTransfer.files[i];
            if (file.name == fileName && file.size == fileSize) {
                continue; // Skip the file to be removed
            }
            newDataTransfer.items.add(file);
        }

        // Update DataTransfer and Input
        subImagesDataTransfer.items.clear();
        for (let i = 0; i < newDataTransfer.files.length; i++) {
            subImagesDataTransfer.items.add(newDataTransfer.files[i]);
        }
        document.getElementById('sub_images').files = subImagesDataTransfer.files;

        // Remove preview
        container.remove();
    }

    // AI Generation
    const AI_USABLE = <%= (typeof aiStatus !== 'undefined' && aiStatus && aiStatus.usable) ? 'true' : 'false' %>;
    const AI_MESSAGE = <%- JSON.stringify((typeof aiStatus !== 'undefined' && aiStatus) ? (aiStatus.message || 'AI 기능을 사용할 수 없습니다.') : 'AI 기능을 사용할 수 없습니다.') %>;
    const generateAiBtn = document.getElementById('generate-ai-btn');
    if (generateAiBtn) {
        generateAiBtn.addEventListener('click', () => {
            if (!AI_USABLE) {
                alert(AI_MESSAGE);
                return;
            }
            const name = document.querySelector('input[name="name"]').value;
            const categoryObj = document.querySelector('select[name="category_id"]');
            const category_name = categoryObj.options[categoryObj.selectedIndex].text;
            const brandSelect = document.querySelector('select[name="brand_category_id"]');
            const provider = (brandSelect && brandSelect.value)
                ? brandSelect.options[brandSelect.selectedIndex].text
                : '';
            const contentArea = document.getElementById('ai_recommendation_content');

            if (!name) {
                alert('상품명을 입력해주세요.');
                return;
            }

            // UI feedback
            const originalText = generateAiBtn.innerHTML;
            generateAiBtn.innerHTML = '생성 중...';
            generateAiBtn.disabled = true;

            fetch('/admin/products/generate-ai-recommendation', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ name, category_name, provider })
            })
                .then(response => response.json())
                .then(data => {
                    if (data.content) {
                        contentArea.value = data.content;
                    } else {
                        alert('AI 생성에 실패했습니다.');
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert('오류가 발생했습니다.');
                })
                .finally(() => {
                    generateAiBtn.innerHTML = originalText;
                    generateAiBtn.disabled = false;
                });
        });
    }


    // Ensure values are unformatted before submit
    // 페이지의 첫 번째 form 이 상품 폼이라는 보장이 없다(레이아웃이 앞에 다른 form 을 깐다).
    // 가격 입력이 실제로 속한 form 에 건다 — 아니면 "12,000" 이 그대로 전송돼 DECIMAL 캐스팅에서 12 로 잘린다.
    const productForm = priceInput && priceInput.form;
    if (productForm) {
        productForm.addEventListener('submit', () => {
            priceInputs.forEach(input => {
                input.value = unformatNumber(input.value);
            });
        });
    }
</script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const commonConfig = {
            menubar: false,
            relative_urls: false,
            remove_script_host: false,
            convert_urls: false,
            plugins: [
                'advlist autolink lists link image charmap print preview anchor',
                'searchreplace visualblocks code fullscreen',
                'insertdatetime media table paste code help wordcount'
            ],
            toolbar: 'undo redo | formatselect | ' +
                'bold italic backcolor | alignleft aligncenter ' +
                'alignright alignjustify | bullist numlist outdent indent | ' +
                'removeformat | help | image | code',
            content_style: 'body { font-family:Pretendard,Helvetica,Arial,sans-serif; font-size:14px; } h1 { font-size:2em; font-weight:700; margin:0.5em 0; } h2 { font-size:1.5em; font-weight:700; margin:0.4em 0; } h3 { font-size:1.25em; font-weight:700; margin:0.3em 0; } h4 { font-size:1.1em; font-weight:600; margin:0.3em 0; } h5 { font-size:1em; font-weight:600; margin:0.2em 0; } h6 { font-size:0.875em; font-weight:600; margin:0.2em 0; }',
            images_upload_handler: function (blobInfo, success, failure) {
                var xhr = new XMLHttpRequest();
                xhr.withCredentials = false;
                xhr.open('POST', '/admin/products/product-image-upload');
                xhr.onload = function () {
                    if (xhr.status != 200) { failure('HTTP Error: ' + xhr.status); return; }
                    var json = JSON.parse(xhr.responseText);
                    if (!json || typeof json.location != 'string') { failure('Invalid JSON: ' + xhr.responseText); return; }
                    success(json.location);
                };
                var formData = new FormData();
                formData.append('file', blobInfo.blob(), blobInfo.filename());
                xhr.send(formData);
            }
        };

        if (typeof tinymce !== 'undefined') {
            tinymce.init({ ...commonConfig, selector: 'textarea#short_description', height: 200 });
            tinymce.init({ ...commonConfig, selector: 'textarea#description', height: 1000 });
        }

        /*
         * URL 로 상품 가져오기 (등록 화면 전용)
         *
         * 서버가 외부 페이지를 읽어 초안을 돌려주면 그 값으로 폼을 채운다. 읽지 못한 필드는 건드리지 않는다
         * — 운영자가 이미 입력해 둔 값을 빈 값으로 덮어쓰면 안 된다.
         * 이미지는 서버가 이미 uploads 에 저장해 두었으므로, 경로만 hidden 으로 실어 보낸다.
         */
        (function () {
            const btn = document.getElementById('import-url-btn');
            const urlInput = document.getElementById('import-url');
            const status = document.getElementById('import-status');
            const imported = document.getElementById('imported-images');
            if (!btn || !urlInput || !status || !imported) return;

            const say = (msg, tone) => {
                status.textContent = msg;
                status.className = 'mt-2 text-xs ' + (tone === 'error' ? 'text-red-600' : tone === 'ok' ? 'text-emerald-700' : 'text-gray-500');
            };

            const setField = (selector, value) => {
                if (value === null || value === undefined || value === '') return false;
                const el = document.querySelector(selector);
                if (!el) return false;
                el.value = value;
                el.dispatchEvent(new Event('input', { bubbles: true }));   // 슬러그 미리보기 등 파생값 갱신
                return true;
            };

            // TinyMCE 가 붙은 textarea 는 value 를 바꿔도 에디터에 보이지 않는다 → 에디터 API 로 넣는다.
            const setEditor = (id, html) => {
                if (!html) return;
                const ed = (typeof tinymce !== 'undefined') && tinymce.get(id);
                if (ed) ed.setContent(html);
                else setField('#' + id, html);
            };

            const hidden = (name, value) => {
                const el = document.createElement('input');
                el.type = 'hidden'; el.name = name; el.value = value;
                imported.appendChild(el);
            };

            async function run() {
                const url = urlInput.value.trim();
                if (!url) return say('상품 상세 페이지 URL 을 입력하세요.', 'error');

                btn.disabled = true;
                btn.textContent = '가져오는 중…';
                say('페이지를 읽고 이미지를 내려받는 중입니다…');

                try {
                    const res = await fetch('/admin/products/import-url', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ url })
                    });
                    const json = await res.json();
                    if (!res.ok || !json.success) throw new Error(json.error || '가져오기에 실패했습니다.');

                    const d = json.data;
                    const filled = [];
                    if (setField('input[name="name"]', d.name)) filled.push('상품명');
                    if (setField('input[name="product_code"]', d.sku)) filled.push('상품코드');
                    if (setField('#price', d.price)) filled.push('판매가');
                    if (setField('#original_price', d.original_price)) filled.push('정가');
                    if (setField('input[name="stock"]', d.stock)) filled.push('재고');
                    if (d.brand_category_id && setField('select[name="brand_category_id"]', d.brand_category_id)) {
                        filled.push('브랜드');
                    } else if (d.brand_name) {
                        // 매칭되는 브랜드가 없으면 이름을 "새 브랜드명" 칸에 채운다 → 저장 시 자동 생성된다.
                        if (setField('#new_brand_name', d.brand_name)) filled.push('브랜드(신규)');
                    }
                    if (d.category_id && setField('select[name="category_id"]', d.category_id)) {
                        filled.push('카테고리');
                    } else if (d.category_name) {
                        // 매칭되는 카테고리가 없으면 "직접 입력"칸에 채운다 → 저장 시 자동 생성된다.
                        if (setField('#new_category_name', d.category_name)) filled.push('카테고리(신규)');
                    }
                    if (d.description) { setEditor('short_description', d.description); filled.push('요약 설명'); }

                    imported.innerHTML = '';
                    if (d.main_image) {
                        hidden('imported_main_image', d.main_image);
                        (d.sub_images || []).forEach(u => hidden('imported_sub_images[]', u));
                        filled.push('이미지 ' + ((d.sub_images || []).length + 1) + '장');

                        const strip = document.createElement('div');
                        strip.className = 'mt-3 flex flex-wrap gap-2';
                        [d.main_image].concat(d.sub_images || []).forEach((u, i) => {
                            const wrap = document.createElement('div');
                            wrap.className = 'relative';
                            wrap.innerHTML = '<img src="' + u + '" class="h-16 w-16 object-cover rounded border border-gray-200">'
                                + (i === 0 ? '<span class="absolute -top-1 -left-1 text-[9px] font-bold bg-blue-600 text-white px-1 rounded">대표</span>' : '');
                            strip.appendChild(wrap);
                        });
                        imported.appendChild(strip);

                        const note = document.createElement('p');
                        note.className = 'mt-1 text-[11px] text-gray-400';
                        note.textContent = '첫 장이 대표 이미지, 나머지는 추가 이미지로 저장됩니다. 파일을 직접 올리면 그쪽이 우선합니다.';
                        imported.appendChild(note);
                    }

                    const missing = ['상품명', '판매가', '이미지'].filter(k => !filled.some(f => f.startsWith(k)));
                    say(
                        (filled.length ? '가져왔습니다: ' + filled.join(', ') : '가져올 수 있는 항목이 없었습니다.')
                        + (missing.length ? ' · 못 가져온 항목(' + missing.join(', ') + ')은 직접 입력하세요.' : ''),
                        filled.length ? 'ok' : 'error'
                    );
                } catch (err) {
                    say(err.message, 'error');
                } finally {
                    btn.disabled = false;
                    btn.textContent = '가져오기';
                }
            }

            btn.addEventListener('click', run);
            urlInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') { e.preventDefault(); run(); }   // 폼 전체가 제출되지 않게 막는다
            });
        })();
    });
</script>

<!-- 네이버 카테고리 리소스 검색 위젯 -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var search = document.getElementById('naver_cat_search');
        var results = document.getElementById('naver_cat_results');
        var hidden = document.getElementById('naver_category_id');
        var freeText = document.getElementById('new_category_name');
        var categorySelect = document.querySelector('select[name="category_id"]');
        if (!search || !results || !hidden) return;

        var timer = null;

        function hideResults() { results.classList.add('hidden'); results.innerHTML = ''; }

        /*
         * [지정 해제] — 검색창만 지우면 hidden 에 ID 가 남아 "지웠는데 그대로 저장되는" 상태가 된다.
         * 화면에서 지운 것과 저장되는 값을 일치시킨다.
         */
        var clearBtn = document.getElementById('naver_cat_clear');
        if (clearBtn) {
            clearBtn.addEventListener('click', function () {
                hidden.value = '';
                search.value = '';
                hideResults();
                clearBtn.parentElement.remove();
            });
        }

        function pick(item) {
            // 네이버 전체 경로(대>중>소>세) 중 우리 몰 최대 3단계(마지막)만 자유입력 칸에 넣는다
            // → 저장 시 taxonomyResolver 가 계층을 단계별로 생성/매핑한다. 대분류는 자동 생략.
            var whole = item.whole_category_name || item.name || '';
            var segs = whole.split('>').map(function (s) { return s.trim(); }).filter(Boolean);
            var pathText = segs.length > 3 ? segs.slice(segs.length - 3).join('>') : segs.join('>');
            if (freeText) freeText.value = pathText || item.name || '';
            // 기존 카테고리 선택은 비운다(자유입력 경로로 새로 만들/매핑). 캐스케이드도 리셋된다.
            if (categorySelect) { categorySelect.value = ''; categorySelect.dispatchEvent(new Event('change')); }
            hidden.value = item.naver_category_id || '';   // 네이버 카테고리 ID 는 상품에 별도 저장(매핑용)
            search.value = whole || item.name || '';
            hideResults();
        }

        function render(list) {
            if (!list || !list.length) {
                results.innerHTML = '<div class="px-3 py-2 text-gray-400">검색 결과가 없습니다. (수집 전이거나 권한이 없을 수 있습니다)</div>';
                results.classList.remove('hidden');
                return;
            }
            results.innerHTML = '';
            list.forEach(function (item) {
                var row = document.createElement('button');
                row.type = 'button';
                row.className = 'block w-full text-left px-3 py-2 hover:bg-emerald-50';
                var path = document.createElement('div');
                path.className = 'text-gray-700';
                path.textContent = item.whole_category_name || item.name;
                var idline = document.createElement('div');
                idline.className = 'text-[11px] text-gray-400';
                idline.textContent = 'ID ' + item.naver_category_id;
                row.appendChild(path);
                row.appendChild(idline);
                row.addEventListener('click', function () { pick(item); });
                results.appendChild(row);
            });
            results.classList.remove('hidden');
        }

        function run() {
            var q = search.value.trim();
            if (q.length < 1) { hideResults(); return; }
            fetch('/admin/sourcing/naver-taxonomy/search?q=' + encodeURIComponent(q) + '&limit=20', {
                headers: { 'Accept': 'application/json' }
            })
                .then(function (r) { return r.ok ? r.json() : { success: false }; })
                .then(function (j) { render(j && j.success ? j.data : []); })
                .catch(function () { hideResults(); });
        }

        search.addEventListener('input', function () {
            clearTimeout(timer);
            timer = setTimeout(run, 250);
        });
        // 사용자가 직접 검색어를 지우면 hidden 도 비운다(선택 취소).
        search.addEventListener('change', function () {
            if (!search.value.trim()) hidden.value = '';
        });
        document.addEventListener('click', function (e) {
            var widget = document.getElementById('naver-cat-widget');
            if (widget && !widget.contains(e.target)) hideResults();
        });
    });
</script>

<!-- 카테고리 단계별(뎁스) 종속 셀렉트박스 -->
<script>
    (function () {
        var el = document.getElementById('cat-tree-data');
        var hiddenSel = document.getElementById('category_id_select');
        if (!el || !hiddenSel) return;
        var tree = [];
        try { tree = JSON.parse(el.textContent || '[]'); } catch (e) { tree = []; }
        var byId = {};
        tree.forEach(function (c) { byId[c.id] = c; });
        function childrenOf(pid) {
            return tree.filter(function (c) { return (pid == null) ? (c.parent_id == null) : (String(c.parent_id) === String(pid)); });
        }
        var sels = [document.getElementById('cat-lv-1'), document.getElementById('cat-lv-2'), document.getElementById('cat-lv-3')];
        if (sels.some(function (s) { return !s; })) return;
        var PH = ['1단계 선택', '2단계', '3단계'];

        function fillOptions(sel, parentId, placeholder) {
            sel.innerHTML = '';
            var o0 = document.createElement('option'); o0.value = ''; o0.textContent = placeholder; sel.appendChild(o0);
            childrenOf(parentId).forEach(function (c) {
                var o = document.createElement('option'); o.value = String(c.id); o.textContent = c.name; sel.appendChild(o);
            });
        }
        function clearFrom(idx) { // idx 이상 레벨 비우기
            for (var i = idx; i < 3; i++) { sels[i].innerHTML = '<option value="">' + PH[i] + '</option>'; sels[i].disabled = (i > 0); sels[i].value = ''; }
        }
        function deepest() { for (var i = 2; i >= 0; i--) { if (sels[i].value) return sels[i].value; } return ''; }
        function syncHidden() { hiddenSel.value = deepest(); } // 이벤트 미발생(무한루프 방지)

        sels.forEach(function (sel, idx) {
            sel.addEventListener('change', function () {
                clearFrom(idx + 1);
                if (idx < 2 && sel.value) {
                    var kids = childrenOf(sel.value);
                    if (kids.length) { fillOptions(sels[idx + 1], sel.value, PH[idx + 1]); sels[idx + 1].disabled = false; }
                }
                syncHidden();
            });
        });

        function chainOf(id) { var out = []; var cur = byId[id]; while (cur) { out.unshift(cur); cur = (cur.parent_id != null) ? byId[cur.parent_id] : null; } return out; }
        function preselect(id) {
            fillOptions(sels[0], null, PH[0]); sels[0].disabled = false;
            clearFrom(1);
            if (!id || !byId[id]) { syncHidden(); return; }
            var chain = chainOf(id).slice(-3);
            if (chain[0]) {
                sels[0].value = String(chain[0].id);
                var k1 = childrenOf(chain[0].id); if (k1.length) { fillOptions(sels[1], chain[0].id, PH[1]); sels[1].disabled = false; }
            }
            if (chain[1]) {
                sels[1].value = String(chain[1].id);
                var k2 = childrenOf(chain[1].id); if (k2.length) { fillOptions(sels[2], chain[1].id, PH[2]); sels[2].disabled = false; }
            }
            if (chain[2]) sels[2].value = String(chain[2].id);
            syncHidden();
        }

        // 초기 렌더: 1단계 채우고, 편집이면 기존 category_id 로 체인 프리필
        fillOptions(sels[0], null, PH[0]); sels[0].disabled = false;
        if (hiddenSel.value) preselect(hiddenSel.value);

        // 외부 JS(네이버 pick 리셋·URL 가져오기 매칭)가 hidden 을 바꾸면 캐스케이드 동기화
        hiddenSel.addEventListener('change', function () {
            if (hiddenSel.value) preselect(hiddenSel.value);
            else { fillOptions(sels[0], null, PH[0]); sels[0].disabled = false; clearFrom(1); }
        });
    })();
</script>
<script>
/*
 * 상품 속성(facet) 입력 — 카테고리에 맞는 항목을 서버에서 받아 그린다.
 * 설계: docs/사이트개선/카테고리_브랜드_상품필터_설계.md §9
 *
 * 제출은 평범한 폼 필드로 한다(name="attr_COLOR"). JSON textarea 를 만들지 않는다.
 */
(function () {
    var box = document.getElementById('facet-attrs');
    if (!box) return;
    var productId = box.dataset.productId || '';
    var hiddenSel = document.getElementById('category_id_select');
    if (!hiddenSel) return;

    function esc(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
            return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
        });
    }

    function render(defs, values) {
        if (!defs.length) {
            box.className = 'border border-gray-300 rounded-md p-3 text-sm text-gray-500';
            box.innerHTML = '이 카테고리에는 입력할 속성이 없습니다. '
                + '<a href="/admin/products/facets" target="_blank" rel="noopener" class="underline">필터 설정</a>에서 추가할 수 있습니다.';
            return;
        }
        box.className = 'border border-gray-300 rounded-md p-3 space-y-3';
        box.innerHTML = defs.map(function (d) {
            var cur = values[d.source_key] || [];
            var name = 'attr_' + d.source_key;
            var body;
            if (d.is_multi) {
                body = d.values.map(function (v) {
                    var on = cur.indexOf(v.value_code) !== -1;
                    return '<label class="inline-flex items-center gap-1.5 mr-3 mb-1 text-sm text-gray-700 cursor-pointer">'
                        + '<input type="checkbox" name="' + esc(name) + '" value="' + esc(v.value_code) + '"'
                        + (on ? ' checked' : '') + ' class="h-4 w-4 border-gray-300">'
                        + '<span>' + esc(v.display_name) + '</span></label>';
                }).join('');
            } else {
                body = '<select name="' + esc(name) + '" class="text-sm border border-gray-300 rounded px-2 py-1">'
                    + '<option value="">선택 안 함</option>'
                    + d.values.map(function (v) {
                        var on = cur.indexOf(v.value_code) !== -1;
                        return '<option value="' + esc(v.value_code) + '"' + (on ? ' selected' : '') + '>'
                            + esc(v.display_name) + '</option>';
                    }).join('')
                    + '</select>';
            }
            return '<div class="flex items-start gap-3">'
                + '<div class="w-28 shrink-0 pt-1 text-xs font-semibold text-gray-600">' + esc(d.facet_name)
                + (d.unit ? ' <span class="font-normal text-gray-400">' + esc(d.unit) + '</span>' : '') + '</div>'
                + '<div class="flex-1 min-w-0">' + body + '</div></div>';
        }).join('');
    }

    var lastCat = null;
    async function load() {
        var cat = hiddenSel.value;
        if (cat === lastCat) return;
        lastCat = cat;
        if (!cat) {
            box.className = 'border border-gray-300 rounded-md p-3 text-sm text-gray-500';
            box.textContent = '카테고리를 선택하면 입력할 속성이 나타납니다.';
            return;
        }
        box.className = 'border border-gray-300 rounded-md p-3 text-sm text-gray-400';
        box.textContent = '불러오는 중...';
        try {
            var url = '/admin/products/attribute-form?categoryId=' + encodeURIComponent(cat)
                + (productId ? '&productId=' + encodeURIComponent(productId) : '');
            var resp = await fetch(url);
            var data = await resp.json();
            if (!data.ok) throw new Error(data.message || '실패');
            render(data.defs || [], data.values || {});
        } catch (e) {
            box.className = 'border border-red-300 rounded-md p-3 text-sm text-red-600';
            box.textContent = '속성을 불러오지 못했습니다: ' + e.message;
        }
    }

    hiddenSel.addEventListener('change', load);
    load();
})();
</script>
