<div class="w-full">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-xl font-bold text-gray-900">옵션·SKU 관리</h1>
            <p class="text-sm text-gray-500 mt-1">
                <span class="font-medium"><%= product.name %></span>
                <span class="ml-2 px-2 py-0.5 rounded text-xs bg-gray-100 text-gray-600" id="typeBadge"><%= product.product_type %></span>
            </p>
        </div>
        <a href="/admin/products/edit/<%= product.id %>" class="text-sm text-gray-500 hover:text-gray-800">← 상품 편집으로</a>
    </div>

    <div class="bg-amber-50 border border-amber-200 text-amber-800 text-sm rounded-lg p-3 mb-6">
        옵션을 정의하고 <b>[조합 생성]</b> 을 누르면 옵션 조합별 SKU 행이 만들어집니다. 각 SKU 의 가격·재고를 입력한 뒤 저장하세요.
        <b>기본 SKU</b> 는 상품이 항상 1개 갖는 행이라 삭제할 수 없고, 여기서 고친 가격·재고가 상품의 값이 됩니다.
        옵션 조합 SKU 는 <b>[삭제]</b> 로 지울 수 있습니다. 옵션을 모두 비우고 저장하면 단일상품으로 되돌아갑니다.
    </div>

    <!-- 옵션 정의 -->
    <div class="bg-white border border-gray-200 rounded-xl p-5 mb-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold text-gray-900">옵션</h2>
            <div class="flex items-center gap-2">
                <button type="button" id="prefillBtn" class="text-sm px-3 py-1.5 rounded-lg border border-indigo-300 bg-indigo-50 text-indigo-700 hover:bg-indigo-100">카테고리 추천 옵션 불러오기</button>
                <button type="button" id="addOptionBtn" class="text-sm px-3 py-1.5 rounded-lg bg-gray-900 text-white hover:bg-gray-700">+ 옵션 추가</button>
            </div>
        </div>
        <div id="optionsWrap" class="space-y-3"></div>
    </div>

    <!-- SKU 그리드 -->
    <div class="bg-white border border-gray-200 rounded-xl p-5 mb-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold text-gray-900">SKU</h2>
            <button type="button" id="genBtn" class="text-sm px-3 py-1.5 rounded-lg bg-indigo-600 text-white hover:bg-indigo-500">조합 생성</button>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-left text-gray-500 border-b">
                        <th class="py-2 pr-3">구분 / 옵션 조합</th>
                        <th class="py-2 px-2 w-28">판매가</th>
                        <th class="py-2 px-2 w-24">재고</th>
                        <th class="py-2 px-2 w-36">SKU코드</th>
                        <th class="py-2 px-2 w-20">상태</th>
                        <th class="py-2 px-2 w-16"></th>
                    </tr>
                </thead>
                <%# 기본 SKU — 항상 맨 위 고정, 삭제 불가 %>
                <tbody id="defaultBody"></tbody>
                <tbody id="skuBody">
                    <tr id="skuEmpty"><td colspan="6" class="py-6 text-center text-gray-400">옵션을 정의하고 [조합 생성] 을 누르세요.</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="flex items-center gap-3">
        <button type="button" id="saveBtn" class="px-5 py-2.5 rounded-xl bg-gray-900 text-white font-semibold hover:bg-gray-700">저장</button>
        <span id="saveMsg" class="text-sm"></span>
    </div>
</div>

<script>
(function () {
    const PRODUCT_ID = <%= product.id %>;
    const BASE_PRICE = <%= Number(product.price) || 0 %>;
    // 서버 초기 데이터
    const initOptions = <%- JSON.stringify(options || []) %>;
    const initSkus = <%- JSON.stringify(skus || []) %>;
    const initDefaultSku = <%- JSON.stringify(defaultSku || null) %>;

    // value_id → value_name 맵 (기존 SKU 조합 복원용)
    const valueNameById = {};
    initOptions.forEach(o => (o.values || []).forEach(v => { valueNameById[v.id] = v.value_name; }));

    const optionsWrap = document.getElementById('optionsWrap');
    const skuBody = document.getElementById('skuBody');
    const defaultBody = document.getElementById('defaultBody');
    const saveMsg = document.getElementById('saveMsg');

    // ── 옵션 UI ──
    function optionRow(name = '', values = []) {
        const div = document.createElement('div');
        div.className = 'option-row border border-gray-200 rounded-lg p-3';
        div.innerHTML =
            '<div class="flex items-center gap-2 mb-2">' +
            '  <input class="opt-name border rounded px-2 py-1 text-sm w-40" placeholder="옵션명 (예: 색상)" />' +
            '  <button type="button" class="rm-opt text-xs text-red-500 hover:text-red-700 ml-auto">옵션 삭제</button>' +
            '</div>' +
            '<input class="opt-values border rounded px-2 py-1 text-sm w-full" placeholder="옵션값 쉼표 구분 (예: 블랙, 화이트)" />';
        div.querySelector('.opt-name').value = name;
        div.querySelector('.opt-values').value = values.join(', ');
        div.querySelector('.rm-opt').addEventListener('click', () => div.remove());
        return div;
    }
    document.getElementById('addOptionBtn').addEventListener('click', () => optionsWrap.appendChild(optionRow()));

    // 카테고리 추천 옵션 프리필 (설계 §11·§18) — 기존 옵션명과 겹치지 않는 것만 추가
    document.getElementById('prefillBtn').addEventListener('click', async () => {
        try {
            const resp = await fetch('/admin/products/options/' + PRODUCT_ID + '/recommended');
            const data = await resp.json();
            if (!data.ok || !data.options || !data.options.length) { alert('이 상품 카테고리에 지정된 추천 옵션이 없습니다.'); return; }
            const existing = new Set([...optionsWrap.querySelectorAll('.opt-name')].map(i => i.value.trim()));
            let added = 0;
            data.options.forEach(o => {
                if (existing.has(o.name)) return;
                optionsWrap.appendChild(optionRow(o.name, o.values || []));
                added++;
            });
            if (!added) alert('이미 모든 추천 옵션이 추가돼 있습니다.');
        } catch (e) { alert('불러오기 오류: ' + e.message); }
    });

    function readOptions() {
        const rows = [...optionsWrap.querySelectorAll('.option-row')];
        return rows.map(r => ({
            name: r.querySelector('.opt-name').value.trim(),
            values: r.querySelector('.opt-values').value.split(',').map(s => s.trim()).filter(Boolean),
        })).filter(o => o.name && o.values.length);
    }

    // ── SKU 그리드 ──
    function cartesian(arrays) {
        return arrays.reduce((acc, arr) => acc.flatMap(a => arr.map(b => [...a, b])), [[]]);
    }
    function skuRow(valueNames, data) {
        const tr = document.createElement('tr');
        tr.className = 'sku-row border-b';
        tr.dataset.values = JSON.stringify(valueNames);
        tr.innerHTML =
            '<td class="py-2 pr-3 font-medium text-gray-800">' + valueNames.join(' / ') + '</td>' +
            '<td class="py-2 px-2"><input type="number" class="sku-price border rounded px-2 py-1 w-full" /></td>' +
            '<td class="py-2 px-2"><input type="number" class="sku-stock border rounded px-2 py-1 w-full" /></td>' +
            '<td class="py-2 px-2"><input type="text" class="sku-code border rounded px-2 py-1 w-full" /></td>' +
            '<td class="py-2 px-2"><select class="sku-status border rounded px-2 py-1 w-full"><option value="ON">판매</option><option value="OFF">중지</option></select></td>';
        tr.querySelector('.sku-price').value = data ? data.price : BASE_PRICE;
        tr.querySelector('.sku-stock').value = data ? data.stock : 0;
        tr.querySelector('.sku-code').value = data ? (data.sku_code || '') : '';
        tr.querySelector('.sku-status').value = data ? (data.status || 'ON') : 'ON';
        tr.appendChild(removeCell(tr));
        return tr;
    }

    // 옵션 조합 SKU 는 행 단위로 지울 수 있다(저장 시 남은 행으로 전체를 다시 만든다).
    function removeCell(tr) {
        const td = document.createElement('td');
        td.className = 'py-2 px-2 text-right';
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'text-xs text-red-500 hover:text-red-700';
        btn.textContent = '삭제';
        btn.addEventListener('click', () => {
            tr.remove();
            if (!skuBody.querySelector('.sku-row')) renderSkuEmpty();
        });
        td.appendChild(btn);
        return td;
    }
    function renderSkuEmpty() {
        skuBody.innerHTML = '';
        const tr = document.createElement('tr');
        tr.id = 'skuEmpty';
        const td = document.createElement('td');
        td.colSpan = 6;
        td.className = 'py-6 text-center text-gray-400';
        td.textContent = '옵션 조합 SKU 가 없습니다. 옵션을 정의하고 [조합 생성] 을 누르세요.';
        tr.appendChild(td);
        skuBody.appendChild(tr);
    }

    /*
     * 기본(대표) SKU 행 — 상품이 항상 1행 갖는 SKU 라 삭제 버튼을 두지 않는다.
     * 옵션상품은 기본 SKU 를 두지 않으므로(옵션 조합 SKU 만) 이 행도 그려지지 않는다.
     */
    function renderDefaultRow(data) {
        defaultBody.innerHTML = '';
        if (!data) return;
        const tr = document.createElement('tr');
        tr.className = 'default-sku-row border-b bg-gray-50';
        tr.innerHTML =
            '<td class="py-2 pr-3"><span class="px-1.5 py-0.5 rounded text-xs bg-gray-800 text-white">기본</span>' +
            '<span class="ml-2 text-xs text-gray-500">옵션 없이 판매되는 기본 SKU</span></td>' +
            '<td class="py-2 px-2"><input type="number" class="sku-price border rounded px-2 py-1 w-full" /></td>' +
            '<td class="py-2 px-2"><input type="number" class="sku-stock border rounded px-2 py-1 w-full" /></td>' +
            '<td class="py-2 px-2"><input type="text" class="sku-code border rounded px-2 py-1 w-full" /></td>' +
            '<td class="py-2 px-2"><select class="sku-status border rounded px-2 py-1 w-full"><option value="ON">판매</option><option value="OFF">중지</option></select></td>' +
            '<td class="py-2 px-2 text-right text-xs text-gray-400">삭제 불가</td>';
        tr.querySelector('.sku-price').value = data.price != null ? data.price : BASE_PRICE;
        tr.querySelector('.sku-stock').value = data.stock != null ? data.stock : 0;
        tr.querySelector('.sku-code').value = data.sku_code || '';
        tr.querySelector('.sku-status').value = data.status || 'ON';
        defaultBody.appendChild(tr);
    }

    function readDefaultSku() {
        const r = defaultBody.querySelector('.default-sku-row');
        if (!r) return null;
        return {
            price: parseInt(r.querySelector('.sku-price').value, 10) || 0,
            stock: parseInt(r.querySelector('.sku-stock').value, 10) || 0,
            sku_code: r.querySelector('.sku-code').value.trim() || null,
            status: r.querySelector('.sku-status').value,
        };
    }
    function keyOf(names) { return names.join(''); }

    function generate() {
        const opts = readOptions();
        if (!opts.length) { alert('옵션을 먼저 정의하세요.'); return; }
        // 기존 입력값 보존
        const existing = {};
        skuBody.querySelectorAll('.sku-row').forEach(r => {
            existing[keyOf(JSON.parse(r.dataset.values))] = {
                price: r.querySelector('.sku-price').value,
                stock: r.querySelector('.sku-stock').value,
                sku_code: r.querySelector('.sku-code').value,
                status: r.querySelector('.sku-status').value,
            };
        });
        const combos = cartesian(opts.map(o => o.values));
        skuBody.innerHTML = '';
        combos.forEach(names => skuBody.appendChild(skuRow(names, existing[keyOf(names)])));
        if (!combos.length) skuBody.innerHTML = '<tr><td colspan="6" class="py-6 text-center text-gray-400">조합 없음</td></tr>';
    }
    document.getElementById('genBtn').addEventListener('click', generate);

    function readSkus() {
        return [...skuBody.querySelectorAll('.sku-row')].map(r => ({
            valueNames: JSON.parse(r.dataset.values),
            price: parseInt(r.querySelector('.sku-price').value, 10) || 0,
            stock: parseInt(r.querySelector('.sku-stock').value, 10) || 0,
            sku_code: r.querySelector('.sku-code').value.trim() || null,
            status: r.querySelector('.sku-status').value,
        }));
    }

    // ── 저장 ──
    document.getElementById('saveBtn').addEventListener('click', async () => {
        const options = readOptions();
        const skus = options.length ? readSkus() : [];
        saveMsg.textContent = '저장 중...';
        saveMsg.className = 'text-sm text-gray-500';
        try {
            const resp = await fetch('/admin/products/options/' + PRODUCT_ID, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ options, skus, defaultSku: readDefaultSku() }),
            });
            const data = await resp.json();
            if (data.ok) {
                saveMsg.textContent = '저장됨 (옵션 ' + data.optionCount + ' · SKU ' + data.skuCount + ')';
                saveMsg.className = 'text-sm text-green-600';
                document.getElementById('typeBadge').textContent = options.length ? 'OPTION' : 'SINGLE';
            } else {
                saveMsg.textContent = data.message || '저장 실패';
                saveMsg.className = 'text-sm text-red-600';
            }
        } catch (e) {
            saveMsg.textContent = '오류: ' + e.message;
            saveMsg.className = 'text-sm text-red-600';
        }
    });

    // ── 초기 렌더 ──
    // 기본 SKU 는 옵션 유무와 무관하게 먼저 그린다(있는 상품만). [조합 생성] 은 skuBody 만
    // 다시 그리므로 이 행은 그대로 남는다.
    renderDefaultRow(initDefaultSku);

    if (initOptions.length) {
        initOptions.forEach(o => optionsWrap.appendChild(optionRow(o.option_name, (o.values || []).map(v => v.value_name))));
        // 기존 SKU 조합 복원
        skuBody.innerHTML = '';
        initSkus.forEach(s => {
            const names = (s.valueIds || []).map(id => valueNameById[id]).filter(Boolean);
            if (names.length) skuBody.appendChild(skuRow(names, { price: s.price, stock: s.stock, sku_code: s.sku_code, status: s.status }));
        });
        if (!skuBody.children.length) skuBody.innerHTML = '<tr id="skuEmpty"><td colspan="6" class="py-6 text-center text-gray-400">옵션을 정의하고 [조합 생성] 을 누르세요.</td></tr>';
    } else {
        optionsWrap.appendChild(optionRow());
    }
})();
</script>
