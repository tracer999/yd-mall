<div class="flex justify-center bg-gray-50 min-h-screen py-8">
    <div class="w-full max-w-7xl bg-white shadow-lg rounded-lg overflow-hidden">
        
        <!-- Header / Navigation -->
        <div class="px-8 py-4 border-b border-gray-100 flex justify-between items-center bg-white sticky top-0 z-10">
            <h1 class="text-xl font-bold text-gray-800">상품 상세 미리보기</h1>
            <div class="flex gap-2">
                <button type="button" onclick="openSEOPopup(<%= product.id %>)" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 bg-indigo-600 text-white hover:bg-indigo-700">
                    SEO 보기
                </button>
                <a href="/admin/products" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">
                    목록으로
                </a>
                <a href="/admin/products/edit/<%= product.id %>" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 no-underline">
                    수정하기
                </a>
                <a href="/admin/products/options/<%= product.id %>" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 border border-indigo-300 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 no-underline">
                    옵션·SKU 관리
                </a>
            </div>
        </div>

        <div class="p-8">
            <!-- Top Section: Images & Basic Info -->
            <div class="flex flex-col lg:flex-row gap-10">
                
                <!-- Left: Image Gallery -->
                <div class="w-full lg:w-1/2 space-y-4">
                    <!-- Main Image Display -->
                    <!-- Main Image Display -->
                    <div class="h-[400px] w-[85%] mx-auto bg-white rounded-xl overflow-hidden border border-gray-100 flex items-center justify-center relative group">
                        <% const mainImg = product.main_image || 'https://via.placeholder.com/600x600?text=No+Image'; %>
                        <img id="mainImage" src="<%= mainImg %>" class="max-w-full max-h-full object-contain transition duration-300">
                    </div>

                    <!-- Thumbnails -->
                    <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide">
                        <!-- Main Image Thumbnail -->
                        <button type="button" onclick="changeMainImage(this, '<%= mainImg %>')" 
                            class="flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden border-2 border-blue-600 ring-2 ring-blue-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition opacity-100 hover:opacity-80">
                            <img src="<%= mainImg %>" class="w-full h-full object-cover">
                        </button>
                        
                        <!-- Additional Images -->
                        <% if(product.images && product.images.length > 0) { %>
                            <% product.images.forEach(img => { %>
                                <button type="button" onclick="changeMainImage(this, '<%= img.image_url %>')" 
                                    class="flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden border-2 border-transparent hover:border-blue-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition opacity-70 hover:opacity-100">
                                    <img src="<%= img.image_url %>" class="w-full h-full object-cover">
                                </button>
                            <% }) %>
                        <% } %>
                    </div>
                </div>

                <!-- Right: Product Information -->
                <div class="w-full lg:w-1/2 flex flex-col">
                    
                    <!-- Themes & Category -->
                    <div class="mb-3 flex flex-wrap gap-2 items-center">
                        <span class="text-sm text-gray-500 font-medium"><%= product.category_name || 'Uncategorized' %></span>
                        <span class="text-gray-300">|</span>
                        <% if (product.themes && product.themes.length > 0) { %>
                            <% product.themes.forEach(theme => { %>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                    ✨ <%= theme.name %>
                                </span>
                            <% }) %>
                        <% } %>
                    </div>

                    <!-- Title -->
                    <h2 class="text-3xl font-bold text-gray-900 leading-tight mb-2"><%= product.name %></h2>
                    
                    <!-- Provider & Slug / URL -->
                    <div class="text-sm text-gray-500 mb-4 space-y-1">
                        <div>
                            판매자: <span class="font-medium text-gray-700"><%= product.provider || 'Dev Mall' %></span>
                        </div>
                        <div class="flex flex-col sm:flex-row sm:items-center sm:gap-2 text-xs text-gray-500">
                            <span class="font-medium text-gray-600">Slug:</span>
                            <span class="font-mono text-gray-800"><%= product.slug || '(미설정)' %></span>
                        </div>
                        <div class="flex flex-col sm:flex-row sm:items-center sm:gap-2 text-xs text-gray-500">
                            <span class="font-medium text-gray-600">공개 URL:</span>
                            <a href="<%= productUrl %>" target="_blank" class="font-mono text-blue-700 hover:underline break-all"><%= productUrl %></a>
                        </div>
                    </div>

                    <!-- Short Description -->
                    <% if(product.short_description) { %>
                        <div class="bg-gray-50 rounded-lg p-3 mb-6 text-gray-600 text-sm leading-relaxed border border-gray-100 max-h-32 overflow-y-auto">
                            <%- product.short_description.replace(/\n/g, '<br>') %> 
                        </div>
                    <% } %>

                    <!-- Price Info -->
                    <div class="mt-auto border-t border-gray-100 pt-6">
                        <div class="space-y-2">
                            <!-- 정가 (할인 시) -->
                            <% if (product.original_price && product.original_price > product.price) { %>
                            <div class="flex items-end justify-end gap-3 text-right">
                                <span class="text-lg font-medium text-gray-400 line-through">₩<%= product.original_price.toLocaleString() %></span>
                                <span class="text-sm bg-gray-100 text-gray-500 px-2 py-1 rounded self-center ml-2">정가</span>
                            </div>
                            <% } %>
                            <!-- 판매가 -->
                            <div class="flex items-end justify-end gap-3 text-right">
                                <% if (product.discount_rate > 0) { %>
                                    <span class="text-xl font-bold text-red-500 self-center"><%= product.discount_rate %>%</span>
                                <% } %>
                                <span class="text-3xl font-bold text-gray-900">₩<%= (product.price || 0).toLocaleString() %></span>
                                <span class="text-sm bg-gray-100 text-gray-600 px-2 py-1 rounded self-center ml-2">판매가</span>
                            </div>
                        </div>

                        <!-- Status & Stock (눈에 띄게) -->
                        <div class="flex gap-6 mt-6 p-5 bg-gray-50 rounded-xl border-2 border-gray-200">
                            <div class="flex items-center gap-3">
                                <span class="text-base font-bold text-gray-700">상태:</span>
                                <% if(product.status === 'ON') { %>
                                    <span class="text-xl text-green-600 font-bold flex items-center gap-2"><i class="bi bi-circle-fill" style="font-size:12px;"></i> 판매중</span>
                                <% } else if(product.status === 'SOLD_OUT') { %>
                                    <span class="text-xl text-yellow-600 font-bold">품절</span>
                                <% } else if(product.status === 'COMING_SOON') { %>
                                    <span class="text-xl text-blue-600 font-bold">판매예정</span>
                                <% } else { %>
                                    <span class="text-xl text-red-600 font-bold">숨김</span>
                                <% } %>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="text-base font-bold text-gray-700">재고:</span>
                                <span class="text-xl font-bold text-gray-900"><%= (product.stock != null ? product.stock : 0).toLocaleString() %>개</span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <hr class="my-10 border-gray-100">

            <!-- Bottom Section: Detailed Content (상단 상품 기본 정보와 동일 너비) -->
            <div class="w-full space-y-12">
                
                <!-- Video Section (접힘) -->
                <% if(product.video_url) { %>
                <details class="group border border-gray-200 rounded-xl overflow-hidden mb-6">
                    <summary class="cursor-pointer list-none p-4 flex justify-between items-center hover:bg-gray-50 transition-colors">
                        <h3 class="text-lg font-bold text-gray-900 flex items-center gap-2">
                            <i class="bi bi-play-circle-fill text-red-500"></i> 관련 영상
                        </h3>
                        <i class="bi bi-chevron-down text-gray-500 transition-transform duration-200 group-open:rotate-180"></i>
                    </summary>
                    <div class="px-4 pb-4 border-t border-gray-100 pt-4">
                        <div class="aspect-w-16 aspect-h-9 h-[500px] w-full bg-black rounded-xl overflow-hidden shadow-lg">
                            <% if(product.video_type === 'YOUTUBE') { %>
                                <iframe width="100%" height="100%" src="<%= product.video_url.replace('watch?v=', 'embed/') %>" frameborder="0" allowfullscreen></iframe>
                            <% } else { %>
                                <video controls class="w-full h-full object-contain">
                                    <source src="<%= product.video_url %>" type="video/mp4">
                                </video>
                            <% } %>
                        </div>
                    </div>
                </details>
                <% } %>

                <!-- AI Recommendation (접힘) -->
                <% if(product.is_ai_recommendation) { %>
                <details class="group border border-gray-200 rounded-xl overflow-hidden mb-6">
                    <summary class="cursor-pointer list-none p-4 flex justify-between items-center hover:bg-gray-50 transition-colors">
                        <h3 class="text-lg font-bold text-purple-900 flex items-center gap-2">
                            <i class="bi bi-stars text-purple-500"></i> AI 추천 포인트
                        </h3>
                        <i class="bi bi-chevron-down text-gray-500 transition-transform duration-200 group-open:rotate-180"></i>
                    </summary>
                    <div class="px-4 pb-8 pt-4 border-t border-gray-100 bg-gradient-to-r from-purple-50 to-indigo-50">
                        <div class="relative overflow-hidden rounded-xl">
                            <div class="absolute top-0 right-0 -mt-4 -mr-4 text-purple-100 opacity-50">
                                <i class="bi bi-stars" style="font-size: 8rem;"></i>
                            </div>
                            <div class="prose prose-purple max-w-none text-gray-700 relative z-10">
                                <%- product.ai_recommendation_content %>
                            </div>
                        </div>
                    </div>
                </details>
                <% } %>

                <!-- Detailed Description (접힘) -->
                <details class="group border border-gray-200 rounded-xl overflow-hidden mb-6">
                    <summary class="cursor-pointer list-none p-4 flex justify-between items-center hover:bg-gray-50 transition-colors">
                        <h3 class="text-lg font-bold text-gray-900">상세 정보</h3>
                        <i class="bi bi-chevron-down text-gray-500 transition-transform duration-200 group-open:rotate-180"></i>
                    </summary>
                    <div class="px-4 pb-4 pt-4 border-t border-gray-100">
                        <div class="prose max-w-none text-gray-800">
                            <%- product.description %>
                        </div>
                    </div>
                </details>

                <!-- 판매이력 -->
                <div class="space-y-4">
                    <h3 class="text-lg font-bold text-gray-900 border-b pb-2 flex items-center gap-2">
                        <i class="bi bi-cart-check text-green-600"></i> 판매이력
                    </h3>
                    <% if (salesHistory && salesHistory.length > 0) { %>
                    <div class="overflow-x-auto rounded-lg border border-gray-200">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">주문번호</th>
                                    <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">주문일시</th>
                                    <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">주문자</th>
                                    <th scope="col" class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase">수량</th>
                                    <th scope="col" class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase">금액</th>
                                    <th scope="col" class="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase">상태</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% salesHistory.forEach(function(item) { %>
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-3 text-sm text-gray-900">
                                        <a href="/admin/sales/<%= item.order_id %>" class="text-blue-600 hover:underline font-medium"><%= item.order_number %></a>
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-600"><%= (item.paid_at || item.created_at) ? new Date(item.paid_at || item.created_at).toLocaleString('ko-KR') : '-' %></td>
                                    <td class="px-4 py-3 text-sm text-gray-600"><%= item.buyer_name %> / <%= item.buyer_email %></td>
                                    <td class="px-4 py-3 text-sm text-gray-900 text-right"><%= item.quantity.toLocaleString() %>개</td>
                                    <td class="px-4 py-3 text-sm text-gray-900 text-right font-medium">₩<%= item.total_price.toLocaleString() %></td>
                                    <td class="px-4 py-3 text-sm text-center">
                                        <% 
                                        const statusMap = { PAID: { label: '결제완료', cls: 'bg-blue-100 text-blue-800' }, PREPARING: { label: '준비중', cls: 'bg-amber-100 text-amber-800' }, SHIPPED: { label: '배송중', cls: 'bg-indigo-100 text-indigo-800' }, DELIVERED: { label: '배송완료', cls: 'bg-green-100 text-green-800' } };
                                        const s = statusMap[item.order_status] || { label: item.order_status, cls: 'bg-gray-100 text-gray-800' };
                                        %>
                                        <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium <%= s.cls %>"><%= s.label %></span>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <p class="text-gray-500 text-sm py-4">해당 상품의 판매이력이 없습니다.</p>
                    <% } %>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    function changeMainImage(btn, url) {
        // Update Main Image
        const mainImg = document.getElementById('mainImage');
        mainImg.src = url;

        // Update Active Styling
        // Reset all buttons
        const buttons = btn.parentElement.querySelectorAll('button');
        buttons.forEach(b => {
            b.classList.remove('border-blue-600', 'ring-2', 'ring-blue-100', 'opacity-100');
            b.classList.add('border-transparent', 'opacity-70');
        });

        // Set active button
        btn.classList.remove('border-transparent', 'opacity-70');
        btn.classList.add('border-blue-600', 'ring-2', 'ring-blue-100', 'opacity-100');
    }
</script>

<script>
    function openSEOPopup(productId) {
        const w = 960;
        const h = 800;
        const left = window.screenX + (window.outerWidth - w) / 2;
        const top = window.screenY + (window.outerHeight - h) / 2;
        window.open(`/admin/products/seo/view/${productId}`, 'productSeoPreview', `width=${w},height=${h},left=${left},top=${top},scrollbars=yes,resizable=yes`);
    }
</script>
