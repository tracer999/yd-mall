<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>상품 SEO 미리보기</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="/css/style.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
</head>
<body class="bg-gray-50">
  <div class="max-w-4xl mx-auto my-6 bg-white shadow-lg rounded-lg border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
      <h1 class="text-lg font-bold text-gray-800">상품 SEO 미리보기</h1>
      <button onclick="window.close()" class="text-sm text-gray-500 hover:text-gray-800">창 닫기</button>
    </div>

    <div class="p-6 space-y-6">
      <% if (message) { %>
        <div class="p-4 bg-yellow-50 border border-yellow-200 rounded text-sm text-yellow-800">
          <%= message %>
        </div>
      <% } %>

      <% if (seo && product) { %>
        <section class="space-y-2">
          <h2 class="text-base font-semibold text-gray-900">기본 정보</h2>
          <dl class="text-sm text-gray-700 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1">
            <div>
              <dt class="font-medium text-gray-500">상품명</dt>
              <dd><%= product.name %></dd>
            </div>
            <div>
              <dt class="font-medium text-gray-500">카테고리</dt>
              <dd><%= product.category_name || '-' %></dd>
            </div>
            <div>
              <dt class="font-medium text-gray-500">공급사</dt>
              <dd><%= product.provider || '-' %></dd>
            </div>
            <div>
              <dt class="font-medium text-gray-500">판매가</dt>
              <dd>
                <% if (product.price) { %>
                  <%= Number(product.price).toLocaleString('ko-KR') %>원
                <% } else { %>
                  -
                <% } %>
              </dd>
            </div>
          </dl>
        </section>

        <!-- Meta Description 편집 영역 -->
        <section class="space-y-3 p-5 bg-blue-50 border border-blue-200 rounded-lg">
          <div class="flex items-center justify-between">
            <h2 class="text-base font-semibold text-gray-900">
              <i class="bi bi-pencil-square text-blue-600 mr-1"></i> Meta Description
            </h2>
            <div class="flex items-center gap-2">
              <% if (seoDescriptionSource === 'db') { %>
                <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold bg-green-100 text-green-700 border border-green-200">DB 저장값</span>
              <% } else if (seoDescriptionSource === 'short_desc') { %>
                <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold bg-yellow-100 text-yellow-700 border border-yellow-200">짧은 설명에서 추출</span>
              <% } else { %>
                <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold bg-gray-100 text-gray-600 border border-gray-200">자동 생성</span>
              <% } %>
            </div>
          </div>

          <textarea id="metaDescInput" rows="3" maxlength="160"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md bg-white focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-blue-400 resize-none"
            placeholder="메타 디스크립션을 입력하세요 (최대 160자)"><%= seo.description || '' %></textarea>
          <% const aiUsable = (typeof aiStatus !== 'undefined' && aiStatus) ? aiStatus.usable : true; %>
          <% const aiMessage = (typeof aiStatus !== 'undefined' && aiStatus) ? (aiStatus.message || '') : ''; %>
          <% if (!aiUsable) { %>
          <div class="mt-2 flex items-start gap-2 rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-800">
            <i class="bi bi-exclamation-triangle-fill mt-0.5"></i>
            <span><%= aiMessage %></span>
          </div>
          <% } %>
          <div class="flex items-center justify-between">
            <span class="text-xs text-gray-500"><span id="metaCharCount"><%= (seo.description || '').length %></span>/160자</span>
            <div class="flex gap-2">
              <button type="button" id="btnAiGenerate" onclick="generateAIMeta()"
                <%= aiUsable ? '' : 'aria-disabled="true"' %>
                style="<%= aiUsable ? 'background:#7c3aed; color:#fff; cursor:pointer;' : 'background:#d1d5db; color:#6b7280; cursor:not-allowed;' %>"
                class="inline-flex items-center h-[34px] px-4 text-xs font-medium rounded-md hover:opacity-90 transition gap-1">
                <i class="bi bi-stars"></i> AI 생성
              </button>
              <button type="button" id="btnSaveMeta" onclick="saveMetaDescription()"
                style="background:#2563eb; color:#fff; cursor:pointer;"
                class="inline-flex items-center h-[34px] px-4 text-xs font-medium rounded-md hover:opacity-90 transition gap-1">
                <i class="bi bi-check-lg"></i> 저장
              </button>
            </div>
          </div>
          <div id="metaStatus" class="hidden text-sm p-2 rounded"></div>
        </section>

        <section class="space-y-2">
          <h2 class="text-base font-semibold text-gray-900">Google 검색 미리보기</h2>
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <div class="text-blue-800 text-lg font-medium hover:underline cursor-pointer truncate"><%= seo.title %></div>
            <div class="text-green-700 text-sm truncate"><%= seo.url %></div>
            <div class="text-sm text-gray-600 mt-1 line-clamp-2" id="googlePreviewDesc"><%= seo.description || '메타 디스크립션이 설정되지 않았습니다.' %></div>
          </div>
        </section>

        <section class="space-y-2">
          <h2 class="text-base font-semibold text-gray-900">검색 엔진용 Head 태그</h2>
          <p class="text-xs text-gray-600 mb-1">
            실제 상품 상세 페이지 &lt;head&gt; 영역에 사용되는 SEO 관련 태그와 JSON-LD입니다.
          </p>
          <pre class="text-xs bg-gray-900 text-green-100 rounded p-4 max-h-96 overflow-auto whitespace-pre-wrap"><%= headHtml %>

&lt;script type=&quot;application/ld+json&quot;&gt;
<%= seo.jsonLd %>
&lt;/script&gt;</pre>
        </section>

        <section class="space-y-2">
          <h2 class="text-base font-semibold text-gray-900">SEO 요약</h2>
          <div class="space-y-3 text-sm text-gray-800">
            <div>
              <div class="font-medium text-gray-500 mb-1">Title</div>
              <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded"><%= seo.title %></div>
            </div>
            <div>
              <div class="font-medium text-gray-500 mb-1">Meta Description</div>
              <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded whitespace-pre-line" id="seoSummaryDesc"><%= seo.description || '-' %></div>
            </div>
            <div>
              <div class="font-medium text-gray-500 mb-1">Canonical URL</div>
              <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded break-all"><%= seo.url %></div>
            </div>
            <div>
              <div class="font-medium text-gray-500 mb-1">Open Graph 이미지</div>
              <% if (seo.image) { %>
                <div class="flex items-center space-x-4">
                  <img src="<%= seo.image %>" alt="OG Image" class="w-24 h-24 object-cover border rounded">
                  <span class="text-xs break-all text-gray-600"><%= seo.image %></span>
                </div>
              <% } else { %>
                <div class="px-3 py-2 bg-gray-50 border border-gray-200 rounded text-gray-500">설정된 대표 이미지가 없습니다.</div>
              <% } %>
            </div>
          </div>
        </section>
      <% } %>
    </div>
  </div>

  <% if (seo && product) { %>
  <script>
    const productId = <%= product.id %>;
    const metaInput = document.getElementById('metaDescInput');
    const charCount = document.getElementById('metaCharCount');
    const statusEl = document.getElementById('metaStatus');

    metaInput.addEventListener('input', function() {
      charCount.textContent = this.value.length;
      // 실시간 Google 프리뷰 업데이트
      document.getElementById('googlePreviewDesc').textContent = this.value || '메타 디스크립션이 설정되지 않았습니다.';
      document.getElementById('seoSummaryDesc').textContent = this.value || '-';
    });

    function showStatus(msg, type) {
      statusEl.className = 'text-sm p-2 rounded ' + (type === 'success' ? 'bg-green-50 text-green-700 border border-green-200' : type === 'error' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-blue-50 text-blue-700 border border-blue-200');
      statusEl.textContent = msg;
      statusEl.classList.remove('hidden');
      if (type !== 'loading') setTimeout(() => statusEl.classList.add('hidden'), 4000);
    }

    const AI_USABLE = <%= (typeof aiStatus !== 'undefined' && aiStatus && aiStatus.usable) ? 'true' : 'false' %>;
    const AI_MESSAGE = <%- JSON.stringify((typeof aiStatus !== 'undefined' && aiStatus) ? (aiStatus.message || 'AI 기능을 사용할 수 없습니다.') : 'AI 기능을 사용할 수 없습니다.') %>;

    async function generateAIMeta() {
      if (!AI_USABLE) {
        showStatus(AI_MESSAGE, 'error');
        return;
      }
      const btn = document.getElementById('btnAiGenerate');
      btn.disabled = true;
      btn.innerHTML = '<i class="bi bi-hourglass-split"></i> 생성 중...';
      showStatus('AI가 메타 디스크립션을 생성하고 있습니다...', 'loading');

      try {
        const res = await fetch('/admin/products/seo/generate-meta', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ product_id: productId })
        });
        const data = await res.json();
        if (data.error) {
          showStatus('오류: ' + data.error, 'error');
        } else {
          metaInput.value = data.content;
          charCount.textContent = data.content.length;
          document.getElementById('googlePreviewDesc').textContent = data.content;
          document.getElementById('seoSummaryDesc').textContent = data.content;
          showStatus('AI 생성 완료! [저장] 버튼을 눌러 DB에 반영하세요.', 'success');
        }
      } catch (err) {
        showStatus('AI 생성 중 오류가 발생했습니다.', 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-stars"></i> AI 생성';
      }
    }

    async function saveMetaDescription() {
      const btn = document.getElementById('btnSaveMeta');
      const value = metaInput.value.trim();
      btn.disabled = true;
      btn.innerHTML = '<i class="bi bi-hourglass-split"></i> 저장 중...';

      try {
        const res = await fetch('/admin/products/seo/save-meta', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ product_id: productId, meta_description: value })
        });
        const data = await res.json();
        if (data.success) {
          showStatus('메타 디스크립션이 저장되었습니다.', 'success');
        } else {
          showStatus('저장 실패: ' + (data.error || ''), 'error');
        }
      } catch (err) {
        showStatus('저장 중 오류가 발생했습니다.', 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check-lg"></i> 저장';
      }
    }
  </script>
  <% } %>
</body>
</html>
