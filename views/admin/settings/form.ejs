                            <input type="number" name="new_product_days" min="1" max="3650"
                                value="<%= (systemSettings && systemSettings.new_product_days) || '100' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">신규 입점 브랜드 노출 기간 (일)</label>
                            <p class="text-xs text-gray-500 mb-2">입점일로부터 이 기간 안에 있는 브랜드를 신규 입점으로 봅니다.</p>
                            <input type="number" name="new_brand_days" min="1" max="3650"
                                value="<%= (systemSettings && systemSettings.new_brand_days) || '180' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white overflow-hidden shadow-sm rounded-lg">
                <div class="px-6 py-4 bg-white border-b border-gray-200">
                    <h5 class="text-lg font-bold text-gray-800">포인트 설정</h5>
                </div>
                <div class="p-6 bg-white space-y-4">
                    <p class="text-xs text-gray-500 mb-4">주문 결제 시 포인트 적립 및 사용 규칙입니다.</p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">구매 적립률 (%)</label>
                            <p class="text-xs text-gray-500 mb-2">결제 금액 대비 적립되는 포인트 비율 (예: 5 = 5%)</p>
                            <input type="number" name="point_accumulate_rate" min="0" max="100"
                                value="<%= (systemSettings && systemSettings.point_accumulate_rate) || '5' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">포인트 최소 사용 단위 (원)</label>
                            <p class="text-xs text-gray-500 mb-2">결제 시 사용 가능한 최소 포인트 단위</p>
                            <input type="number" name="point_min_use" min="0"
                                value="<%= (systemSettings && systemSettings.point_min_use) || '1000' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">포인트 유효기간 (개월)</label>
                            <p class="text-xs text-gray-500 mb-2">
                                적립일로부터 이 기간이 지나면 자동으로 소멸합니다.
                                <b>0 이면 소멸하지 않습니다.</b> 앞으로 적립되는 포인트부터 적용되며, 이미 적립된 포인트는 소급되지 않습니다.
                            </p>
                            <input type="number" name="point_expiry_months" min="0" max="120"
                                value="<%= (systemSettings && systemSettings.point_expiry_months) || '0' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">자동 배송완료 처리 (일)</label>
                            <p class="text-xs text-gray-500 mb-2">
                                송장 등록(발송) 후 이 일수가 지난 <b>배송중</b> 주문을 자동으로 배송완료 처리합니다.
                                <b>0 이면 자동 처리하지 않습니다.</b> 배송완료일은 반품 가능 기간의 기준이 됩니다.
                            </p>
                            <input type="number" name="auto_deliver_days" min="0" max="60"
                                value="<%= (systemSettings && systemSettings.auto_deliver_days) || '0' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">자동 구매확정 (일)</label>
                            <p class="text-xs text-gray-500 mb-2">
                                <b class="text-gray-700">적립금은 구매확정 시점에 지급됩니다.</b>
                                배송완료 후 이 일수가 지나도 고객이 확정하지 않으면 자동으로 확정하고 적립금을 지급합니다.
                                <b>0 이면 자동 확정하지 않습니다</b> — 이 경우 고객이 직접 [구매확정]을 누르지 않으면
                                <b class="text-red-600">적립금이 지급되지 않습니다.</b>
                                반품 가능 기간(7일)보다 짧게 넣어도 7일이 지나야 확정됩니다.
                            </p>
                            <input type="number" name="auto_confirm_days" min="0" max="60"
                                value="<%= (systemSettings && systemSettings.auto_confirm_days) || '7' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white overflow-hidden shadow-sm rounded-lg">
                <div class="px-6 py-4 bg-white border-b border-gray-200">
                    <h5 class="text-lg font-bold text-gray-800">문자 · 카카오 알림톡</h5>
                </div>
                <div class="p-6 bg-white space-y-4">
                    <div class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-xs text-amber-900 leading-relaxed">
                        <b>이 기능은 외부 계약이 있어야 실제로 발송됩니다.</b><br>
                        · <b>문자</b> — 문자 중계사 가입 후 <b>발신번호 사전등록</b>(통신사 규정, 서류 심사)을 마쳐야 합니다.<br>
                        · <b>알림톡</b> — 카카오 비즈니스 채널 개설 후 <b>템플릿 사전승인</b>이 필요합니다(영업일 기준 수일 소요).
                        승인된 템플릿과 문구가 한 글자라도 다르면 발송되지 않으며, 템플릿이 없으면 <b>문자로 대신 발송</b>됩니다.<br>
                        설정이 비어 있으면 아무것도 보내지 않고 조용히 건너뜁니다. 주문·클레임 처리에는 영향이 없습니다.
                    </div>

                    <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                        <input type="checkbox" name="sms_enabled" value="1"
                            <%= (systemSettings && systemSettings.sms_enabled === '1') ? 'checked' : '' %>
                            class="w-4 h-4 rounded border-gray-300">
                        문자·알림톡 발송 사용
                    </label>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">문자 중계사</label>
                            <select name="sms_provider" class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm">
                                <% const prov = (systemSettings && systemSettings.sms_provider) || ''; %>
                                <option value="" <%= !prov ? 'selected' : '' %>>선택 안 함</option>
                                <option value="aligo" <%= prov === 'aligo' ? 'selected' : '' %>>알리고 (Aligo)</option>
                                <option value="solapi" <%= prov === 'solapi' ? 'selected' : '' %>>솔라피 (Solapi/CoolSMS)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">발신번호</label>
                            <p class="text-xs text-gray-500 mb-2">통신사에 사전등록을 마친 번호만 쓸 수 있습니다.</p>
                            <input type="text" name="sms_sender" placeholder="02-0000-0000"
                                value="<%= (systemSettings && systemSettings.sms_sender) || '' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">API 키</label>
                            <input type="text" name="sms_api_key"
                                value="<%= (systemSettings && systemSettings.sms_api_key) || '' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">계정 ID <span class="text-gray-400 font-normal">(알리고)</span></label>
                            <input type="text" name="sms_user_id"
                                value="<%= (systemSettings && systemSettings.sms_user_id) || '' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">API 시크릿 <span class="text-gray-400 font-normal">(솔라피)</span></label>
                            <input type="text" name="sms_api_secret"
                                value="<%= (systemSettings && systemSettings.sms_api_secret) || '' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">알림톡 채널 키</label>
                            <p class="text-xs text-gray-500 mb-2">비우면 알림톡 없이 문자로만 발송합니다.</p>
                            <input type="text" name="alimtalk_sender_key"
                                value="<%= (systemSettings && systemSettings.alimtalk_sender_key) || '' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm">
                        </div>
                    </div>

                    <div class="pt-3 border-t border-gray-100">
                        <p class="text-sm font-medium text-gray-700 mb-1">알림톡 템플릿 코드</p>
                        <p class="text-xs text-gray-500 mb-3">카카오에서 승인받은 템플릿의 코드입니다. 비워 두면 그 안내는 문자로 나갑니다.</p>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">클레임 접수</label>
                                <input type="text" name="alimtalk_tpl_claim_requested"
                                    value="<%= (systemSettings && systemSettings.alimtalk_tpl_claim_requested) || '' %>"
                                    class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">클레임 처리결과</label>
                                <input type="text" name="alimtalk_tpl_claim_processed"
                                    value="<%= (systemSettings && systemSettings.alimtalk_tpl_claim_processed) || '' %>"
                                    class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">회수 접수</label>
                                <input type="text" name="alimtalk_tpl_return_pickup"
                                    value="<%= (systemSettings && systemSettings.alimtalk_tpl_return_pickup) || '' %>"
                                    class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white overflow-hidden shadow-sm rounded-lg">
                <div class="px-6 py-4 bg-white border-b border-gray-200">
                    <h5 class="text-lg font-bold text-gray-800">토스페이먼츠 결제 설정</h5>
                </div>
                <div class="p-6 bg-white space-y-4">
                    <p class="text-xs text-gray-500 mb-4">상품 구매 시 결제에 사용됩니다. <a href="https://developers.tosspayments.com" target="_blank" rel="noopener" class="text-blue-600 hover:underline">토스페이먼츠 개발자센터</a>에서 API 키를 발급받으세요.</p>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">클라이언트 키 (테스트)</label>
                        <p class="text-xs text-gray-500 mb-2">결제창 연동용. 테스트 키는 test_ 로 시작합니다.</p>
                           <input type="text" name="tosspayments_client_key"
                               placeholder="test_ck_..."
                               value="<%= (systemSettings && systemSettings.tosspayments_client_key) || '' %>"
                               class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">시크릿 키 (테스트)</label>
                        <p class="text-xs text-gray-500 mb-2">서버 결제 승인 API용. 절대 클라이언트에 노출하지 마세요.</p>
                           <input type="password" name="tosspayments_secret_key"
                               placeholder="test_sk_..."
                               value="<%= (systemSettings && systemSettings.tosspayments_secret_key) || '' %>"
                               autocomplete="off"
                               class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                    </div>
                </div>
            </div>

            <div class="bg-white overflow-hidden shadow-sm rounded-lg">
                <div class="px-6 py-4 bg-white border-b border-gray-200">
                    <h5 class="text-lg font-bold text-gray-800">SMTP 메일 설정</h5>
                </div>
                <div class="p-6 bg-white space-y-4">
                    <p class="text-xs text-gray-500 mb-4">주문 알림, 배송 알림, 운영자 이중인증 등 공통 이메일 발송에 사용됩니다.</p>

                    <%
                    /* 미설정이면 발송(기본값 유지) — 서비스의 isEmailEnabled() 와 같은 규칙 */
                    const _mailRaw = (systemSettings && systemSettings.email_enabled);
                    const _mailOn = (_mailRaw === undefined || _mailRaw === null || String(_mailRaw).trim() === '')
                        ? true : !['0','false','off','no'].includes(String(_mailRaw).trim().toLowerCase());
                    %>
                    <div class="rounded-md border <%= _mailOn ? 'border-gray-200 bg-gray-50' : 'border-amber-300 bg-amber-50' %> p-4">
                        <label class="flex items-center gap-2 text-sm font-medium text-gray-800">
                            <input type="checkbox" name="email_enabled" value="1" <%= _mailOn ? 'checked' : '' %>
                                   class="rounded border-gray-300">
                            이메일 발송 사용
                        </label>
                        <p class="mt-2 text-xs text-gray-600">
                            끄면 <strong>모든 이메일 발송이 차단</strong>됩니다(주문·승인·2FA 포함).
                            테스트나 리허설 중 실제 고객에게 메일이 나가는 것을 막을 때 사용하세요.
                        </p>
                        <% if (!_mailOn) { %>
                            <p class="mt-2 text-xs font-semibold text-amber-800">
                                현재 발송이 꺼져 있습니다 — 주문 알림·승인 안내가 나가지 않습니다.
                            </p>
                        <% } %>
                        <p class="mt-2 text-xs text-gray-500">
                            참고: <code>example.com</code>·<code>.test</code>·<code>.invalid</code>·<code>.local</code> 같은
                            <strong>배달 불가 예약 도메인</strong>은 이 설정과 무관하게 항상 차단됩니다(반송만 쌓이고 발신 평판이 깎입니다).
                        </p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">메일 서버 주소</label>
                            <input type="text" name="smtp_host"
                                placeholder="smtp.gmail.com"
                                value="<%= (systemSettings && systemSettings.smtp_host) || '' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">포트</label>
                            <input type="text" name="smtp_port"
                                placeholder="587"
                                value="<%= (systemSettings && systemSettings.smtp_port) || '' %>"
                                class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                        </div>
                    </div>
                    <div>
                           <label class="block text-sm font-medium text-gray-700 mb-1">발송자 이메일 주소</label>
                           <input type="email" name="smtp_sender_email"
                               placeholder="noreply@example.com"
                               value="<%= (systemSettings && systemSettings.smtp_sender_email) || '' %>"
                               class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">메일 서비스 유형</label>
                        <div class="flex gap-6">
                            <label class="inline-flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="smtp_is_gmail" value="1" <%= (systemSettings && systemSettings.smtp_is_gmail === '1') ? 'checked' : '' %>>
                                <span class="text-sm">지메일 (Gmail) — 앱 비밀번호 사용</span>
                            </label>
                            <label class="inline-flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="smtp_is_gmail" value="0" <%= (!systemSettings || systemSettings.smtp_is_gmail !== '1') ? 'checked' : '' %>>
                                <span class="text-sm">기타 SMTP</span>
                            </label>
                        </div>
                    </div>
                    <div id="smtpGmailField" class="<%= (systemSettings && systemSettings.smtp_is_gmail === '1') ? '' : 'hidden' %>">
                        <label class="block text-sm font-medium text-gray-700 mb-1">지메일 앱 비밀번호</label>
                        <p class="text-xs text-gray-500 mb-2">Google 계정에서 2단계 인증 후 발급한 앱 비밀번호를 입력하세요. 공백 포함 가능합니다.</p>
                           <input type="password" name="smtp_app_password"
                               placeholder="xxxx xxxx xxxx xxxx"
                               value="<%= (systemSettings && systemSettings.smtp_app_password) || '' %>"
                               autocomplete="off"
                               class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                    </div>
                    <div id="smtpOtherField" class="<%= (!systemSettings || systemSettings.smtp_is_gmail === '1') ? 'hidden' : '' %>">
                        <label class="block text-sm font-medium text-gray-700 mb-1">SMTP 비밀번호</label>
                        <p class="text-xs text-gray-500 mb-2">지메일이 아닌 메일 서버의 SMTP 인증 비밀번호를 입력하세요.</p>
                           <input type="password" name="smtp_password"
                               value="<%= (systemSettings && systemSettings.smtp_password) || '' %>"
                               autocomplete="off"
                               class="w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                    </div>
                    <div class="pt-4 border-t border-gray-100">
                        <label class="block text-sm font-medium text-gray-700 mb-2">테스트 발송</label>
                        <p class="text-xs text-gray-500 mb-2">설정을 저장한 후, 아래에서 테스트 메일을 발송해 보세요.</p>
                        <div class="flex gap-2">
                            <input type="email" id="testEmailTo" placeholder="수신자 이메일"
                                class="flex-1 rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500">
                            <button type="button" id="sendTestEmailBtn"
                                    class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">
                                테스트 발송
                            </button>
                        </div>
                        <p id="testEmailResult" class="mt-2 text-sm hidden"></p>
                    </div>
                </div>
            </div>

            <div class="flex justify-end pt-4 pb-8">
                <button type="submit"
                        class="inline-flex items-center justify-center h-[50px] px-6 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700">
                    저장하기
                </button>
            </div>
        </form>
        <% } %>

<% if (_activeTab === 'system') { %>
<script>
(function() {
    const gmailRadios = document.querySelectorAll('input[name="smtp_is_gmail"]');
    const gmailField = document.getElementById('smtpGmailField');
    const otherField = document.getElementById('smtpOtherField');
    gmailRadios.forEach(function(radio) {
        radio.addEventListener('change', function() {
            const isGmail = this.value === '1';
            gmailField.classList.toggle('hidden', !isGmail);
            otherField.classList.toggle('hidden', isGmail);
        });
    });

    // 테스트 이메일 발송
    const sendTestBtn = document.getElementById('sendTestEmailBtn');
    const testEmailInput = document.getElementById('testEmailTo');
    const testEmailResult = document.getElementById('testEmailResult');
    if (sendTestBtn && testEmailInput) {
        sendTestBtn.addEventListener('click', async function() {
            const to = testEmailInput.value.trim();
            if (!to) {
                testEmailResult.textContent = '수신자 이메일을 입력하세요.';
                testEmailResult.className = 'mt-2 text-sm text-red-600';
                testEmailResult.classList.remove('hidden');
                return;
            }
            sendTestBtn.disabled = true;
            testEmailResult.classList.add('hidden');
            try {
                const res = await fetch('<%= _basePath %>/send-test-email', {
                    method: 'POST',
                    body: new URLSearchParams({ test_email_to: to }),
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    credentials: 'same-origin'
                });
                const data = await res.json();
                testEmailResult.classList.remove('hidden');
                if (data.success) {
                    testEmailResult.textContent = data.message || '발송되었습니다.';
                    testEmailResult.className = 'mt-2 text-sm text-green-600';
                } else {
                    testEmailResult.textContent = data.error || '발송 실패';
                    testEmailResult.className = 'mt-2 text-sm text-red-600';
                }
            } catch (err) {
                testEmailResult.classList.remove('hidden');
                testEmailResult.textContent = '요청 중 오류가 발생했습니다.';
                testEmailResult.className = 'mt-2 text-sm text-red-600';
            }
            sendTestBtn.disabled = false;
        });
    }

})();
</script>
<% } %>
