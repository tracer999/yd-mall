<% const _basePath = (typeof basePath !== 'undefined' && basePath) ? basePath : '/admin/settings'; %>
<% const _showTabs = (typeof showTabs === 'undefined') ? true : !!showTabs; %>
<% const _activeTab = (activeTab === 'system') ? 'system' : 'company'; %>

<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4 sm:gap-0">
    <p class="text-sm text-gray-500">
        <% if (_activeTab === 'company') { %>
            사이트 기본 정보 및 회사 정보를 관리합니다.
        <% } else { %>
            시스템 API 키, 결제, 인증 등의 설정을 관리합니다.
        <% } %>
    </p>
</div>

<% if (_showTabs) { %>
    <div class="bg-white border-b border-gray-200 px-4 mb-6 rounded-t-lg">
        <nav class="-mb-px flex space-x-8" aria-label="Tabs">
            <a href="<%= _basePath %>?tab=company" 
               class="<%= _activeTab === 'company' ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
                기본 정보관리
            </a>
            <a href="<%= _basePath %>?tab=system" 
               class="<%= _activeTab === 'system' ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
                시스템 설정
            </a>
        </nav>
    </div>
<% } %>

