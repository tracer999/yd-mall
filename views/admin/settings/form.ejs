                            { name: 'Blue', main: '#3B82F6', dark: '#1D4ED8', light: '#DBEAFE' },
                            { name: 'Purple', main: '#8B5CF6', dark: '#6D28D9', light: '#EDE9FE' },
                            { name: 'Rose', main: '#F43F5E', dark: '#BE123C', light: '#FFE4E6' },
                            { name: 'Amber', main: '#F59E0B', dark: '#B45309', light: '#FEF3C7' },
                            { name: 'Teal', main: '#14B8A6', dark: '#0F766E', light: '#CCFBF1' },
