<%
  /* 클레임 관리 (주문/클레임 문서 §5-2) */
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');
  const dt = (v) => (v ? new Date(v).toLocaleString('ko-KR') : '-');
  const TYPE = { CANCEL: ['취소', 'bg-orange-100 text-orange-800'], RETURN: ['반품', 'bg-sky-100 text-sky-800'], EXCHANGE: ['교환', 'bg-purple-100 text-purple-800'] };
  const STATUS = {
    REQUESTED: ['접수', 'bg-amber-100 text-amber-800'],
    APPROVED:  ['승인', 'bg-blue-100 text-blue-800'],
    COMPLETED: ['완료', 'bg-green-100 text-green-800'],
    REJECTED:  ['거절', 'bg-red-100 text-red-700'],
    WITHDRAWN: ['철회', 'bg-gray-100 text-gray-600'],
  };
  const REASON = { CHANGE_OF_MIND: '단순 변심', DEFECT: '불량', WRONG_DELIVERY: '오배송', OTHER: '기타' };
%>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">클레임 관리</h1>
  <p class="mt-1 text-sm text-gray-500">취소·반품·환불 요청을 처리합니다. 승인하면 재고·쿠폰·적립금이 복원되고 결제가 취소됩니다.</p>
</div>

<form method="GET" action="/admin/claims" class="mb-4 flex flex-wrap items-end gap-3 bg-white p-4 rounded-lg shadow-sm">
  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">상태</label>
    <select name="status" class="text-sm border-gray-300 rounded-md">
      <option value="">전체</option>
      <% Object.keys(STATUS).forEach(function (k) { %>
        <option value="<%= k %>" <%= filters.status === k ? 'selected' : '' %>><%= STATUS[k][0] %></option>
      <% }); %>
    </select>
  </div>
  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">유형</label>
    <select name="claim_type" class="text-sm border-gray-300 rounded-md">
      <option value="">전체</option>
      <option value="CANCEL" <%= filters.claim_type === 'CANCEL' ? 'selected' : '' %>>취소</option>
      <option value="RETURN" <%= filters.claim_type === 'RETURN' ? 'selected' : '' %>>반품</option>
    </select>
  </div>
  <button type="submit" class="h-[38px] px-4 text-sm font-medium rounded-md bg-gray-800 text-white hover:bg-gray-900">검색</button>
</form>

<div class="bg-white overflow-hidden shadow-sm rounded-lg">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">신청일</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">주문번호</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">고객</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">유형</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">사유</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">금액</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">처리</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if (!claims.length) { %>
          <tr><td colspan="8" class="px-6 py-8 text-center text-gray-500">조건에 맞는 클레임이 없습니다.</td></tr>
        <% } %>
        <% claims.forEach(function (c) {
             const t = TYPE[c.claim_type] || TYPE.CANCEL;
             const s = STATUS[c.status] || STATUS.REQUESTED;
        %>
          <tr class="<%= c.status === 'REQUESTED' ? 'bg-amber-50/40' : '' %>">
            <td class="px-4 py-3 text-sm text-gray-500"><%= dt(c.requested_at) %></td>
            <td class="px-4 py-3 text-sm font-mono text-gray-800"><%= c.order_number %></td>
            <td class="px-4 py-3 text-sm text-gray-700"><%= c.customer_name || '비회원' %></td>
            <td class="px-4 py-3 text-sm"><span class="px-2 py-0.5 rounded text-xs <%= t[1] %>"><%= t[0] %></span></td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= REASON[c.reason_type] || '기타' %></td>
            <td class="px-4 py-3 text-sm text-gray-800"><%= won(c.total_amount) %>원</td>
            <td class="px-4 py-3 text-sm"><span class="px-2 py-0.5 rounded-full text-xs <%= s[1] %>"><%= s[0] %></span></td>
            <td class="px-4 py-3 text-right">
              <a href="/admin/claims/<%= c.id %>" class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md border border-indigo-200 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 no-underline">
                <%= c.status === 'REQUESTED' ? '처리' : '상세' %>
              </a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
