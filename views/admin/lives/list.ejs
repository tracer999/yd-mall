<%
  /*
   * 쇼핑라이브 목록
   *
   * 공동구매 목록과 결정적으로 다른 점: 상태를 여기서 바로 바꾼다.
   * 방송 시작·종료는 초 단위로 급한 조작이라, 수정 폼에 들어가 전체를 다시 저장하게 하면 안 된다.
   * status 는 수동이다 — 시간이 지났다고 코드가 넘기지 않는다(설계서 §3-1).
   */
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');
  const fmtDT = (d) => d ? new Date(d).toLocaleString('ko-KR', { month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }) : '-';

  const STATUS_CLASS = {
    ON_AIR: 'bg-red-100 text-red-700',
    SCHEDULED: 'bg-purple-100 text-purple-700',
    DRAFT: 'bg-yellow-100 text-yellow-700',
    ENDED: 'bg-gray-100 text-gray-500',
    CANCELLED: 'bg-gray-200 text-gray-600',
  };
%>
<div class="p-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800"><%= title %></h1>
            <% if (subtitle) { %><p class="mt-1 text-sm text-gray-500"><%= subtitle %></p><% } %>
        </div>
        <a href="/admin/lives/add" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
            <i class="bi bi-plus-lg"></i> 라이브 등록
        </a>
    </div>

    <% if (saved) { %>
        <div class="mb-4 px-4 py-3 rounded bg-green-50 text-green-700 text-sm">저장되었습니다.</div>
    <% } %>
    <% if (error) { %>
        <div class="mb-4 px-4 py-3 rounded bg-red-50 text-red-600 text-sm"><%= error %></div>
    <% } %>

    <form method="GET" action="/admin/lives" class="bg-white rounded-xl shadow p-4 mb-4 flex flex-wrap gap-3 items-end">
        <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">방송 상태</label>
            <select name="status" class="border-gray-300 rounded-md text-sm">
                <option value="">전체</option>
                <% statuses.forEach(function (s) { %>
                    <option value="<%= s.value %>" <%= status === s.value ? 'selected' : '' %>><%= s.label %></option>
                <% }); %>
            </select>
        </div>
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-medium text-gray-600 mb-1">검색 (방송명/슬러그)</label>
            <input type="text" name="q" value="<%= q %>" class="w-full border-gray-300 rounded-md text-sm">
        </div>
        <button type="submit" class="px-4 py-2 bg-gray-700 text-white rounded text-sm hover:bg-gray-800">검색</button>
    </form>

    <div class="bg-white rounded-xl shadow overflow-x-auto">
        <table class="min-w-full text-sm whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-600">
                <tr>
                    <th class="px-4 py-3 text-left">ID</th>
                    <th class="px-4 py-3 text-left">썸네일</th>
                    <th class="px-4 py-3 text-left">방송명 / 상품</th>
                    <th class="px-4 py-3 text-left">상태</th>
                    <th class="px-4 py-3 text-left">영상</th>
                    <th class="px-4 py-3 text-left">방송 시간</th>
                    <th class="px-4 py-3 text-right">쿠폰</th>
                    <th class="px-4 py-3 text-right">공지</th>
                    <th class="px-4 py-3 text-right">주문</th>
                    <th class="px-4 py-3 text-right">매출</th>
                    <th class="px-4 py-3 text-center">방송 제어</th>
                    <th class="px-4 py-3 text-center">관리</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% if (!lives.length) { %>
                    <tr><td colspan="12" class="px-4 py-10 text-center text-gray-400">등록된 라이브가 없습니다.</td></tr>
                <% } %>
                <% lives.forEach(function (l) { %>
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 text-gray-500"><%= l.id %></td>
                        <td class="px-4 py-3">
                            <% if (l.list_thumbnail_url) { %>
                                <img src="<%= l.list_thumbnail_url %>" alt="" class="w-16 h-10 object-cover rounded">
                            <% } else { %>
                                <div class="w-16 h-10 bg-gray-100 rounded"></div>
                            <% } %>
                        </td>
                        <td class="px-4 py-3">
                            <div class="font-medium text-gray-800"><%= l.title %></div>
                            <div class="text-xs text-gray-400">/live/<%= l.slug %></div>
                            <% if (l.main_product_name) { %>
                                <div class="text-xs text-gray-500 mt-0.5"><i class="bi bi-box-seam"></i> <%= l.main_product_name %><% if (l.product_count > 1) { %> 외 <%= l.product_count - 1 %>건<% } %></div>
                            <% } else { %>
                                <div class="text-xs text-red-500 mt-0.5">상품 미연결 — 고객 화면에 구매 버튼이 없습니다</div>
                            <% } %>
                        </td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-0.5 rounded text-xs <%= STATUS_CLASS[l.status] || 'bg-gray-100 text-gray-600' %>">
                                <% if (l.isLive) { %><i class="bi bi-broadcast"></i> <% } %><%= l.statusLabel %>
                            </span>
                            <% if (l.overdue) { %>
                                <div class="text-xs text-red-500 mt-1">종료 시각이 지났습니다</div>
                            <% } %>
                            <% if (l.startingSoon) { %>
                                <div class="text-xs text-purple-600 mt-1">시작 시각이 지났습니다</div>
                            <% } %>
                        </td>
                        <td class="px-4 py-3 text-xs">
                            <% if (l.video_id) { %>
                                <span class="text-gray-600"><%= l.provider %></span>
                                <div class="text-gray-400"><%= l.video_id %></div>
                            <% } else { %>
                                <span class="text-red-500">영상 없음</span>
                            <% } %>
                        </td>
                        <td class="px-4 py-3 text-xs text-gray-500"><%= fmtDT(l.start_at) %><br><%= fmtDT(l.end_at) %></td>
                        <td class="px-4 py-3 text-right text-gray-600"><%= l.coupon_count %></td>
                        <td class="px-4 py-3 text-right text-gray-600"><%= l.notice_count %></td>
                        <td class="px-4 py-3 text-right text-gray-600"><%= won(l.order_count) %></td>
                        <td class="px-4 py-3 text-right text-gray-800 font-medium"><%= won(l.revenue) %>원</td>
                        <td class="px-4 py-3 text-center">
                            <%
                              /* 상태 전환은 운영자가 누른다. 방송 중에는 '종료'만, 그 외에는 '방송 시작'만 띄운다. */
                            %>
                            <% if (l.status === 'ON_AIR') { %>
                                <form action="/admin/lives/<%= l.id %>/status" method="POST" class="inline"
                                      onsubmit="return confirm('방송을 종료합니다. 고객 화면이 다시보기로 바뀝니다.');">
                                    <input type="hidden" name="status" value="ENDED">
                                    <button type="submit" class="px-3 py-1 bg-gray-800 text-white rounded hover:bg-gray-900 text-xs">
                                        <i class="bi bi-stop-circle"></i> 방송 종료
                                    </button>
                                </form>
                            <% } else if (l.status === 'SCHEDULED' || l.status === 'DRAFT' || l.status === 'ENDED') { %>
                                <form action="/admin/lives/<%= l.id %>/status" method="POST" class="inline"
                                      onsubmit="return confirm('방송을 시작합니다. 고객 화면에 즉시 LIVE 로 표시됩니다.');">
                                    <input type="hidden" name="status" value="ON_AIR">
                                    <button type="submit"
                                            class="px-3 py-1 rounded text-xs <%= l.video_id ? 'bg-red-600 text-white hover:bg-red-700' : 'bg-gray-200 text-gray-400 cursor-not-allowed' %>"
                                            <%= l.video_id ? '' : 'disabled title="방송 영상이 없습니다"' %>>
                                        <i class="bi bi-broadcast"></i> 방송 시작
                                    </button>
                                </form>
                            <% } else { %>
                                <span class="text-xs text-gray-400">-</span>
                            <% } %>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <a href="/admin/lives/<%= l.id %>/edit" class="px-3 py-1 bg-gray-100 rounded hover:bg-gray-200 text-xs">수정</a>
                            <form action="/admin/lives/<%= l.id %>/delete" method="POST" class="inline"
                                  onsubmit="return confirm('삭제하면 연결된 상품·쿠폰·공지 설정도 함께 지워집니다. 계속할까요?');">
                                <button type="submit" class="px-3 py-1 bg-red-50 text-red-600 rounded hover:bg-red-100 text-xs">삭제</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <p class="mt-4 text-xs text-gray-400">
        방송 상태는 <strong>운영자가 직접 바꿉니다.</strong> 외부 영상(YouTube/Vimeo)을 임베드하는 방식이라
        실제 방송 시작·종료를 시스템이 알 수 없습니다. 시간이 지나도 상태는 자동으로 바뀌지 않습니다.<br>
        주문·매출은 이 라이브를 통해 결제된 주문(<code>order_items.source_type = 'LIVE_SHOW'</code>)만 집계하며,
        취소·환불 주문은 제외합니다.
    </p>
</div>
