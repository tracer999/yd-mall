<!-- 유입 매체 상세 -->
<div class="mb-4 flex items-center gap-2 text-sm">
    <a href="/admin" class="text-gray-400 hover:text-gray-600 transition">← 대시보드</a>
    <span class="text-gray-300">/</span>
    <span class="font-medium text-gray-700">유입 매체 상세</span>
    <span class="text-xs text-gray-400 ml-auto"><%= new Date().toISOString().split('T')[0] %> 기준</span>
</div>

<%
  const _baseQ = (overrides) => {
    const p = { period: filters.period, device: filters.device, type: filters.type, sort: filters.sort, start: filters.start, end: filters.end, ...overrides };
    const parts = [];
    Object.entries(p).forEach(([k, v]) => { if (v) parts.push(k + '=' + encodeURIComponent(v)); });
    return '?' + parts.join('&');
  };
  const _periodLabels = { today: '오늘', '7d': '7일', '15d': '15일', '1m': '1개월', '3m': '3개월', '1y': '1년' };
  const _typeOptions = [
    { val: 'all', label: '전체' }, { val: 'search', label: '검색' }, { val: 'social', label: 'SNS' },
    { val: 'direct', label: '직접' }, { val: 'viral', label: '바이럴' }, { val: 'referral', label: '레퍼럴' }
  ];
%>
<!-- 필터 바 -->
<div class="bg-white rounded-lg border border-gray-200 px-4 py-3 mb-4 text-xs space-y-3">
    <!-- 1행: 기간 + 디바이스 -->
    <div class="flex flex-wrap items-center gap-3">
        <span class="text-gray-500 font-medium">기간</span>
        <div class="inline-flex border border-gray-300 rounded-md overflow-hidden">
            <% Object.entries(_periodLabels).forEach(([k, v]) => { %>
                <a href="<%= _baseQ({ period: k, start: '', end: '' }) %>"
                   class="px-3 py-1.5 <%= filters.period === k ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %> transition no-underline"><%= v %></a>
            <% }) %>
        </div>
        <form class="inline-flex items-center gap-1" method="GET" action="/admin/traffic-sources">
            <input type="hidden" name="period" value="custom">
            <input type="hidden" name="device" value="<%= filters.device %>">
            <input type="hidden" name="type" value="<%= filters.type %>">
            <input type="hidden" name="sort" value="<%= filters.sort %>">
            <input type="date" name="start" value="<%= filters.start %>"
                   class="border border-gray-300 rounded px-2 py-1 text-xs w-28 <%= filters.period === 'custom' ? 'border-gray-800' : '' %>">
            <span class="text-gray-400">~</span>
            <input type="date" name="end" value="<%= filters.end %>"
                   class="border border-gray-300 rounded px-2 py-1 text-xs w-28 <%= filters.period === 'custom' ? 'border-gray-800' : '' %>">
            <button type="submit" class="px-2 py-1 bg-gray-700 text-white rounded text-xs hover:bg-gray-800 transition">적용</button>
        </form>
        <div class="w-px h-4 bg-gray-200"></div>
        <span class="text-gray-500 font-medium">디바이스</span>
        <div class="inline-flex border border-gray-300 rounded-md overflow-hidden">
            <% ['all','desktop','mobile','tablet'].forEach(d => { %>
                <a href="<%= _baseQ({ device: d }) %>"
                   class="px-3 py-1.5 <%= filters.device === d ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %> transition no-underline"><%= d === 'all' ? '전체' : d === 'desktop' ? 'PC' : d === 'mobile' ? '모바일' : '태블릿' %></a>
            <% }) %>
        </div>
    </div>
    <!-- 2행: 매체 유형 -->
    <div class="flex items-center gap-3">
        <span class="text-gray-500 font-medium">매체 유형</span>
        <div class="inline-flex border border-gray-300 rounded-md overflow-hidden">
            <% _typeOptions.forEach(t => { %>
                <a href="<%= _baseQ({ type: t.val }) %>"
                   class="px-3 py-1.5 <%= filters.type === t.val ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %> transition no-underline"><%= t.label %></a>
        <% }) %>
        </div>
    </div>
</div>

<!-- 요약 카드 4개 -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
    <div class="bg-white rounded-lg border border-gray-200 p-4">
        <div class="text-xs text-gray-500 mb-1">총 유입 UV</div>
        <div class="text-2xl font-semibold text-gray-900"><%= summary.totalUv.toLocaleString() %></div>
        <div class="text-xs text-gray-500 mt-1">전기간 대비
            <% if (Number(summary.uvDeltaPct) > 0) { %>
                <span class="text-green-600">▲ <%= summary.uvDeltaPct %>%</span>
            <% } else if (Number(summary.uvDeltaPct) < 0) { %>
                <span class="text-red-600">▼ <%= Math.abs(summary.uvDeltaPct) %>%</span>
            <% } else { %>변동 없음<% } %>
        </div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
        <div class="text-xs text-gray-500 mb-1">최저 이탈률 매체</div>
        <div class="text-lg font-semibold text-gray-900 truncate"><%= summary.bestMedia ? summary.bestMedia.label : '-' %></div>
        <div class="text-xs text-gray-500 mt-1">이탈률 <span class="text-green-600 font-medium"><%= summary.bestMedia ? summary.bestMedia.bounceRate : 0 %>%</span></div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
        <div class="text-xs text-gray-500 mb-1">평균 이탈률</div>
        <div class="text-2xl font-semibold text-gray-900"><%= summary.avgBounce %><span class="text-sm font-normal text-gray-500">%</span></div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
        <div class="text-xs text-gray-500 mb-1">총 가입 전환</div>
        <div class="text-2xl font-semibold text-gray-900"><%= summary.totalSignups %><span class="text-sm font-normal text-gray-500">명</span></div>
        <div class="text-xs text-gray-500 mt-1">전환율 <span class="text-green-600 font-medium"><%= summary.convRate %>%</span></div>
    </div>
</div>

<!-- 추이 차트 + 유형별 비중 -->
<div class="grid grid-cols-1 lg:grid-cols-5 gap-4 mb-4">
    <!-- 좌: 추이 차트 -->
    <div class="lg:col-span-3 bg-white rounded-lg border border-gray-200 p-4">
        <div class="text-sm font-medium text-gray-800 mb-3">매체별 UV 추이 (상위 3개)</div>
        <% if (trendChart.labels && trendChart.labels.length > 0) { %>
            <canvas id="trendLineChart" height="120"></canvas>
            <div class="flex gap-4 mt-2">
                <% trendChart.datasets.forEach(ds => { %>
                    <span class="flex items-center gap-1 text-[10px] text-gray-500">
                        <span class="w-2 h-2 rounded-full" style="background:<%= ds.color %>"></span><%= ds.label %>
                    </span>
                <% }) %>
            </div>
        <% } else { %>
            <p class="text-sm text-gray-400 py-8 text-center">데이터가 없습니다.</p>
        <% } %>
    </div>

    <!-- 우: 유형별 비중 -->
    <div class="lg:col-span-2 bg-white rounded-lg border border-gray-200 p-4">
        <div class="text-sm font-medium text-gray-800 mb-3">매체 유형별 비중</div>
        <div class="flex h-3 rounded-full overflow-hidden mb-3">
            <% typeBreakdown.forEach(t => { %>
                <div style="width:<%= t.pct %>%;background:<%= t.color %>"></div>
            <% }) %>
        </div>
        <div class="flex flex-wrap gap-3 mb-4">
            <% typeBreakdown.forEach(t => { %>
                <span class="flex items-center gap-1 text-xs text-gray-500">
                    <span class="w-2 h-2 rounded-sm" style="background:<%= t.color %>"></span>
                    <%= t.label %> <strong class="text-gray-800 ml-0.5"><%= t.pct %>%</strong>
                </span>
            <% }) %>
        </div>
        <div class="border-t border-gray-100 pt-3">
            <div class="text-[10px] text-gray-400 mb-2">이탈률 기준 매체 순위</div>
            <% [...sources].sort((a,b) => a.bounceRate - b.bounceRate).slice(0, 5).forEach(s => { %>
                <div class="flex items-center justify-between text-xs mb-1.5">
                    <span class="text-gray-600"><%= s.label %></span>
                    <div class="flex items-center gap-2">
                        <div class="w-12 h-1 bg-gray-100 rounded-full overflow-hidden">
                            <div class="h-full bg-green-500 rounded-full" style="width:<%= 100 - s.bounceRate %>%"></div>
                        </div>
                        <span class="text-green-600 font-medium w-8 text-right"><%= s.bounceRate %>%</span>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<!-- 매체별 성과 테이블 -->
<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 flex-wrap gap-2">
        <span class="text-sm font-medium text-gray-800">매체별 성과 TOP 20 <span class="text-xs font-normal text-gray-400">행 클릭 시 상세 펼침</span></span>
        <div class="flex items-center gap-2">
            <span class="text-[10px] text-gray-400">정렬</span>
            <div class="inline-flex border border-gray-300 rounded-md overflow-hidden">
                <% ['uv','bounce','duration'].forEach(s => { %>
                    <a href="?period=<%= filters.period %>&device=<%= filters.device %>&type=<%= filters.type %>&sort=<%= s %>"
                       class="px-2 py-1 text-[10px] <%= filters.sort === s ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %> transition no-underline"><%= s === 'uv' ? 'UV' : s === 'bounce' ? '이탈률' : '체류시간' %></a>
                <% }) %>
            </div>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-xs">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                    <th class="px-3 py-2 text-left text-gray-500 font-medium w-8">#</th>
                    <th class="px-3 py-2 text-left text-gray-500 font-medium">매체명</th>
                    <th class="px-3 py-2 text-left text-gray-500 font-medium w-16">유형</th>
                    <th class="px-3 py-2 text-right text-gray-500 font-medium w-16">UV</th>
                    <th class="px-3 py-2 text-right text-gray-500 font-medium w-16">PV</th>
                    <th class="px-3 py-2 text-right text-gray-500 font-medium w-20">체류시간</th>
                    <th class="px-3 py-2 text-right text-gray-500 font-medium w-16">이탈률</th>
                    <th class="px-3 py-2 text-right text-gray-500 font-medium w-32">신규 / 재방문</th>
                </tr>
            </thead>
            <tbody>
                <% if (sources.length === 0) { %>
                    <tr><td colspan="8" class="px-4 py-8 text-center text-gray-400">아직 유입 데이터가 없습니다.</td></tr>
                <% } else { %>
                    <% sources.forEach((s, i) => {
                        const mins = Math.floor(s.avgDuration / 60);
                        const secs = s.avgDuration % 60;
                        const durStr = `${mins}:${String(secs).padStart(2, '0')}`;
                    %>
                        <tr class="border-b border-gray-100 hover:bg-gray-50 cursor-pointer drill-trigger" data-host="<%= s.host %>" data-idx="<%= i %>">
                            <td class="px-3 py-2.5 text-gray-400 font-medium"><%= i + 1 %></td>
                            <td class="px-3 py-2.5 font-medium text-gray-800"><%= s.label %></td>
                            <td class="px-3 py-2.5">
                                <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-medium <%= typeTagClass[s.type] || 'bg-gray-100 text-gray-600' %>"><%= typeLabels[s.type] || s.type %></span>
                            </td>
                            <td class="px-3 py-2.5 text-right font-medium"><%= s.uv.toLocaleString() %></td>
                            <td class="px-3 py-2.5 text-right text-gray-500"><%= s.pv.toLocaleString() %></td>
                            <td class="px-3 py-2.5 text-right text-gray-500"><%= durStr %></td>
                            <td class="px-3 py-2.5 text-right <%= s.bounceRate > 50 ? 'text-amber-600' : 'text-green-600' %>"><%= s.bounceRate %>%</td>
                            <td class="px-3 py-2.5 text-right text-gray-500 text-[10px]">신규 <%= s.newPct %>% / 재 <%= s.returnPct %>%</td>
                        </tr>
                        <tr class="drill-panel hidden" id="drill-<%= i %>">
                            <td colspan="8" class="p-0">
                                <div class="bg-gray-50 px-6 py-4 grid grid-cols-1 md:grid-cols-3 gap-4 text-xs">
                                    <div>
                                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">진입 URL TOP 5</div>
                                        <div id="drill-pages-<%= i %>" class="space-y-1 text-gray-600">로딩 중...</div>
                                    </div>
                                    <div>
                                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">유입 검색어 TOP 5</div>
                                        <div id="drill-keywords-<%= i %>" class="space-y-1 text-gray-600">로딩 중...</div>
                                    </div>
                                    <div>
                                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">일별 UV 추이</div>
                                        <div id="drill-trend-<%= i %>">로딩 중...</div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// 추이 라인차트
<% if (trendChart.labels && trendChart.labels.length > 0) { %>
(function() {
    const ctx = document.getElementById('trendLineChart');
    if (!ctx) return;
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: <%- JSON.stringify(trendChart.labels) %>,
            datasets: [
                <% trendChart.datasets.forEach((ds, i) => { %>
                { label: '<%= ds.label %>', data: <%- JSON.stringify(ds.data) %>, borderColor: '<%= ds.color %>', backgroundColor: 'transparent', borderWidth: 2, pointRadius: 0, tension: 0.3 }<%= i < trendChart.datasets.length - 1 ? ',' : '' %>
                <% }) %>
            ]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { font: { size: 9 }, maxTicksLimit: 8 } },
                y: { grid: { color: '#f3f4f6' }, ticks: { font: { size: 9 } }, beginAtZero: true }
            }
        }
    });
})();
<% } %>

// 드릴다운
document.querySelectorAll('.drill-trigger').forEach(row => {
    row.addEventListener('click', async function() {
        const idx = this.dataset.idx;
        const host = this.dataset.host;
        const panel = document.getElementById('drill-' + idx);
        if (!panel) return;

        if (!panel.classList.contains('hidden')) {
            panel.classList.add('hidden');
            return;
        }

        document.querySelectorAll('.drill-panel').forEach(p => p.classList.add('hidden'));
        panel.classList.remove('hidden');

        if (panel.dataset.loaded) return;

        try {
            const res = await fetch('/admin/traffic-sources/drill?host=' + encodeURIComponent(host) + '&days=<%= filters.days %>');
            const data = await res.json();

            // 진입 URL
            const pagesEl = document.getElementById('drill-pages-' + idx);
            pagesEl.innerHTML = data.pages.length > 0
                ? data.pages.map(p => '<div class="flex justify-between py-0.5 border-b border-gray-100 last:border-0"><span class="truncate max-w-[180px]">' + p.url + '</span><span class="font-medium text-gray-800 ml-2 shrink-0">' + p.uv + ' UV</span></div>').join('')
                : '<span class="text-gray-400">데이터 없음</span>';

            // 검색어
            const kwEl = document.getElementById('drill-keywords-' + idx);
            kwEl.innerHTML = data.keywords.length > 0
                ? data.keywords.map(k => '<div class="flex justify-between py-0.5 border-b border-gray-100 last:border-0"><span class="truncate max-w-[180px]">' + k.keyword + '</span><span class="font-medium text-gray-800 ml-2 shrink-0">' + k.count + '회</span></div>').join('')
                : '<span class="text-gray-400">검색어 없음</span>';

            // 추이 막대
            const trendEl = document.getElementById('drill-trend-' + idx);
            if (data.trend.length > 0) {
                const maxUv = Math.max(...data.trend.map(t => t.uv), 1);
                const bars = data.trend.map(t =>
                    '<div style="flex:1;height:' + Math.max(t.uv / maxUv * 100, 5) + '%;background:#378ADD;border-radius:2px 2px 0 0;opacity:0.7"></div>'
                ).join('');
                const firstDate = new Date(data.trend[0].date);
                const lastDate = new Date(data.trend[data.trend.length - 1].date);
                const fmt = d => (d.getMonth()+1) + '/' + d.getDate();
                trendEl.innerHTML = '<div class="flex items-end gap-px h-10 w-full">' + bars + '</div>'
                    + '<div style="display:flex;justify-content:space-between;margin-top:3px;font-size:9px;color:#9ca3af;"><span>' + fmt(firstDate) + '</span><span>' + fmt(lastDate) + '</span></div>';
            } else {
                trendEl.innerHTML = '<span class="text-gray-400 text-[10px]">데이터 없음</span>';
            }

            panel.dataset.loaded = '1';
        } catch (e) {
            console.error(e);
        }
    });
});
</script>
