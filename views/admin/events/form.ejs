<%
  function dtLocal(v) {
    if (!v) return '';
    const d = new Date(v);
    const pad = (n) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }
  const action = event ? `/admin/events/edit/${event.id}` : '/admin/events/add';
%>
<div class="p-6">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800"><%= title %></h1>
        <a href="/admin/events" class="text-sm text-gray-500 hover:text-gray-700">← 목록으로</a>
    </div>

    <% if (typeof saved !== 'undefined' && saved) { %>
        <div class="mb-4 px-4 py-3 rounded bg-green-50 text-green-700 text-sm">저장되었습니다.</div>
    <% } %>

    <form action="<%= action %>" method="POST">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- 좌: 기본 정보 -->
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-xl shadow p-6 space-y-4">
                    <h2 class="font-semibold text-gray-700">기본 정보</h2>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">이벤트명 <span class="text-red-500">*</span></label>
                        <input type="text" name="title" required maxlength="200"
                               value="<%= event ? event.title : '' %>"
                               class="w-full border-gray-300 rounded-md shadow-sm">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">슬러그 (URL)</label>
                        <div class="flex items-center gap-2">
                            <span class="text-sm text-gray-400">/event/</span>
                            <input type="text" name="slug" maxlength="200"
                                   value="<%= event ? event.slug : '' %>"
                                   placeholder="비워두면 이벤트명에서 자동 생성"
                                   class="flex-1 border-gray-300 rounded-md shadow-sm">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">한 줄 요약</label>
                        <input type="text" name="summary" maxlength="500"
                               value="<%= event && event.summary ? event.summary : '' %>"
                               class="w-full border-gray-300 rounded-md shadow-sm">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">상세 본문</label>
                        <textarea id="editor" name="content"><%= event && event.content ? event.content : '' %></textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">유의사항</label>
                        <textarea name="notice" rows="4" class="w-full border-gray-300 rounded-md shadow-sm text-sm"><%= event && event.notice ? event.notice : '' %></textarea>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow p-6 space-y-4">
                    <h2 class="font-semibold text-gray-700">이미지</h2>
                    <p class="text-xs text-gray-400">이미지 URL 을 직접 입력합니다. 업로드는 배너 관리에서 올린 경로를 붙여넣으세요.</p>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">목록 썸네일</label>
                        <input type="text" name="thumbnail_url" value="<%= event && event.thumbnail_url ? event.thumbnail_url : '' %>" class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">상세 PC 대표 이미지</label>
                        <input type="text" name="pc_hero_url" value="<%= event && event.pc_hero_url ? event.pc_hero_url : '' %>" class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">상세 모바일 대표 이미지</label>
                        <input type="text" name="mobile_hero_url" value="<%= event && event.mobile_hero_url ? event.mobile_hero_url : '' %>" class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                    </div>
                </div>
            </div>

            <!-- 우: 발행 · 기간 · 참여 -->
            <div class="space-y-6">
                <div class="bg-white rounded-xl shadow p-6 space-y-4">
                    <h2 class="font-semibold text-gray-700">발행</h2>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">운영 상태</label>
                        <select name="status" class="w-full border-gray-300 rounded-md shadow-sm">
                            <option value="DRAFT" <%= (!event || event.status === 'DRAFT') ? 'selected' : '' %>>임시저장 (고객 미노출)</option>
                            <option value="PUBLISHED" <%= (event && event.status === 'PUBLISHED') ? 'selected' : '' %>>발행</option>
                            <option value="HIDDEN" <%= (event && event.status === 'HIDDEN') ? 'selected' : '' %>>숨김</option>
                        </select>
                        <p class="mt-1 text-xs text-gray-400">예정·진행중·종료는 아래 기간에서 자동 계산됩니다.</p>
                    </div>

                    <label class="flex items-center">
                        <input type="checkbox" name="list_visible" value="1" <%= (!event || event.list_visible) ? 'checked' : '' %> class="rounded border-gray-300">
                        <span class="ml-2 text-sm text-gray-700">이벤트 목록에 노출</span>
                    </label>
                </div>

                <div class="bg-white rounded-xl shadow p-6 space-y-4">
                    <h2 class="font-semibold text-gray-700">기간</h2>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">시작 일시 <span class="text-red-500">*</span></label>
                        <input type="datetime-local" name="start_at" required
                               value="<%= event ? dtLocal(event.start_at) : '' %>"
                               class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">종료 일시</label>
                        <input type="datetime-local" name="end_at"
                               value="<%= event ? dtLocal(event.end_at) : '' %>"
                               class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                        <p class="mt-1 text-xs text-gray-400">비우면 상시 진행</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">당첨자 발표</label>
                        <input type="datetime-local" name="winner_announce_at"
                               value="<%= event ? dtLocal(event.winner_announce_at) : '' %>"
                               class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow p-6 space-y-4">
                    <h2 class="font-semibold text-gray-700">참여 설정</h2>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">참여 방식</label>
                        <select name="event_type" class="w-full border-gray-300 rounded-md shadow-sm">
                            <% eventTypes.forEach(function(t) { %>
                                <option value="<%= t %>" <%= (event && event.event_type === t) || (!event && t === 'NOTICE') ? 'selected' : '' %>>
                                    <%= eventTypeLabels[t] %>
                                </option>
                            <% }); %>
                        </select>
                        <p class="mt-1 text-xs text-gray-400">공지형은 참여 버튼이 없습니다.</p>
                    </div>

                    <label class="flex items-center">
                        <input type="checkbox" name="login_required" value="1" <%= (!event || event.login_required) ? 'checked' : '' %> class="rounded border-gray-300">
                        <span class="ml-2 text-sm text-gray-700">참여 시 로그인 필요</span>
                    </label>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">선착순 인원</label>
                        <input type="number" name="issue_limit" min="1"
                               value="<%= event && event.issue_limit ? event.issue_limit : '' %>"
                               placeholder="비우면 무제한"
                               class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                    </div>

                    <% if (event) { %>
                        <div class="pt-2 border-t border-gray-100 text-sm text-gray-600">
                            현재 참여
                            <span class="font-semibold text-gray-800"><%= event.issued_count %></span>명
                            <% if (typeof participants !== 'undefined' && participants !== event.issued_count) { %>
                                <span class="text-xs text-red-500">(참여자 테이블 <%= participants %>건 — 불일치)</span>
                            <% } %>
                        </div>
                    <% } %>
                </div>

                <div class="flex gap-2">
                    <a href="/admin/events" class="flex-1 text-center px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300">취소</a>
                    <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">저장</button>
                </div>
            </div>
        </div>
    </form>
</div>

<% if (tinymceKey) { %>
<script src="https://cdn.tiny.cloud/1/<%= tinymceKey %>/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
<script>
    tinymce.init({
        selector: '#editor',
        plugins: 'image link lists table code',
        toolbar: 'undo redo | blocks | bold italic | alignleft aligncenter alignright | bullist numlist | link image | code',
        height: 420,
        menubar: false,
    });
</script>
<% } else { %>
<script>
    // TINYMCE_KEY 가 없으면 일반 textarea 로 둔다(에디터 미로드).
    document.getElementById('editor').rows = 16;
    document.getElementById('editor').className = 'w-full border-gray-300 rounded-md shadow-sm text-sm font-mono';
</script>
<% } %>
