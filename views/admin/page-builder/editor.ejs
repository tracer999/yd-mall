<% if (!page) { %>
  <div class="bg-white rounded-lg shadow-sm p-8 text-center text-gray-500">
    <i class="bi bi-exclamation-triangle text-2xl text-amber-500"></i>
    <p class="mt-2 text-sm">이 몰에 편집할 SDUI 페이지가 없습니다. 시드 데이터를 먼저 생성하세요.</p>
  </div>
<% } else { %>

<%
  /* 두 탭 — 테마 설정 / 페이지 설정(홈 페이지에서만). 페이지 설정 안에서 다시 이지모드 / 직접설정.
       테마 설정 = 히어로·색·폰트(테마 적용). 이지모드 = 콘텐츠 캐러셀 번들 선택. 직접설정 = 섹션 직접 편집. */
  var _isHome = page.page_type === 'home';
  var _pl = (typeof presetList !== 'undefined') ? presetList : [];
  var _cur = (typeof currentPreset !== 'undefined') ? currentPreset : '';
  var _bundles = (typeof pageBundles !== 'undefined') ? pageBundles : [];
%>

<% if (typeof notice !== 'undefined' && notice) { %>
  <div class="mb-4 flex items-start gap-2 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
    <i class="bi bi-check-circle-fill mt-0.5"></i><span><%= notice %></span>
  </div>
<% } %>
<% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
  <div class="mb-4 flex items-start gap-2 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
    <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= errorMsg %></span>
  </div>
<% } %>

<% if (_isHome) { %>
  <div class="mb-4 flex flex-col sm:flex-row sm:items-center gap-2">
    <div class="inline-flex rounded-lg border border-gray-200 bg-white p-1 text-sm" role="tablist">
      <button type="button" data-pb-tab="theme" class="pb-tab px-4 py-1.5 rounded-md font-medium text-gray-600 hover:text-gray-900">테마 설정</button>
      <button type="button" data-pb-tab="page" class="pb-tab px-4 py-1.5 rounded-md font-medium bg-indigo-600 text-white">페이지 설정</button>
    </div>
    <span class="text-xs text-gray-400">테마 설정 = 히어로·색·폰트 · 페이지 설정 = 메인에 표시할 캐러셀 구성</span>
  </div>

  <!-- ── 테마 설정 탭 ── -->
  <div id="pb-pane-theme" class="hidden">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden max-w-2xl">
      <div class="px-5 py-3 border-b border-gray-100 bg-gray-50/60">
        <h2 class="text-sm font-semibold text-gray-800">테마로 메인 화면 다시 구성</h2>
        <p class="mt-0.5 text-xs text-gray-500">테마를 고르면 <strong>홈 섹션이 그 테마의 기본 구성(베스트·쇼핑특가·베스트 카테고리·베스트 브랜드)으로 교체·발행</strong>됩니다. 현재 홈 섹션은 삭제됩니다.</p>
      </div>
      <form method="POST" action="/admin/malls/<%= mallId %>/provision" class="p-5 space-y-3"
            onsubmit="return confirm('선택한 테마의 기본 구성으로 메인 화면을 다시 만듭니다.\n현재 홈 섹션은 삭제됩니다. 계속할까요?');">
        <input type="hidden" name="include_home" value="1">
        <input type="hidden" name="return_to" value="page-builder">
        <% _pl.forEach(function (p) { %>
          <label class="flex items-start gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer has-[:checked]:border-indigo-400 has-[:checked]:bg-indigo-50/40">
            <input type="radio" name="preset_key" value="<%= p.key %>" <%= _cur === p.key ? 'checked' : '' %> class="mt-1 w-4 h-4 border-gray-300">
            <span class="flex-1">
              <span class="flex items-center gap-2">
                <span class="text-sm font-semibold text-gray-900"><%= p.label %></span>
                <% if (p.skinLabel) { %><span class="text-[10px] font-semibold px-1.5 py-0.5 rounded bg-indigo-50 text-indigo-600 border border-indigo-100"><%= p.skinLabel %></span><% } %>
              </span>
              <span class="mt-0.5 block text-xs text-gray-500 leading-relaxed"><%= p.summary %></span>
            </span>
          </label>
        <% }); %>
        <div class="flex justify-end pt-1">
          <button type="submit" class="inline-flex items-center h-[38px] px-5 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700"><i class="bi bi-magic mr-1.5"></i>이 테마로 다시 구성</button>
        </div>
      </form>
    </div>
  </div>
<% } %>

<!-- ── 페이지 설정 탭 ── -->
<div id="pb-pane-page">

<% if (_isHome) { %>
  <div class="mb-4 flex flex-col sm:flex-row sm:items-center gap-2">
    <div class="inline-flex rounded-lg border border-gray-200 bg-gray-100 p-1 text-sm" role="tablist">
      <button type="button" data-pb-sub="easy" class="pb-sub px-4 py-1.5 rounded-md font-medium text-gray-600 hover:text-gray-900">이지모드</button>
      <button type="button" data-pb-sub="direct" class="pb-sub px-4 py-1.5 rounded-md font-medium bg-white shadow-sm text-gray-900">직접설정</button>
    </div>
    <span class="text-xs text-gray-400">이지모드 = 미리 만든 캐러셀 구성 선택 · 직접설정 = 섹션 직접 편집</span>
  </div>

  <!-- 이지모드: 미리 구성된 캐러셀 번들 -->
  <div id="pb-sub-easy" class="hidden">
    <div class="mb-3 text-xs text-gray-500">
      원하는 구성을 고르면 <strong>메인 상단 히어로는 그대로 두고, 그 아래 캐러셀을 선택한 구성으로 교체·발행</strong>합니다.
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <% _bundles.forEach(function (b) { %>
        <form method="POST" action="/admin/page-builder/apply-bundle"
              class="flex flex-col bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden hover:border-indigo-300 transition"
              onsubmit="return confirm('&quot;<%= b.label %>&quot; 구성으로 메인 캐러셀을 교체·발행합니다.\n계속할까요?');">
          <input type="hidden" name="bundle_key" value="<%= b.key %>">
          <div class="px-4 py-3 border-b border-gray-100 bg-gray-50/60">
            <h3 class="text-sm font-semibold text-gray-900"><%= b.label %></h3>
            <p class="mt-0.5 text-xs text-gray-500 leading-relaxed"><%= b.summary %></p>
          </div>
          <div class="flex-1 p-4">
            <ol class="space-y-1.5">
              <% (b.items || []).forEach(function (it, i) { %>
                <li class="flex items-center gap-2 text-sm text-gray-700">
                  <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-indigo-50 text-indigo-600 text-[11px] font-semibold"><%= i + 1 %></span>
                  <%= it %>
                </li>
              <% }); %>
            </ol>
          </div>
          <div class="p-4 pt-0">
            <button type="submit" class="w-full inline-flex items-center justify-center h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
              <i class="bi bi-magic mr-1.5"></i>이 구성 적용
            </button>
          </div>
        </form>
      <% }); %>
    </div>
  </div>
<% } %>

<!-- 직접설정: 섹션 직접 편집(기존 UI) -->
<div id="pb-sub-direct">

<!-- 상단 툴바 -->
<div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-4">
  <div class="mr-auto flex items-center gap-2">
    <span class="text-sm text-gray-500">페이지</span>
    <%/* 빌더가 홈만 편집하던 시절에는 라벨이 '홈' 하나로 박혀 있었다.
         랜딩(/new 등)을 편집·발행할 수 없으면 그 페이지는 영영 발행 스냅샷이 없고,
         스토어프론트가 라이브 page_section 으로 폴백한다 = 고치는 순간 운영 반영. */%>
    <select id="pb-page-select" class="border border-gray-300 rounded-md text-sm px-2 py-1.5 font-semibold">
      <% (pages || []).forEach(p => { %>
        <option value="<%= p.id %>" <%= p.id === page.id ? 'selected' : '' %>>
          <%= p.page_type === 'home' ? '홈' : (p.title || p.slug) %>
          <%= p.slug && p.page_type !== 'home' ? '(/' + p.slug + ')' : '' %>
          · 섹션 <%= p.section_count %><%= p.published_no ? '' : ' · 미발행' %>
        </option>
      <% }); %>
    </select>
    <span class="px-2 py-0.5 rounded text-[11px] font-medium <%= revisions.length ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
      <%= revisions.length ? '발행됨 #' + revisions[0].revision_no : '발행 이력 없음' %>
    </span>
    <%/* 서버가 작업본 ↔ 최신 발행 스냅샷을 비교해 준다. 예전엔 클라이언트가 편집할 때만 켜서,
         새로고침하면 배지가 사라지고 발행을 잊은 변경분이 조용히 남았다. */%>
    <span id="pb-dirty" class="<%= dirty ? '' : 'hidden ' %>px-2 py-0.5 rounded text-[11px] font-medium bg-amber-100 text-amber-700">미발행 변경사항</span>
  </div>

  <div class="flex items-center gap-2 flex-wrap">
    <select id="pb-revision-select" class="border border-gray-300 rounded-md text-sm px-2 py-1.5">
      <option value="">— 리비전 선택(롤백) —</option>
      <% revisions.forEach(r => { %>
        <option value="<%= r.id %>">#<%= r.revision_no %> · <%= r.created_by || 'system' %> · <%= new Date(r.published_at || r.created_at).toLocaleString('ko-KR') %></option>
      <% }); %>
    </select>
    <button id="pb-rollback-btn" class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-gray-700 text-sm rounded-md hover:bg-gray-50">
      <i class="bi bi-arrow-counterclockwise mr-1"></i>롤백
    </button>
    <button id="pb-preview-refresh" class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-gray-700 text-sm rounded-md hover:bg-gray-50">
      <i class="bi bi-arrow-clockwise mr-1"></i>미리보기 새로고침
    </button>
    <button id="pb-publish-btn" class="inline-flex items-center px-4 py-1.5 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
      <i class="bi bi-cloud-upload mr-1"></i>발행
    </button>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
  <!-- 좌: 섹션 목록 + 추가 -->
  <div class="lg:col-span-4 space-y-3">
    <div class="bg-white rounded-lg shadow-sm p-3">
      <div class="flex items-center gap-2">
        <select id="pb-add-type" class="flex-1 border border-gray-300 rounded-md text-sm px-2 py-1.5">
          <% palette.forEach(p => { %>
            <option value="<%= p.type %>"><%= p.label %></option>
          <% }); %>
        </select>
        <button id="pb-add-btn" class="inline-flex items-center px-3 py-1.5 bg-emerald-600 text-white text-sm font-medium rounded-md hover:bg-emerald-700">
          <i class="bi bi-plus-lg mr-1"></i>추가
        </button>
      </div>
      <%/* 섹션 이름만으로는 '혜택 벤토'·'랭킹 탭'이 무엇인지 알 수 없다.
           카탈로그는 각 섹션을 실제 데이터로 렌더해 보여주고 거기서 바로 추가하게 한다. */%>
      <button id="pb-catalog-btn" class="mt-2 w-full inline-flex items-center justify-center px-3 py-1.5 border border-gray-300 text-gray-700 text-sm rounded-md hover:bg-gray-50">
        <i class="bi bi-grid-3x3-gap mr-1.5"></i>섹션 둘러보기 — 뭐가 있고 어떻게 보이는지
      </button>
    </div>

    <div id="pb-section-list" class="space-y-2">
      <!-- JS 렌더 -->
    </div>
  </div>

  <!-- 중: 미리보기 -->
  <div class="lg:col-span-5">
    <div class="bg-white rounded-lg shadow-sm p-3">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-gray-700">미리보기 <span class="text-xs text-gray-400">(발행 전 작업본)</span></span>
        <div class="flex items-center gap-1">
          <button data-device="pc" class="pb-device-btn px-2 py-1 text-xs rounded border border-gray-300 bg-blue-50 text-blue-700">PC</button>
          <button data-device="mobile" class="pb-device-btn px-2 py-1 text-xs rounded border border-gray-300 text-gray-600">모바일</button>
        </div>
      </div>
      <div class="border border-gray-200 rounded-lg overflow-hidden bg-gray-100 flex justify-center">
        <iframe id="pb-preview" src="/admin/page-builder/preview?page=<%= page.id %>"
          class="bg-white transition-all" style="width:100%;height:680px;border:0;"></iframe>
      </div>
    </div>
  </div>

  <!-- 우: 선택 섹션 설정 -->
  <div class="lg:col-span-3">
    <div id="pb-settings" class="bg-white rounded-lg shadow-sm p-4">
      <p class="text-sm text-gray-400 text-center py-8">
        <i class="bi bi-arrow-left-circle mr-1"></i>왼쪽에서 섹션을 선택하면<br>설정이 여기에 표시됩니다.
      </p>
    </div>
  </div>
</div>

<!-- ── 섹션 카탈로그 모달 ── -->
<div id="pb-catalog" class="hidden fixed inset-0 z-50 bg-black/50 p-4 sm:p-8 overflow-y-auto">
  <div class="mx-auto max-w-6xl bg-gray-50 rounded-xl shadow-2xl">
    <div class="sticky top-0 z-10 flex items-center gap-3 px-5 py-4 bg-white border-b border-gray-200 rounded-t-xl">
      <div class="mr-auto">
        <h2 class="text-base font-semibold text-gray-900">섹션 둘러보기</h2>
        <p class="text-xs text-gray-500 mt-0.5">현재 몰의 실제 데이터로 그린 미리보기입니다. 마음에 드는 섹션을 바로 추가하세요.</p>
      </div>
      <button id="pb-catalog-close" class="p-2 text-gray-400 hover:text-gray-700 rounded-md hover:bg-gray-100">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 p-5">
      <% palette.forEach(p => { %>
        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden flex flex-col">
          <div class="flex items-start gap-3 px-4 py-3 border-b border-gray-100">
            <div class="mr-auto min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-sm font-semibold text-gray-900"><%= p.label %></span>
                <% if (p.dataSource === 'product_group') { %>
                  <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-indigo-50 text-indigo-700">상품 그룹 필요</span>
                <% } else if (p.dataSource === 'banner_group') { %>
                  <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-50 text-amber-700">배너 그룹 필요</span>
                <% } %>
              </div>
              <p class="mt-1 text-xs text-gray-500 leading-relaxed"><%= p.description %></p>
            </div>
            <button type="button" data-catalog-add="<%= p.type %>"
              class="shrink-0 inline-flex items-center px-2.5 py-1.5 bg-emerald-600 text-white text-xs font-medium rounded-md hover:bg-emerald-700">
              <i class="bi bi-plus-lg mr-1"></i>추가
            </button>
          </div>
          <%/* 팔레트 18종을 한꺼번에 렌더하면 요청이 18개 나간다. 카탈로그를 연 뒤
               data-src → src 로 지연 로드한다. */%>
          <div class="bg-gray-100 h-64 overflow-hidden">
            <iframe class="pb-catalog-frame w-full h-full bg-white" style="border:0;"
              data-src="/admin/page-builder/section-preview?type=<%= p.type %>" loading="lazy"></iframe>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</div>

</div><!-- /pb-sub-direct -->

</div><!-- /pb-pane-page -->

<% if (typeof page !== 'undefined' && page && page.page_type === 'home') { %>
<script>
  (function () {
    // ── 상위 탭: 테마 설정 / 페이지 설정 ──
    var tabs = document.querySelectorAll('.pb-tab');
    var themePane = document.getElementById('pb-pane-theme');
    var pagePane = document.getElementById('pb-pane-page');
    if (tabs.length && themePane && pagePane) {
      function activateTab(which) {
        themePane.classList.toggle('hidden', which !== 'theme');
        pagePane.classList.toggle('hidden', which !== 'page');
        tabs.forEach(function (t) {
          var on = t.getAttribute('data-pb-tab') === which;
          t.classList.toggle('bg-indigo-600', on);
          t.classList.toggle('text-white', on);
          t.classList.toggle('text-gray-600', !on);
        });
      }
      tabs.forEach(function (t) {
        t.addEventListener('click', function () { activateTab(t.getAttribute('data-pb-tab')); });
      });
    }

    // ── 하위 토글: 이지모드 / 직접설정 (페이지 설정 안) ──
    var subs = document.querySelectorAll('.pb-sub');
    var easy = document.getElementById('pb-sub-easy');
    var direct = document.getElementById('pb-sub-direct');
    if (subs.length && easy && direct) {
      function activateSub(which) {
        easy.classList.toggle('hidden', which !== 'easy');
        direct.classList.toggle('hidden', which !== 'direct');
        subs.forEach(function (s) {
          var on = s.getAttribute('data-pb-sub') === which;
          s.classList.toggle('bg-white', on);
          s.classList.toggle('shadow-sm', on);
          s.classList.toggle('text-gray-900', on);
          s.classList.toggle('text-gray-600', !on);
        });
      }
      subs.forEach(function (s) {
        s.addEventListener('click', function () { activateSub(s.getAttribute('data-pb-sub')); });
      });
    }
  })();
</script>
<% } %>

<script id="pb-data" type="application/json">
  <%- JSON.stringify({ pageId: page.id, sections, palette, productGroups, linkTargets: (typeof linkTargets !== 'undefined' ? linkTargets : []) })
    .replace(/<\//g, '<\\/')
    .replace(/<!--/g, '<\\!--')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029') %>
</script>
<script src="/js/admin/page-builder.js"></script>

<% } %>
