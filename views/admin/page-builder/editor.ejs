<% if (!page) { %>
  <div class="bg-white rounded-lg shadow-sm p-8 text-center text-gray-500">
    <i class="bi bi-exclamation-triangle text-2xl text-amber-500"></i>
    <p class="mt-2 text-sm">이 몰에 편집할 SDUI 페이지가 없습니다. 시드 데이터를 먼저 생성하세요.</p>
  </div>
<% } else { %>

<!-- 상단 툴바 -->
<div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-4">
  <div class="mr-auto flex items-center gap-2">
    <span class="text-sm text-gray-500">페이지</span>
    <%/* 빌더가 홈만 편집하던 시절에는 라벨이 '홈' 하나로 박혀 있었다.
         랜딩(/new 등)을 편집·발행할 수 없으면 그 페이지는 영영 발행 스냅샷이 없고,
         스토어프론트가 라이브 page_section 으로 폴백한다 = 고치는 순간 운영 반영. */%>
    <select id="pb-page-select" class="border border-gray-300 rounded-md text-sm px-2 py-1.5 font-semibold">
      <% (pages || []).forEach(p => { %>
        <option value="<%= p.id %>" <%= p.id === page.id ? 'selected' : '' %>>
          <%= p.page_type === 'home' ? '홈' : (p.title || p.slug) %>
          <%= p.slug && p.page_type !== 'home' ? '(/' + p.slug + ')' : '' %>
          · 섹션 <%= p.section_count %><%= p.published_no ? '' : ' · 미발행' %>
        </option>
      <% }); %>
    </select>
    <span class="px-2 py-0.5 rounded text-[11px] font-medium <%= revisions.length ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
      <%= revisions.length ? '발행됨 #' + revisions[0].revision_no : '발행 이력 없음' %>
    </span>
    <%/* 서버가 작업본 ↔ 최신 발행 스냅샷을 비교해 준다. 예전엔 클라이언트가 편집할 때만 켜서,
         새로고침하면 배지가 사라지고 발행을 잊은 변경분이 조용히 남았다. */%>
    <span id="pb-dirty" class="<%= dirty ? '' : 'hidden ' %>px-2 py-0.5 rounded text-[11px] font-medium bg-amber-100 text-amber-700">미발행 변경사항</span>
  </div>

  <div class="flex items-center gap-2 flex-wrap">
    <select id="pb-revision-select" class="border border-gray-300 rounded-md text-sm px-2 py-1.5">
      <option value="">— 리비전 선택(롤백) —</option>
      <% revisions.forEach(r => { %>
        <option value="<%= r.id %>">#<%= r.revision_no %> · <%= r.created_by || 'system' %> · <%= new Date(r.published_at || r.created_at).toLocaleString('ko-KR') %></option>
      <% }); %>
    </select>
    <button id="pb-rollback-btn" class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-gray-700 text-sm rounded-md hover:bg-gray-50">
      <i class="bi bi-arrow-counterclockwise mr-1"></i>롤백
    </button>
    <button id="pb-preview-refresh" class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-gray-700 text-sm rounded-md hover:bg-gray-50">
      <i class="bi bi-arrow-clockwise mr-1"></i>미리보기 새로고침
    </button>
    <button id="pb-publish-btn" class="inline-flex items-center px-4 py-1.5 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
      <i class="bi bi-cloud-upload mr-1"></i>발행
    </button>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
  <!-- 좌: 섹션 목록 + 추가 -->
  <div class="lg:col-span-4 space-y-3">
    <div class="bg-white rounded-lg shadow-sm p-3">
      <div class="flex items-center gap-2">
        <select id="pb-add-type" class="flex-1 border border-gray-300 rounded-md text-sm px-2 py-1.5">
          <% palette.forEach(p => { %>
            <option value="<%= p.type %>"><%= p.label %></option>
          <% }); %>
        </select>
        <button id="pb-add-btn" class="inline-flex items-center px-3 py-1.5 bg-emerald-600 text-white text-sm font-medium rounded-md hover:bg-emerald-700">
          <i class="bi bi-plus-lg mr-1"></i>추가
        </button>
      </div>
      <%/* 섹션 이름만으로는 '혜택 벤토'·'랭킹 탭'이 무엇인지 알 수 없다.
           카탈로그는 각 섹션을 실제 데이터로 렌더해 보여주고 거기서 바로 추가하게 한다. */%>
      <button id="pb-catalog-btn" class="mt-2 w-full inline-flex items-center justify-center px-3 py-1.5 border border-gray-300 text-gray-700 text-sm rounded-md hover:bg-gray-50">
        <i class="bi bi-grid-3x3-gap mr-1.5"></i>섹션 둘러보기 — 뭐가 있고 어떻게 보이는지
      </button>
    </div>

    <div id="pb-section-list" class="space-y-2">
      <!-- JS 렌더 -->
    </div>
  </div>

  <!-- 중: 미리보기 -->
  <div class="lg:col-span-5">
    <div class="bg-white rounded-lg shadow-sm p-3">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-gray-700">미리보기 <span class="text-xs text-gray-400">(발행 전 작업본)</span></span>
        <div class="flex items-center gap-1">
          <button data-device="pc" class="pb-device-btn px-2 py-1 text-xs rounded border border-gray-300 bg-blue-50 text-blue-700">PC</button>
          <button data-device="mobile" class="pb-device-btn px-2 py-1 text-xs rounded border border-gray-300 text-gray-600">모바일</button>
        </div>
      </div>
      <div class="border border-gray-200 rounded-lg overflow-hidden bg-gray-100 flex justify-center">
        <iframe id="pb-preview" src="/admin/page-builder/preview?page=<%= page.id %>"
          class="bg-white transition-all" style="width:100%;height:680px;border:0;"></iframe>
      </div>
    </div>
  </div>

  <!-- 우: 선택 섹션 설정 -->
  <div class="lg:col-span-3">
    <div id="pb-settings" class="bg-white rounded-lg shadow-sm p-4">
      <p class="text-sm text-gray-400 text-center py-8">
        <i class="bi bi-arrow-left-circle mr-1"></i>왼쪽에서 섹션을 선택하면<br>설정이 여기에 표시됩니다.
      </p>
    </div>
  </div>
</div>

<!-- ── 섹션 카탈로그 모달 ── -->
<div id="pb-catalog" class="hidden fixed inset-0 z-50 bg-black/50 p-4 sm:p-8 overflow-y-auto">
  <div class="mx-auto max-w-6xl bg-gray-50 rounded-xl shadow-2xl">
    <div class="sticky top-0 z-10 flex items-center gap-3 px-5 py-4 bg-white border-b border-gray-200 rounded-t-xl">
      <div class="mr-auto">
        <h2 class="text-base font-semibold text-gray-900">섹션 둘러보기</h2>
        <p class="text-xs text-gray-500 mt-0.5">현재 몰의 실제 데이터로 그린 미리보기입니다. 마음에 드는 섹션을 바로 추가하세요.</p>
      </div>
      <button id="pb-catalog-close" class="p-2 text-gray-400 hover:text-gray-700 rounded-md hover:bg-gray-100">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 p-5">
      <% palette.forEach(p => { %>
        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden flex flex-col">
          <div class="flex items-start gap-3 px-4 py-3 border-b border-gray-100">
            <div class="mr-auto min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-sm font-semibold text-gray-900"><%= p.label %></span>
                <% if (p.dataSource === 'product_group') { %>
                  <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-indigo-50 text-indigo-700">상품 그룹 필요</span>
                <% } else if (p.dataSource === 'banner_group') { %>
                  <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-50 text-amber-700">배너 그룹 필요</span>
                <% } %>
              </div>
              <p class="mt-1 text-xs text-gray-500 leading-relaxed"><%= p.description %></p>
            </div>
            <button type="button" data-catalog-add="<%= p.type %>"
              class="shrink-0 inline-flex items-center px-2.5 py-1.5 bg-emerald-600 text-white text-xs font-medium rounded-md hover:bg-emerald-700">
              <i class="bi bi-plus-lg mr-1"></i>추가
            </button>
          </div>
          <%/* 팔레트 18종을 한꺼번에 렌더하면 요청이 18개 나간다. 카탈로그를 연 뒤
               data-src → src 로 지연 로드한다. */%>
          <div class="bg-gray-100 h-64 overflow-hidden">
            <iframe class="pb-catalog-frame w-full h-full bg-white" style="border:0;"
              data-src="/admin/page-builder/section-preview?type=<%= p.type %>" loading="lazy"></iframe>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</div>

<script id="pb-data" type="application/json">
  <%- JSON.stringify({ pageId: page.id, sections, palette, productGroups, linkTargets: (typeof linkTargets !== 'undefined' ? linkTargets : []) })
    .replace(/<\//g, '<\\/')
    .replace(/<!--/g, '<\\!--')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029') %>
</script>
<script src="/js/admin/page-builder.js"></script>

<% } %>
