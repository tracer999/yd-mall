<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 sm:gap-0">
    <p class="text-sm text-gray-500">고객 문의 내역을 확인하고 답변 상태를 관리합니다.</p>
    <form method="get" action="/admin/inquiries"
        class="flex flex-wrap items-center gap-2 w-full sm:w-auto justify-start sm:justify-end">
        <label for="mallId" class="text-sm text-gray-500">몰</label>
        <select name="mallId" id="mallId" onchange="this.form.submit()"
            class="rounded-md border-gray-300 text-sm focus:border-blue-500 focus:ring-blue-500">
            <option value="">전체 몰</option>
            <% malls.forEach(function(m){ %>
                <option value="<%= m.id %>" <%= selectedMallId === Number(m.id) ? 'selected' : '' %>>
                    <%= m.name %>
                </option>
            <% }) %>
        </select>
    </form>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col"
                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">번호</th>
                    <th scope="col"
                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">제목</th>
                    <th scope="col"
                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">몰</th>
                    <th scope="col"
                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">작성자</th>
                    <th scope="col"
                        class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
                    <th scope="col"
                        class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">작성일
                    </th>
                    <th scope="col"
                        class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">관리</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                <% inquiries.forEach(inquiry=> { %>
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            <%= inquiry.id %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm font-medium text-gray-900">
                                <%= inquiry.title %>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="px-2 inline-flex text-xs leading-5 font-medium rounded-full bg-gray-100 text-gray-700">
                                <%= inquiry.mall_name || '-' %>
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm text-gray-900">
                                <%= inquiry.user_name %>
                            </div>
                            <div class="text-xs text-gray-500">
                                <%= inquiry.user_email %>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-center">
                            <% if(inquiry.is_answered) { %>
                                <span
                                    class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                    답변완료
                                </span>
                                <% } else { %>
                                    <span
                                        class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                                        답변대기
                                    </span>
                                    <% } %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                            <%= inquiry.created_at.toISOString().split('T')[0] %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                            <a href="/admin/inquiries/<%= inquiry.id %>"
                                class="text-blue-600 hover:text-blue-900">상세보기</a>
                        </td>
                    </tr>
                    <% }) %>
                        <% if(inquiries.length===0) { %>
                            <tr>
                                <td colspan="7" class="px-6 py-10 text-center text-gray-500">
                                    등록된 문의가 없습니다.
                                </td>
                            </tr>
                            <% } %>
            </tbody>
        </table>
    </div>
</div>