<div class="flex items-center mb-6">
  <a href="/admin/inquiries" class="mr-4 text-gray-500 hover:text-gray-700">
    <i class="bi bi-arrow-left text-xl"></i>
  </a>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden mb-6">
  <div
    class="px-6 py-5 border-b border-gray-200 bg-gray-50 flex justify-between items-center"
  >
    <div>
      <span class="text-sm text-gray-500 mr-2">No. <%= inquiry.id %></span>
      <span
        class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= inquiry.is_answered ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>"
      >
        <%= inquiry.is_answered ? '답변완료' : '답변대기' %>
      </span>
    </div>
    <div class="text-sm text-gray-500">
      <%= inquiry.created_at.toLocaleString() %>
    </div>
  </div>
  <div class="p-6">
    <div class="mb-6">
      <h3 class="text-lg font-bold text-gray-900 mb-2"><%= inquiry.title %></h3>
      <div
        class="flex items-center text-sm text-gray-600 mb-4 pb-4 border-b border-gray-100"
      >
        <i class="bi bi-person-circle mr-2"></i>
        <span class="font-medium mr-2"><%= inquiry.user_name %></span>
        <span class="text-gray-400">&lt;<%= inquiry.user_email %>&gt;</span>
        <span class="ml-3 px-2 inline-flex text-xs leading-5 font-medium rounded-full bg-gray-100 text-gray-700">
          <%= inquiry.mall_name || '-' %>
        </span>
      </div>
      <div
        class="text-gray-800 whitespace-pre-wrap leading-relaxed bg-gray-50 p-4 rounded-md border border-gray-100 min-h-[150px]"
      >
        <%= inquiry.content %>
      </div>
    </div>
  </div>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200 bg-blue-50">
    <h3 class="text-lg font-bold text-blue-900 flex items-center">
      <i class="bi bi-chat-dots mr-2"></i> 답변 작성
    </h3>
  </div>
  <div class="p-6">
    <form action="/admin/inquiries/<%= inquiry.id %>/answer" method="POST">
      <div class="mb-4">
        <label for="answer" class="block text-sm font-medium text-gray-700 mb-1"
          >답변 내용</label
        >
        <textarea
          id="answer"
          name="answer"
          rows="6"
          class="appearance-none block w-full px-4 py-3 border border-blue-200 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 text-base"
          required
        >
<%= inquiry.answer || '' %></textarea
        >
      </div>
      <div class="flex justify-end">
        <button
          type="submit"
          class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700"
        >
          <i class="bi bi-send mr-2"></i> <%= inquiry.is_answered ? '답변 수정'
          : '답변 등록' %>
        </button>
      </div>
    </form>
  </div>
</div>
