<%
  /* 외부몰 연동 · 상품 가져오기 (Phase 2)
     검색은 GET 쿼리, 적재는 POST /import/run. "가져오기 ≠ 상품 등록". */
  const r = result || null;
  const won = (v) => (v == null ? '-' : Number(v).toLocaleString('ko-KR') + '원');
  const qs = (over) => {
    const p = new URLSearchParams({
      supplier: supplier, q: keyword || '', cat: categoryCode || '',
      page: String(page), size: String(size),
    });
    Object.entries(over || {}).forEach(([k, v]) => p.set(k, String(v)));
    return '/admin/sourcing/import?' + p.toString();
  };
%>

<div class="w-full">

  <div class="mb-6">
    <div class="mb-3 flex items-center gap-2 rounded-lg border border-indigo-200 bg-indigo-50 px-4 py-3">
      <i class="bi bi-shop text-lg text-indigo-600"></i>
      <span class="text-sm font-medium text-indigo-700">현재 편집 몰</span>
      <span class="text-lg font-bold text-indigo-900"><%= (adminMall && adminMall.name) || ('mall #' + adminMallId) %></span>
    </div>
    <h1 class="text-2xl font-bold text-gray-900"><%= title %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= subtitle %></p>
  </div>

  <% if (msg) { %>
    <div class="mb-4 rounded-md bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800"><%= msg %></div>
  <% } %>
  <% if (error) { %>
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
      <i class="bi bi-exclamation-triangle mr-1"></i><%= error %>
    </div>
  <% } %>

  <!-- 검색 -->
  <div class="bg-white shadow-sm rounded-lg mb-6">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-bold text-gray-800">공급처 상품 검색</h2>
      <p class="mt-1 text-xs text-gray-500">
        도매꾹과 도매매는 API Key 를 공유하지만 <b>노출 상품과 공급가가 다릅니다</b> — 가져올 마켓을 정확히 고르세요.
      </p>
    </div>
    <form method="get" action="/admin/sourcing/import" class="p-6 grid grid-cols-1 sm:grid-cols-12 gap-3 items-end">
      <div class="sm:col-span-2">
        <label class="block text-sm text-gray-600 mb-1">공급처</label>
        <select name="supplier" class="w-full rounded-md border border-gray-300 text-sm px-3 py-2">
          <option value="DOMEGGOOK" <%= supplier === 'DOMEGGOOK' ? 'selected' : '' %>>도매꾹</option>
          <option value="DOMEME" <%= supplier === 'DOMEME' ? 'selected' : '' %>>도매매</option>
        </select>
      </div>
      <div class="sm:col-span-4">
        <label class="block text-sm text-gray-600 mb-1">검색어</label>
        <input type="text" name="q" value="<%= keyword %>" placeholder="예) 홍삼"
               class="w-full rounded-md border border-gray-300 text-sm px-3 py-2">
      </div>
      <div class="sm:col-span-1">
        <label class="block text-sm text-gray-600 mb-1">개수</label>
        <select name="size" class="w-full rounded-md border border-gray-300 text-sm px-3 py-2">
          <% [20, 50, 100].forEach((n) => { %>
            <option value="<%= n %>" <%= Number(size) === n ? 'selected' : '' %>><%= n %></option>
          <% }) %>
        </select>
      </div>
      <div class="sm:col-span-5">
        <button type="submit"
          class="w-full inline-flex items-center justify-center gap-1.5 rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">
          <i class="bi bi-search"></i> 검색
        </button>
      </div>

      <!-- 카테고리 선택기 — 코드를 직접 입력하지 않고 이름으로 고른다.
           실제 검색에 쓰이는 값은 아래 hidden(cat) 이며 선택에 따라 채워진다. -->
      <div class="sm:col-span-12 border-t border-gray-100 pt-4">
        <div class="flex items-center justify-between mb-2">
          <label class="block text-sm text-gray-600">
            카테고리로 찾기 <span class="text-xs text-gray-400">(검색어 없이도 가능)</span>
          </label>
          <button type="button" id="cat-clear" class="text-xs text-gray-500 hover:text-indigo-600 hidden">
            <i class="bi bi-x-circle"></i> 선택 해제
          </button>
        </div>
        <input type="hidden" name="cat" id="cat-code" value="<%= categoryCode %>">
        <div id="cat-selects" class="grid grid-cols-1 sm:grid-cols-4 gap-2">
          <div class="sm:col-span-4 text-xs text-gray-400" id="cat-loading">
            <i class="bi bi-hourglass-split"></i> 분류 목록을 불러오는 중…
          </div>
        </div>
        <p id="cat-picked" class="mt-2 text-xs text-indigo-700 hidden"></p>
        <p id="cat-warn" class="mt-2 text-xs text-amber-700 hidden">
          <i class="bi bi-info-circle"></i> 대분류만으로는 검색할 수 없습니다. <b>중분류 이상</b>을 선택해 주세요.
        </p>
        <p id="cat-error" class="mt-2 text-xs text-red-600 hidden"></p>
      </div>

      <p class="sm:col-span-12 text-xs text-gray-400">
        검색어 또는 카테고리 중 하나 이상이 필요합니다(도매꾹 API 제약). 검색만으로는 저장되지 않습니다.
      </p>
    </form>
  </div>

  <% if (searched && r) { %>
    <form method="post" action="/admin/sourcing/import/run">
      <input type="hidden" name="supplier" value="<%= supplier %>">
      <input type="hidden" name="q" value="<%= keyword %>">
      <input type="hidden" name="cat" value="<%= categoryCode %>">
      <input type="hidden" name="page" value="<%= page %>">

      <div class="bg-white shadow-sm rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200 flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-lg font-bold text-gray-800">
              검색 결과 <span class="text-indigo-600"><%= (r.total || 0).toLocaleString('ko-KR') %></span>건
            </h2>
            <p class="mt-1 text-xs text-gray-500">
              <%= r.page %> / <%= (r.totalPages || 1).toLocaleString('ko-KR') %> 페이지 ·
              한 번에 최대 <b><%= maxBatch %></b>건까지 가져올 수 있습니다.
            </p>
          </div>
          <button type="submit"
            class="inline-flex items-center gap-1.5 rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
            <i class="bi bi-download"></i> 선택 상품 가져오기
          </button>
        </div>

        <% if (!r.items.length) { %>
          <div class="p-10 text-center text-sm text-gray-500">검색 결과가 없습니다.</div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead class="bg-gray-50 text-gray-600">
                <tr>
                  <th class="px-4 py-3 w-10 text-left">
                    <input type="checkbox" id="chk-all" class="h-4 w-4">
                  </th>
                  <th class="px-4 py-3 w-16 text-left">이미지</th>
                  <th class="px-4 py-3 text-left">상품명</th>
                  <th class="px-4 py-3 w-28 text-right">공급가</th>
                  <th class="px-4 py-3 w-24 text-right">최소수량</th>
                  <th class="px-4 py-3 w-28 text-left">판매자</th>
                  <th class="px-4 py-3 w-28 text-right">배송비</th>
                  <th class="px-4 py-3 w-24 text-center">상태</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% r.items.forEach((it) => { %>
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3 align-top">
                      <input type="checkbox" name="item_no" value="<%= it.itemNo %>" class="chk-item h-4 w-4">
                    </td>
                    <td class="px-4 py-3 align-top">
                      <% if (it.thumbUrl) { %>
                        <img src="<%= it.thumbUrl %>" alt="" class="h-12 w-12 rounded object-cover border border-gray-200" loading="lazy">
                      <% } else { %>
                        <div class="h-12 w-12 rounded bg-gray-100"></div>
                      <% } %>
                    </td>
                    <td class="px-4 py-3 align-top">
                      <div class="font-medium text-gray-900"><%= it.title %></div>
                      <div class="mt-0.5 text-xs text-gray-400">
                        상품번호 <%= it.itemNo %>
                        <% if (it.sourceUrl) { %>
                          · <a href="<%= it.sourceUrl %>" target="_blank" rel="noopener"
                               class="text-indigo-600 hover:underline">공급처에서 보기</a>
                        <% } %>
                      </div>
                      <% if (it.adultOnly) { %>
                        <span class="mt-1 inline-block rounded bg-red-50 px-1.5 py-0.5 text-xs text-red-700">성인</span>
                      <% } %>
                      <% if (it.comOnly) { %>
                        <span class="mt-1 inline-block rounded bg-amber-50 px-1.5 py-0.5 text-xs text-amber-700">사업자전용</span>
                      <% } %>
                    </td>
                    <td class="px-4 py-3 align-top text-right font-medium text-gray-900"><%= won(it.price) %></td>
                    <td class="px-4 py-3 align-top text-right text-gray-600"><%= it.unitQty != null ? it.unitQty : '-' %></td>
                    <td class="px-4 py-3 align-top text-gray-600"><%= it.sellerId || '-' %></td>
                    <td class="px-4 py-3 align-top text-right text-gray-600"><%= won(it.deliFee) %></td>
                    <td class="px-4 py-3 align-top text-center">
                      <% if (it.alreadyImported) { %>
                        <span class="rounded bg-gray-100 px-2 py-1 text-xs text-gray-600">가져옴</span>
                      <% } else { %>
                        <span class="text-xs text-gray-300">-</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="px-6 py-4 border-t border-gray-200 flex items-center justify-between">
            <span class="text-xs text-gray-500">
              '가져옴' 표시된 상품을 다시 선택하면 <b>최신 정보로 갱신</b>됩니다(중복 생성 아님).
            </span>
            <div class="flex items-center gap-2">
              <% if (r.page > 1) { %>
                <a href="<%= qs({ page: r.page - 1 }) %>"
                   class="rounded-md border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50">이전</a>
              <% } %>
              <span class="text-sm text-gray-600"><%= r.page %> / <%= r.totalPages || 1 %></span>
              <% if (r.page < (r.totalPages || 1)) { %>
                <a href="<%= qs({ page: r.page + 1 }) %>"
                   class="rounded-md border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50">다음</a>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </form>
  <% } else if (!searched) { %>
    <div class="bg-white shadow-sm rounded-lg p-10 text-center">
      <i class="bi bi-search text-3xl text-gray-300"></i>
      <p class="mt-3 text-sm text-gray-500">검색어 또는 카테고리 코드를 입력해 공급처 상품을 찾아보세요.</p>
      <p class="mt-1 text-xs text-gray-400">검색 결과에서 원하는 상품만 선택해 가져옵니다.</p>
    </div>
  <% } %>
</div>

<script>
  /* 카테고리 단계별 선택기.
     사용자는 코드를 모르므로 이름으로 고르고, 실제 검색값(hidden cat)은 여기서 채운다.
     초기값은 EJS 보간 대신 hidden 의 value 에서 읽는다(따옴표 이스케이프 사고 방지). */
  (function () {
    var wrap = document.getElementById('cat-selects');
    if (!wrap) return;

    var hidden = document.getElementById('cat-code');
    var loading = document.getElementById('cat-loading');
    var picked = document.getElementById('cat-picked');
    var warn = document.getElementById('cat-warn');
    var errBox = document.getElementById('cat-error');
    var clearBtn = document.getElementById('cat-clear');
    var initial = (hidden.value || '').trim();
    var TREE = null;

    // '12_03_13_00_00' → 3 : 00 이 아닌 세그먼트 수가 뎁스다.
    function depthOf(code) {
      if (!code) return 0;
      return String(code).split('_').filter(function (s) { return s && s !== '00'; }).length;
    }

    function findChain(nodes, code, trail) {
      for (var i = 0; i < nodes.length; i++) {
        var n = nodes[i];
        var next = trail.concat([n]);
        if (n.c === code) return next;
        if (n.k) {
          var got = findChain(n.k, code, next);
          if (got) return got;
        }
      }
      return null;
    }

    function makeSelect(nodes, level, selectedCode) {
      var sel = document.createElement('select');
      sel.className = 'w-full rounded-md border border-gray-300 text-sm px-3 py-2';
      sel.dataset.level = String(level);
      var ph = document.createElement('option');
      ph.value = '';
      ph.textContent = level === 0 ? '대분류 선택' : (level === 1 ? '중분류 선택' : '소분류 선택 (선택)');
      sel.appendChild(ph);
      nodes.forEach(function (n) {
        var o = document.createElement('option');
        o.value = n.c;
        o.textContent = n.n;
        if (n.c === selectedCode) o.selected = true;
        sel.appendChild(o);
      });
      sel.addEventListener('change', function () { onChange(level); });
      return sel;
    }

    function nodesAt(level) {
      // 상위 선택을 따라 내려가며 해당 레벨의 후보 목록을 구한다.
      var nodes = TREE;
      for (var i = 0; i < level; i++) {
        var s = wrap.querySelector('select[data-level="' + i + '"]');
        if (!s || !s.value) return null;
        var found = null;
        for (var j = 0; j < nodes.length; j++) {
          if (nodes[j].c === s.value) { found = nodes[j]; break; }
        }
        if (!found || !found.k) return null;
        nodes = found.k;
      }
      return nodes;
    }

    function onChange(changedLevel) {
      // 변경된 레벨보다 하위 선택은 모두 제거한다.
      wrap.querySelectorAll('select').forEach(function (s) {
        if (Number(s.dataset.level) > changedLevel) s.remove();
      });
      var next = nodesAt(changedLevel + 1);
      if (next && next.length) wrap.appendChild(makeSelect(next, changedLevel + 1, ''));
      sync();
    }

    function sync() {
      // 가장 깊게 선택된 값이 검색에 쓰이는 코드다.
      var code = '';
      var names = [];
      wrap.querySelectorAll('select').forEach(function (s) {
        if (s.value) {
          code = s.value;
          names.push(s.options[s.selectedIndex].textContent);
        }
      });
      hidden.value = code;

      var d = depthOf(code);
      warn.classList.toggle('hidden', !(code && d < 2));
      clearBtn.classList.toggle('hidden', !code);
      if (code && d >= 2) {
        picked.textContent = '선택됨: ' + names.join(' > ') + '  (코드 ' + code + ')';
        picked.classList.remove('hidden');
      } else {
        picked.classList.add('hidden');
      }
    }

    // 도매꾹은 조건이 없거나 대분류만 있으면 거부한다 — 서버에 보내기 전에 막는다.
    var searchForm = document.querySelector('form[action="/admin/sourcing/import"]');
    if (searchForm) {
      searchForm.addEventListener('submit', function (e) {
        var kw = (searchForm.querySelector('input[name="q"]').value || '').trim();
        var code = (hidden.value || '').trim();
        if (!kw && !code) {
          e.preventDefault();
          alert('검색어를 입력하거나 카테고리를 선택해 주세요.');
          return;
        }
        if (!kw && depthOf(code) < 2) {
          e.preventDefault();
          alert('대분류만으로는 검색할 수 없습니다. 중분류 이상을 선택하거나 검색어를 함께 입력해 주세요.');
        }
      });
    }

    clearBtn.addEventListener('click', function () {
      wrap.querySelectorAll('select').forEach(function (s) {
        if (Number(s.dataset.level) > 0) s.remove(); else s.value = '';
      });
      sync();
    });

    fetch('/admin/sourcing/domeggook-categories', { credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (!d.success) throw new Error(d.error || '불러오기 실패');
        TREE = d.tree;
        loading.remove();
        var chain = initial ? findChain(TREE, initial, []) : null;
        wrap.appendChild(makeSelect(TREE, 0, chain ? chain[0].c : ''));
        // 검색 후 돌아왔을 때 이전 선택을 복원한다.
        if (chain) {
          for (var i = 1; i < chain.length; i++) {
            var nodes = nodesAt(i);
            if (!nodes) break;
            wrap.appendChild(makeSelect(nodes, i, chain[i].c));
          }
          var deeper = nodesAt(chain.length);
          if (deeper && deeper.length) wrap.appendChild(makeSelect(deeper, chain.length, ''));
        }
        sync();
      })
      .catch(function (e) {
        loading.remove();
        errBox.textContent = '카테고리 목록을 불러오지 못했습니다: ' + e.message
          + ' — 검색어로 찾거나, [공급처/채널 연결]에서 도매꾹 자격증명을 확인하세요.';
        errBox.classList.remove('hidden');
      });
  })();

  (function () {
    var all = document.getElementById('chk-all');
    if (!all) return;
    var items = document.querySelectorAll('.chk-item');
    var MAX = <%= maxBatch %>;

    all.addEventListener('change', function () {
      // 전체선택이라도 상한을 넘기지 않는다(초과분은 서버에서 잘리므로 미리 막는다).
      var n = 0;
      items.forEach(function (c) {
        c.checked = all.checked && n < MAX;
        if (c.checked) n++;
      });
      if (all.checked && items.length > MAX) {
        alert('한 번에 최대 ' + MAX + '건까지 가져올 수 있어 앞에서 ' + MAX + '건만 선택했습니다.');
      }
    });

    document.querySelector('form[action="/admin/sourcing/import/run"]').addEventListener('submit', function (e) {
      var n = document.querySelectorAll('.chk-item:checked').length;
      if (n === 0) {
        e.preventDefault();
        alert('가져올 상품을 선택하세요.');
        return;
      }
      if (n > MAX) {
        e.preventDefault();
        alert('한 번에 최대 ' + MAX + '건까지만 가져올 수 있습니다. 현재 ' + n + '건 선택됨.');
      }
    });
  })();
</script>
