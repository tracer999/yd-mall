<%
  /* 네이버 리소스 관리 — 수집 현황 · 수동수집 · 스케줄 · 수집 리소스 브라우징.
     구 "몰 관리 → 리소스 관리"(/admin/resources)를 이 화면으로 통합했다. */
  var BASE = '/admin/sourcing/naver-taxonomy';
  var f = filters || { q: '', activeOnly: true, leafOnly: false };

  // 탭/필터를 유지한 채 page 만 바꾼 링크를 만든다.
  function pageUrl(p) {
    var qs = ['tab=' + encodeURIComponent(tab)];
    if (f.q) qs.push('q=' + encodeURIComponent(f.q));
    if (f.activeOnly) qs.push('active=1');
    if (tab === 'category' && f.leafOnly) qs.push('leaf=1');
    if (p > 1) qs.push('page=' + p);
    return BASE + '?' + qs.join('&');
  }
%>
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= title %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= subtitle %></p>
  </div>

  <% if (msg) { %>
    <div class="mb-4 rounded-md bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800"><%= msg %></div>
  <% } %>
  <% if (saved) { %>
    <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">저장되었습니다.</div>
  <% } %>
  <% if (error) { %>
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800"><%= error %></div>
  <% } %>

  <% if (!status) { %>
    <div class="bg-white shadow-sm rounded-lg p-10 text-center text-sm text-gray-500">현황을 불러오지 못했습니다.</div>
  <% } else { %>

    <% if (!status.hasActiveCredential) { %>
      <div class="mb-6 rounded-md bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
        <i class="bi bi-exclamation-triangle mr-1"></i>
        ACTIVE 상태의 네이버 스마트스토어 자격증명이 없습니다.
        <a href="/admin/sourcing/connections" class="underline font-medium">공급처/채널 연결</a>
        에서 client_id / client_secret 를 입력하고 <b>[검증]</b> 을 눌러 ACTIVE 로 만든 뒤 수집하세요.
      </div>
    <% } %>

    <%#
      리소스 4종을 한 자리에 나란히 둔다.
      각 카드가 "무엇을 · 몇 건 · 언제 · 어떻게 다시 가져오는지"를 스스로 말해야
      어떤 리소스가 비어 있는지 즉시 드러난다.
    %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

      <!-- 1. 카테고리 -->
      <div class="bg-white shadow-sm rounded-lg p-4 border-t-4 border-emerald-500">
        <div class="text-xs font-semibold text-gray-700"><i class="bi bi-diagram-3"></i> 카테고리</div>
        <div class="mt-1 text-2xl font-bold text-gray-900"><%= Number(status.counts.total || 0).toLocaleString() %></div>
        <div class="text-xs text-emerald-700">활성 리프 <%= Number(status.counts.active_leaf || 0).toLocaleString() %></div>
        <div class="mt-1 text-xs text-gray-400">
          <%= status.counts.last_fetched_at ? new Date(status.counts.last_fetched_at).toLocaleString('ko-KR') : '수집 이력 없음' %>
        </div>
        <form method="post" action="<%= BASE %>/refresh" class="mt-3">
          <button type="submit" class="w-full rounded-md bg-emerald-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-emerald-700">
            <i class="bi bi-arrow-repeat"></i> 지금 수집
          </button>
        </form>
      </div>

      <!-- 2. 원산지 -->
      <div class="bg-white shadow-sm rounded-lg p-4 border-t-4 border-sky-500">
        <div class="text-xs font-semibold text-gray-700"><i class="bi bi-geo-alt"></i> 원산지 코드</div>
        <div class="mt-1 text-2xl font-bold text-gray-900"><%= Number(status.originCounts && status.originCounts.total || 0).toLocaleString() %></div>
        <div class="text-xs text-sky-700">활성 <%= Number(status.originCounts && status.originCounts.active_total || 0).toLocaleString() %></div>
        <div class="mt-1 text-xs text-gray-400">
          <%= status.originCounts && status.originCounts.last_fetched_at
                ? new Date(status.originCounts.last_fetched_at).toLocaleString('ko-KR') : '수집 이력 없음' %>
        </div>
        <form method="post" action="<%= BASE %>/origin-areas/refresh" class="mt-3">
          <button type="submit" class="w-full rounded-md bg-sky-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-sky-700">
            <i class="bi bi-arrow-repeat"></i> 지금 수집
          </button>
        </form>
      </div>

      <!-- 3. 고시 상품군 — 시드로 배포되므로 자격증명 없이도 채워져 있다 -->
      <div class="bg-white shadow-sm rounded-lg p-4 border-t-4 border-amber-500">
        <div class="text-xs font-semibold text-gray-700"><i class="bi bi-card-checklist"></i> 고시 상품군</div>
        <div class="mt-1 text-2xl font-bold text-gray-900"><%= Number(status.noticeCounts && status.noticeCounts.total || 0).toLocaleString() %></div>
        <div class="text-xs text-amber-700">입력 항목 <%= Number(status.noticeCounts && status.noticeCounts.fields || 0).toLocaleString() %>개</div>
        <div class="mt-1 text-xs text-gray-400">
          <%= status.noticeCounts && status.noticeCounts.fromNaver
                ? ('네이버 수집 ' + status.noticeCounts.fromNaver + '종') : '기본 제공(시드)' %>
        </div>
        <form method="post" action="/admin/sourcing/publish/notice-schema/refresh" class="mt-3">
          <button type="submit" class="w-full rounded-md bg-amber-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-amber-700">
            <i class="bi bi-arrow-repeat"></i> 지금 수집
          </button>
        </form>
      </div>

      <%# 4. 브랜드 — 수집 함수가 없다. 빈 표를 그냥 보여 주면 "고장난 것"처럼 보이므로
             미구현 사실을 카드에 그대로 적는다. %>
      <div class="bg-white shadow-sm rounded-lg p-4 border-t-4 border-gray-300">
        <div class="text-xs font-semibold text-gray-700"><i class="bi bi-tags"></i> 브랜드</div>
        <div class="mt-1 text-2xl font-bold text-gray-400"><%= Number(status.brandCounts && status.brandCounts.total || 0).toLocaleString() %></div>
        <div class="text-xs text-gray-500">활성 <%= Number(status.brandCounts && status.brandCounts.active_total || 0).toLocaleString() %></div>
        <div class="mt-2 rounded bg-gray-50 px-2 py-1.5 text-xs text-gray-500 leading-relaxed">
          <b>수집 미구현</b> — 네이버 브랜드 API(<code>/v1/product-brands</code>)의
          검색 파라미터가 확인되지 않았습니다. 브랜드 없이도 상품 등록은 가능합니다.
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
      <!-- 수집 안내 -->
      <div class="bg-white shadow-sm rounded-lg p-5">
        <h2 class="text-sm font-semibold text-gray-900 mb-2">수집이란</h2>
        <p class="text-xs text-gray-500 leading-relaxed">
          네이버가 정한 코드값(카테고리 ID·원산지 코드·고시 항목)을 미리 받아 두는 작업입니다.
          받아 둔 값은 <b>상품 등록 화면에서 검색·선택</b>으로 쓰이며, 코드를 직접 입력할 일이 없습니다.
          <br><br>
          수집은 <b>우리 DB 에만</b> 저장되고 <b>몰 카테고리에는 반영되지 않습니다.</b>
        </p>
      </div>

      <!-- 스케줄 -->
      <div class="bg-white shadow-sm rounded-lg p-5">
        <h2 class="text-sm font-semibold text-gray-900 mb-2">자동 수집 주기</h2>
        <p class="text-xs text-gray-500 mb-4">크론(<code>naver_taxonomy_cron.sh</code>)이 5분마다 확인해 주기가 되면 수집합니다.</p>
        <form method="post" action="<%= BASE %>/schedule" class="space-y-3">
          <label class="flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="enabled" value="1" <%= status.schedule && status.schedule.enabled ? 'checked' : '' %>>
            자동 수집 사용
          </label>
          <div class="flex items-center gap-2 text-sm text-gray-700">
            주기
            <input type="number" name="interval_hours" min="1" max="720" step="1"
              value="<%= status.schedule ? status.schedule.interval_hours : 24 %>"
              class="w-24 border rounded px-2 py-1 text-sm">
            시간마다 (24=하루 1회)
          </div>
          <div class="text-xs text-gray-500">
            마지막 실행:
            <%= status.schedule && status.schedule.last_run_at ? new Date(status.schedule.last_run_at).toLocaleString('ko-KR') : '없음' %>
            <% if (status.schedule && status.schedule.last_status) { %> · <%= status.schedule.last_status %><% } %>
          </div>
          <button type="submit"
            class="inline-flex items-center gap-1.5 rounded-md bg-gray-800 px-4 py-2 text-sm font-medium text-white hover:bg-black">
            저장
          </button>
        </form>
      </div>
    </div>

    <!-- ============ 수집된 리소스 브라우징 ============ -->
    <div class="bg-white shadow-sm rounded-lg mb-6">
      <!-- 탭 -->
      <div class="border-b px-5 pt-4">
        <nav class="flex gap-6 text-sm">
          <a href="<%= BASE %>?tab=category&active=1"
             class="pb-3 border-b-2 <%= tab === 'category' ? 'border-emerald-600 text-emerald-700 font-semibold' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
            <i class="bi bi-diagram-3 mr-1"></i> 카테고리 리소스
          </a>
          <a href="<%= BASE %>?tab=origin"
             class="pb-3 border-b-2 <%= tab === 'origin' ? 'border-sky-600 text-sky-700 font-semibold' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
            <i class="bi bi-geo-alt mr-1"></i> 원산지 코드
          </a>
          <a href="<%= BASE %>?tab=notice"
             class="pb-3 border-b-2 <%= tab === 'notice' ? 'border-amber-600 text-amber-700 font-semibold' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
            <i class="bi bi-card-checklist mr-1"></i> 고시 상품군
          </a>
          <a href="<%= BASE %>?tab=brand&active=1"
             class="pb-3 border-b-2 <%= tab === 'brand' ? 'border-indigo-600 text-indigo-700 font-semibold' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
            <i class="bi bi-tags mr-1"></i> 브랜드 <span class="text-xs font-normal text-gray-400">(미구현)</span>
          </a>
        </nav>
      </div>

      <!-- 검색·필터 -->
      <div class="px-5 py-4 border-b bg-gray-50">
        <form method="get" action="<%= BASE %>" class="flex flex-wrap items-center gap-3 text-sm">
          <input type="hidden" name="tab" value="<%= tab %>">
          <input type="text" name="q" value="<%= f.q %>"
            placeholder="<%= tab === 'brand' ? '브랜드명 또는 브랜드 ID'
                          : tab === 'origin' ? '원산지명(예: 강원도) 또는 코드'
                          : tab === 'notice' ? '상품군명(예: 건강기능식품) 또는 코드'
                          : '카테고리명·전체경로 또는 카테고리 ID' %>"
            class="flex-1 min-w-56 border rounded px-3 py-1.5 text-sm">
          <% if (tab === 'category' || tab === 'brand') { %>
            <label class="flex items-center gap-1.5 text-gray-700 whitespace-nowrap">
              <input type="checkbox" name="active" value="1" <%= f.activeOnly ? 'checked' : '' %>> 활성만
            </label>
          <% } %>
          <% if (tab === 'category') { %>
            <label class="flex items-center gap-1.5 text-gray-700 whitespace-nowrap">
              <input type="checkbox" name="leaf" value="1" <%= f.leafOnly ? 'checked' : '' %>> 리프만
            </label>
          <% } %>
          <button type="submit"
            class="rounded-md bg-gray-800 px-4 py-1.5 text-sm font-medium text-white hover:bg-black">검색</button>
          <% if (f.q || f.leafOnly || !f.activeOnly) { %>
            <a href="<%= BASE %>?tab=<%= tab %>&active=1" class="text-xs text-gray-500 underline">초기화</a>
          <% } %>
        </form>
      </div>

      <%# 고시 유형 배정 — 네이버가 카테고리별 유형을 주지 않아 우리가 경로 규칙으로 만든다.
          여기서 만든 값이 상품 등록 시 그대로 쓰이므로 현황을 카테고리 탭에 붙여 둔다. %>
      <% if (tab === 'category' && status.noticeMapping) { %>
        <div class="px-5 py-3 border-b bg-amber-50">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="text-xs text-amber-900">
              <b><i class="bi bi-card-checklist"></i> 리프별 고시 유형</b>
              — 배정 <b><%= status.noticeMapping.assigned.toLocaleString() %></b>
              / 전체 리프 <%= status.noticeMapping.leafTotal.toLocaleString() %>
              <% if (status.noticeMapping.unassigned) { %>
                · <span class="text-red-700">미지정 <%= status.noticeMapping.unassigned.toLocaleString() %></span>
              <% } %>
              <% if (status.noticeMapping.manual) { %>
                · <span class="text-indigo-700">직접 지정 <%= status.noticeMapping.manual.toLocaleString() %></span>
              <% } %>
              <div class="mt-1 text-amber-800">
                네이버는 카테고리별 고시 유형을 알려주지 않습니다. 카테고리 <b>경로 규칙</b>으로 자동 배정하고,
                맞지 않는 것만 아래 표에서 직접 고치세요. <b>직접 고친 값은 재적용해도 유지됩니다.</b>
              </div>
            </div>
            <form method="post" action="<%= BASE %>/notice-rules" class="shrink-0"
                  onsubmit="return confirm('경로 규칙으로 고시 유형을 다시 배정합니다.\n직접 지정한 값은 유지됩니다. 진행할까요?');">
              <button type="submit" class="rounded-md bg-amber-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-amber-700">
                <i class="bi bi-magic"></i> 규칙으로 일괄 배정
              </button>
            </form>
          </div>
        </div>
      <% } %>

      <!-- 목록 -->
      <div class="px-5 py-4">
        <% if (!list || !list.rows || !list.rows.length) { %>
          <div class="py-10 text-center text-sm text-gray-400">
            <% if (f.q) { %>
              검색 결과가 없습니다.
            <% } else if (tab === 'brand') { %>
              브랜드 수집은 <b>아직 구현되지 않았습니다</b> — 네이버 브랜드 API 의 검색 파라미터가 확인되지 않았습니다.
              브랜드 없이도 상품 등록은 정상 동작합니다.
            <% } else if (tab === 'origin') { %>
              수집된 원산지 코드가 없습니다. 위 <b>원산지 코드 [지금 수집]</b> 을 눌러 적재하세요.
            <% } else if (tab === 'notice') { %>
              고시 상품군이 비어 있습니다. 마이그레이션(<code>migrate_naver_notice_schema.sql</code>)이 적용되지 않았을 수 있습니다.
            <% } else { %>
              수집된 카테고리가 없습니다. 위 <b>[지금 수집]</b> 을 눌러 적재하세요.
            <% } %>
          </div>
        <% } else { %>
          <div class="mb-3 text-xs text-gray-500">
            <% if (list.total == null) { %>
              최대 <b class="text-gray-800"><%= list.rows.length %></b>건 표시 — 더 좁히려면 검색어를 입력하세요.
            <% } else { %>
              총 <b class="text-gray-800"><%= Number(list.total).toLocaleString() %></b>건
              · <%= list.page %>/<%= list.totalPages %> 페이지
            <% } %>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead>
                <tr class="text-left text-xs text-gray-500 border-b">
                  <% if (tab === 'brand') { %>
                    <th class="py-2 pr-4">브랜드 ID</th>
                    <th class="py-2 pr-4">브랜드명</th>
                    <th class="py-2 pr-4">영문명</th>
                    <th class="py-2 pr-4">상태</th>
                    <th class="py-2">수집시각</th>
                  <% } else if (tab === 'origin') { %>
                    <th class="py-2 pr-4">원산지 코드</th>
                    <th class="py-2 pr-4">표시명</th>
                    <th class="py-2">단계</th>
                  <% } else if (tab === 'notice') { %>
                    <th class="py-2 pr-4">상품군 코드</th>
                    <th class="py-2 pr-4">상품군명</th>
                    <th class="py-2 pr-4">입력 항목</th>
                    <th class="py-2">출처</th>
                  <% } else { %>
                    <th class="py-2 pr-4">카테고리 ID</th>
                    <th class="py-2 pr-4">전체 경로</th>
                    <th class="py-2 pr-4">리프</th>
                    <th class="py-2 pr-4">고시 유형</th>
                    <th class="py-2">상태</th>
                  <% } %>
                </tr>
              </thead>
              <tbody>
                <% list.rows.forEach(function (r) { %>
                  <tr class="border-b last:border-0 hover:bg-gray-50">
                    <% if (tab === 'brand') { %>
                      <td class="py-2 pr-4 font-mono text-xs text-gray-500"><%= r.naver_brand_id %></td>
                      <td class="py-2 pr-4 text-gray-800"><%= r.name %></td>
                      <td class="py-2 pr-4 text-gray-500"><%= r.name_en || '-' %></td>
                      <td class="py-2 pr-4">
                        <% if (r.is_active) { %>
                          <span class="text-emerald-700 font-medium">활성</span>
                        <% } else { %>
                          <span class="text-gray-400">비활성</span>
                        <% } %>
                      </td>
                      <td class="py-2 whitespace-nowrap text-xs text-gray-500">
                        <%= r.fetched_at ? new Date(r.fetched_at).toLocaleString('ko-KR') : '-' %>
                      </td>
                    <% } else if (tab === 'origin') { %>
                      <td class="py-2 pr-4 font-mono text-xs text-gray-500"><%= r.code %></td>
                      <td class="py-2 pr-4 text-gray-800"><%= r.name %></td>
                      <td class="py-2 text-xs text-gray-500">
                        <%= r.level === 1 ? '대분류' : r.level === 2 ? '중분류' : '시군구' %>
                      </td>
                    <% } else if (tab === 'notice') { %>
                      <td class="py-2 pr-4 font-mono text-xs text-gray-500"><%= r.notice_type %></td>
                      <td class="py-2 pr-4 text-gray-800"><%= r.label %></td>
                      <td class="py-2 pr-4 text-gray-600"><%= r.fields.length %>개</td>
                      <td class="py-2 text-xs">
                        <% if (r.source === 'NAVER') { %>
                          <span class="text-emerald-700 font-medium">네이버 수집</span>
                        <% } else { %>
                          <span class="text-gray-500">기본 제공</span>
                        <% } %>
                      </td>
                    <% } else { %>
                      <td class="py-2 pr-4 font-mono text-xs text-gray-500"><%= r.naver_category_id %></td>
                      <td class="py-2 pr-4 text-gray-800"><%= r.whole_category_name || r.name %></td>
                      <td class="py-2 pr-4">
                        <% if (r.is_leaf) { %>
                          <span class="text-emerald-700 font-medium">리프</span>
                        <% } else { %>
                          <span class="text-gray-400">중간</span>
                        <% } %>
                      </td>
                      <%# 고시 유형은 리프에서만 의미가 있다 — 상품은 리프에만 등록되기 때문. %>
                      <td class="py-2 pr-4">
                        <% if (!r.is_leaf) { %>
                          <span class="text-xs text-gray-300">-</span>
                        <% } else { %>
                          <div class="flex items-center gap-1">
                            <select name="notice_type" form="notice-<%= r.naver_category_id %>"
                                    class="rounded border border-gray-300 text-xs px-1.5 py-1 max-w-44">
                              <option value="">미지정</option>
                              <% noticeTypes.forEach(function (t) { %>
                                <option value="<%= t.notice_type %>" <%= r.notice_type === t.notice_type ? 'selected' : '' %>><%= t.label %></option>
                              <% }); %>
                            </select>
                            <button type="submit" form="notice-<%= r.naver_category_id %>"
                                    class="rounded border border-gray-300 bg-white px-1.5 py-1 text-xs text-gray-600 hover:bg-gray-100">저장</button>
                            <% if (r.notice_source === 'MANUAL') { %>
                              <span class="text-xs text-indigo-600" title="직접 지정 — 규칙 재적용에도 유지됩니다">직접</span>
                            <% } %>
                          </div>
                          <%# form 을 표 밖에 두면 tbody 구조가 깨지지 않는다(form 속성으로 연결). %>
                          <form id="notice-<%= r.naver_category_id %>" method="post"
                                action="<%= BASE %>/notice-assign" class="hidden">
                            <input type="hidden" name="naver_category_id" value="<%= r.naver_category_id %>">
                          </form>
                        <% } %>
                      </td>
                      <td class="py-2">
                        <% if (r.is_active) { %>
                          <span class="text-emerald-700 font-medium">활성</span>
                        <% } else { %>
                          <span class="text-gray-400">비활성</span>
                        <% } %>
                      </td>
                    <% } %>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>

          <!-- 페이징 -->
          <% if (list.totalPages > 1) { %>
            <%
              var cur = list.page;
              var from = Math.max(1, cur - 2);
              var to = Math.min(list.totalPages, from + 4);
              from = Math.max(1, to - 4);
            %>
            <div class="mt-4 flex items-center justify-center gap-1 text-sm">
              <% if (cur > 1) { %>
                <a href="<%= pageUrl(1) %>" class="px-2.5 py-1 rounded border text-gray-600 hover:bg-gray-100">&laquo;</a>
                <a href="<%= pageUrl(cur - 1) %>" class="px-2.5 py-1 rounded border text-gray-600 hover:bg-gray-100">이전</a>
              <% } %>
              <% for (var i = from; i <= to; i++) { %>
                <% if (i === cur) { %>
                  <span class="px-3 py-1 rounded border border-gray-800 bg-gray-800 text-white font-medium"><%= i %></span>
                <% } else { %>
                  <a href="<%= pageUrl(i) %>" class="px-3 py-1 rounded border text-gray-600 hover:bg-gray-100"><%= i %></a>
                <% } %>
              <% } %>
              <% if (cur < list.totalPages) { %>
                <a href="<%= pageUrl(cur + 1) %>" class="px-2.5 py-1 rounded border text-gray-600 hover:bg-gray-100">다음</a>
                <a href="<%= pageUrl(list.totalPages) %>" class="px-2.5 py-1 rounded border text-gray-600 hover:bg-gray-100">&raquo;</a>
              <% } %>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>

    <!-- 최근 수집 로그 -->
    <div class="bg-white shadow-sm rounded-lg p-5">
      <h2 class="text-sm font-semibold text-gray-900 mb-3">최근 수집 로그</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead>
            <tr class="text-left text-xs text-gray-500 border-b">
              <th class="py-2 pr-4">시작</th>
              <th class="py-2 pr-4">종류</th>
              <th class="py-2 pr-4">트리거</th>
              <th class="py-2 pr-4">상태</th>
              <th class="py-2 pr-4">수집</th>
              <th class="py-2 pr-4">비활성</th>
              <th class="py-2">메시지</th>
            </tr>
          </thead>
          <tbody>
            <% if (!status.logs || !status.logs.length) { %>
              <tr><td colspan="7" class="py-4 text-center text-gray-400">수집 이력이 없습니다.</td></tr>
            <% } else { status.logs.forEach(function(l) { %>
              <tr class="border-b last:border-0">
                <td class="py-2 pr-4 whitespace-nowrap text-gray-600"><%= new Date(l.started_at).toLocaleString('ko-KR') %></td>
                <td class="py-2 pr-4"><%= l.resource %></td>
                <td class="py-2 pr-4"><%= l.trigger_by %></td>
                <td class="py-2 pr-4">
                  <% var cls = l.status === 'SUCCESS' ? 'text-emerald-700' : (l.status === 'FAILED' ? 'text-red-600' : 'text-gray-500'); %>
                  <span class="font-medium <%= cls %>"><%= l.status %></span>
                </td>
                <td class="py-2 pr-4 text-gray-600"><%= l.total_count == null ? '-' : l.total_count.toLocaleString() %></td>
                <td class="py-2 pr-4 text-gray-600"><%= l.deactivated_count == null ? '-' : l.deactivated_count %></td>
                <td class="py-2 text-gray-500"><%= l.message || '' %></td>
              </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>
    </div>

  <% } %>
</div>
