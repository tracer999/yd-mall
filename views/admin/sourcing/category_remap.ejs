<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= title %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= subtitle %></p>
  </div>

  <% if (msg) { %>
    <div class="mb-4 rounded-md bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800"><%= msg %></div>
  <% } %>
  <% if (saved) { %>
    <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">저장되었습니다.</div>
  <% } %>
  <% if (error) { %>
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800"><%= error %></div>
  <% } %>

  <% if (!status) { %>
    <div class="bg-white shadow-sm rounded-lg p-10 text-center text-sm text-gray-500">현황을 불러오지 못했습니다.</div>
  <% } else { %>

    <!-- 요약 -->
    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="bg-white shadow-sm rounded-lg p-4">
        <div class="text-xs text-gray-500">FUZZY 자동편입 (검토 대기)</div>
        <div class="mt-1 text-2xl font-bold text-amber-700"><%= Number(status.summary.fuzzy_open || 0).toLocaleString() %></div>
      </div>
      <div class="bg-white shadow-sm rounded-lg p-4">
        <div class="text-xs text-gray-500">되돌림 완료</div>
        <div class="mt-1 text-2xl font-bold text-gray-900"><%= Number(status.summary.fuzzy_reverted || 0).toLocaleString() %></div>
      </div>
      <div class="bg-white shadow-sm rounded-lg p-4">
        <div class="text-xs text-gray-500">수동 지정 대기 (모호·무매칭)</div>
        <div class="mt-1 text-2xl font-bold text-gray-900"><%= Number(status.summary.queue_open || 0).toLocaleString() %></div>
      </div>
    </div>

    <!-- FUZZY 롤백 -->
    <div class="bg-white shadow-sm rounded-lg p-5 mb-6">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-gray-900">FUZZY 자동편입 검토 <span class="text-gray-400 font-normal">(오매칭 가능 — 되돌리면 원 카테고리로 복원)</span></h2>
        <% if ((status.fuzzy || []).length) { %>
          <form method="post" action="/admin/sourcing/category-remap/rollback" onsubmit="return confirm('열린 FUZZY 편입을 모두 되돌립니다. 계속할까요?');">
            <input type="hidden" name="all" value="1">
            <button class="rounded-md bg-gray-800 px-3 py-1.5 text-xs font-medium text-white">전체 되돌리기</button>
          </form>
        <% } %>
      </div>
      <% if (!(status.fuzzy || []).length) { %>
        <p class="text-sm text-gray-500 py-4 text-center">검토 대기 중인 FUZZY 편입이 없습니다.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="text-xs text-gray-500 border-b">
                <th class="text-left py-2 pr-3">원 카테고리</th>
                <th class="text-left py-2 pr-3">→ 네이버 노드</th>
                <th class="text-right py-2 pr-3">score</th>
                <th class="text-right py-2 pr-3">상품</th>
                <th class="text-right py-2">작업</th>
              </tr>
            </thead>
            <tbody>
              <% status.fuzzy.forEach(function(r){ %>
                <tr class="border-b last:border-0">
                  <td class="py-2 pr-3 text-gray-900"><%= r.from_name || ('#'+r.from_category_id) %></td>
                  <td class="py-2 pr-3 text-gray-700"><%= r.to_name || ('#'+r.to_category_id) %></td>
                  <td class="py-2 pr-3 text-right text-gray-500"><%= r.score != null ? Number(r.score).toFixed(2) : '-' %></td>
                  <td class="py-2 pr-3 text-right font-medium"><%= Number(r.product_count || 0).toLocaleString() %></td>
                  <td class="py-2 text-right">
                    <form method="post" action="/admin/sourcing/category-remap/rollback" class="inline">
                      <input type="hidden" name="log_id" value="<%= r.id %>">
                      <button class="rounded-md border border-gray-300 px-3 py-1 text-xs text-gray-700 hover:bg-gray-50">되돌리기</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- 수동 지정 큐 -->
    <div class="bg-white shadow-sm rounded-lg p-5">
      <h2 class="text-sm font-semibold text-gray-900 mb-3">수동 지정 큐 <span class="text-gray-400 font-normal">(모호·무매칭 — 네이버 노드를 골라 상품 이동)</span></h2>
      <% if (!(status.queue || []).length) { %>
        <p class="text-sm text-gray-500 py-4 text-center">수동 지정 대기 항목이 없습니다.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="text-xs text-gray-500 border-b">
                <th class="text-left py-2 pr-3">원 카테고리</th>
                <th class="text-left py-2 pr-3">사유</th>
                <th class="text-right py-2 pr-3">상품</th>
                <th class="text-left py-2">타겟 네이버 노드 지정</th>
              </tr>
            </thead>
            <tbody>
              <% status.queue.forEach(function(r){ %>
                <tr class="border-b last:border-0">
                  <td class="py-2 pr-3 text-gray-900"><%= r.from_name || ('#'+r.from_category_id) %></td>
                  <td class="py-2 pr-3 text-gray-500"><span class="inline-block rounded bg-gray-100 px-1.5 py-0.5 text-xs"><%= r.match_kind %></span> <%= r.note || '' %></td>
                  <td class="py-2 pr-3 text-right font-medium"><%= Number(r.product_count || 0).toLocaleString() %></td>
                  <td class="py-2">
                    <form method="post" action="/admin/sourcing/category-remap/assign" class="flex items-center gap-2 remap-assign">
                      <input type="hidden" name="log_id" value="<%= r.id %>">
                      <input type="hidden" name="target_id" class="target-id">
                      <div class="relative">
                        <input type="text" class="target-search rounded-md border border-gray-300 px-2 py-1 text-xs w-56" placeholder="네이버 카테고리 검색…" autocomplete="off">
                        <div class="target-results absolute z-10 hidden mt-1 w-72 max-h-60 overflow-auto rounded-md border border-gray-200 bg-white shadow-lg text-xs"></div>
                      </div>
                      <button type="submit" class="assign-btn rounded-md bg-emerald-600 px-3 py-1 text-xs font-medium text-white opacity-50" disabled>지정</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  <% } %>
</div>

<script>
// 수동 지정 — 네이버 노드 autocomplete (250ms 디바운스). CSRF 없음, 순수 fetch.
document.querySelectorAll('.remap-assign').forEach(function(form){
  const search = form.querySelector('.target-search');
  const results = form.querySelector('.target-results');
  const hidden = form.querySelector('.target-id');
  const btn = form.querySelector('.assign-btn');
  let timer = null;

  function hide(){ results.classList.add('hidden'); results.innerHTML = ''; }
  function setChosen(id, label){
    hidden.value = id; search.value = label;
    btn.disabled = false; btn.classList.remove('opacity-50');
    hide();
  }
  search.addEventListener('input', function(){
    hidden.value = ''; btn.disabled = true; btn.classList.add('opacity-50');
    const q = search.value.trim();
    clearTimeout(timer);
    if (q.length < 1) return hide();
    timer = setTimeout(function(){
      fetch('/admin/sourcing/category-remap/search?q=' + encodeURIComponent(q), { headers: { 'Accept':'application/json' } })
        .then(function(r){ return r.ok ? r.json() : { success:false }; })
        .then(function(j){
          const rows = (j && j.success) ? j.data : [];
          if (!rows.length) return hide();
          results.innerHTML = rows.map(function(x){
            return '<div class="px-2 py-1.5 hover:bg-emerald-50 cursor-pointer" data-id="'+x.id+'" data-label="'+(x.path||x.name).replace(/"/g,'&quot;')+'">'
              + '<span class="text-gray-900">'+ (x.path || x.name) +'</span></div>';
          }).join('');
          results.classList.remove('hidden');
          results.querySelectorAll('[data-id]').forEach(function(el){
            el.addEventListener('click', function(){ setChosen(el.getAttribute('data-id'), el.getAttribute('data-label')); });
          });
        }).catch(hide);
    }, 250);
  });
  form.addEventListener('submit', function(e){ if (!hidden.value) { e.preventDefault(); alert('타겟 네이버 카테고리를 검색해 선택하세요.'); } });
  document.addEventListener('click', function(e){ if (!form.contains(e.target)) hide(); });
});
</script>
