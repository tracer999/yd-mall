<%
  /* 외부몰 연동 · 공급처/채널 연결 (골격) */
  const chans = channels || {};
  const _creds = creds || [];
  const s = setting || {};
  const _others = otherMalls || [];
  const mask = (v) => { const x = String(v || ''); return x.length <= 6 ? x : x.slice(0, 3) + '***' + x.slice(-2); };
  const STATUS_CLS = {
    ACTIVE: 'bg-green-50 text-green-700',
    INVALID: 'bg-red-50 text-red-700',
    EXPIRED: 'bg-amber-50 text-amber-700',
    DISABLED: 'bg-gray-100 text-gray-500',
  };
%>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="mb-6">
    <div class="mb-3 flex items-center gap-2 rounded-lg border border-indigo-200 bg-indigo-50 px-4 py-3">
      <i class="bi bi-shop text-lg text-indigo-600"></i>
      <span class="text-sm font-medium text-indigo-700">현재 편집 몰</span>
      <span class="text-lg font-bold text-indigo-900"><%= (adminMall && adminMall.name) || ('mall #' + adminMallId) %></span>
    </div>
    <h1 class="text-2xl font-bold text-gray-900"><%= title %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= subtitle %></p>
    <p class="mt-1 text-xs text-gray-400">자격증명·설정은 위 편집 몰 기준으로 저장됩니다.</p>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800">저장되었습니다.</div>
  <% } %>
  <% if (msg) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-blue-50 border border-blue-200 text-sm text-blue-800"><%= msg %></div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800"><%= error %></div>
  <% } %>

  <!-- 사용여부 / 기본 정책 -->
  <div class="bg-white shadow-sm rounded-lg mb-6">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h5 class="text-lg font-bold text-gray-800">연동 사용 설정</h5>
      <span class="text-xs px-2 py-1 rounded <%= sourcingEnabled ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-500' %>">
        <%= sourcingEnabled ? '사용 중' : '미사용' %>
      </span>
    </div>
    <form action="/admin/sourcing/connections/setting" method="POST" class="p-6 space-y-4">
      <div class="flex items-center gap-3">
        <input type="checkbox" id="sourcing_enabled" name="sourcing_enabled" value="1"
               <%= sourcingEnabled ? 'checked' : '' %> <%= isProvider ? '' : 'disabled' %>
               class="h-4 w-4">
        <label for="sourcing_enabled" class="text-sm text-gray-700">
          이 몰에서 외부몰 연동 사용
          <% if (!isProvider) { %>
            <span class="text-xs text-gray-400">(제공자[super_admin]만 변경 가능 — 유료 계약 항목)</span>
          <% } %>
        </label>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl">
        <div>
          <label class="block text-sm text-gray-600 mb-1">
            기본 목표 마진율(%)
            <span class="ml-1 rounded bg-emerald-50 px-1.5 py-0.5 text-xs font-medium text-emerald-700">사용 중</span>
          </label>
          <input type="number" step="0.01" name="default_margin_rate"
                 value="<%= s.default_margin_rate != null ? s.default_margin_rate : '' %>"
                 class="w-full rounded-md border border-gray-300 text-sm px-3 py-2">
          <p class="mt-1 text-xs text-gray-500">
            <b>우리 몰 판매가 계산에 사용됩니다.</b><br>
            판매가 = 공급가 × (1 + 마진율), 10원 단위 반올림.
            상품 등록 시 마진율을 비워두면 이 값이 적용됩니다.
          </p>
        </div>
        <div>
          <label class="block text-sm text-gray-600 mb-1">
            기본 채널 수수료율(%)
            <span class="ml-1 rounded bg-gray-100 px-1.5 py-0.5 text-xs font-medium text-gray-500">아직 미사용</span>
          </label>
          <input type="number" step="0.01" name="default_channel_fee_rate"
                 value="<%= s.default_channel_fee_rate != null ? s.default_channel_fee_rate : '' %>"
                 class="w-full rounded-md border border-gray-300 text-sm px-3 py-2">
          <p class="mt-1 text-xs text-gray-500">
            네이버 스마트스토어 등 <b>외부 판매채널이 떼가는 수수료율</b>입니다.
            스마트스토어 등록 기능에서 쓸 값이라 <b class="text-amber-700">지금은 저장만 되고 어떤 가격에도 반영되지 않습니다</b> —
            우리 몰 판매가는 목표 마진율만으로 계산됩니다.
          </p>
        </div>
      </div>
      <div>
        <button class="inline-flex items-center h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">설정 저장</button>
      </div>
    </form>
  </div>

  <!-- 연결된 계정 목록 -->
  <div class="bg-white shadow-sm rounded-lg mb-6">
    <div class="px-6 py-4 border-b border-gray-200"><h5 class="text-lg font-bold text-gray-800">연결된 계정</h5></div>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50 text-gray-500">
          <tr>
            <th class="text-left px-4 py-2">채널</th>
            <th class="text-left px-4 py-2">계정</th>
            <th class="text-left px-4 py-2">client_id / API Key</th>
            <th class="text-left px-4 py-2">시크릿</th>
            <th class="text-left px-4 py-2">상태</th>
            <th class="text-left px-4 py-2">최근 확인</th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (!_creds.length) { %>
            <tr><td colspan="7" class="px-4 py-6 text-center text-gray-400">연결된 계정이 없습니다. 아래에서 추가하세요.</td></tr>
          <% } %>
          <% _creds.forEach(function (c) { %>
            <tr>
              <td class="px-4 py-2"><%= (chans[c.channel] && chans[c.channel].label) || c.channel %></td>
              <td class="px-4 py-2"><%= c.account_label %></td>
              <td class="px-4 py-2 text-gray-500"><%= c.client_id ? mask(c.client_id) : '-' %></td>
              <td class="px-4 py-2"><%= c.has_secret ? '설정됨' : '-' %></td>
              <td class="px-4 py-2">
                <span class="text-xs px-2 py-0.5 rounded <%= STATUS_CLS[c.status] || 'bg-gray-100 text-gray-500' %>"><%= c.status %></span>
              </td>
              <td class="px-4 py-2 text-gray-400 text-xs">
                <%= c.last_verified_at ? new Date(c.last_verified_at).toLocaleString('ko-KR') : '-' %>
                <% if (c.last_error) { %><div class="text-gray-400"><%= c.last_error %></div><% } %>
              </td>
              <td class="px-4 py-2 text-right whitespace-nowrap">
                <form action="/admin/sourcing/connections/<%= c.id %>/verify" method="POST" class="inline">
                  <button class="text-xs text-indigo-600 hover:underline">검증</button>
                </form>
                <form action="/admin/sourcing/connections/<%= c.id %>/delete" method="POST" class="inline ml-2"
                      onsubmit="return confirm('삭제할까요?')">
                  <button class="text-xs text-red-500 hover:underline">삭제</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- 계정 추가 / 수정 -->
  <div class="bg-white shadow-sm rounded-lg mb-6">
    <div class="px-6 py-4 border-b border-gray-200">
      <h5 class="text-lg font-bold text-gray-800">계정 추가 / 수정</h5>
      <p class="text-xs text-gray-400 mt-1">채널을 고르면 그 채널에 필요한 칸만 나타납니다. 같은 채널+계정이름으로 저장하면 기존 값이 갱신되고, 시크릿을 비우면 기존 시크릿이 유지됩니다.</p>
    </div>
    <form action="/admin/sourcing/connections/save" method="POST" class="p-6 space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm text-gray-600 mb-1">채널</label>
          <select name="channel" id="ch-select" class="w-full rounded-md border border-gray-300 text-sm px-3 py-2">
            <% Object.keys(chans).forEach(function (k) { if (chans[k].hidden) return; %>
              <option value="<%= k %>"><%= chans[k].label %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="block text-sm text-gray-600 mb-1">계정 이름</label>
          <input type="text" name="account_label" value="기본" class="w-full rounded-md border border-gray-300 text-sm px-3 py-2">
        </div>
        <div class="sm:col-span-2">
          <p id="ch-help" class="text-xs text-gray-600 bg-gray-50 border border-gray-200 rounded-md px-3 py-2"></p>
        </div>
        <div id="fld-clientid">
          <label id="lbl-clientid" for="in-clientid" class="block text-sm text-gray-600 mb-1">client_id / API Key</label>
          <input type="text" id="in-clientid" name="client_id" autocomplete="off" class="w-full rounded-md border border-gray-300 text-sm px-3 py-2">
        </div>
        <div id="fld-secret">
          <label id="lbl-secret" for="in-secret" class="block text-sm text-gray-600 mb-1">client_secret / 시크릿</label>
          <input type="password" id="in-secret" name="secret" autocomplete="new-password" placeholder="변경 시에만 입력"
                 class="w-full rounded-md border border-gray-300 text-sm px-3 py-2">
        </div>
        <%#
          부가 설정(JSON) 입력칸은 제거했다.
          - 운영자에게 JSON 을 적게 하지 않는다(CLAUDE.md §33).
          - 게다가 이 값을 읽어 쓰는 코드가 없었다. credential.js 가 저장·복사만 하고
            어떤 어댑터도 참조하지 않는다(저장된 행도 전부 NULL 이었다).
          실제로 필요한 부가값(스토어채널ID 등)이 생기면 **이름 있는 필드 하나**로 추가하고
          서버가 JSON 으로 조립한다 — 네이버 고시 입력(§6.4)과 같은 방식.
        %>
      </div>
      <div>
        <button class="inline-flex items-center h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">계정 저장</button>
      </div>
    </form>
  </div>

  <!-- 다른 몰에서 복사 (서브몰 대비) -->
  <% if (_others.length) { %>
    <div class="bg-white shadow-sm rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200">
        <h5 class="text-lg font-bold text-gray-800">다른 몰의 자격증명 복사</h5>
        <p class="text-xs text-gray-400 mt-1">여러 서브몰이 같은 계정을 쓸 때, 다른 몰의 설정을 이 몰로 복제합니다(값 복사이지 공유가 아닙니다).</p>
      </div>
      <form action="/admin/sourcing/connections/copy" method="POST" class="p-6 flex items-end gap-3"
            onsubmit="return confirm('이 몰의 동일 채널 설정을 덮어씁니다. 진행할까요?')">
        <div>
          <label class="block text-sm text-gray-600 mb-1">원본 몰</label>
          <select name="from_mall_id" class="rounded-md border border-gray-300 text-sm px-3 py-2">
            <% _others.forEach(function (m) { %><option value="<%= m.id %>"><%= m.name %></option><% }); %>
          </select>
        </div>
        <button class="inline-flex items-center h-[38px] px-4 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50">복사</button>
      </form>
    </div>
  <% } %>

</div>

<script type="application/json" id="ch-meta"><%- JSON.stringify(chans).replace(/</g, '\\u003c') %></script>
<script>
  /* 채널마다 필요한 자격증명이 달라서, 고른 채널에 해당하는 칸만 남긴다. */
  (function () {
    var meta = document.getElementById('ch-meta');
    var sel = document.getElementById('ch-select');
    if (!meta || !sel) return;
    var META = JSON.parse(meta.textContent);

    var fields = [
      { box: 'fld-clientid', label: 'lbl-clientid', input: 'in-clientid',
        on: function (m) { return !!m.needsClientId; },
        text: function (m) { return m.clientIdLabel || 'client_id / API Key'; } },
      { box: 'fld-secret', label: 'lbl-secret', input: 'in-secret',
        on: function (m) { return !!m.needsSecret; },
        text: function (m) { return (m.secretLabel || 'client_secret') + ' — 변경 시에만 입력'; } }
    ];

    function apply() {
      var m = META[sel.value] || {};
      document.getElementById('ch-help').textContent = m.help || '';
      fields.forEach(function (f) {
        var on = f.on(m);
        document.getElementById(f.box).style.display = on ? '' : 'none';
        if (on) document.getElementById(f.label).textContent = f.text(m);
        // 숨긴 칸은 값을 비운다 — 채널을 바꿔가며 입력한 값이 딸려 저장되지 않게.
        else document.getElementById(f.input).value = '';
      });
    }

    sel.addEventListener('change', apply);
    apply();
  })();
</script>
