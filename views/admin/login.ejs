<!DOCTYPE html>
<html lang="ko" class="h-full bg-gray-50">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <% if (siteSettings && (siteSettings.favicon_url || siteSettings.logo_url)) { %>
      <link rel="icon" href="<%= siteSettings.favicon_url || siteSettings.logo_url %>" />
      <link rel="apple-touch-icon" href="<%= siteSettings.favicon_url || siteSettings.logo_url %>" />
    <% } %>
    <title>관리자 로그인 - <%= (siteSettings && siteSettings.company_name) ? siteSettings.company_name : '관리자' %></title>
    <!-- Tailwind CSS -->
    <link href="/css/style.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
  </head>
  <body class="h-full flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full">
      <!-- 브랜딩 영역: 로고 또는 회사명, 헤더 슬로건 -->
      <div class="text-center mb-8">
        <% if (siteSettings && siteSettings.logo_url) { %>
          <div class="flex justify-center mb-4">
            <img
              src="<%= siteSettings.logo_url %>"
              alt="<%= (siteSettings && siteSettings.company_name) ? siteSettings.company_name : '' %>"
              class="h-16 sm:h-20 w-auto object-contain"
            />
          </div>
        <% } else { %>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
            <%= (siteSettings && siteSettings.company_name) ? siteSettings.company_name : '관리자' %>
          </h1>
        <% } %>
      </div>

      <!-- 로그인 카드 -->
      <div class="bg-white rounded-xl shadow-md border border-gray-100 p-8">
        <h2 class="text-lg font-semibold text-gray-800 mb-6">
          <%= step === 'code' ? '이중인증' : '관리자 로그인' %>
        </h2>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="mb-4 p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
            <i class="bi bi-exclamation-circle mr-2"></i><%= error %>
          </div>
        <% } %>

        <% if (step === 'code') { %>
          <!-- 2단계: 인증코드 입력 -->
          <div class="mb-4 p-3 rounded-lg bg-blue-50 border border-blue-200 text-blue-800 text-sm">
            <i class="bi bi-envelope-check mr-2"></i>
            <% if (codeSent && typeof maskedEmail !== 'undefined' && maskedEmail) { %>
              <strong><%= maskedEmail %></strong>으로 6자리 인증코드를 발송했습니다.
            <% } else if (codeSent) { %>
              6자리 인증코드를 발송했습니다. 아래에 입력해 주세요.
            <% } else { %>
              이메일로 발송된 6자리 인증코드를 입력해 주세요.
            <% } %>
            <span class="text-blue-600 text-xs mt-1 block">인증코드는 5분 동안 유효합니다.</span>
          </div>

          <form id="formCode" class="space-y-4" action="/admin/login" method="POST">
            <div>
              <label for="verificationCode" class="block text-sm font-medium text-gray-700 mb-1">인증코드</label>
              <input
                id="verificationCode"
                name="verificationCode"
                type="text"
                required
                maxlength="6"
                pattern="[0-9]{6}"
                inputmode="numeric"
                autocomplete="one-time-code"
                placeholder="000000"
                class="block w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-center text-xl tracking-widest font-mono"
              />
            </div>

            <button
              id="btnCode"
              type="submit"
              class="w-full inline-flex justify-center items-center gap-2 h-[50px] px-6 text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors disabled:opacity-70 disabled:cursor-not-allowed"
            >
              <span class="btn-content flex items-center gap-2">
                <i class="bi bi-shield-check"></i>
                인증 후 로그인
              </span>
              <span class="btn-loading hidden items-center gap-2">
                <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                처리 중...
              </span>
            </button>
          </form>

          <p class="mt-4 text-center">
            <a href="/admin/login?reset=1" class="text-sm text-gray-500 hover:text-gray-700">
              <i class="bi bi-arrow-left mr-1"></i>아이디/비밀번호 다시 입력
            </a>
          </p>
        <% } else { %>
          <!-- 1단계: 아이디/비밀번호 -->
          <form id="formCredentials" class="space-y-4" action="/admin/login" method="POST">
            <div>
              <label for="username" class="block text-sm font-medium text-gray-700 mb-1">아이디</label>
              <input
                id="username"
                name="username"
                type="text"
                required
                autocomplete="username"
                class="block w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
                placeholder="Admin ID"
              />
            </div>
            <div>
              <label for="password" class="block text-sm font-medium text-gray-700 mb-1">비밀번호</label>
              <input
                id="password"
                name="password"
                type="password"
                required
                autocomplete="current-password"
                class="block w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
                placeholder="Password"
              />
            </div>

            <button
              id="btnCredentials"
              type="submit"
              class="w-full inline-flex justify-center items-center gap-2 h-[50px] px-6 text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors disabled:opacity-70 disabled:cursor-not-allowed"
            >
              <span class="btn-content flex items-center gap-2">
                <i class="bi bi-box-arrow-in-right"></i>
                로그인
              </span>
              <span class="btn-loading hidden items-center gap-2">
                <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                로그인 중...
              </span>
            </button>
          </form>
        <% } %>

        <% if (siteSettings && siteSettings.header_slogan && siteSettings.header_slogan.trim()) { %>
          <p class="mt-6 text-center text-sm text-gray-500">
            <%= siteSettings.header_slogan %>
          </p>
        <% } %>
        <p class="mt-4 text-center text-sm text-gray-500">
          &copy; <%= new Date().getFullYear() %> <%= (siteSettings && siteSettings.company_name) ? siteSettings.company_name : 'Mall' %>
        </p>
      </div>
    </div>
    <script>
    (function() {
      function setLoading(btn, loading) {
        if (!btn) return;
        var content = btn.querySelector('.btn-content');
        var loadingEl = btn.querySelector('.btn-loading');
        if (loading) {
          btn.disabled = true;
          if (content) content.classList.add('hidden');
          if (loadingEl) {
            loadingEl.classList.remove('hidden');
            loadingEl.classList.add('flex');
          }
        } else {
          btn.disabled = false;
          if (content) content.classList.remove('hidden');
          if (loadingEl) {
            loadingEl.classList.add('hidden');
            loadingEl.classList.remove('flex');
          }
        }
      }
      var formCredentials = document.getElementById('formCredentials');
      var formCode = document.getElementById('formCode');
      if (formCredentials) {
        formCredentials.addEventListener('submit', function() {
          setLoading(document.getElementById('btnCredentials'), true);
        });
      }
      if (formCode) {
        formCode.addEventListener('submit', function() {
          setLoading(document.getElementById('btnCode'), true);
        });
      }
    })();
    </script>
  </body>
</html>
