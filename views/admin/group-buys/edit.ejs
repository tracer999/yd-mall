<%
  /*
   * 공동구매 등록·수정 (§5-2)
   *
   * 폼이 셋으로 갈린다 — 저장 버튼도 셋이다. 하나의 <form> 안에 다른 <form> 을 넣을 수 없다.
   *   1) 기본 정보    → POST /admin/group-buys/:id/edit   (multipart, 이미지 포함)
   *   2) 상품·가격    → POST /admin/group-buys/:id/products
   *   3) 상품 담기    → POST /admin/group-buys/:id/products/add
   *
   * 신규 등록(isNew) 화면에는 아직 id 가 없으므로 상품 영역을 감춘다.
   */
  const g = groupBuy;
  const isNew = !g.id;
  const action = isNew ? '/admin/group-buys/add' : `/admin/group-buys/${g.id}/edit`;
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');
  const fmtDT = (d) => d ? new Date(d).toLocaleString('ko-KR', { dateStyle: 'short', timeStyle: 'short' }) : '-';

  const PHASE_CLASS = {
    ACTIVE: 'bg-blue-100 text-blue-700',
    CLOSING: 'bg-red-100 text-red-700',
    SCHEDULED: 'bg-purple-100 text-purple-700',
    ENDED: 'bg-gray-100 text-gray-500',
  };
%>
<div class="p-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800"><%= title %></h1>
            <% if (subtitle) { %><p class="mt-1 text-sm text-gray-500"><%= subtitle %></p><% } %>
        </div>
        <a href="/admin/group-buys" class="text-sm text-gray-500 hover:text-gray-700">← 목록으로</a>
    </div>

    <% if (saved) { %>
        <div class="mb-4 px-4 py-3 rounded bg-green-50 text-green-700 text-sm">저장되었습니다.</div>
    <% } %>
    <% if (error) { %>
        <div class="mb-4 px-4 py-3 rounded bg-red-50 text-red-600 text-sm"><%= error %></div>
    <% } %>

    <%# ── 1) 기본 정보 ──────────────────────────────────── %>
    <form action="<%= action %>" method="POST" enctype="multipart/form-data">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-xl shadow p-6 space-y-4">
                    <h2 class="font-semibold text-gray-700">기본 정보</h2>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">공동구매명 <span class="text-red-500">*</span></label>
                        <input type="text" name="title" required maxlength="200" value="<%= g.title || '' %>"
                               class="w-full border-gray-300 rounded-md shadow-sm">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">슬러그 (URL)</label>
                        <div class="flex items-center gap-2">
                            <span class="text-sm text-gray-400">/group-buy/</span>
                            <input type="text" name="slug" maxlength="200" value="<%= g.slug || '' %>"
                                   placeholder="비워두면 공동구매명에서 자동 생성"
                                   class="flex-1 border-gray-300 rounded-md shadow-sm">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">한 줄 요약</label>
                        <input type="text" name="summary" maxlength="500" value="<%= g.summary || '' %>"
                               placeholder="목록 카드에 노출됩니다"
                               class="w-full border-gray-300 rounded-md shadow-sm">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">상세 본문</label>
                        <textarea name="description" rows="10"
                                  class="w-full border-gray-300 rounded-md shadow-sm text-sm font-mono"><%= g.description || '' %></textarea>
                        <p class="mt-1 text-xs text-gray-400">HTML 을 쓸 수 있습니다. 저장할 때 위험한 태그는 제거됩니다.</p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">공동구매 유의사항</label>
                        <textarea name="notice" rows="6"
                                  class="w-full border-gray-300 rounded-md shadow-sm text-sm"><%= g.notice || '' %></textarea>
                        <p class="mt-1 text-xs text-gray-400">목표 미달 시 처리, 주문 취소/환불 기준, 배송 예정일 등을 적습니다.</p>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow p-6 space-y-4">
                    <h2 class="font-semibold text-gray-700">이미지</h2>
                    <% [
                        { field: 'gb_list_thumbnail',    column: 'list_thumbnail_url',    label: '목록 카드 썸네일' },
                        { field: 'gb_pc_hero_image',     column: 'pc_hero_image_url',     label: '상세 PC 대표 이미지' },
                        { field: 'gb_mobile_hero_image', column: 'mobile_hero_image_url', label: '상세 모바일 대표 이미지' },
                    ].forEach(function (img) { %>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1"><%= img.label %></label>
                            <% if (g[img.column]) { %>
                                <div class="flex items-center gap-3 mb-2">
                                    <img src="<%= g[img.column] %>" alt="" class="h-16 rounded border border-gray-200">
                                    <label class="flex items-center text-xs text-gray-500">
                                        <input type="checkbox" name="<%= img.field %>_clear" value="1" class="rounded border-gray-300 mr-1">
                                        삭제
                                    </label>
                                </div>
                            <% } %>
                            <input type="file" name="<%= img.field %>" accept="image/*" class="w-full text-sm text-gray-600">
                        </div>
                    <% }); %>
                </div>
            </div>

            <div class="space-y-6">
                <div class="bg-white rounded-xl shadow p-6 space-y-4">
                    <h2 class="font-semibold text-gray-700">발행</h2>

                    <% if (!isNew) { %>
                        <div class="flex items-center gap-2 text-sm">
                            <span class="text-gray-500">현재 노출 상태</span>
                            <span class="px-2 py-0.5 rounded text-xs <%= PHASE_CLASS[phase] %>"><%= phaseLabels[phase] %></span>
                        </div>
                    <% } %>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">운영 상태</label>
                        <select name="status" class="w-full border-gray-300 rounded-md shadow-sm">
                            <% statuses.forEach(function (s) { %>
                                <option value="<%= s.value %>" <%= g.status === s.value ? 'selected' : '' %>><%= s.label %></option>
                            <% }); %>
                        </select>
                        <p class="mt-1 text-xs text-gray-400">예정·진행중·마감임박·종료는 아래 기간에서 자동 계산됩니다.</p>
                    </div>

                    <label class="flex items-center">
                        <input type="checkbox" name="list_visible" value="1" <%= g.list_visible ? 'checked' : '' %> class="rounded border-gray-300">
                        <span class="ml-2 text-sm text-gray-700">공동구매 목록에 노출</span>
                    </label>
                    <label class="flex items-center">
                        <input type="checkbox" name="search_visible" value="1" <%= g.search_visible ? 'checked' : '' %> class="rounded border-gray-300">
                        <span class="ml-2 text-sm text-gray-700">검색엔진 색인 허용</span>
                    </label>
                </div>

                <div class="bg-white rounded-xl shadow p-6 space-y-4">
                    <h2 class="font-semibold text-gray-700">기간</h2>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">시작 일시 <span class="text-red-500">*</span></label>
                        <input type="datetime-local" name="start_at" required value="<%= g.start_at_input %>"
                               class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">종료 일시 <span class="text-red-500">*</span></label>
                        <input type="datetime-local" name="end_at" required value="<%= g.end_at_input %>"
                               class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                        <p class="mt-1 text-xs text-gray-400">공동구매는 기간이 본질이라 종료일시를 비울 수 없습니다.</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">마감임박 기준 (시간)</label>
                        <input type="number" name="closing_hours" min="1" value="<%= g.closing_hours || 24 %>"
                               class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                        <p class="mt-1 text-xs text-gray-400">종료 N시간 전부터 '마감임박' 배지가 붙습니다.</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">종료 후 구매</label>
                        <select name="ended_purchase_policy" class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                            <% endedPurchasePolicies.forEach(function (p) { %>
                                <option value="<%= p.value %>" <%= g.ended_purchase_policy === p.value ? 'selected' : '' %>><%= p.label %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">배송 예정 안내</label>
                        <input type="text" name="delivery_note" maxlength="200" value="<%= g.delivery_note || '' %>"
                               placeholder="예: 마감 후 3영업일 내 순차 발송"
                               class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow p-6 space-y-4">
                    <h2 class="font-semibold text-gray-700">목표 / 참여 표시</h2>

                    <label class="flex items-center">
                        <input type="checkbox" name="target_enabled" value="1" <%= g.target_enabled ? 'checked' : '' %> class="rounded border-gray-300">
                        <span class="ml-2 text-sm text-gray-700">목표 수량 사용</span>
                    </label>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">목표 수량</label>
                        <input type="number" name="target_quantity" min="1" value="<%= g.target_quantity || '' %>"
                               placeholder="예: 100"
                               class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                    </div>

                    <div class="pt-2 border-t border-gray-100 space-y-2">
                        <label class="flex items-center">
                            <input type="checkbox" name="progress_visible" value="1" <%= g.progress_visible ? 'checked' : '' %> class="rounded border-gray-300">
                            <span class="ml-2 text-sm text-gray-700">달성률 막대 표시</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="quantity_count_visible" value="1" <%= g.quantity_count_visible ? 'checked' : '' %> class="rounded border-gray-300">
                            <span class="ml-2 text-sm text-gray-700">참여 수량 표시</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="participant_count_visible" value="1" <%= g.participant_count_visible ? 'checked' : '' %> class="rounded border-gray-300">
                            <span class="ml-2 text-sm text-gray-700">참여자 수 표시</span>
                        </label>
                    </div>

                    <% if (!isNew) { %>
                        <div class="pt-2 border-t border-gray-100 text-sm text-gray-600">
                            현재 참여 <span class="font-semibold text-gray-800"><%= won(g.current_quantity) %></span>개
                            / <span class="font-semibold text-gray-800"><%= won(g.participant_count) %></span>건
                            <p class="mt-1 text-xs text-gray-400">결제 완료 시 자동으로 누적됩니다.</p>
                        </div>
                    <% } %>
                </div>

                <div class="flex gap-2">
                    <a href="/admin/group-buys" class="flex-1 text-center px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300">취소</a>
                    <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">저장</button>
                </div>
            </div>
        </div>
    </form>

    <% if (!isNew) { %>
        <%# ── 2) 상품 · 가격 ────────────────────────────── %>
        <div class="mt-8 bg-white rounded-xl shadow p-6">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <h2 class="font-semibold text-gray-700">공동구매 상품 · 가격</h2>
                    <p class="mt-1 text-xs text-gray-400">
                        결제 금액은 여기 적은 <strong>공동구매가</strong>로 서버가 다시 계산합니다. 할인율은 정상가 대비 자동 계산됩니다.
                        1차는 맨 위 <strong>대표(MAIN)</strong> 상품 하나로 구매합니다.
                    </p>
                </div>
                <button type="button" id="openProductSearch"
                        class="px-4 py-2 bg-gray-700 text-white rounded text-sm hover:bg-gray-800">
                    <i class="bi bi-plus-lg"></i> 상품 담기
                </button>
            </div>

            <% if (!products.length) { %>
                <div class="py-10 text-center text-gray-400 text-sm">
                    담긴 상품이 없습니다. 상품을 담아야 고객 화면에 구매 버튼이 생깁니다.
                </div>
            <% } else { %>
                <form action="/admin/group-buys/<%= g.id %>/products" method="POST">
                    <div class="overflow-x-auto">
                        <table class="min-w-full text-sm">
                            <thead class="bg-gray-50 text-gray-600">
                                <tr>
                                    <th class="px-3 py-2 text-left">상품</th>
                                    <th class="px-3 py-2 text-left">역할</th>
                                    <th class="px-3 py-2 text-right">정상가</th>
                                    <th class="px-3 py-2 text-right">공동구매가 <span class="text-red-500">*</span></th>
                                    <th class="px-3 py-2 text-right">할인율</th>
                                    <th class="px-3 py-2 text-right">최소</th>
                                    <th class="px-3 py-2 text-right">최대</th>
                                    <th class="px-3 py-2 text-right">1인제한</th>
                                    <th class="px-3 py-2 text-center">구매</th>
                                    <th class="px-3 py-2 text-center">노출</th>
                                    <th class="px-3 py-2 text-center">삭제</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                <% products.forEach(function (p, i) { %>
                                    <tr>
                                        <td class="px-3 py-2">
                                            <input type="hidden" name="products[<%= i %>][mapping_id]" value="<%= p.id %>">
                                            <input type="hidden" name="products[<%= i %>][sort_order]" value="<%= i + 1 %>">
                                            <div class="flex items-center gap-2">
                                                <% if (p.main_image) { %>
                                                    <img src="<%= p.main_image %>" alt="" class="w-10 h-10 object-cover rounded">
                                                <% } else { %>
                                                    <div class="w-10 h-10 bg-gray-100 rounded"></div>
                                                <% } %>
                                                <div>
                                                    <div class="text-gray-800"><%= p.name %></div>
                                                    <div class="text-xs text-gray-400">
                                                        #<%= p.product_id %> · 재고 <%= won(p.stock) %>
                                                        <% if (p.product_status !== 'ON') { %>
                                                            <span class="text-red-500">· <%= p.product_status %> (고객 화면에서 구매 불가)</span>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-3 py-2">
                                            <select name="products[<%= i %>][role]" class="border-gray-300 rounded text-xs w-20">
                                                <option value="MAIN" <%= p.role === 'MAIN' ? 'selected' : '' %>>대표</option>
                                                <option value="SUB" <%= p.role !== 'MAIN' ? 'selected' : '' %>>추가</option>
                                            </select>
                                        </td>
                                        <td class="px-3 py-2 text-right">
                                            <input type="number" name="products[<%= i %>][normal_price]" min="0" value="<%= p.normal_price || '' %>"
                                                   placeholder="<%= won(p.product_price) %>"
                                                   class="w-28 border-gray-300 rounded text-sm text-right">
                                        </td>
                                        <td class="px-3 py-2 text-right">
                                            <input type="number" name="products[<%= i %>][group_buy_price]" min="1" required value="<%= p.group_buy_price %>"
                                                   class="w-28 border-gray-300 rounded text-sm text-right font-semibold">
                                        </td>
                                        <td class="px-3 py-2 text-right text-gray-600"><%= p.discount_rate || 0 %>%</td>
                                        <td class="px-3 py-2 text-right">
                                            <input type="number" name="products[<%= i %>][min_order_quantity]" min="1" value="<%= p.min_order_quantity %>"
                                                   class="w-16 border-gray-300 rounded text-sm text-right">
                                        </td>
                                        <td class="px-3 py-2 text-right">
                                            <input type="number" name="products[<%= i %>][max_order_quantity]" min="1" value="<%= p.max_order_quantity || '' %>"
                                                   placeholder="재고까지" class="w-20 border-gray-300 rounded text-sm text-right">
                                        </td>
                                        <td class="px-3 py-2 text-right">
                                            <input type="number" name="products[<%= i %>][per_user_limit_quantity]" min="1" value="<%= p.per_user_limit_quantity || '' %>"
                                                   placeholder="무제한" class="w-20 border-gray-300 rounded text-sm text-right">
                                        </td>
                                        <td class="px-3 py-2 text-center">
                                            <input type="checkbox" name="products[<%= i %>][purchase_enabled]" value="1" <%= p.purchase_enabled ? 'checked' : '' %> class="rounded border-gray-300">
                                        </td>
                                        <td class="px-3 py-2 text-center">
                                            <input type="checkbox" name="products[<%= i %>][visible]" value="1" <%= p.visible ? 'checked' : '' %> class="rounded border-gray-300">
                                        </td>
                                        <td class="px-3 py-2 text-center">
                                            <button type="button" class="text-red-500 hover:text-red-700 text-xs remove-product"
                                                    data-mapping-id="<%= p.id %>">삭제</button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <div class="mt-4 flex justify-end">
                        <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded text-sm hover:bg-blue-700">상품 설정 저장</button>
                    </div>
                </form>

                <p class="mt-2 text-xs text-gray-400">
                    '1인제한' 은 화면에만 저장되고 아직 주문에서 적용되지 않습니다(2차).
                </p>
            <% } %>
        </div>

        <%# 상품 삭제 — 표 안의 <form> 중첩을 피해 밖에 둔다 %>
        <form id="removeProductForm" method="POST" class="hidden"></form>

        <%# ── 3) 참여자 ──────────────────────────────────── %>
        <div class="mt-8 bg-white rounded-xl shadow p-6">
            <h2 class="font-semibold text-gray-700 mb-4">참여자 / 주문 <span class="text-sm font-normal text-gray-400">(최근 100건)</span></h2>
            <% if (!participants.length) { %>
                <div class="py-10 text-center text-gray-400 text-sm">아직 참여(결제 완료)한 주문이 없습니다.</div>
            <% } else { %>
                <div class="overflow-x-auto">
                    <table class="min-w-full text-sm whitespace-nowrap">
                        <thead class="bg-gray-50 text-gray-600">
                            <tr>
                                <th class="px-3 py-2 text-left">참여일시</th>
                                <th class="px-3 py-2 text-left">주문번호</th>
                                <th class="px-3 py-2 text-left">구매자</th>
                                <th class="px-3 py-2 text-right">수량</th>
                                <th class="px-3 py-2 text-right">단가</th>
                                <th class="px-3 py-2 text-right">금액</th>
                                <th class="px-3 py-2 text-left">주문상태</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% participants.forEach(function (p) { %>
                                <tr class="hover:bg-gray-50">
                                    <td class="px-3 py-2 text-gray-500 text-xs"><%= fmtDT(p.created_at) %></td>
                                    <td class="px-3 py-2 text-gray-700"><%= p.order_number || '-' %></td>
                                    <td class="px-3 py-2 text-gray-700">
                                        <%= p.user_name || '비회원' %>
                                        <% if (p.user_email) { %><span class="text-xs text-gray-400">(<%= p.user_email %>)</span><% } %>
                                    </td>
                                    <td class="px-3 py-2 text-right"><%= won(p.quantity) %></td>
                                    <td class="px-3 py-2 text-right"><%= won(p.unit_price) %>원</td>
                                    <td class="px-3 py-2 text-right font-medium"><%= won(p.quantity * p.unit_price) %>원</td>
                                    <td class="px-3 py-2 text-gray-600"><%= p.order_status || p.status %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>

        <%# ── 상품 검색 모달 ─────────────────────────────── %>
        <div id="productSearchModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
            <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl max-h-[80vh] flex flex-col">
                <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
                    <h3 class="font-semibold text-gray-800">상품 담기</h3>
                    <button type="button" id="closeProductSearch" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
                </div>
                <div class="px-6 py-4 border-b border-gray-100">
                    <input type="text" id="productSearchInput" placeholder="상품명으로 검색"
                           class="w-full border-gray-300 rounded-md shadow-sm text-sm">
                </div>
                <div id="productSearchResults" class="flex-1 overflow-y-auto px-6 py-2">
                    <p class="py-10 text-center text-gray-400 text-sm">상품명을 입력하세요.</p>
                </div>
            </div>
        </div>

        <form id="addProductForm" action="/admin/group-buys/<%= g.id %>/products/add" method="POST" class="hidden">
            <input type="hidden" name="product_id" id="addProductId">
        </form>

        <script>
        (function () {
            const GROUP_BUY_ID = <%= g.id %>;

            // ── 상품 삭제 (표 안에 <form> 을 중첩할 수 없어 action 을 갈아끼운다)
            const removeForm = document.getElementById('removeProductForm');
            document.querySelectorAll('.remove-product').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (!confirm('이 상품을 공동구매에서 제외할까요?')) return;
                    removeForm.action = '/admin/group-buys/' + GROUP_BUY_ID + '/products/' + btn.dataset.mappingId + '/delete';
                    removeForm.submit();
                });
            });

            // ── 상품 검색 모달
            const modal = document.getElementById('productSearchModal');
            const input = document.getElementById('productSearchInput');
            const results = document.getElementById('productSearchResults');
            const addForm = document.getElementById('addProductForm');
            const addProductId = document.getElementById('addProductId');

            const openModal = function () {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                input.focus();
            };
            const closeModal = function () {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            };

            document.getElementById('openProductSearch').addEventListener('click', openModal);
            document.getElementById('closeProductSearch').addEventListener('click', closeModal);
            modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });

            const escapeHtml = function (s) {
                const div = document.createElement('div');
                div.textContent = s == null ? '' : String(s);
                return div.innerHTML;
            };

            let timer = null;
            input.addEventListener('input', function () {
                clearTimeout(timer);
                const q = input.value.trim();
                if (!q) {
                    results.innerHTML = '<p class="py-10 text-center text-gray-400 text-sm">상품명을 입력하세요.</p>';
                    return;
                }
                timer = setTimeout(function () {
                    fetch('/admin/group-buys/product-search?q=' + encodeURIComponent(q))
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            const list = data.products || [];
                            if (!list.length) {
                                results.innerHTML = '<p class="py-10 text-center text-gray-400 text-sm">검색 결과가 없습니다.</p>';
                                return;
                            }
                            results.innerHTML = list.map(function (p) {
                                const img = p.main_image
                                    ? '<img src="' + escapeHtml(p.main_image) + '" class="w-12 h-12 object-cover rounded">'
                                    : '<div class="w-12 h-12 bg-gray-100 rounded"></div>';
                                return '<button type="button" data-id="' + p.id + '" ' +
                                    'class="pick w-full flex items-center gap-3 px-2 py-2 hover:bg-gray-50 rounded text-left">' +
                                    img +
                                    '<div class="flex-1"><div class="text-sm text-gray-800">' + escapeHtml(p.name) + '</div>' +
                                    '<div class="text-xs text-gray-400">#' + p.id + ' · ' + Number(p.price || 0).toLocaleString() + '원 · ' + escapeHtml(p.status) + '</div></div>' +
                                    '</button>';
                            }).join('');

                            results.querySelectorAll('.pick').forEach(function (btn) {
                                btn.addEventListener('click', function () {
                                    addProductId.value = btn.dataset.id;
                                    addForm.submit();
                                });
                            });
                        })
                        .catch(function () {
                            results.innerHTML = '<p class="py-10 text-center text-red-400 text-sm">검색 중 오류가 발생했습니다.</p>';
                        });
                }, 250);
            });
        })();
        </script>
    <% } %>
</div>
