<%
  /*
   * 공동구매 목록 (§5-1)
   *
   * 운영상태(status)와 노출상태(phase)를 나란히 보여준다.
   * phase 는 컬럼이 아니라 start_at·end_at 에서 파생된 값이다.
   */
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');
  const fmtD = (d) => d ? new Date(d).toLocaleDateString('ko-KR', { year: '2-digit', month: '2-digit', day: '2-digit' }) : '-';

  const STATUS_CLASS = {
    PUBLISHED: 'bg-green-100 text-green-700',
    HIDDEN: 'bg-gray-200 text-gray-600',
    DRAFT: 'bg-yellow-100 text-yellow-700',
  };
  const PHASE_CLASS = {
    ACTIVE: 'bg-blue-100 text-blue-700',
    CLOSING: 'bg-red-100 text-red-700',
    SCHEDULED: 'bg-purple-100 text-purple-700',
    ENDED: 'bg-gray-100 text-gray-500',
  };
%>
<div class="p-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800"><%= title %></h1>
            <% if (subtitle) { %><p class="mt-1 text-sm text-gray-500"><%= subtitle %></p><% } %>
        </div>
        <a href="/admin/group-buys/add" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
            <i class="bi bi-plus-lg"></i> 공동구매 등록
        </a>
    </div>

    <% if (saved) { %>
        <div class="mb-4 px-4 py-3 rounded bg-green-50 text-green-700 text-sm">저장되었습니다.</div>
    <% } %>
    <% if (error) { %>
        <div class="mb-4 px-4 py-3 rounded bg-red-50 text-red-600 text-sm"><%= error %></div>
    <% } %>

    <form method="GET" action="/admin/group-buys" class="bg-white rounded-xl shadow p-4 mb-4 flex flex-wrap gap-3 items-end">
        <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">운영 상태</label>
            <select name="status" class="border-gray-300 rounded-md text-sm">
                <option value="">전체</option>
                <% statuses.forEach(function (s) { %>
                    <option value="<%= s.value %>" <%= status === s.value ? 'selected' : '' %>><%= s.label %></option>
                <% }); %>
            </select>
        </div>
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-medium text-gray-600 mb-1">검색 (공동구매명/슬러그)</label>
            <input type="text" name="q" value="<%= q %>" class="w-full border-gray-300 rounded-md text-sm">
        </div>
        <button type="submit" class="px-4 py-2 bg-gray-700 text-white rounded text-sm hover:bg-gray-800">검색</button>
    </form>

    <div class="bg-white rounded-xl shadow overflow-x-auto">
        <table class="min-w-full text-sm whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-600">
                <tr>
                    <th class="px-4 py-3 text-left">ID</th>
                    <th class="px-4 py-3 text-left">썸네일</th>
                    <th class="px-4 py-3 text-left">공동구매명 / 상품</th>
                    <th class="px-4 py-3 text-left">운영상태</th>
                    <th class="px-4 py-3 text-left">노출상태</th>
                    <th class="px-4 py-3 text-left">기간</th>
                    <th class="px-4 py-3 text-right">공동구매가</th>
                    <th class="px-4 py-3 text-right">참여/목표</th>
                    <th class="px-4 py-3 text-right">달성률</th>
                    <th class="px-4 py-3 text-right">주문</th>
                    <th class="px-4 py-3 text-right">매출</th>
                    <th class="px-4 py-3 text-center">관리</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% if (!groupBuys.length) { %>
                    <tr><td colspan="12" class="px-4 py-10 text-center text-gray-400">등록된 공동구매가 없습니다.</td></tr>
                <% } %>
                <% groupBuys.forEach(function (g) { %>
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 text-gray-500"><%= g.id %></td>
                        <td class="px-4 py-3">
                            <% if (g.list_thumbnail_url) { %>
                                <img src="<%= g.list_thumbnail_url %>" alt="" class="w-16 h-10 object-cover rounded">
                            <% } else { %>
                                <div class="w-16 h-10 bg-gray-100 rounded"></div>
                            <% } %>
                        </td>
                        <td class="px-4 py-3">
                            <div class="font-medium text-gray-800"><%= g.title %></div>
                            <div class="text-xs text-gray-400">/group-buy/<%= g.slug %></div>
                            <% if (g.main_product_name) { %>
                                <div class="text-xs text-gray-500 mt-0.5"><i class="bi bi-box-seam"></i> <%= g.main_product_name %><% if (g.product_count > 1) { %> 외 <%= g.product_count - 1 %>건<% } %></div>
                            <% } else { %>
                                <div class="text-xs text-red-500 mt-0.5">상품 미연결 — 고객 화면에 구매 버튼이 없습니다</div>
                            <% } %>
                        </td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-0.5 rounded text-xs <%= STATUS_CLASS[g.status] || 'bg-gray-100 text-gray-600' %>"><%= g.status %></span>
                        </td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-0.5 rounded text-xs <%= PHASE_CLASS[g.phase] %>"><%= g.phaseLabel %></span>
                        </td>
                        <td class="px-4 py-3 text-xs text-gray-500"><%= fmtD(g.start_at) %> ~ <%= fmtD(g.end_at) %></td>
                        <td class="px-4 py-3 text-right text-gray-700">
                            <%= g.main_price ? won(g.main_price) + '원' : '-' %>
                        </td>
                        <td class="px-4 py-3 text-right text-gray-600">
                            <%= won(g.current_quantity) %><% if (g.target_enabled && g.target_quantity) { %> / <%= won(g.target_quantity) %><% } %>
                        </td>
                        <td class="px-4 py-3 text-right">
                            <% if (g.progressRate !== null) { %>
                                <span class="<%= g.targetReached ? 'text-green-600 font-semibold' : 'text-gray-600' %>"><%= g.progressRate %>%</span>
                            <% } else { %>
                                <span class="text-gray-300">-</span>
                            <% } %>
                        </td>
                        <td class="px-4 py-3 text-right text-gray-600"><%= won(g.order_count) %></td>
                        <td class="px-4 py-3 text-right text-gray-800 font-medium"><%= won(g.revenue) %>원</td>
                        <td class="px-4 py-3 text-center">
                            <a href="/admin/group-buys/<%= g.id %>/edit" class="px-3 py-1 bg-gray-100 rounded hover:bg-gray-200 text-xs">수정</a>
                            <form action="/admin/group-buys/<%= g.id %>/delete" method="POST" class="inline"
                                  onsubmit="return confirm('삭제하면 연결된 상품 설정도 함께 지워집니다. 계속할까요?');">
                                <button type="submit" class="px-3 py-1 bg-red-50 text-red-600 rounded hover:bg-red-100 text-xs">삭제</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <p class="mt-4 text-xs text-gray-400">
        운영상태(임시저장/발행/숨김)만 저장합니다. 예정·진행중·마감임박·종료는 시작·종료일시에서 자동으로 계산됩니다.
        참여 수량과 매출은 <strong>결제가 완료된 주문</strong>만 집계합니다.
    </p>
</div>
