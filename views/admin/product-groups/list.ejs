<%
  /*
   * 상품 그룹 관리 (B6) — 목록
   *
   * `page_section.data_source_id` 에 FK 가 없으므로 참조 중인 섹션을 함께 보여준다.
   * 참조가 있으면 삭제·비활성화가 막힌다(섹션이 조용히 비는 것을 방지).
   */
  const _groups = groups || [];
  // 메뉴 쇼케이스 그룹은 '담긴 상품 우선 → 조건 폴백'이라 수동/조건 어느 쪽으로도 못 적는다.
  const isMenu = (g) => !!g.menu_code;
  const condText = (g) => {
    const c = g.cond || {};
    const parts = [];
    if (c.badge) parts.push(`배지=${c.badge}`);
    if (c.category_id) parts.push(`카테고리#${c.category_id}`);
    if (c.min_discount) parts.push(`할인≥${c.min_discount}%`);
    if (c.in_stock) parts.push('재고있음');
    return parts.length ? parts.join(' · ') : null;
  };
  const condSummary = (g) => {
    if (isMenu(g)) {
      const cond = condText(g);
      return g.item_count > 0
        ? `담긴 ${g.item_count}개 우선` + (cond ? ` (폴백: ${cond})` : '')
        : (cond ? `폴백 조건: ${cond}` : '담긴 상품·조건 모두 없음');
    }
    if (g.group_type === 'manual') return `수동 ${g.item_count}개`;
    return condText(g) || '조건 없음 (전체)';
  };
%>

<div class="w-full">

  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">상품 그룹 관리</h1>
      <p class="mt-1 text-sm text-gray-500">여기서 만든 그룹을 페이지 빌더 섹션에 연결해 화면에 노출합니다.</p>
    </div>
    <a href="/admin/product-groups/new"
       class="inline-flex items-center h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 no-underline">
      <i class="bi bi-plus-lg mr-1.5"></i> 그룹 등록
    </a>
  </div>

  <%- include('../../partials/admin/usage_notice', {
        heading: '이 그룹은 페이지 빌더 섹션의 데이터 소스입니다.',
        chips: ['상품 그리드', '상품 캐러셀', '혜택 벤토'],
        chipsLabel: '이 섹션들이 씁니다',
        note: '그룹만 만들면 화면은 그대로입니다. 페이지 빌더에서 위 섹션을 놓고 이 그룹을 연결해야 노출됩니다. '
            + '메뉴 상단 노출(쇼케이스)을 지정한 그룹은 해당 GNB 메뉴 페이지 맨 위 캐러셀로도 나갑니다.',
        link: { href: '/admin/page-builder', label: '페이지 빌더에서 섹션 배치하기' },
      }) %>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
            <th class="px-4 py-2.5 w-14">ID</th>
            <th class="px-4 py-2.5">그룹명</th>
            <th class="px-4 py-2.5 w-44">종류 / 노출 위치</th>
            <th class="px-4 py-2.5">구성 / 조건</th>
            <th class="px-4 py-2.5 w-24">정렬</th>
            <th class="px-4 py-2.5 w-20 text-center">사용</th>
            <th class="px-4 py-2.5 w-44">사용 중인 섹션</th>
            <th class="px-4 py-2.5 w-28 text-center">관리</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (_groups.length === 0) { %>
            <tr><td colspan="8" class="px-6 py-16 text-center text-gray-500">등록된 상품 그룹이 없습니다.</td></tr>
          <% } %>
          <% _groups.forEach(function (g) { %>
            <tr class="<%= g.is_active ? '' : 'bg-gray-50/60' %>">
              <td class="px-4 py-3 text-gray-400"><%= g.id %></td>
              <td class="px-4 py-3">
                <a href="/admin/product-groups/<%= g.id %>" class="font-medium text-gray-900 hover:text-indigo-600"><%= g.name %></a>
                <% if (isMenu(g) && g.showcase_title) { %>
                  <div class="mt-0.5 text-xs text-gray-500">고객 화면 제목 · <%= g.showcase_title %></div>
                <% } %>
              </td>
              <%#
                일반 그룹은 페이지 빌더 섹션에 연결해야만 보이고, 메뉴 그룹은 연결 없이도
                해당 GNB 메뉴 상단에 바로 뜬다. 목록에서 이 둘을 못 가리면 '어디에도 안 걸었는데
                화면에 나오는 그룹'의 정체를 알 수 없다.
              %>
              <td class="px-4 py-3">
                <% if (isMenu(g)) { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-amber-100 text-amber-800"
                        title="담긴 상품 우선, 없으면 조건으로 자동 수집">메뉴 상단</span>
                  <div class="mt-1 text-xs text-amber-700">
                    <i class="bi bi-box-arrow-in-up"></i> <%= g.menu_name %><% if (g.menu_path) { %>
                    <span class="text-gray-400"><%= g.menu_path %></span><% } %>
                  </div>
                <% } else { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-slate-100 text-slate-700">일반</span>
                  <div class="mt-1 text-xs text-gray-500">
                    <%= g.group_type === 'manual' ? '수동 선택' : '조건 수집' %> · 섹션 연결 필요
                  </div>
                <% } %>
              </td>
              <td class="px-4 py-3 text-gray-600"><%= condSummary(g) %></td>
              <td class="px-4 py-3 text-gray-500 text-xs"><%= (!isMenu(g) && g.group_type === 'manual') ? '등록순' : g.sort_type %></td>
              <td class="px-4 py-3 text-center">
                <% if (g.is_active) { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-green-50 text-green-700">ON</span>
                <% } else { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-gray-200 text-gray-600">OFF</span>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <% if (g.refs.length === 0) { %>
                  <span class="text-xs text-gray-400">없음</span>
                <% } else { %>
                  <div class="flex flex-wrap gap-1">
                    <% g.refs.forEach(function (r) { %>
                      <span class="text-[10px] px-1.5 py-0.5 rounded <%= r.is_active ? 'bg-amber-50 text-amber-800' : 'bg-gray-100 text-gray-500' %>"
                            title="섹션 #<%= r.id %><%= r.is_active ? '' : ' (비활성)' %>"><%= r.label %></span>
                    <% }); %>
                  </div>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1.5">
                  <a href="/admin/product-groups/<%= g.id %>"
                     class="text-xs px-2 py-1 rounded border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">수정</a>
                  <% if (g.refs.length === 0) { %>
                    <form method="POST" action="/admin/product-groups/<%= g.id %>/delete"
                          onsubmit="return confirm('그룹 &quot;<%= g.name %>&quot; 을(를) 삭제합니다. 담긴 상품 목록도 함께 지워집니다.');">
                      <button type="submit" class="text-xs px-2 py-1 rounded border border-red-200 text-red-600 hover:bg-red-50">삭제</button>
                    </form>
                  <% } else { %>
                    <span class="text-xs px-2 py-1 rounded border border-gray-100 text-gray-300 cursor-not-allowed"
                          title="섹션이 사용 중이라 삭제할 수 없습니다">삭제</span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <p class="mt-4 text-xs text-gray-400">
    섹션이 사용 중인 그룹은 삭제·비활성화할 수 없습니다. <code>page_section.data_source_id</code> 에 외래키가 없어
    DB 가 막아주지 않으므로, 지우거나 끄면 해당 섹션이 <strong>빈 상태로 노출</strong>됩니다.
  </p>
</div>
