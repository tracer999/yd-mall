<%
  /*
   * 상품 그룹 등록/수정 (B6)
   *
   * group_type 으로 폼이 완전히 갈린다. resolve() 가 읽지 않는 필드는 보여주지 않는다.
   *   manual    → 상품 피커만 (sort_type / 필터는 무시됨)
   *   condition → 필터 + 정렬만 (담긴 상품은 무시됨)
   */
  const isNew = !group.id;
  const action = isNew ? '/admin/product-groups' : `/admin/product-groups/${group.id}`;
  const _cond = cond || {};
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');
%>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="mb-6">
    <a href="/admin/product-groups" class="text-sm text-gray-500 hover:text-gray-700 no-underline">
      <i class="bi bi-chevron-left"></i> 상품 그룹 목록
    </a>
    <h1 class="mt-2 text-2xl font-bold text-gray-900"><%= title %></h1>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <% if (refs && refs.length) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-amber-50 border border-amber-200 text-sm text-amber-800">
      <div class="flex items-start gap-2">
        <i class="bi bi-info-circle-fill mt-0.5"></i>
        <div>
          <p><strong>섹션 <%= refs.length %>개가 이 그룹을 사용 중</strong>입니다.
             비활성화하거나 삭제하면 해당 섹션이 빈 상태로 노출되므로 막혀 있습니다.</p>
          <p class="mt-1 text-xs">
            <% refs.forEach(function (r) { %>
              <span class="inline-block mr-2">· <%= r.label %> (섹션 #<%= r.id %><%= r.is_active ? '' : ', 비활성' %>)</span>
            <% }); %>
          </p>
        </div>
      </div>
    </div>
  <% } %>

  <form method="POST" action="<%= action %>" class="space-y-6">

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">기본 정보</h2>
      </div>
      <div class="p-5 space-y-5">

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">그룹명</label>
          <input type="text" name="name" value="<%= group.name %>" maxlength="200" required
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
        </div>

        <%
          /*
           * 메뉴 쇼케이스 — 이 그룹을 GNB 메뉴 페이지 상단 캐러셀로 띄운다.
           * 지정하면 그 메뉴의 이미지 배너 대신 이 상품 캐러셀이 노출된다(상품그룹이 우선).
           * 상품 풀이 있는 메뉴(특가·베스트·신상품)는 상품 선택 팝업의 후보가 그 풀로 좁혀진다.
           */
          const _menuTargets = menuTargets || [];
          const _curMenu = group.menu_code || '';
        %>
        <div class="rounded-md border border-indigo-100 bg-indigo-50/50 p-4 space-y-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              메뉴 상단 노출
              <span class="text-xs font-normal text-gray-500">— 지정한 메뉴 페이지 맨 위에 이 그룹이 캐러셀로 뜹니다</span>
            </label>
            <select name="menu_code" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm bg-white">
              <option value="">사용 안 함 (일반 상품 그룹)</option>
              <% _menuTargets.forEach(function (t) { %>
                <option value="<%= t.key %>" <%= _curMenu === t.key ? 'selected' : '' %>>
                  <%= t.label %><%= t.pool ? ' — 상품 선택 시 해당 메뉴 상품만 후보' : ' — 이 메뉴의 이미지 배너를 대체합니다' %>
                </option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">섹션 제목</label>
            <input type="text" name="showcase_title" value="<%= group.showcase_title || '' %>" maxlength="100"
                   placeholder="예: 추천 특가 · 추천 베스트 · 주목할 신상품"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
            <p class="mt-1 text-xs text-gray-500">비우면 그룹명이 제목으로 쓰입니다.</p>
          </div>
          <% if (typeof poolLabel !== 'undefined' && poolLabel) { %>
            <p class="text-xs text-indigo-700">
              <i class="bi bi-funnel"></i> 상품 선택 팝업에서 <strong><%= poolLabel %></strong>만 후보로 나옵니다.
            </p>
          <% } %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">구성 방식</label>
          <div class="flex gap-4">
            <label class="inline-flex items-center gap-2 text-sm text-gray-700">
              <input type="radio" name="group_type" value="manual" data-group-type
                     <%= group.group_type === 'manual' ? 'checked' : '' %> class="w-4 h-4">
              수동 선택 <span class="text-xs text-gray-400">(상품을 직접 담고 순서 지정)</span>
            </label>
            <label class="inline-flex items-center gap-2 text-sm text-gray-700">
              <input type="radio" name="group_type" value="condition" data-group-type
                     <%= group.group_type === 'condition' ? 'checked' : '' %> class="w-4 h-4">
              조건 검색 <span class="text-xs text-gray-400">(배지·카테고리 등으로 자동 수집)</span>
            </label>
          </div>
        </div>

        <div>
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="is_active" value="1" <%= group.is_active ? 'checked' : '' %>
                   class="w-4 h-4 rounded border-gray-300">
            사용 (끄면 이 그룹을 쓰는 섹션이 빈 상태가 됩니다)
          </label>
        </div>

      </div>
    </div>

    <%# ── 조건 검색 전용 ─────────────────────────────── %>
    <div data-panel="condition" class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">수집 조건</h2>
        <p class="mt-0.5 text-xs text-gray-500">모든 조건은 AND 로 결합됩니다. 판매중·노출중 상품만 대상입니다.</p>
      </div>
      <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-5">

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">배지</label>
          <select name="badge" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
            <option value="">전체</option>
            <% badges.forEach(function (b) { %>
              <option value="<%= b %>" <%= _cond.badge === b ? 'selected' : '' %>><%= b %></option>
            <% }); %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">카테고리</label>
          <select name="category_id" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
            <option value="">전체</option>
            <% categories.forEach(function (c) { %>
              <option value="<%= c.id %>" <%= Number(_cond.category_id) === c.id ? 'selected' : '' %>><%= c.name %></option>
            <% }); %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">최소 할인율 (%)</label>
          <input type="number" name="min_discount" value="<%= _cond.min_discount || '' %>" min="0" max="100" placeholder="제한 없음"
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">정렬</label>
          <select name="sort_type" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
            <% sortTypes.forEach(function (s) { %>
              <option value="<%= s.value %>" <%= group.sort_type === s.value ? 'selected' : '' %>><%= s.label %></option>
            <% }); %>
          </select>
        </div>

        <div class="sm:col-span-2">
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="in_stock" value="1" <%= _cond.in_stock ? 'checked' : '' %>
                   class="w-4 h-4 rounded border-gray-300">
            재고가 있는 상품만
          </label>
        </div>

      </div>
    </div>

    <div class="flex justify-end gap-2">
      <a href="/admin/product-groups" class="inline-flex items-center h-[38px] px-4 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">취소</a>
      <button type="submit" class="inline-flex items-center h-[38px] px-5 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
        <i class="bi bi-save mr-1.5"></i> 저장
      </button>
    </div>
  </form>

  <%# ── 수동 선택 전용: 상품 피커 (그룹 생성 후에만) ───────── %>
  <% if (!isNew) { %>
    <div data-panel="manual" class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">담긴 상품 <span class="text-gray-400 font-normal">(<%= items.length %>개)</span></h2>
        <p class="mt-0.5 text-xs text-gray-500">위에서 아래 순서로 노출됩니다. 추가·삭제·순서 변경은 즉시 저장됩니다.</p>
      </div>

      <div class="p-5 border-b border-gray-100">
        <button type="button" id="pgOpenPicker"
                class="inline-flex items-center gap-1.5 h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
          <i class="bi bi-plus-lg"></i> 상품 추가
        </button>
        <span class="ml-2 text-xs text-gray-400">조회 팝업에서 카테고리·브랜드·재고·노출 필터로 찾아 여러 개를 한 번에 담을 수 있습니다.</span>
      </div>

      <ul id="pgItems" class="divide-y divide-gray-100">
        <% if (items.length === 0) { %>
          <li class="px-5 py-10 text-center text-sm text-gray-500">담긴 상품이 없습니다.</li>
        <% } %>
        <% items.forEach(function (it) { %>
          <li class="px-5 py-3 flex items-center gap-3" data-item-id="<%= it.item_id %>">
            <span class="w-6 text-center text-xs text-gray-400 pg-index"></span>
            <img src="<%= it.main_image || '/images/no-image.png' %>" alt="" class="w-10 h-10 rounded object-cover bg-gray-100">
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-gray-900 truncate"><%= it.name %></div>
              <div class="text-xs text-gray-400"><%= won(it.price) %>원 · <%= it.status %></div>
            </div>
            <button type="button" class="pg-up text-gray-400 hover:text-gray-700 px-1" title="위로"><i class="bi bi-arrow-up"></i></button>
            <button type="button" class="pg-down text-gray-400 hover:text-gray-700 px-1" title="아래로"><i class="bi bi-arrow-down"></i></button>
            <form method="POST" action="/admin/product-groups/<%= group.id %>/items/<%= it.item_id %>/delete">
              <button type="submit" class="text-xs px-2 py-1 rounded border border-red-200 text-red-600 hover:bg-red-50">제거</button>
            </form>
          </li>
        <% }); %>
      </ul>
    </div>
  <% } else { %>
    <div data-panel="manual" class="mt-6 px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-600">
      그룹을 먼저 저장하면 상품을 담을 수 있습니다.
    </div>
  <% } %>

  <%# ── 미리보기: 스토어프론트와 동일한 resolve() 결과 ───────── %>
  <% if (!isNew) { %>
    <div class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">미리보기 <span class="text-gray-400 font-normal">(최대 12개)</span></h2>
        <p class="mt-0.5 text-xs text-gray-500">스토어프론트와 같은 경로로 뽑은 실제 결과입니다(비로그인 기준).</p>
      </div>
      <div class="p-5">
        <% if (!preview.length) { %>
          <p class="py-8 text-center text-sm text-gray-500">조건에 맞는 상품이 없습니다. 이 그룹을 쓰는 섹션은 빈 상태로 노출됩니다.</p>
        <% } else { %>
          <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-3">
            <% preview.forEach(function (p) { %>
              <div class="text-center">
                <img src="<%= p.main_image || '/images/no-image.png' %>" alt="" class="w-full aspect-square rounded object-cover bg-gray-100">
                <div class="mt-1.5 text-xs text-gray-800 truncate" title="<%= p.name %>"><%= p.name %></div>
                <div class="text-[11px] text-gray-400"><%= won(p.price) %>원</div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>

  <%# ── 상품 조회 팝업 (수동 선택 · 필터 + 멀티선택) ───────── %>
  <% if (!isNew) { %>
  <div id="pgPicker" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true">
    <div class="absolute inset-0 bg-black/40" data-pg-close></div>
    <div class="relative mx-auto my-8 w-[95%] max-w-4xl bg-white rounded-xl shadow-xl flex flex-col max-h-[85vh]">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <h3 class="text-base font-bold text-gray-800">상품 조회</h3>
        <button type="button" data-pg-close class="text-gray-400 hover:text-gray-700"><i class="bi bi-x-lg"></i></button>
      </div>

      <%# 필터 %>
      <div class="px-5 py-4 border-b border-gray-100 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2 items-end">
        <div class="col-span-2">
          <label class="block text-xs text-gray-500 mb-1">검색어</label>
          <input type="text" id="pgfQ" placeholder="상품명·상품코드" class="w-full px-2.5 py-1.5 rounded-md border border-gray-200 text-sm">
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">카테고리</label>
          <select id="pgfCategory" class="w-full px-2.5 py-1.5 rounded-md border border-gray-200 text-sm">
            <option value="">전체</option>
            <% categories.forEach(function (c) { %><option value="<%= c.id %>"><%= c.name %></option><% }); %>
          </select>
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">브랜드</label>
          <select id="pgfBrand" class="w-full px-2.5 py-1.5 rounded-md border border-gray-200 text-sm">
            <option value="">전체</option>
            <% (brands || []).forEach(function (b) { %><option value="<%= b.id %>"><%= b.name %></option><% }); %>
          </select>
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">재고</label>
          <select id="pgfStock" class="w-full px-2.5 py-1.5 rounded-md border border-gray-200 text-sm">
            <option value="">전체</option>
            <option value="y">재고 있음</option>
            <option value="n">재고 없음</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">노출</label>
          <select id="pgfVisibility" class="w-full px-2.5 py-1.5 rounded-md border border-gray-200 text-sm">
            <option value="">전체</option>
            <option value="PUBLIC">노출</option>
            <option value="HIDDEN">숨김</option>
            <option value="MEMBER_ONLY">회원전용</option>
          </select>
        </div>
        <div class="col-span-2 sm:col-span-3 lg:col-span-6 flex items-center gap-2">
          <button type="button" id="pgfSearch" class="h-[34px] px-4 text-sm font-semibold rounded-md bg-gray-800 text-white hover:bg-gray-900"><i class="bi bi-search mr-1"></i>검색</button>
          <button type="button" id="pgfReset" class="h-[34px] px-3 text-sm rounded-md border border-gray-200 text-gray-600 hover:bg-gray-50">초기화</button>
          <label class="ml-auto inline-flex items-center gap-1.5 text-xs text-gray-600">
            <input type="checkbox" id="pgfAll" class="w-4 h-4"> 결과 전체 선택
          </label>
        </div>
      </div>

      <%# 결과 %>
      <div id="pgfResults" class="flex-1 overflow-y-auto px-5 py-3 space-y-1">
        <p class="py-10 text-center text-sm text-gray-400">필터를 지정하고 검색하세요.</p>
      </div>

      <%# 푸터 %>
      <div class="px-5 py-3 border-t border-gray-100 flex items-center justify-between">
        <span class="text-xs text-gray-500"><span id="pgfCount">0</span>개 선택됨</span>
        <div class="flex gap-2">
          <button type="button" data-pg-close class="h-[36px] px-4 text-sm rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50">닫기</button>
          <button type="button" id="pgfAdd" class="h-[36px] px-5 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 disabled:opacity-50" disabled>선택 담기</button>
        </div>
      </div>
    </div>
  </div>
  <% } %>
</div>

<script>
(function () {
  const groupId = <%- JSON.stringify(group.id) %>;

  // group_type 에 따라 무의미한 패널을 숨긴다 — resolve() 가 읽지 않는 설정은 내주지 않는다.
  function syncPanels() {
    const type = document.querySelector('[data-group-type]:checked').value;
    document.querySelectorAll('[data-panel]').forEach(el => {
      el.style.display = (el.dataset.panel === type) ? '' : 'none';
    });
  }
  document.querySelectorAll('[data-group-type]').forEach(r => r.addEventListener('change', syncPanels));
  syncPanels();

  if (!groupId) return;

  /* ── 담긴 상품 순서 변경 ── */
  const list = document.getElementById('pgItems');
  function renumber() {
    list.querySelectorAll('[data-item-id]').forEach((li, i) => {
      li.querySelector('.pg-index').textContent = i + 1;
    });
  }
  function persistOrder() {
    const order = [...list.querySelectorAll('[data-item-id]')].map(li => Number(li.dataset.itemId));
    fetch(`/admin/product-groups/${groupId}/items/reorder`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ order }),
    }).catch(() => {});
  }
  list && list.addEventListener('click', (e) => {
    const li = e.target.closest('[data-item-id]');
    if (!li) return;
    if (e.target.closest('.pg-up') && li.previousElementSibling) {
      li.parentNode.insertBefore(li, li.previousElementSibling);
    } else if (e.target.closest('.pg-down') && li.nextElementSibling) {
      li.parentNode.insertBefore(li.nextElementSibling, li);
    } else { return; }
    renumber();
    persistOrder();
  });
  renumber();

  /* ── 상품 조회 팝업 (필터 + 멀티선택) ── */
  const picker = document.getElementById('pgPicker');
  if (!picker) return;

  const openBtn = document.getElementById('pgOpenPicker');
  const resultsEl = document.getElementById('pgfResults');
  const countEl = document.getElementById('pgfCount');
  const addBtn = document.getElementById('pgfAdd');
  const allChk = document.getElementById('pgfAll');
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');
  const VIS = { PUBLIC: '노출', HIDDEN: '숨김', MEMBER_ONLY: '회원전용' };
  const selected = new Set();

  function openPicker() { picker.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
  function closePicker() { picker.classList.add('hidden'); document.body.style.overflow = ''; }
  openBtn && openBtn.addEventListener('click', openPicker);
  picker.querySelectorAll('[data-pg-close]').forEach(el => el.addEventListener('click', closePicker));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !picker.classList.contains('hidden')) closePicker(); });

  function updateCount() {
    countEl.textContent = selected.size;
    addBtn.disabled = selected.size === 0;
  }

  function render(products, limited) {
    selected.clear(); updateCount();
    if (allChk) allChk.checked = false;
    if (!products.length) {
      resultsEl.innerHTML = '<p class="py-10 text-center text-sm text-gray-400">조건에 맞는 상품이 없습니다.</p>';
      return;
    }
    const frag = document.createDocumentFragment();
    if (limited) {
      const note = document.createElement('p');
      note.className = 'mb-2 text-xs text-amber-600';
      note.textContent = '결과가 100개에 도달했습니다. 필터를 더 좁혀 주세요.';
      frag.appendChild(note);
    }
    products.forEach(p => {
      const row = document.createElement('label');
      row.className = 'flex items-center gap-3 px-2 py-2 rounded border border-gray-100 hover:bg-gray-50 cursor-pointer';
      const chk = document.createElement('input');
      chk.type = 'checkbox'; chk.className = 'w-4 h-4 flex-shrink-0'; chk.value = String(p.id);
      chk.addEventListener('change', () => {
        if (chk.checked) selected.add(p.id); else selected.delete(p.id);
        updateCount();
      });
      const img = document.createElement('img');
      img.src = p.main_image || '/images/no-image.png';
      img.className = 'w-10 h-10 rounded object-cover bg-gray-100 flex-shrink-0';
      const info = document.createElement('div');
      info.className = 'flex-1 min-w-0';
      const nm = document.createElement('div');
      nm.className = 'text-sm text-gray-900 truncate';
      nm.textContent = p.name;              // textContent — 상품명이 마크업으로 해석되지 않도록
      const meta = document.createElement('div');
      meta.className = 'text-xs text-gray-400';
      meta.textContent = `${won(p.price)}원 · 재고 ${p.stock} · ${VIS[p.visibility] || p.visibility}`;
      info.append(nm, meta);
      row.append(chk, img, info);
      frag.appendChild(row);
    });
    resultsEl.innerHTML = '';
    resultsEl.appendChild(frag);
  }

  async function doSearch() {
    const params = new URLSearchParams();
    const q = document.getElementById('pgfQ').value.trim();
    const cat = document.getElementById('pgfCategory').value;
    const brand = document.getElementById('pgfBrand').value;
    const stock = document.getElementById('pgfStock').value;
    const vis = document.getElementById('pgfVisibility').value;
    if (q) params.set('q', q);
    if (cat) params.set('category_id', cat);
    if (brand) params.set('brand_id', brand);
    if (stock) params.set('in_stock', stock);
    if (vis) params.set('visibility', vis);
    resultsEl.innerHTML = '<p class="py-10 text-center text-sm text-gray-400">조회 중…</p>';
    try {
      const res = await fetch(`/admin/product-groups/${groupId}/product-search?` + params.toString());
      const data = await res.json();
      render(data.products || [], data.limited);
    } catch (e) {
      resultsEl.innerHTML = '<p class="py-10 text-center text-sm text-red-500">조회에 실패했습니다.</p>';
    }
  }
  document.getElementById('pgfSearch').addEventListener('click', doSearch);
  document.getElementById('pgfQ').addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); doSearch(); } });
  document.getElementById('pgfReset').addEventListener('click', () => {
    ['pgfQ', 'pgfCategory', 'pgfBrand', 'pgfStock', 'pgfVisibility'].forEach(id => { document.getElementById(id).value = ''; });
    resultsEl.innerHTML = '<p class="py-10 text-center text-sm text-gray-400">필터를 지정하고 검색하세요.</p>';
    selected.clear(); updateCount();
    if (allChk) allChk.checked = false;
  });

  allChk && allChk.addEventListener('change', () => {
    resultsEl.querySelectorAll('input[type=checkbox]').forEach(chk => {
      chk.checked = allChk.checked;
      const pid = Number(chk.value);
      if (allChk.checked) selected.add(pid); else selected.delete(pid);
    });
    updateCount();
  });

  addBtn.addEventListener('click', async () => {
    if (!selected.size) return;
    addBtn.disabled = true;
    try {
      const res = await fetch(`/admin/product-groups/${groupId}/items/bulk`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ product_ids: [...selected] }),
      });
      const data = await res.json();
      if (data && data.success) {
        location.href = `/admin/product-groups/${groupId}?saved=1`;
      } else { addBtn.disabled = false; alert('담기에 실패했습니다.'); }
    } catch (e) { addBtn.disabled = false; alert('담기에 실패했습니다.'); }
  });
})();
</script>
