<%
  /*
   * 상품 추천관리 — 그룹 목록
   *
   * 그룹 하나 = /recommend 랜딩의 섹션 하나. 위에서부터 sort_order 순으로 노출된다.
   */
%>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="flex items-start justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">상품 추천관리</h1>
      <p class="mt-1 text-sm text-gray-500">여기서 만든 그룹이 추천 화면의 섹션이 됩니다.</p>
    </div>
    <a href="/admin/recommend-groups/new"
       class="inline-flex items-center gap-1.5 h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 no-underline">
      <i class="bi bi-plus-lg"></i> 그룹 등록
    </a>
  </div>

  <%- include('../../partials/admin/usage_notice', {
        heading: '그룹 하나가 추천 화면(/recommend)의 섹션 하나가 됩니다.',
        chips: ['그룹명 → 섹션 제목', '설명 → 추천 근거 문구', '순서 → 섹션 순서'],
        chipsLabel: '이렇게 쓰입니다',
        note: '페이지 빌더에 배치하지 않아도 저장 즉시 추천 화면에 반영됩니다. '
            + '담긴 상품이 숨김·판매중지면 그 섹션은 그리지 않으므로, 전부 숨겨진 그룹은 화면에서 사라집니다.',
        link: { href: '/recommend', label: '추천 화면 열어 확인하기', blank: true },
      }) %>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-600">
        <tr>
          <th class="px-5 py-3 text-left font-semibold w-20">순서</th>
          <th class="px-5 py-3 text-left font-semibold">그룹명</th>
          <th class="px-5 py-3 text-left font-semibold w-40">담긴 상품</th>
          <th class="px-5 py-3 text-left font-semibold w-24">사용</th>
          <th class="px-5 py-3 text-right font-semibold w-32"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if (!groups.length) { %>
          <tr>
            <td colspan="5" class="px-5 py-16 text-center text-gray-500">
              <i class="bi bi-stars text-3xl text-gray-300"></i>
              <p class="mt-3">등록된 추천 그룹이 없습니다.</p>
              <p class="mt-1 text-xs text-gray-400">예: '면역력 관리', '선물 추천', '유산균 모음'</p>
            </td>
          </tr>
        <% } %>

        <% groups.forEach(function (g) { %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3 text-gray-400"><%= g.sort_order %></td>
            <td class="px-5 py-3">
              <a href="/admin/recommend-groups/<%= g.id %>" class="font-medium text-gray-900 hover:text-indigo-600 no-underline">
                <%= g.name %>
              </a>
              <% if (g.description) { %>
                <div class="text-xs text-gray-400 mt-0.5"><%= g.description %></div>
              <% } %>
            </td>
            <td class="px-5 py-3">
              <%= g.item_count %>개
              <% if (g.item_count > g.visible_count) { %>
                <span class="ml-1 text-xs text-amber-600" title="숨김·판매중지 상품은 추천 화면에 뜨지 않습니다">
                  (노출 <%= g.visible_count %>)
                </span>
              <% } %>
            </td>
            <td class="px-5 py-3">
              <% if (g.is_active && g.visible_count > 0) { %>
                <span class="inline-block px-2 py-0.5 rounded text-xs bg-green-100 text-green-800">노출</span>
              <% } else if (g.is_active) { %>
                <span class="inline-block px-2 py-0.5 rounded text-xs bg-amber-100 text-amber-800" title="담긴 상품이 없어 섹션이 그려지지 않습니다">상품 없음</span>
              <% } else { %>
                <span class="inline-block px-2 py-0.5 rounded text-xs bg-gray-100 text-gray-500">미사용</span>
              <% } %>
            </td>
            <td class="px-5 py-3 text-right">
              <a href="/admin/recommend-groups/<%= g.id %>"
                 class="inline-flex items-center h-[30px] px-3 text-xs rounded border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">수정</a>
              <form method="POST" action="/admin/recommend-groups/<%= g.id %>/delete" class="inline"
                    onsubmit="return confirm('«<%= g.name %>» 그룹을 삭제할까요? 담긴 상품 목록도 함께 지워집니다.');">
                <button type="submit"
                        class="inline-flex items-center h-[30px] px-3 text-xs rounded border border-red-200 text-red-600 hover:bg-red-50">삭제</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <p class="mt-4 text-xs text-gray-400">
    · 추천 화면 섹션 순서: 회원 맞춤 추천 → <strong>추천 그룹(위 순서대로)</strong> → MD 추천(상품 배지) → 지금 많이 보는 상품<br>
    · 숨김·판매중지 상품은 담겨 있어도 고객 화면에는 뜨지 않습니다.
  </p>
</div>
