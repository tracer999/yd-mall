<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 sm:gap-0">
    <p class="text-sm text-gray-500">주문 결제 및 배송 상태를 모니터링하고 관리합니다.</p>
    <div class="flex items-center gap-2 w-full sm:w-auto justify-start sm:justify-end">
        <% const statusLabels = { PENDING: '대기', PAID: '결제완료', PREPARING: '배송준비', SHIPPED: '배송중', DELIVERED: '배송완료', CANCELLED: '취소', REFUNDED: '환불' }; %>
        <% if (statusFilter) { %>
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-sm font-medium">
                <%= statusLabels[statusFilter] || statusFilter %>
                <a href="/admin/sales" class="ml-1 text-blue-600 hover:text-blue-800" title="필터 해제">×</a>
            </span>
        <% } %>
    </div>
</div>

<div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col"
                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">주문번호</th>
                    <th scope="col"
                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">몰</th>
                    <th scope="col"
                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">주문일시</th>
                    <th scope="col"
                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">주문자</th>
                    <th scope="col"
                        class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">결제금액
                    </th>
                    <th scope="col"
                        class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
                    <th scope="col"
                        class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">관리</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                <% if (orders && orders.length> 0) { %>
                    <% orders.forEach(order=> { %>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-blue-600">
                                <a href="/admin/sales/<%= order.id %>">
                                    <%= order.order_number %>
                                </a>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <% if (order.mall_name) { %>
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-indigo-50 text-[11px] font-semibold text-indigo-700 border border-indigo-100">
                                        <i class="bi bi-shop text-[10px]"></i><%= order.mall_name %><% if (order.mall_is_default) { %> · 기본<% } %>
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-100 text-[11px] font-medium text-gray-400 border border-gray-200">미확인</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                <%= new Date(order.created_at).toLocaleDateString('ko-KR') %>
                                    <span class="text-xs text-gray-400 ml-1">
                                        <%= new Date(order.created_at).toLocaleTimeString('ko-KR', {hour: '2-digit' ,
                                            minute:'2-digit'}) %>
                                    </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    <div class="flex-shrink-0">
                                        <% if (order.customer_picture) { %>
                                            <img src="<%= order.customer_picture %>" alt="프로필"
                                                class="h-8 w-8 rounded-full object-cover border border-gray-200">
                                        <% } else { %>
                                            <div
                                                class="h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center text-xs text-gray-500">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div>
                                        <div class="flex items-center gap-2">
                                            <div class="text-sm font-medium text-gray-900">
                                                <%= order.customer_name || '비회원' %>
                                            </div>
                                            <% if (order.customer_google_id) { %>
                                                <span
                                                    class="inline-flex items-center px-1.5 py-0.5 rounded-full bg-red-50 text-[10px] font-semibold text-red-600 border border-red-100">Google</span>
                                            <% } else if (order.customer_kakao_id) { %>
                                                <span
                                                    class="inline-flex items-center px-1.5 py-0.5 rounded-full bg-yellow-100 text-[10px] font-semibold text-yellow-800 border border-yellow-200">Kakao</span>
                                            <% } %>
                                        </div>
                                        <div class="text-xs text-gray-500">
                                            <%= order.receiver_name %> (<%= order.receiver_phone %>)
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-bold text-gray-900">
                                <%= order.total_amount.toLocaleString() %>원
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                <% let statusClass='bg-gray-100 text-gray-800' ; if(order.status==='PAID' )
                                    statusClass='bg-green-100 text-green-800' ; else if(order.status==='PREPARING' )
                                    statusClass='bg-blue-100 text-blue-800' ; else if(order.status==='SHIPPED' )
                                    statusClass='bg-purple-100 text-purple-800' ; else if(order.status==='DELIVERED' )
                                    statusClass='bg-gray-800 text-white' ; else if(order.status==='CANCELLED' )
                                    statusClass='bg-red-100 text-red-800' ; %>
                                    <span
                                        class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= statusClass %>">
                                        <%= statusLabels[order.status] || order.status %>
                                    </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                                <a href="/admin/sales/<%= order.id %>" class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 border border-indigo-200 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 no-underline">상세보기</a>
                            </td>
                        </tr>
                        <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="px-6 py-10 text-center text-gray-500">주문 내역이 없습니다.</td>
                                </tr>
                                <% } %>
            </tbody>
        </table>
    </div>
</div>