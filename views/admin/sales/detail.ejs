<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4 sm:gap-0">
    <div class="flex items-center gap-2 text-sm text-gray-600">
        <a href="/admin/sales" class="text-gray-400 hover:text-gray-600"><i class="bi bi-arrow-left-circle"></i></a>
        <span class="font-medium text-gray-700">주문번호</span>
        <span class="text-base font-semibold text-gray-900">#<%= order.order_number %></span>
        <% if (order.mall_name) { %>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-indigo-50 text-[11px] font-semibold text-indigo-700 border border-indigo-100">
                <i class="bi bi-shop text-[10px]"></i><%= order.mall_name %><% if (order.mall_is_default) { %> · 기본<% } %>
            </span>
        <% } else { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-100 text-[11px] font-medium text-gray-400 border border-gray-200">몰 미확인</span>
        <% } %>
    </div>

    <form action="/admin/sales/status" method="POST" class="flex items-center gap-2">
        <input type="hidden" name="id" value="<%= order.id %>">
        <select name="status">
            <option value="PENDING" <%=order.status==='PENDING' ? 'selected' : '' %>>대기</option>
            <option value="PAID" <%=order.status==='PAID' ? 'selected' : '' %>>결제완료</option>
            <option value="PREPARING" <%=order.status==='PREPARING' ? 'selected' : '' %>>배송준비</option>
            <option value="SHIPPED" <%=order.status==='SHIPPED' ? 'selected' : '' %>>배송중</option>
            <option value="DELIVERED" <%=order.status==='DELIVERED' ? 'selected' : '' %>>배송완료</option>
            <option value="CANCELLED" <%=order.status==='CANCELLED' ? 'selected' : '' %>>취소</option>
        </select>
        <button type="submit"
            class="inline-flex items-center justify-center h-[38px] min-w-[140px] px-8 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 whitespace-nowrap">상태 변경</button>
    </form>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Order Info -->
    <div class="lg:col-span-2 space-y-6">
        <!-- Items -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="font-bold text-gray-800">주문 상품</h3>
            </div>
            <div class="p-6">
                <table class="min-w-full">
                    <thead>
                        <tr
                            class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-b border-gray-100">
                            <th class="pb-3">상품명</th>
                            <th class="pb-3 text-right">수량</th>
                            <th class="pb-3 text-right">가격</th>
                            <th class="pb-3 text-right">합계</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% items.forEach(item=> { %>
                            <tr>
                                <td class="py-4 text-sm text-gray-800">
                                    <%= item.product_name %>
                                        <% if(!item.product_id) { %> <span class="text-xs text-red-400">(삭제된 상품)</span>
                                            <% } %>
                                </td>
                                <td class="py-4 text-sm text-gray-600 text-right">
                                    <%= item.quantity %>
                                </td>
                                <td class="py-4 text-sm text-gray-600 text-right">
                                    <%= item.product_price.toLocaleString() %>원
                                </td>
                                <td class="py-4 text-sm font-bold text-gray-800 text-right">
                                    <%= item.total_price.toLocaleString() %>원
                                </td>
                            </tr>
                            <% }) %>
                                <% const subtotal = order.subtotal_amount != null ? order.subtotal_amount : items.reduce((s, i) => s + (i.total_price || 0), 0); %>
                                <tr class="bg-gray-50">
                                    <td colspan="3" class="py-2 text-right text-sm text-gray-600 pr-6">상품 금액 합계</td>
                                    <td class="py-2 text-right text-sm text-gray-800"><%= subtotal.toLocaleString() %>원</td>
                                </tr>
                                <% if (order.coupon_discount && order.coupon_discount > 0) { %>
                                <tr class="bg-gray-50">
                                    <td colspan="3" class="py-2 text-right text-sm text-gray-600 pr-6">
                                        쿠폰 할인<% if (usedCoupon && (usedCoupon.coupon_name || usedCoupon.coupon_code)) { %> (<%= usedCoupon.coupon_name || usedCoupon.coupon_code %>)<% } %>
                                    </td>
                                    <td class="py-2 text-right text-sm text-green-600">-<%= order.coupon_discount.toLocaleString() %>원</td>
                                </tr>
                                <% } %>
                                <% if (order.point_used && order.point_used > 0) { %>
                                <tr class="bg-gray-50">
                                    <td colspan="3" class="py-2 text-right text-sm text-gray-600 pr-6">포인트 사용</td>
                                    <td class="py-2 text-right text-sm text-green-600">-<%= order.point_used.toLocaleString() %>원</td>
                                </tr>
                                <% } %>
                                <tr class="bg-gray-50">
                                    <td colspan="3" class="py-2 text-right text-sm text-gray-600 pr-6">배송비</td>
                                    <td class="py-2 text-right text-sm text-gray-800">
                                        <% if (Number(order.shipping_fee) > 0) { %>+<%= Number(order.shipping_fee).toLocaleString() %>원<% } else { %>무료<% } %>
                                    </td>
                                </tr>
                                <% if (Number(order.shipping_discount) > 0) { %>
                                <tr class="bg-gray-50">
                                    <td colspan="3" class="py-2 text-right text-sm text-gray-600 pr-6">
                                        배송비 할인<% if (shippingCoupon && shippingCoupon.coupon_name) { %> (<%= shippingCoupon.coupon_name %>)<% } %>
                                    </td>
                                    <td class="py-2 text-right text-sm text-green-600">-<%= Number(order.shipping_discount).toLocaleString() %>원</td>
                                </tr>
                                <% } %>
                                <tr class="bg-gray-100 border-t border-gray-200">
                                    <td colspan="3" class="py-3 text-right text-sm font-bold text-gray-700 pr-6">최종 결제 금액</td>
                                    <td class="py-3 text-right text-lg font-bold text-indigo-600">
                                        <%= order.total_amount.toLocaleString() %>원
                                    </td>
                                </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Shipping Info -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                <h3 class="font-bold text-gray-800">배송 정보</h3>
                <% if (shipment) { %>
                    <% const shipmentStatusLabels = { READY: '준비', IN_TRANSIT: '배송중', DELIVERED: '배송완료' }; %>
                    <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-semibold rounded-full">
                        <%= shipmentStatusLabels[shipment.status] || shipment.status %>
                    </span>
                    <% } else { %>
                        <span class="px-2 py-1 bg-gray-100 text-gray-800 text-xs font-semibold rounded-full">배송 정보
                            없음</span>
                        <% } %>
            </div>
            <div class="p-6">
                <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
                    <div class="sm:col-span-1">
                        <dt class="text-sm font-medium text-gray-500">받는 분</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            <%= order.receiver_name %>
                        </dd>
                    </div>
                    <div class="sm:col-span-1">
                        <dt class="text-sm font-medium text-gray-500">연락처</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            <%= order.receiver_phone %>
                        </dd>
                    </div>
                    <div class="sm:col-span-2">
                        <dt class="text-sm font-medium text-gray-500">주소</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            <%= order.shipping_address %>
                        </dd>
                    </div>
                    <div class="sm:col-span-2">
                        <dt class="text-sm font-medium text-gray-500">배송 메시지</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            <%= order.shipping_message || '-' %>
                        </dd>
                    </div>
                    <% if (shipment) { %>
                        <div class="sm:col-span-1 border-t border-gray-100 pt-4 mt-2">
                            <dt class="text-sm font-medium text-gray-500">택배사</dt>
                            <dd class="mt-1 text-sm font-bold text-gray-900">
                                <%= shipment.courier_company %>
                            </dd>
                        </div>
                        <div class="sm:col-span-1 border-t border-gray-100 pt-4 mt-2">
                            <dt class="text-sm font-medium text-gray-500">운송장 번호</dt>
                            <dd class="mt-1 text-sm font-bold text-blue-600">
                                <%= shipment.tracking_number %>
                            </dd>
                        </div>
                        <div class="sm:col-span-2">
                            <dt class="text-sm font-medium text-gray-500">배송 시작일</dt>
                            <dd class="mt-1 text-sm text-gray-900">
                                <%= shipment.shipped_at ? new Date(shipment.shipped_at).toLocaleString('ko-KR') : '-' %>
                            </dd>
                        </div>
                        <% } else { %>
                            <div class="sm:col-span-2 border-t border-gray-100 pt-4 mt-2">
                                <p class="text-sm text-gray-500 italic">아직 배송이 시작되지 않았습니다. 배송 관리 메뉴에서 배송 처리를 진행해주세요.</p>
                                <a href="/admin/shipping"
                                    class="inline-block mt-2 text-sm text-blue-600 hover:text-blue-800 font-medium">배송
                                    관리 바로가기 &rarr;</a>
                            </div>
                            <% } %>
                </dl>
            </div>
        </div>
    </div>

    <!-- Customer & System Info -->
    <div class="lg:col-span-1 space-y-6">
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="font-bold text-gray-800">주문자 정보</h3>
            </div>
            <div class="p-6">
                <div class="flex items-center mb-4">
                    <div class="h-10 w-10 flex-shrink-0">
                        <% if (order.customer_picture) { %>
                            <img src="<%= order.customer_picture %>" alt="프로필"
                                class="h-10 w-10 rounded-full object-cover border border-gray-200">
                        <% } else { %>
                            <div
                                class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500">
                                <i class="bi bi-person-fill"></i>
                            </div>
                        <% } %>
                    </div>
                    <div class="ml-3">
                        <div class="flex items-center gap-2">
                            <div class="text-sm font-medium text-gray-900">
                                <%= order.customer_name || '비회원' %>
                            </div>
                            <% if (order.customer_google_id) { %>
                                <span
                                    class="inline-flex items-center px-2 py-0.5 rounded-full bg-red-50 text-[11px] font-semibold text-red-600 border border-red-100">Google</span>
                            <% } else if (order.customer_kakao_id) { %>
                                <span
                                    class="inline-flex items-center px-2 py-0.5 rounded-full bg-yellow-100 text-[11px] font-semibold text-yellow-800 border border-yellow-200">Kakao</span>
                            <% } %>
                        </div>
                        <div class="text-xs text-gray-500">
                            <%= order.customer_email || '-' %>
                        </div>
                    </div>
                </div>
                <% if (order.user_id) { %>
                    <a href="/admin/users/<%= order.user_id %>" class="text-xs text-blue-600 hover:underline">회원 정보
                        보기</a>
                    <% } %>
            </div>
        </div>

        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="font-bold text-gray-800">시스템 정보</h3>
            </div>
            <div class="p-6 text-sm">
                <div class="flex justify-between py-2 border-b border-gray-50">
                    <span class="text-gray-500">주문 번호</span>
                    <span class="font-mono text-gray-900">
                        <%= order.order_number %>
                    </span>
                </div>
                <div class="flex justify-between py-2 border-b border-gray-50">
                    <span class="text-gray-500">주문 일시</span>
                    <span class="text-gray-900">
                        <%= new Date(order.created_at).toLocaleString('ko-KR') %>
                    </span>
                </div>
                <div class="flex justify-between py-2 border-b border-gray-50">
                    <span class="text-gray-500">결제 수단</span>
                    <span class="text-gray-900">
                        <%= order.payment_method || '카드' %>
                    </span>
                </div>
                <div class="flex justify-between py-2">
                    <span class="text-gray-500">결제 일시</span>
                    <span class="text-gray-900">
                        <%= order.paid_at ? new Date(order.paid_at).toLocaleString('ko-KR') : '-' %>
                    </span>
                </div>
                <%# 분리된 상태 축 (주문/클레임 문서 §4). 주문 상태 하나로 뭉개지 않는다. %>
                <div class="flex justify-between py-2 border-t border-gray-100 mt-2 pt-3">
                    <span class="text-gray-500">결제 상태</span>
                    <span class="text-gray-900"><%= { PENDING:'결제대기', PAID:'결제완료', CANCELLED:'결제취소', REFUNDED:'환불완료', PARTIAL_REFUNDED:'부분환불' }[order.payment_status] || order.payment_status %></span>
                </div>
                <% if (order.claim_status && order.claim_status !== 'NONE') { %>
                <div class="flex justify-between py-2">
                    <span class="text-gray-500">클레임</span>
                    <span class="text-gray-900"><%= { REQUESTED:'접수', APPROVED:'승인', COMPLETED:'완료', REJECTED:'거절' }[order.claim_status] || order.claim_status %></span>
                </div>
                <% } %>
                <% if (order.refund_status && order.refund_status !== 'NONE') { %>
                <div class="flex justify-between py-2">
                    <span class="text-gray-500">환불</span>
                    <span class="text-gray-900"><%= { REQUESTED:'요청', COMPLETED:'완료', FAILED:'실패' }[order.refund_status] || order.refund_status %></span>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- 클레임 -->
    <% if (typeof claims !== 'undefined' && claims.length) { %>
    <div class="bg-white shadow-sm rounded-lg border border-gray-100 mt-6">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
            <h3 class="font-bold text-gray-800">클레임</h3>
            <a href="/admin/claims" class="text-xs text-indigo-600 hover:underline">클레임 관리 →</a>
        </div>
        <ul class="divide-y divide-gray-100">
            <% claims.forEach(function (c) { %>
                <li class="px-6 py-3 flex items-center justify-between text-sm">
                    <span><%= { CANCEL:'취소', RETURN:'반품', EXCHANGE:'교환' }[c.claim_type] %> · <%= { CHANGE_OF_MIND:'단순변심', DEFECT:'불량', WRONG_DELIVERY:'오배송', OTHER:'기타' }[c.reason_type] %></span>
                    <div class="flex items-center gap-3">
                        <span class="text-gray-400"><%= new Date(c.requested_at).toLocaleDateString('ko-KR') %></span>
                        <a href="/admin/claims/<%= c.id %>" class="px-2 py-1 rounded border border-indigo-200 bg-indigo-50 text-indigo-700 text-xs">보기</a>
                    </div>
                </li>
            <% }); %>
        </ul>
    </div>
    <% } %>

    <!-- 주문 변경 이력 -->
    <% if (typeof logs !== 'undefined' && logs.length) { %>
    <div class="bg-white shadow-sm rounded-lg border border-gray-100 mt-6">
        <div class="px-6 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800">주문 변경 이력</h3>
        </div>
        <ul class="divide-y divide-gray-50">
            <% logs.forEach(function (l) { %>
                <li class="px-6 py-2.5 flex items-center justify-between text-xs">
                    <span class="text-gray-700">
                        <span class="text-gray-400"><%= l.field %></span>
                        <%= l.old_value || '-' %> → <strong><%= l.new_value || '-' %></strong>
                        <% if (l.memo) { %><span class="text-gray-400 ml-1">(<%= l.memo %>)</span><% } %>
                    </span>
                    <span class="text-gray-400">
                        <%= { CUSTOMER:'고객', ADMIN:'관리자', SYSTEM:'시스템' }[l.actor_type] %> ·
                        <%= new Date(l.created_at).toLocaleString('ko-KR') %>
                    </span>
                </li>
            <% }); %>
        </ul>
    </div>
    <% } %>
</div>