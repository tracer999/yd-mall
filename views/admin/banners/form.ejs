<div class="flex justify-center">
  <div class="w-full lg:max-w-5xl">
    <div class="mb-6">
      <p class="mt-1 text-sm text-gray-500">메인 배너 또는 카테고리별 배너를 등록합니다.</p>
    </div>

    <form action="<%= banner ? '/admin/banners/edit/' + banner.id : '/admin/banners/add' %>" method="POST"
      enctype="multipart/form-data" class="space-y-6">
      <%# 이 화면과 무관한 group_key(예: 홈 프로모션 'home_promo')를 편집 시 보존하기 위한 hidden. %>
      <input type="hidden" name="existing_group_key" value="<%= banner && banner.group_key ? banner.group_key : '' %>">
      <div class="bg-white shadow-sm rounded-xl border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-100">
          <h3 class="text-lg font-semibold text-gray-800">기본 정보</h3>
        </div>
        <div class="px-6 py-5 space-y-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">배너 타입</label>
            <div class="flex flex-wrap gap-4">
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="MAIN"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='MAIN') ? 'checked' : '' %>>
                <span>메인 배너</span>
              </label>
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="CATEGORY"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='CATEGORY') ? 'checked' : '' %>>
                <span>카테고리 배너</span>
              </label>
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="POPUP"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='POPUP') ? 'checked' : '' %>>
                <span>팝업 배너</span>
              </label>
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="BRAND"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='BRAND') ? 'checked' : '' %>>
                <span>브랜드 배너</span>
              </label>
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="MENU"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='MENU') ? 'checked' : '' %>>
                <span>메뉴별 배너</span>
              </label>
            </div>
          </div>

          <div id="menuTargetField" class="hidden">
            <label class="block text-sm font-medium text-gray-700 mb-2">노출 메뉴</label>
            <select name="menu_target" id="menuTargetSelect"
              class="block w-full text-sm border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500">
              <% (menuTargets || []).forEach(function(t) { %>
                <option value="<%= t.key %>" <%= currentMenuKey === t.key ? 'selected' : '' %>><%= t.label %></option>
              <% }) %>
            </select>
            <p class="mt-1 text-xs text-gray-400">선택한 프론트 메뉴 목록 페이지 상단에 이 배너가 노출됩니다.</p>
          </div>

          <div id="categoryField" class="hidden">
            <label class="block text-sm font-medium text-gray-700 mb-2">카테고리/브랜드 선택</label>
            <select name="category_id" id="categoryIdSelect"
              class="block w-full text-sm border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500">
              <option value="">선택하세요</option>
              <% if (categories && categories.length) { %>
                <% categories.forEach(function(category) { %>
                  <option value="<%= category.id %>" data-type="<%= category.type %>" <%=banner &&
                    String(banner.category_id)===String(category.id) ? 'selected' : '' %>><%= category.name %>
                  </option>
                  <% }) %>
                    <% } %>
            </select>
            <p class="mt-1 text-xs text-gray-400">배너가 노출될 대상을 선택합니다.</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">배너 제목</label>
            <input type="text" name="title" placeholder="예: 봄맞이 할인 이벤트" value="<%= banner ? banner.title : '' %>" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">이미지 업로드</label>
            <input type="file" name="banner_image" id="bannerImageInput" accept="image/*"
              class="block w-full text-sm text-gray-500 file:mr-4 file:py-3 file:px-6 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 border-gray-300"
              <%=banner ? '' : 'required' %> />
            <p id="bannerSizeGuide" class="mt-1 text-xs text-gray-500 leading-relaxed"></p>
            <p class="mt-1 text-xs text-blue-700 leading-relaxed">최대 업로드 용량: <%= maxUploadFileMb || 20 %>MB</p>
            <% if(banner && banner.image_url) { %>
              <input type="hidden" name="existing_image" value="<%= banner.image_url %>">
              <% } %>

                <!-- Image Preview -->
                <div id="previewContainer" class="mt-4 <%= banner && banner.image_url ? '' : 'hidden' %>">
                  <p class="text-sm text-gray-700 mb-2 font-medium">✨ 미리보기</p>
                  <div class="border rounded-lg overflow-hidden bg-gray-50">
                    <img id="previewImage" src="<%= banner ? banner.image_url : '' %>" alt="Banner Preview"
                      class="max-w-full h-auto mx-auto object-contain" style="max-height: 300px;">
                  </div>
                </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">연결 링크 (URL)</label>
            <input type="text" name="link_url" placeholder="/products/view/1 또는 외부 URL"
              value="<%= banner ? banner.link_url : '' %>" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">노출 순서</label>
              <input type="number" name="display_order" value="<%= banner ? banner.display_order : 0 %>" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">시작일</label>
              <input type="date" name="start_date"
                value="<%= banner && banner.start_date ? new Date(banner.start_date).toISOString().split('T')[0] : '' %>" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">종료일</label>
              <input type="date" name="end_date"
                value="<%= banner && banner.end_date ? new Date(banner.end_date).toISOString().split('T')[0] : '' %>" />
            </div>
          </div>

          <div class="flex items-center mt-2">
            <input type="checkbox" class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
              name="is_active" id="isActive" <%=(!banner) || (banner && banner.is_active) ? 'checked' : '' %>
            />
            <label class="ml-2 block text-sm text-gray-700" for="isActive">
              활성화 (즉시 노출)
            </label>
          </div>
        </div>
      </div>

      <div class="flex justify-end pt-2">
        <button type="submit"
          class="inline-flex items-center justify-center h-[50px] px-6 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700">
          저장하기
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    const maxUploadMb = Number('<%= maxUploadFileMb || 20 %>');
    const maxUploadBytes = maxUploadMb * 1024 * 1024;
    const typeRadios = document.querySelectorAll('input[name="banner_type"]');
    const categoryField = document.getElementById('categoryField');
    const menuTargetField = document.getElementById('menuTargetField');
    const sizeGuide = document.getElementById('bannerSizeGuide');

    const categoryIdSelect = document.getElementById('categoryIdSelect');

    function updateCategoryVisibility() {
      const selected = document.querySelector('input[name="banner_type"]:checked');
      // 메뉴별 배너 선택 필드 토글
      if (menuTargetField) {
        menuTargetField.classList.toggle('hidden', !(selected && selected.value === 'MENU'));
      }
      if (selected && (selected.value === 'CATEGORY' || selected.value === 'BRAND')) {
        categoryField.classList.remove('hidden');

        const options = categoryIdSelect.querySelectorAll('option');
        let firstVisible = null;
        let isSelectedVisible = false;

        options.forEach(opt => {
          if (opt.value === '') return;
          const type = opt.getAttribute('data-type');
          let shouldShow = false;

          if (selected.value === 'BRAND' && type === 'BRAND') {
            shouldShow = true;
          } else if (selected.value === 'CATEGORY' && type !== 'BRAND') {
            shouldShow = true;
          }

          if (shouldShow) {
            opt.hidden = false;
            opt.disabled = false;
            if (!firstVisible) firstVisible = opt;
            if (opt.selected) isSelectedVisible = true;
          } else {
            opt.hidden = true;
            opt.disabled = true;
          }
        });

        // 만약 기존에 선택되어 있던 값이 숨김 처리되었다면 선택 해제
        if (!isSelectedVisible && categoryIdSelect.value !== '') {
          categoryIdSelect.value = '';
        }

      } else {
        categoryField.classList.add('hidden');
        categoryIdSelect.value = '';
      }
    }

    function updateSizeGuide() {
      if (!sizeGuide) return;
      const selected = document.querySelector('input[name="banner_type"]:checked');
      if (!selected) {
        sizeGuide.textContent = '배너 타입을 선택하면 권장 이미지 사이즈가 표시됩니다.';
        return;
      }

      if (selected.value === 'MAIN') {
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">메인 배너 권장 사이즈</span><br>
          기본: <span class="font-mono">1920 × 600px</span> (가로:세로 <span class="font-mono">3.2 : 1</span>)<br>
          2배 해상도 작업 시: <span class="font-mono">3840 × 1200px</span><br>
          <span class="text-[11px] text-gray-400">브라우저 전체 폭에 맞춰 노출되므로, 위 비율(3.2:1)을 유지해서 제작해 주세요.</span>
        `;
      } else if (selected.value === 'CATEGORY') {
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">카테고리 배너 권장 사이즈</span><br>
          기본: <span class="font-mono">900 × 200px</span> (가로:세로 <span class="font-mono">4.5 : 1</span> 내외)</span><br>
          2배 해상도 작업 시: <span class="font-mono">1800 × 400px</span><br>
          <span class="text-[11px] text-gray-400">카테고리 상단 배너 영역은 약 900px 폭 기준이며, 위 비율(대략 4.5:1)을 유지해서 제작하시면 됩니다.</span>
        `;
      } else if (selected.value === 'POPUP') {
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">팝업 배너 권장 사이즈</span><br>
          기본: <span class="font-mono">960 × 960px</span> (가로:세로 <span class="font-mono">1 : 1</span>, 정사각형)<br>
          2배 해상도 작업 시: <span class="font-mono">1920 × 1920px</span><br>
          <span class="text-[11px] text-gray-400">팝업은 정사각형으로 노출되므로, 1:1 비율만 유지해 주시면 됩니다.</span>
        `;
      } else if (selected.value === 'BRAND') {
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">브랜드 상단 배너 권장 사이즈</span><br>
          기본: <span class="font-mono">900 × 200px</span> (가로:세로 <span class="font-mono">4.5 : 1</span> 내외)<br>
          2배 해상도 작업 시: <span class="font-mono">1800 × 400px</span><br>
          <span class="text-[11px] text-gray-400">브랜드 상세 페이지 최상단에 노출되는 맞춤 배너입니다.</span>
        `;
      } else if (selected.value === 'MENU') {
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">메뉴별 배너 권장 사이즈</span><br>
          기본: <span class="font-mono">1200 × 260px</span> (가로:세로 <span class="font-mono">4.6 : 1</span> 내외)<br>
          2배 해상도 작업 시: <span class="font-mono">2400 × 520px</span><br>
          <span class="text-[11px] text-gray-400">선택한 메뉴(베스트·신상품 등) 목록 페이지 상단에 노출됩니다.</span>
        `;
      } else {
        sizeGuide.textContent = '배너 타입을 선택하면 권장 이미지 사이즈가 표시됩니다.';
      }
    }

    typeRadios.forEach(r => r.addEventListener('change', updateCategoryVisibility));
    typeRadios.forEach(r => r.addEventListener('change', updateSizeGuide));
    updateCategoryVisibility();
    updateSizeGuide();

    // Inject mobile image upload field right after PC banner field.
    const pcImageInput = document.getElementById('bannerImageInput');
    if (pcImageInput && pcImageInput.parentElement) {
      const parent = pcImageInput.parentElement;
      const mobileFieldHtml = `
        <div class="mt-6">
          <label class="block text-sm font-medium text-gray-700 mb-2">모바일용 이미지 업로드</label>
          <input type="file" name="mobile_banner_image" id="mobileBannerImageInput" accept="image/*" class="block w-full text-sm text-gray-500 file:mr-4 file:py-3 file:px-6 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100 border-gray-300" />
          <p class="mt-1 text-xs text-gray-500 leading-relaxed">미등록 시 PC 이미지를 모바일에서도 사용합니다.</p>
          <p class="mt-1 text-xs text-emerald-700 leading-relaxed">권장 사이즈: 390 × 422px, 2배 해상도 작업 시 780 × 844px</p>
          <p class="mt-1 text-xs text-emerald-700 leading-relaxed">최대 업로드 용량: <%= maxUploadFileMb || 20 %>MB</p>
          <input type="hidden" name="existing_mobile_image" value="<%= banner && banner.mobile_image_url ? banner.mobile_image_url : '' %>">
          <div id="mobilePreviewContainer" class="mt-4 <%= banner && banner.mobile_image_url ? '' : 'hidden' %>">
            <p class="text-sm text-gray-700 mb-2 font-medium">모바일 이미지 미리보기</p>
            <div class="border rounded-lg overflow-hidden bg-gray-50">
                <img id="mobilePreviewImage" src="<%= banner && banner.mobile_image_url ? banner.mobile_image_url : '' %>" alt="Mobile Banner Preview" class="max-w-full h-auto mx-auto object-contain" style="max-height: 300px;">
            </div>
          </div>
        </div>
      `;
      parent.insertAdjacentHTML('beforeend', mobileFieldHtml);
    }

    // Image Preview Logic
    const imageInput = document.getElementById('bannerImageInput');
    const previewContainer = document.getElementById('previewContainer');
    const previewImage = document.getElementById('previewImage');
    const mobileImageInput = document.getElementById('mobileBannerImageInput');
    const mobilePreviewContainer = document.getElementById('mobilePreviewContainer');
    const mobilePreviewImage = document.getElementById('mobilePreviewImage');

    if (imageInput) {
      imageInput.addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (file) {
          if (file.size > maxUploadBytes) {
            alert(`파일 크기는 ${maxUploadMb}MB를 초과할 수 없습니다.`);
            imageInput.value = '';
            previewImage.src = '';
            previewContainer.classList.add('hidden');
            return;
          }
          const reader = new FileReader();
          reader.onload = function (e) {
            previewImage.src = e.target.result;
            previewContainer.classList.remove('hidden');
          };
          reader.readAsDataURL(file);
        } else {
          previewImage.src = '';
          previewContainer.classList.add('hidden');
        }
      });
    }

    if (mobileImageInput) {
      mobileImageInput.addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (file) {
          if (file.size > maxUploadBytes) {
            alert(`파일 크기는 ${maxUploadMb}MB를 초과할 수 없습니다.`);
            mobileImageInput.value = '';
            mobilePreviewImage.src = '';
            mobilePreviewContainer.classList.add('hidden');
            return;
          }
          const reader = new FileReader();
          reader.onload = function (e) {
            mobilePreviewImage.src = e.target.result;
            mobilePreviewContainer.classList.remove('hidden');
          };
          reader.readAsDataURL(file);
        } else {
          mobilePreviewImage.src = '';
          mobilePreviewContainer.classList.add('hidden');
        }
      });
    }
  })();
</script>
