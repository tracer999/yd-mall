<div class="flex justify-center">
  <div class="w-full lg:max-w-5xl">
    <div class="mb-6">
      <p class="mt-1 text-sm text-gray-500">메인 배너 또는 카테고리별 배너를 등록합니다.</p>
    </div>

    <form action="<%= banner ? '/admin/banners/edit/' + banner.id : '/admin/banners/add' %>" method="POST"
      enctype="multipart/form-data" class="space-y-6">
      <%# 이 화면과 무관한 group_key(예: 홈 프로모션 'home_promo')를 편집 시 보존하기 위한 hidden. %>
      <input type="hidden" name="existing_group_key" value="<%= banner && banner.group_key ? banner.group_key : '' %>">
      <div class="bg-white shadow-sm rounded-xl border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-100">
          <h3 class="text-lg font-semibold text-gray-800">기본 정보</h3>
        </div>
        <div class="px-6 py-5 space-y-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">배너 타입</label>
            <div class="flex flex-wrap gap-4">
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="MAIN"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='MAIN') ? 'checked' : '' %>>
                <span>메인 슬라이더 (이미지 배너)</span>
              </label>
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="CATEGORY"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='CATEGORY') ? 'checked' : '' %>>
                <span>카테고리 배너</span>
              </label>
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="POPUP"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='POPUP') ? 'checked' : '' %>>
                <span>팝업 배너</span>
              </label>
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="BRAND"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='BRAND') ? 'checked' : '' %>>
                <span>브랜드 배너</span>
              </label>
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="MENU"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='MENU') ? 'checked' : '' %>>
                <span>메뉴별 배너</span>
              </label>
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input type="radio" name="banner_type" value="PROMO"
                  class="text-blue-600 border-gray-300 focus:ring-blue-500" <%=(currentType==='PROMO') ? 'checked' : '' %>>
                <span>프로모션 배너</span>
              </label>
            </div>
          </div>

          <%#
            프로모션 배너 — 페이지 빌더 'promotion_banner' 섹션이 group_key 로 집어간다.
            섹션의 '배너 그룹 키'와 같은 값을 넣어야 노출되므로, 기존 그룹을 datalist 로 제시한다.
          %>
          <div id="promoGroupField" class="hidden">
            <label class="block text-sm font-medium text-gray-700 mb-2">배너 그룹 키</label>
            <input type="text" name="promo_group" id="promoGroupInput" maxlength="50"
              list="promoGroupOptions" placeholder="예: home_promo"
              value="<%= typeof currentPromoKey !== 'undefined' && currentPromoKey ? currentPromoKey : '' %>"
              class="font-mono" />
            <datalist id="promoGroupOptions">
              <% (typeof promoGroups !== 'undefined' ? promoGroups : []).forEach(function (g) { %>
                <option value="<%= g.key %>"></option>
              <% }) %>
            </datalist>
            <p class="mt-1 text-xs text-gray-400">
              페이지 빌더 → 프로모션 배너 섹션의 <span class="font-medium text-gray-600">배너 그룹 키</span>와 같은 값을 넣으세요.
              같은 키를 가진 배너들이 한 캐러셀로 묶여 노출됩니다.
            </p>
            <p class="mt-1 text-xs text-gray-400">영문으로 시작하고 영문·숫자·<span class="font-mono">_</span>·<span class="font-mono">-</span> 만 쓸 수 있습니다. (최대 50자)</p>
          </div>

          <div id="menuTargetField" class="hidden">
            <label class="block text-sm font-medium text-gray-700 mb-2">노출 메뉴</label>
            <select name="menu_target" id="menuTargetSelect"
              class="block w-full text-sm border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500">
              <% (menuTargets || []).forEach(function(t) { %>
                <option value="<%= t.key %>" data-pool="<%= t.pool || '' %>" <%= currentMenuKey === t.key ? 'selected' : '' %>><%= t.label %></option>
              <% }) %>
            </select>
            <p class="mt-1 text-xs text-gray-400">선택한 프론트 메뉴 목록 페이지 상단에 이 배너가 노출됩니다.</p>
            <%# 상품 캐러셀이 걸린 메뉴(쇼핑특가·베스트·신상품)는 배너가 그 위에 함께 뜬다. %>
            <p id="menuPoolNotice" class="mt-2 hidden rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-900">
              이 메뉴에는 상품 캐러셀이 함께 노출됩니다. 배너는 상품 캐러셀 <span class="font-semibold">위</span>에 표시됩니다.
            </p>
          </div>

          <div id="categoryField" class="hidden">
            <label id="categoryFieldLabel" class="block text-sm font-medium text-gray-700 mb-2">대상 선택</label>

            <%# 전체 공통 배너 — 개별 설정이 없는 카테고리/브랜드에 폴백으로 노출. 체크 시 대상 선택을 감춘다. %>
            <label class="mb-3 inline-flex items-start gap-2 text-sm text-gray-700 rounded-md border border-gray-200 bg-gray-50 px-3 py-2 w-full">
              <input type="checkbox" name="is_common" value="1" id="isCommonCheckbox"
                class="mt-0.5 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
                <%= ((banner && banner.group_key && banner.group_key.indexOf('common:') === 0) || (!banner && typeof preselectCommon !== 'undefined' && preselectCommon)) ? 'checked' : '' %>>
              <span>
                <span id="isCommonLabel" class="font-medium">전체 공통 배너로 설정</span>
                <span class="block text-xs text-gray-400 mt-0.5">개별 설정이 없는 카테고리/브랜드 접근 시 이 배너가 노출됩니다. 개별 설정이 있으면 개별 배너가 우선합니다.</span>
              </span>
            </label>

            <div id="categorySelectWrap">
              <select name="category_id" id="categoryIdSelect"
                class="block w-full text-sm border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500">
                <option value="">선택하세요</option>
                <% if (categories && categories.length) { %>
                  <% categories.forEach(function(category) { %>
                    <option value="<%= category.id %>" data-type="<%= category.type %>" <%=
                      (banner && String(banner.category_id)===String(category.id)) ||
                      (!banner && typeof preselectTarget !== 'undefined' && preselectTarget && Number(preselectTarget)===category.id)
                      ? 'selected' : '' %>><%= category.name %>
                    </option>
                    <% }) %>
                      <% } %>
              </select>
              <p id="categoryFieldHint" class="mt-1 text-xs text-gray-400">배너가 노출될 대상을 선택합니다.</p>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">배너 제목</label>
            <input type="text" name="title" placeholder="예: 봄맞이 할인 이벤트" value="<%= banner ? banner.title : '' %>" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">이미지 업로드</label>
            <%#
              메인 슬라이더(MAIN)만 영상을 재생할 수 있다(hero_media.ejs). 다른 타입은 <img> 로만
              그려서 영상이 들어가면 깨지므로 accept 를 타입에 따라 바꾼다(서버도 같은 규칙으로 막는다).
            %>
            <input type="file" name="banner_image" id="bannerImageInput" accept="image/*"
              class="block w-full text-sm text-gray-500 file:mr-4 file:py-3 file:px-6 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 border-gray-300"
              <%=banner ? '' : 'required' %> />
            <p id="bannerSizeGuide" class="mt-1 text-xs text-gray-500 leading-relaxed"></p>
            <p id="bannerUploadLimit" class="mt-1 text-xs text-blue-700 leading-relaxed">최대 업로드 용량: <%= maxUploadFileMb || 20 %>MB</p>
            <% if(banner && banner.image_url) { %>
              <input type="hidden" name="existing_image" value="<%= banner.image_url %>">
              <p class="mt-1 text-[11px] text-gray-400">PC 이미지는 배너의 본체라 지울 수 없습니다. 새 파일을 올리면 교체되고, 배너 자체가 필요 없으면 목록에서 배너를 삭제하세요.</p>
              <% } %>

                <!-- Image Preview -->
                <%# 이미지/영상 미리보기는 한 칸을 나눠 쓴다 — 고른 파일 종류에 따라 스크립트가 바꿔 낸다. %>
                <% var _pcIsVideo = banner && banner.image_url && isVideoUrl(banner.image_url); %>
                <div id="previewContainer" class="mt-4 <%= banner && banner.image_url ? '' : 'hidden' %>">
                  <p class="text-sm text-gray-700 mb-2 font-medium">✨ 미리보기</p>
                  <div class="border rounded-lg overflow-hidden bg-gray-50">
                    <img id="previewImage" src="<%= banner && !_pcIsVideo ? banner.image_url : '' %>" alt="Banner Preview"
                      class="max-w-full h-auto mx-auto object-contain <%= _pcIsVideo ? 'hidden' : '' %>" style="max-height: 300px;">
                    <video id="previewVideo" src="<%= _pcIsVideo ? banner.image_url : '' %>" muted loop playsinline autoplay
                      class="max-w-full h-auto mx-auto object-contain <%= _pcIsVideo ? '' : 'hidden' %>" style="max-height: 300px;"></video>
                  </div>
                </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">연결 링크 (URL)</label>
            <input type="text" name="link_url" placeholder="/products/view/1 또는 외부 URL"
              value="<%= banner ? banner.link_url : '' %>" />
            <p class="mt-1 text-xs text-gray-400">이미지 배너 슬라이더의 <strong>이동 버튼</strong>도 이 링크로 갑니다.</p>
          </div>

          <%#
            ── 배너 문구(오버레이) ──
            · 메인 슬라이더(MAIN): 큰 제목 + 추가 문구(최대 2줄) + 이동 버튼/색/정렬 — hero_banner.ejs
            · 카테고리·브랜드·메뉴별·프로모션: '배너 문구'(최대 3줄)만. 배너 제목은 지금 크기 그대로,
              이 문구는 크게(줄 수에 따라 크기 조절) 배너 위에 얹힌다 — partials/banner_copy.ejs
            · 팝업: 렌더할 자리가 없어 블록 전체를 감춘다(서버도 저장하지 않는다).
            문구 입력칸은 **하나**다. 타입별로 두 벌 두면 숨긴 칸도 함께 전송돼 값이 배열로 들어온다.
          %>
          <div id="overlayField" class="hidden rounded-lg border border-gray-200 bg-gray-50/60 p-4 space-y-4">
            <div class="flex items-center justify-between">
              <h3 class="text-sm font-bold text-gray-800">배너 문구 <span id="overlayFieldNote" class="font-normal text-gray-400">(비우면 이미지만 노출)</span></h3>
            </div>

            <div id="overlayTitleField">
              <label class="block text-sm font-medium text-gray-700 mb-2">배너 제목 (큰 글자)</label>
              <input type="text" name="overlay_title" maxlength="120" placeholder="예: 건강식품 B2B 유통 플랫폼"
                value="<%= banner && banner.overlay_title ? banner.overlay_title : '' %>" />
            </div>

            <div>
              <label id="overlaySubtitleLabel" class="block text-sm font-medium text-gray-700 mb-2">배너 문구 (최대 3줄)</label>
              <textarea name="overlay_subtitle" id="overlaySubtitleInput" rows="3" maxlength="300"
                class="block w-full text-sm border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                placeholder="한 줄에 하나씩 입력하세요."><%= banner && banner.overlay_subtitle ? banner.overlay_subtitle : '' %></textarea>
              <p id="overlaySubtitleHint" class="mt-1 text-xs text-gray-400"></p>
            </div>

            <div id="overlayMainOnly" class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">이동 버튼 문구</label>
                <input type="text" name="overlay_button_text" maxlength="40" placeholder="예: 이용가이드 보러가기"
                  value="<%= banner && banner.overlay_button_text ? banner.overlay_button_text : '' %>" />
                <p class="mt-1 text-xs text-gray-400">비우면 버튼이 나오지 않습니다.</p>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">버튼 색상</label>
                <%# 배너 이미지와 색을 맞출 수 있게 컬러피커 + HEX 직접 입력을 함께 둔다(둘은 서로 동기화). %>
                <div class="flex items-center gap-2">
                  <input type="color" id="overlayButtonColorPicker"
                    value="<%= banner && banner.overlay_button_color ? banner.overlay_button_color : '#1a7f37' %>"
                    class="h-10 w-12 p-1 border border-gray-300 rounded-md bg-white cursor-pointer">
                  <input type="text" name="overlay_button_color" id="overlayButtonColorHex" maxlength="7" placeholder="#1a7f37"
                    value="<%= banner && banner.overlay_button_color ? banner.overlay_button_color : '' %>"
                    class="flex-1 min-w-0 font-mono text-sm" />
                </div>
                <p class="mt-1 text-xs text-gray-400">글자색(흰/검정)은 배경 밝기에 따라 자동 선택됩니다.</p>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">문구 정렬</label>
                <select name="overlay_align" class="block w-full text-sm border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500">
                  <% ['LEFT','CENTER','RIGHT'].forEach(function (a) { %>
                    <option value="<%= a %>" <%= banner && banner.overlay_align === a ? 'selected' : (!banner && a === 'LEFT' ? 'selected' : '') %>>
                      <%= a === 'LEFT' ? '왼쪽' : (a === 'CENTER' ? '가운데' : '오른쪽') %>
                    </option>
                  <% }); %>
                </select>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">노출 순서</label>
              <input type="number" name="display_order" value="<%= banner ? banner.display_order : 0 %>" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">시작일</label>
              <input type="date" name="start_date"
                value="<%= banner && banner.start_date ? new Date(banner.start_date).toISOString().split('T')[0] : '' %>" />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">종료일</label>
              <input type="date" name="end_date"
                value="<%= banner && banner.end_date ? new Date(banner.end_date).toISOString().split('T')[0] : '' %>" />
            </div>
          </div>

          <div class="flex items-center mt-2">
            <input type="checkbox" class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
              name="is_active" id="isActive" <%=(!banner) || (banner && banner.is_active) ? 'checked' : '' %>
            />
            <label class="ml-2 block text-sm text-gray-700" for="isActive">
              활성화 (즉시 노출)
            </label>
          </div>
        </div>
      </div>

      <div class="flex justify-end pt-2">
        <button type="submit"
          class="inline-flex items-center justify-center h-[50px] px-6 text-base font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700">
          저장하기
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    const maxUploadMb = Number('<%= maxUploadFileMb || 20 %>');
    // 영상은 상한이 따로다(서버도 인스턴스가 다르다) — 파일 종류에 따라 나눠 검사한다.
    const maxVideoMb = Number('<%= typeof maxVideoUploadMb !== "undefined" && maxVideoUploadMb ? maxVideoUploadMb : 80 %>');
    const isVideoFile = (file) => !!file && (String(file.type || '').indexOf('video/') === 0
      || /\.(mp4|webm|mov|m4v|ogv)$/i.test(file.name || ''));
    /** 이 파일이 상한을 넘겼는가 — 넘겼으면 안내 문구, 아니면 null. */
    function overLimit(file) {
      const video = isVideoFile(file);
      const limitMb = video ? maxVideoMb : maxUploadMb;
      if (file.size <= limitMb * 1024 * 1024) return null;
      return (video ? '동영상' : '이미지') + ' 파일 크기는 ' + limitMb + 'MB를 초과할 수 없습니다.';
    }
    const typeRadios = document.querySelectorAll('input[name="banner_type"]');
    const categoryField = document.getElementById('categoryField');
    const menuTargetField = document.getElementById('menuTargetField');
    const promoGroupField = document.getElementById('promoGroupField');
    const promoGroupInput = document.getElementById('promoGroupInput');
    const sizeGuide = document.getElementById('bannerSizeGuide');

    const categoryIdSelect = document.getElementById('categoryIdSelect');
    const menuTargetSelect = document.getElementById('menuTargetSelect');
    const menuPoolNotice = document.getElementById('menuPoolNotice');
    const isCommonCheckbox = document.getElementById('isCommonCheckbox');
    const categorySelectWrap = document.getElementById('categorySelectWrap');

    /* 전체 공통 배너 체크 시 대상 선택을 감춘다(서버는 is_common=1 이면 대상값을 무시). */
    function updateCommonToggle() {
      const selected = document.querySelector('input[name="banner_type"]:checked');
      const isBrand = selected && selected.value === 'BRAND';
      const on = isCommonCheckbox && isCommonCheckbox.checked;
      if (categorySelectWrap) categorySelectWrap.classList.toggle('hidden', on);
      const commonLabel = document.getElementById('isCommonLabel');
      if (commonLabel) {
        commonLabel.textContent = isBrand
          ? '전체 공통 브랜드 배너로 설정'
          : '전체 공통 카테고리 배너로 설정';
      }
    }

    /* 선택한 메뉴에 상품 캐러셀(product_group)이 걸려 있으면 공존 안내를 띄운다. */
    function updateMenuPoolNotice() {
      if (!menuTargetSelect || !menuPoolNotice) return;
      const opt = menuTargetSelect.selectedOptions[0];
      const hasPool = !!(opt && opt.getAttribute('data-pool'));
      menuPoolNotice.classList.toggle('hidden', !hasPool);
    }

    /*
     * 배너 문구 블록 — 타입에 따라 보이는 항목이 다르다(서버 readOverlay 와 같은 갈래).
     *   MAIN                      : 제목(큰 글자) + 문구 2줄 + 버튼/색/정렬
     *   CATEGORY·BRAND·MENU·PROMO : 문구 3줄만
     *   POPUP                     : 블록 전체 숨김
     */
    const COPY_TYPES = ['CATEGORY', 'BRAND', 'MENU', 'PROMO'];

    function updateOverlayFields(type) {
      const overlayField = document.getElementById('overlayField');
      if (!overlayField) return;
      const isMain = type === 'MAIN';
      const isCopy = COPY_TYPES.indexOf(type) !== -1;

      overlayField.classList.toggle('hidden', !(isMain || isCopy));

      const titleField = document.getElementById('overlayTitleField');
      const mainOnly = document.getElementById('overlayMainOnly');
      if (titleField) titleField.classList.toggle('hidden', !isMain);
      if (mainOnly) mainOnly.classList.toggle('hidden', !isMain);

      const note = document.getElementById('overlayFieldNote');
      const label = document.getElementById('overlaySubtitleLabel');
      const input = document.getElementById('overlaySubtitleInput');
      const hint = document.getElementById('overlaySubtitleHint');
      if (note) {
        note.textContent = isMain
          ? '(이미지 배너 슬라이더 전용 · 비우면 이미지만 노출)'
          : '(비우면 이미지만 노출)';
      }
      if (label) label.textContent = isMain ? '추가 문구 (최대 2줄)' : '배너 문구 (최대 3줄)';
      if (input) {
        input.rows = isMain ? 2 : 3;
        input.placeholder = isMain
          ? '한 줄에 하나씩. 3줄째부터는 저장되지 않습니다.'
          : '한 줄에 하나씩. 4줄째부터는 저장되지 않습니다.';
      }
      if (hint) {
        hint.textContent = isMain
          ? '배너 제목(큰 글자) 아래에 작게 표시됩니다.'
          : '배너 제목보다 크게 표시됩니다. 줄 수가 많을수록 글자 크기는 자동으로 작아집니다.';
      }
    }

    function updateCategoryVisibility() {
      const selected = document.querySelector('input[name="banner_type"]:checked');
      // 메뉴별 배너 선택 필드 토글
      if (menuTargetField) {
        menuTargetField.classList.toggle('hidden', !(selected && selected.value === 'MENU'));
      }
      // 프로모션 그룹 키 — PROMO 일 때만 보이고, 그때만 필수다(숨긴 채 required 면 제출이 막힌다).
      if (promoGroupField) {
        const isPromo = !!(selected && selected.value === 'PROMO');
        promoGroupField.classList.toggle('hidden', !isPromo);
        if (promoGroupInput) promoGroupInput.required = isPromo;
      }
      updateOverlayFields(selected && selected.value);
      if (selected && (selected.value === 'CATEGORY' || selected.value === 'BRAND')) {
        categoryField.classList.remove('hidden');
        updateCommonToggle();

        // 타입에 따라 라벨/안내를 바꿔 '카테고리 vs 브랜드' 혼동을 없앤다.
        const isBrand = selected.value === 'BRAND';
        const fieldLabel = document.getElementById('categoryFieldLabel');
        const fieldHint = document.getElementById('categoryFieldHint');
        const placeholderOpt = categoryIdSelect.querySelector('option[value=""]');
        if (fieldLabel) fieldLabel.textContent = isBrand ? '브랜드 선택' : '카테고리 선택';
        if (fieldHint) fieldHint.textContent = isBrand
          ? '이 배너가 노출될 브랜드를 선택합니다.'
          : '이 배너가 노출될 카테고리를 선택합니다.';
        if (placeholderOpt) placeholderOpt.textContent = isBrand ? '브랜드를 선택하세요' : '카테고리를 선택하세요';

        const options = categoryIdSelect.querySelectorAll('option');
        let firstVisible = null;
        let isSelectedVisible = false;

        options.forEach(opt => {
          if (opt.value === '') return;
          const type = opt.getAttribute('data-type');
          let shouldShow = false;

          if (selected.value === 'BRAND' && type === 'BRAND') {
            shouldShow = true;
          } else if (selected.value === 'CATEGORY' && type !== 'BRAND') {
            shouldShow = true;
          }

          if (shouldShow) {
            opt.hidden = false;
            opt.disabled = false;
            if (!firstVisible) firstVisible = opt;
            if (opt.selected) isSelectedVisible = true;
          } else {
            opt.hidden = true;
            opt.disabled = true;
          }
        });

        // 만약 기존에 선택되어 있던 값이 숨김 처리되었다면 선택 해제
        if (!isSelectedVisible && categoryIdSelect.value !== '') {
          categoryIdSelect.value = '';
        }

      } else {
        categoryField.classList.add('hidden');
        categoryIdSelect.value = '';
      }
    }

    /*
     * 파일 선택 칸 — 영상은 메인 슬라이더(MAIN)만 재생할 수 있다(hero_media.ejs).
     * 다른 타입은 <img> 로만 그려 영상이 들어가면 깨지므로 accept 를 좁히고,
     * 이미 골라 둔 영상이 있으면 비운다(그대로 두면 저장 때 서버가 400 으로 막는다).
     */
    function updateMediaAccept() {
      const selected = document.querySelector('input[name="banner_type"]:checked');
      const allowVideo = !!(selected && selected.value === 'MAIN');
      const accept = allowVideo ? 'image/*,video/*' : 'image/*';

      ['bannerImageInput', 'mobileBannerImageInput'].forEach(function (id) {
        const el = document.getElementById(id);
        if (!el) return;
        el.setAttribute('accept', accept);
        if (!allowVideo && isVideoFile(el.files && el.files[0])) {
          el.value = '';
          el.dispatchEvent(new Event('change'));
        }
      });

      const limitText = allowVideo
        ? '최대 업로드 용량: 이미지 ' + maxUploadMb + 'MB · 동영상 ' + maxVideoMb + 'MB (동영상 파일도 등록할 수 있습니다)'
        : '최대 업로드 용량: ' + maxUploadMb + 'MB';
      ['bannerUploadLimit', 'mobileUploadLimit'].forEach(function (id) {
        const el = document.getElementById(id);
        if (el) el.textContent = limitText;
      });
    }

    function updateSizeGuide() {
      if (!sizeGuide) return;
      const selected = document.querySelector('input[name="banner_type"]:checked');
      if (!selected) {
        sizeGuide.textContent = '배너 타입을 선택하면 권장 이미지 사이즈가 표시됩니다.';
        return;
      }

      if (selected.value === 'MAIN') {
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">메인 배너 권장 사이즈</span><br>
          기본: <span class="font-mono">1920 × 600px</span> (가로:세로 <span class="font-mono">3.2 : 1</span>)<br>
          2배 해상도 작업 시: <span class="font-mono">3840 × 1200px</span><br>
          <span class="text-[11px] text-gray-400">브라우저 전체 폭에 맞춰 노출되므로, 위 비율(3.2:1)을 유지해서 제작해 주세요.</span><br>
          <span class="font-medium text-gray-700">동영상도 등록할 수 있습니다</span>
          <span class="text-[11px] text-gray-400">(mp4 · webm 권장 / 같은 3.2:1 비율 · 소리 없이 자동 반복 재생되므로 자막이 필요하면 영상에 넣어 주세요)</span>
        `;
      } else if (selected.value === 'CATEGORY') {
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">카테고리 배너 권장 사이즈</span><br>
          기본: <span class="font-mono">900 × 200px</span> (가로:세로 <span class="font-mono">4.5 : 1</span> 내외)</span><br>
          2배 해상도 작업 시: <span class="font-mono">1800 × 400px</span><br>
          <span class="text-[11px] text-gray-400">카테고리 상단 배너 영역은 약 900px 폭 기준이며, 위 비율(대략 4.5:1)을 유지해서 제작하시면 됩니다.</span>
        `;
      } else if (selected.value === 'POPUP') {
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">팝업 배너 권장 사이즈</span><br>
          기본: <span class="font-mono">960 × 960px</span> (가로:세로 <span class="font-mono">1 : 1</span>, 정사각형)<br>
          2배 해상도 작업 시: <span class="font-mono">1920 × 1920px</span><br>
          <span class="text-[11px] text-gray-400">팝업은 정사각형으로 노출되므로, 1:1 비율만 유지해 주시면 됩니다.</span>
        `;
      } else if (selected.value === 'BRAND') {
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">브랜드 상단 배너 권장 사이즈</span><br>
          기본: <span class="font-mono">900 × 200px</span> (가로:세로 <span class="font-mono">4.5 : 1</span> 내외)<br>
          2배 해상도 작업 시: <span class="font-mono">1800 × 400px</span><br>
          <span class="text-[11px] text-gray-400">브랜드 상세 페이지 최상단에 노출되는 맞춤 배너입니다.</span>
        `;
      } else if (selected.value === 'PROMO') {
        // 섹션 레이아웃에 따라 비율이 다르다(partials/sections/promotion_banner.ejs).
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">프로모션 배너 권장 사이즈</span><br>
          가로형(rect): <span class="font-mono">800 × 300px</span> (가로:세로 <span class="font-mono">16 : 6</span>)<br>
          세로형(vertical): <span class="font-mono">600 × 800px</span> (가로:세로 <span class="font-mono">3 : 4</span>)<br>
          <span class="text-[11px] text-gray-400">페이지 빌더 섹션의 레이아웃 설정에 맞춰 제작하세요. 한 그룹 안에서는 비율을 통일해야 캐러셀이 고르게 보입니다.</span>
        `;
      } else if (selected.value === 'MENU') {
        sizeGuide.innerHTML = `
          <span class="font-medium text-gray-700">메뉴별 배너 권장 사이즈</span><br>
          기본: <span class="font-mono">1200 × 260px</span> (가로:세로 <span class="font-mono">4.6 : 1</span> 내외)<br>
          2배 해상도 작업 시: <span class="font-mono">2400 × 520px</span><br>
          <span class="text-[11px] text-gray-400">선택한 메뉴(베스트·신상품 등) 목록 페이지 상단에 노출됩니다.</span>
        `;
      } else {
        sizeGuide.textContent = '배너 타입을 선택하면 권장 이미지 사이즈가 표시됩니다.';
      }
    }

    // 버튼 색상 — 컬러피커와 HEX 입력을 양방향 동기화한다(HEX 가 저장되는 값이다).
    (function () {
      const picker = document.getElementById('overlayButtonColorPicker');
      const hex = document.getElementById('overlayButtonColorHex');
      if (!picker || !hex) return;
      picker.addEventListener('input', function () { hex.value = picker.value; });
      hex.addEventListener('input', function () {
        if (/^#[0-9a-fA-F]{6}$/.test(hex.value.trim())) picker.value = hex.value.trim();
      });
    })();

    typeRadios.forEach(r => r.addEventListener('change', updateCategoryVisibility));
    typeRadios.forEach(r => r.addEventListener('change', updateSizeGuide));
    typeRadios.forEach(r => r.addEventListener('change', updateMediaAccept));
    if (menuTargetSelect) menuTargetSelect.addEventListener('change', updateMenuPoolNotice);
    if (isCommonCheckbox) isCommonCheckbox.addEventListener('change', updateCommonToggle);
    updateCategoryVisibility();
    updateSizeGuide();
    updateMenuPoolNotice();

    <% var _mobileIsVideo = banner && banner.mobile_image_url && isVideoUrl(banner.mobile_image_url); %>
    // Inject mobile image upload field right after PC banner field.
    const pcImageInput = document.getElementById('bannerImageInput');
    if (pcImageInput && pcImageInput.parentElement) {
      const parent = pcImageInput.parentElement;
      const mobileFieldHtml = `
        <div class="mt-6">
          <label class="block text-sm font-medium text-gray-700 mb-2">모바일용 이미지 업로드</label>
          <input type="file" name="mobile_banner_image" id="mobileBannerImageInput" accept="image/*" class="block w-full text-sm text-gray-500 file:mr-4 file:py-3 file:px-6 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100 border-gray-300" />
          <p class="mt-1 text-xs text-gray-500 leading-relaxed">미등록 시 PC 이미지(또는 동영상)를 모바일에서도 사용합니다.</p>
          <p class="mt-1 text-xs text-emerald-700 leading-relaxed">권장 사이즈: 390 × 422px, 2배 해상도 작업 시 780 × 844px</p>
          <p id="mobileUploadLimit" class="mt-1 text-xs text-emerald-700 leading-relaxed">최대 업로드 용량: <%= maxUploadFileMb || 20 %>MB</p>
          <input type="hidden" name="existing_mobile_image" value="<%= banner && banner.mobile_image_url ? banner.mobile_image_url : '' %>">
          <% if (banner && banner.mobile_image_url) { %>
          <label class="mt-2 inline-flex items-center gap-1.5 text-xs text-red-600">
            <input type="checkbox" name="clear_mobile_image" id="clearMobileImage" value="1" class="w-4 h-4 rounded border-gray-300"> 등록된 모바일 이미지 삭제
          </label>
          <p class="mt-1 text-[11px] text-gray-400">삭제하면 모바일에서도 PC 이미지를 사용합니다. 새 파일을 함께 올리면 교체가 우선입니다.</p>
          <% } %>
          <div id="mobilePreviewContainer" class="mt-4 <%= banner && banner.mobile_image_url ? '' : 'hidden' %>">
            <p class="text-sm text-gray-700 mb-2 font-medium">모바일 이미지 미리보기</p>
            <div class="border rounded-lg overflow-hidden bg-gray-50">
                <img id="mobilePreviewImage" src="<%= banner && banner.mobile_image_url && !_mobileIsVideo ? banner.mobile_image_url : '' %>" alt="Mobile Banner Preview" class="max-w-full h-auto mx-auto object-contain <%= _mobileIsVideo ? 'hidden' : '' %>" style="max-height: 300px;">
                <video id="mobilePreviewVideo" src="<%= _mobileIsVideo ? banner.mobile_image_url : '' %>" muted loop playsinline autoplay class="max-w-full h-auto mx-auto object-contain <%= _mobileIsVideo ? '' : 'hidden' %>" style="max-height: 300px;"></video>
            </div>
          </div>
        </div>
      `;
      parent.insertAdjacentHTML('beforeend', mobileFieldHtml);
    }

    // 파일 칸의 accept·안내 문구를 지금 선택된 배너 타입에 맞춘다(모바일 칸 주입 뒤에 호출해야 한다).
    updateMediaAccept();

    /*
     * 미리보기 — 고른 파일이 이미지면 <img>, 동영상이면 <video> 로 낸다.
     *
     * 영상은 FileReader 의 dataURL 로 만들면 수십 MB 짜리 문자열이 되어 브라우저가 멈춘다.
     * objectURL 을 쓰고, 새로 고를 때마다 이전 것을 revoke 한다(안 하면 페이지를 떠날 때까지 물고 있다).
     */
    const imageInput = document.getElementById('bannerImageInput');
    const mobileImageInput = document.getElementById('mobileBannerImageInput');
    const pcSlot = {
      box: document.getElementById('previewContainer'),
      img: document.getElementById('previewImage'),
      video: document.getElementById('previewVideo'),
    };
    const mobileSlot = {
      box: document.getElementById('mobilePreviewContainer'),
      img: document.getElementById('mobilePreviewImage'),
      video: document.getElementById('mobilePreviewVideo'),
    };

    function showPreview(slot, src, asVideo) {
      if (!slot.box || !slot.img || !slot.video) return;
      slot.img.src = (src && !asVideo) ? src : '';
      slot.video.src = (src && asVideo) ? src : '';
      slot.img.classList.toggle('hidden', !!asVideo);
      slot.video.classList.toggle('hidden', !asVideo);
      slot.box.classList.toggle('hidden', !src);
      // 자동재생이 막히는 브라우저가 있어도 미리보기는 첫 프레임이 보이면 충분하다.
      if (src && asVideo) { const p = slot.video.play(); if (p && p.catch) p.catch(function () {}); }
    }

    // 저장돼 있던 미디어 — 새로 고른 파일을 취소하면 여기로 되돌아간다.
    const savedPcSrc = '<%= banner && banner.image_url ? banner.image_url : "" %>';
    const savedPcIsVideo = <%= _pcIsVideo ? 'true' : 'false' %>;
    const savedMobileSrc = '<%= banner && banner.mobile_image_url ? banner.mobile_image_url : "" %>';
    const savedMobileIsVideo = <%= _mobileIsVideo ? 'true' : 'false' %>;

    let pcObjectUrl = '';
    let mobileObjectUrl = '';

    if (imageInput) {
      imageInput.addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (pcObjectUrl) { URL.revokeObjectURL(pcObjectUrl); pcObjectUrl = ''; }
        if (!file) return showPreview(pcSlot, savedPcSrc, savedPcIsVideo);

        const over = overLimit(file);
        if (over) {
          alert(over);
          imageInput.value = '';
          return showPreview(pcSlot, savedPcSrc, savedPcIsVideo);
        }
        pcObjectUrl = URL.createObjectURL(file);
        showPreview(pcSlot, pcObjectUrl, isVideoFile(file));
      });
    }

    // 모바일 이미지 삭제 — 저장된 이미지를 비운다. 새 파일을 고르면 교체가 이기므로 체크를 푼다
    // (서버 postEdit 의 우선순위: 새 파일 > 비우기 > 기존).
    const clearMobileImage = document.getElementById('clearMobileImage');

    function syncMobilePreview() {
      if (mobileObjectUrl) return; // 새로 고른 파일이 있으면 그게 우선
      const cleared = clearMobileImage && clearMobileImage.checked;
      showPreview(mobileSlot, cleared ? '' : savedMobileSrc, savedMobileIsVideo);
    }

    if (clearMobileImage) clearMobileImage.addEventListener('change', syncMobilePreview);

    if (mobileImageInput) {
      mobileImageInput.addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (mobileObjectUrl) { URL.revokeObjectURL(mobileObjectUrl); mobileObjectUrl = ''; }
        if (!file) return syncMobilePreview();

        const over = overLimit(file);
        if (over) {
          alert(over);
          mobileImageInput.value = '';
          return syncMobilePreview();
        }
        if (clearMobileImage) clearMobileImage.checked = false;
        mobileObjectUrl = URL.createObjectURL(file);
        showPreview(mobileSlot, mobileObjectUrl, isVideoFile(file));
      });
    }
  })();
</script>
