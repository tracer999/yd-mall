<%
  /*
   * 메인 슬라이더 관리 — 히어로 방식(상품 쇼케이스 / 이미지 배너) 선택 + 선택한 방식의 콘텐츠 편집.
   * locals: activeVariant(적용 중), mode(열람 중), mainSlides, featureSlides, mainBanners
   *
   * activeVariant 는 site_settings.hero_variant. 프론트는 이 값 하나로 둘 중 하나만 렌더한다.
   * mode 는 화면에서 보고 있는 방식 — 적용 중이 아닌 방식도 미리 채워둘 수 있게 분리했다.
   */
  const isShowcase = mode === 'product_showcase';
  const isPreviewingInactive = mode !== activeVariant;

  /*
   * 배치(테마)는 이 화면 소관이 아니다 — 페이지 빌더 > 테마 관리에서 정한다.
   * 여기서는 "지금 어떤 배치인지"만 읽어 보여주고, 그 안에 넣을 콘텐츠를 고른다.
   */
  const LAYOUT_INFO = {
    split_feature: { no: 1, name: '좌 히어로 + 우 상품 카드' },
    full_width:    { no: 2, name: '전체폭 히어로' },
    full_bleed:    { no: 3, name: '풀블리드(에디토리얼)' },
    // 옛 값이 남아 있어도 이름이 비지 않게 한다.
    showcase:      { no: 1, name: '좌 히어로 + 우 상품 카드' },
    banner:        { no: 2, name: '전체폭 히어로' },
    editorial:     { no: 3, name: '풀블리드(에디토리얼)' },
  };
  const _layoutInfo = locals.themeLayout ? LAYOUT_INFO[locals.themeLayout] : null;

  const _autoBest = Number(locals.autoBestCount || 0);
  const _autoMax = Number(locals.autoMaxCount || 7);
  // 슬롯별 상한·남은 자리. 중앙은 여러 장, 우측 카드는 한 장만 렌더된다.
  const _cap  = locals.slotCap  || { MAIN: 7, FEATURE: 1 };
  const _room = locals.slotRoom || { MAIN: 0, FEATURE: 0 };
  const _maxSlides = Number(_cap.MAIN || 7);
  // 실제 노출 기준(활성 슬라이드)으로 센다 — 꺼둔 슬라이드는 홈에 안 나오므로 안내가 갈리면 안 된다.
  const _manualCount = Number(locals.activeMainCount || 0);
  // 쇼케이스인데 고른 상품도, 자동으로 채울 베스트도 없으면 히어로가 아예 안 뜬다.
  const _needsProducts = isShowcase && _manualCount === 0 && _autoBest === 0;

  const MODES = [
    {
      key: 'product_showcase',
      name: '상품 쇼케이스',
      desc: '상품을 골라 슬라이드로 돌립니다. 고르지 않으면 베스트 상위 ' + _autoMax + '개가 자동으로 노출됩니다.',
    },
    {
      key: 'full_banner',
      name: '이미지 배너 슬라이드',
      desc: '직접 만든 이미지 배너를 넘기는 방식. PC·모바일 이미지를 따로 등록할 수 있습니다.',
    },
  ];
%>

<div class="mb-6">
    <p class="text-sm text-gray-500">홈 상단 히어로에 <span class="font-medium text-gray-700">무엇을 넣을지</span>를 정합니다.
       배치(테마)는 <a href="/admin/page-builder?tab=theme" class="text-blue-600 underline">페이지 빌더 &gt; 테마 관리</a>에서 바꿉니다.</p>
</div>

<% if (_layoutInfo) { %>
<div class="mb-6 flex items-start gap-3 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
    <i class="bi bi-layout-text-window-reverse text-gray-500 mt-0.5"></i>
    <p class="text-sm text-gray-700">
        현재 배치: <span class="font-semibold">테마 <%= _layoutInfo.no %> — <%= _layoutInfo.name %></span>
        <span class="block mt-0.5 text-xs text-gray-500">아래에서 고른 콘텐츠가 이 배치에 담겨 노출됩니다.</span>
    </p>
</div>
<% } %>

<% if (_needsProducts) { %>
<div class="mb-6 flex items-start gap-3 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3">
    <i class="bi bi-exclamation-triangle text-amber-600 mt-0.5"></i>
    <p class="text-sm text-amber-900">
        <span class="font-semibold">상품을 선택해 주세요.</span>
        고른 상품이 없고 베스트 집계도 아직 없어 <span class="font-semibold">홈 상단 히어로가 노출되지 않습니다.</span>
        <span class="block mt-0.5 text-xs text-amber-800">아래 &lt;상품 골라 추가&gt;에서 상품을 담으면 즉시 노출됩니다. 베스트 집계가 쌓이면 고르지 않아도 자동으로 채워집니다.</span>
    </p>
</div>
<% } else if (isShowcase && _manualCount === 0 && _autoBest > 0) { %>
<div class="mb-6 flex items-start gap-3 rounded-lg border border-blue-200 bg-blue-50 px-4 py-3">
    <i class="bi bi-magic text-blue-600 mt-0.5"></i>
    <p class="text-sm text-blue-900">
        고른 상품이 없어 <span class="font-semibold">베스트 상위 <%= _autoBest %>개가 자동으로 노출 중</span>입니다.
        <span class="block mt-0.5 text-xs text-blue-700">아래에서 상품을 담으면 자동 대신 고른 상품이 노출됩니다.</span>
    </p>
</div>
<% } %>

<%- include('../_tabs', { activeTab: 'HERO' }) %>

<!-- ── 하단 흐름문구(마퀴) — 에디토리얼 히어로 전용 ── -->
<%
  const _mq = (typeof marquee !== 'undefined' && marquee) ? marquee : { enabled: true, text: '', speed: 28 };
%>
<form action="/admin/banners/hero-slides/marquee" method="POST"
      class="mb-8 rounded-lg border border-gray-200 bg-white p-4">
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <h3 class="text-base font-bold text-gray-800">하단 흐름문구 (마퀴)</h3>
        <span class="px-2 py-0.5 text-[11px] leading-4 font-semibold rounded-full bg-gray-100 text-gray-600">에디토리얼 히어로 전용</span>
        <% if (typeof marqueeSaved !== 'undefined' && marqueeSaved) { %>
            <span class="text-xs text-emerald-600">저장되었습니다. 홈에 바로 반영됩니다.</span>
        <% } %>
    </div>
    <p class="text-xs text-gray-500 mb-4">
        히어로 배너 아래에 가로로 흐르는 문구입니다. 저장 즉시 홈에 반영됩니다(발행 불필요).
        <span class="text-gray-400">에디토리얼 표현의 히어로에서만 노출됩니다.</span>
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">문구 내용</label>
            <textarea name="marquee_text" rows="4"
                placeholder="한 줄에 항목 하나씩 (줄바꿈으로 구분)"
                class="block w-full text-sm border-gray-300 rounded-md"><%= _mq.text %></textarea>
            <p class="mt-1 text-[11px] text-gray-400">한 줄에 항목 하나. 비워두면 기본 문구가 노출됩니다.</p>
        </div>
        <div class="space-y-4">
            <div>
                <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                    <input type="checkbox" name="marquee_enabled" value="1"
                        class="h-4 w-4 text-blue-600 border-gray-300 rounded" <%= _mq.enabled ? 'checked' : '' %>>
                    문구 표시
                </label>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">흐름 속도 (초)</label>
                <input type="number" name="marquee_speed" value="<%= _mq.speed %>" min="5" max="120"
                    class="block w-28 text-sm border-gray-300 rounded-md">
                <p class="mt-1 text-[11px] text-gray-400">작을수록 빠릅니다 (5~120).</p>
            </div>
            <button type="submit"
                class="w-full inline-flex justify-center items-center h-[38px] px-4 text-sm font-semibold rounded-md bg-blue-600 text-white hover:bg-blue-700">
                흐름문구 저장
            </button>
        </div>
    </div>
</form>

<!-- ── 히어로 콘텐츠 종류 선택 (배치와 무관하게 항상 고를 수 있다) ── -->
<form action="/admin/banners/hero-slides/variant" method="POST" class="mb-8">
    <div class="flex items-center gap-2 mb-3">
        <h3 class="text-base font-bold text-gray-800">히어로 방식</h3>
        <span class="text-xs text-gray-400">고른 방식만 홈에 노출됩니다. 다른 방식의 콘텐츠는 지워지지 않고 보존됩니다.</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <% MODES.forEach(function (m) {
               const isActive = m.key === activeVariant;
               const isViewing = m.key === mode;
        %>
            <label class="relative flex cursor-pointer rounded-lg border-2 bg-white p-4 transition-colors
                          <%= isViewing ? 'border-blue-500 ring-1 ring-blue-200' : 'border-gray-200 hover:border-gray-300' %>">
                <input type="radio" name="hero_variant" value="<%= m.key %>"
                       class="mt-1 h-4 w-4 text-blue-600 focus:ring-blue-500"
                       <%= isViewing ? 'checked' : '' %>
                       onchange="location.href='/admin/banners/hero-slides?mode=<%= m.key %>'">
                <span class="ml-3 flex-1">
                    <span class="flex items-center gap-2">
                        <span class="block text-sm font-semibold text-gray-900"><%= m.name %></span>
                        <% if (isActive) { %>
                            <span class="px-2 py-0.5 text-[11px] leading-4 font-semibold rounded-full bg-green-100 text-green-800">적용 중</span>
                        <% } %>
                    </span>
                    <span class="mt-1 block text-xs text-gray-500"><%= m.desc %></span>
                </span>
            </label>
        <% }); %>
    </div>

    <% if (isPreviewingInactive) { %>
        <div class="flex flex-wrap items-center gap-3 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
            <span class="text-sm text-amber-900">
                지금 보고 있는 <span class="font-semibold"><%= isShowcase ? '상품 쇼케이스' : '이미지 배너 슬라이드' %></span> 방식은
                <span class="font-semibold">홈에 적용돼 있지 않습니다.</span> 여기서 등록한 내용은 적용 전까지 노출되지 않습니다.
            </span>
            <button type="submit"
                class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md bg-amber-600 text-white hover:bg-amber-700">
                이 방식을 홈에 적용
            </button>
        </div>
    <% } else { %>
        <p class="text-xs text-gray-400">이 방식이 현재 홈에 적용돼 있습니다.</p>
    <% } %>
</form>

<hr class="border-gray-200 mb-8">

<% if (isShowcase) { %>
    <!-- ══════ 상품 쇼케이스 (hero_slide) ══════ -->
    <div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 sm:gap-0">
        <p class="text-sm text-gray-500">
            쇼케이스에 노출할 상품을 고릅니다.
            <span class="text-gray-400">라벨·헤드라인·이미지·링크를 비워두면 상품 정보로 자동 표시됩니다.</span>
        </p>
    </div>

    <% if (Number(locals.skippedFull || 0) > 0) {
         const _fs = locals.skippedSlot === 'FEATURE' ? '우측 추천 카드' : '중앙 슬라이더';
         const _fc = locals.skippedSlot === 'FEATURE' ? _cap.FEATURE : _cap.MAIN; %>
    <div class="mb-6 flex items-start gap-3 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3">
        <i class="bi bi-exclamation-triangle text-amber-600 mt-0.5"></i>
        <p class="text-sm text-amber-900">
            <span class="font-semibold"><%= _fs %></span>는 최대 <span class="font-semibold"><%= _fc %>개</span>까지입니다 —
            <span class="font-semibold"><%= locals.skippedFull %>개는 추가되지 않았습니다.</span>
            <span class="block mt-0.5 text-xs text-amber-800">기존 슬라이드를 지운 뒤 다시 담아 주세요.</span>
        </p>
    </div>
    <% } %>

    <!-- ── 상품 고르기 모달 ── -->
    <div id="productPicker" class="hidden fixed inset-0 z-50 bg-black/40 flex items-start justify-center p-4 overflow-y-auto">
      <form action="/admin/banners/hero-slides/products" method="POST"
            class="bg-white rounded-xl shadow-xl w-full max-w-2xl mt-12 mb-12">
        <input type="hidden" name="slot" id="pickerSlot" value="MAIN">
        <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
          <h3 class="text-base font-bold text-gray-900"><span id="pickerTitle">중앙 슬라이더</span>에 넣을 상품 고르기</h3>
          <button type="button" id="closeProductPicker" class="text-gray-400 hover:text-gray-600"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="px-5 py-4 space-y-3">
          <div class="flex gap-2">
            <input type="text" id="pickerQuery" placeholder="상품명 또는 상품코드로 검색"
                   class="flex-1 text-sm border-gray-300 rounded-md" autocomplete="off">
            <button type="button" id="pickerSearch"
                    class="shrink-0 h-[38px] px-4 text-sm font-medium rounded-md bg-gray-800 text-white hover:bg-gray-900">검색</button>
          </div>
          <p class="text-xs text-gray-400">이미 슬라이드에 등록된 상품은 목록에 나오지 않습니다.</p>
          <div id="pickerResults" class="border border-gray-200 rounded-lg divide-y divide-gray-100 max-h-80 overflow-y-auto">
            <p class="p-4 text-sm text-gray-400">검색어를 입력하고 검색을 누르세요. 비워두고 검색하면 최근 등록 상품이 나옵니다.</p>
          </div>
        </div>
        <div class="px-5 py-4 border-t border-gray-100 flex items-center justify-between">
          <span class="text-sm text-gray-500"><span id="pickerCount">0</span>개 선택됨</span>
          <div class="flex gap-2">
            <button type="button" id="cancelProductPicker"
                    class="h-[38px] px-4 text-sm rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50">취소</button>
            <button type="submit" id="pickerSubmit" disabled
                    class="h-[38px] px-4 text-sm font-semibold rounded-md bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-40 disabled:cursor-not-allowed">
              선택한 상품 추가
            </button>
          </div>
        </div>
      </form>
    </div>

    <%
      function renderSlideCard(slide) {
        const img = slide.image_url || slide.main_image || '';
        // 상품배너/일반배너는 product_id 유무로 갈린다. 일반배너를 '(상품 미연결)'로 부르면
        // 잘못 만든 것처럼 보이므로, 종류로 표기한다.
        const isProductKind = !!slide.product_id;
        const title = slide.headline || slide.product_name || (isProductKind ? '(삭제된 상품)' : '(문구 없음)');
    %>
        <div class="bg-white overflow-hidden shadow-sm rounded-lg flex flex-col h-full border border-gray-100">
            <div class="w-full h-40 bg-gray-50 flex items-center justify-center overflow-hidden">
                <% if (img) { %>
                    <img src="<%= img %>" class="w-full h-40 object-cover" alt="<%= title %>">
                <% } else { %>
                    <span class="text-gray-300 text-sm">이미지 없음</span>
                <% } %>
            </div>
            <div class="p-5 flex-1 flex flex-col">
                <div class="flex items-center justify-between mb-2 gap-2">
                    <h5 class="text-base font-bold text-gray-900 truncate"><%= title %></h5>
                    <span class="shrink-0 px-2 py-0.5 text-[11px] leading-4 font-semibold rounded-full <%= slide.slot === 'FEATURE' ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800' %>">
                        <%= slide.slot === 'FEATURE' ? '우측 카드' : '중앙 슬라이더' %>
                    </span>
                </div>
                <div class="mb-2">
                    <span class="px-2 py-0.5 text-[11px] leading-4 font-semibold rounded-full <%= isProductKind ? 'bg-emerald-100 text-emerald-800' : 'bg-gray-100 text-gray-700' %>">
                        <%= isProductKind ? '상품배너' : '일반배너' %>
                    </span>
                </div>
                <p class="text-xs text-gray-500 mb-1">
                    <span class="font-semibold text-gray-700">라벨:</span> <%= slide.label || '없음' %>
                </p>
                <% if (isProductKind) { %>
                    <p class="text-xs text-gray-500 mb-1">
                        <span class="font-semibold text-gray-700">연결 상품:</span>
                        #<%= slide.product_id %> <%= slide.product_name || '(삭제된 상품)' %>
                    </p>
                <% } %>
                <p class="text-xs text-gray-500 mb-3 truncate">
                    <span class="font-semibold text-gray-700">링크:</span>
                    <%= slide.link_url || (isProductKind ? '상품 상세(자동)' : '없음') %>
                </p>
                <div class="mt-auto flex justify-between items-center">
                    <div class="flex items-center gap-2">
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= slide.is_active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                            <%= slide.is_active ? '노출중' : '중지' %>
                        </span>
                        <span class="text-[11px] text-gray-400">순서 <%= slide.sort_order %></span>
                    </div>
                    <form action="/admin/banners/hero-slides/delete" method="POST" onsubmit="return confirm('삭제하시겠습니까?');" class="flex gap-2">
                        <a href="/admin/banners/hero-slides/edit/<%= slide.id %>"
                            class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정</a>
                        <input type="hidden" name="id" value="<%= slide.id %>">
                        <button type="submit"
                            class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md border border-red-200 bg-red-50 text-red-700 hover:bg-red-100">삭제</button>
                    </form>
                </div>
            </div>
        </div>
    <% } %>

    <%
      /* 영역 헤더 — 제목 + 남은 자리 + [상품 골라 추가] + [직접 등록].
         버튼을 영역마다 두는 건 두 슬롯의 규칙이 다르기 때문이다(중앙 여러 장 / 우측 한 장). */
      function sectionHeader(slot, title, hint, count) {
        const cap = Number(_cap[slot] || 1);
        const room = Number(_room[slot] || 0);
    %>
        <div class="flex flex-wrap items-center gap-2 mb-3">
            <h3 class="text-base font-bold text-gray-800"><%= title %></h3>
            <span class="text-xs text-gray-400"><%= hint %></span>
            <span class="ml-auto text-xs <%= room > 0 ? 'text-gray-400' : 'text-amber-600 font-medium' %>">
                <%= count %>/<%= cap %>개<%= room > 0 ? ' · ' + room + '개 더 추가 가능' : ' · 가득 참' %>
            </span>
            <button type="button" class="js-open-picker inline-flex items-center gap-1.5 justify-center h-[34px] px-3 text-sm font-medium rounded-md bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-40 disabled:cursor-not-allowed"
                    data-slot="<%= slot %>" data-room="<%= room %>" data-title="<%= title %>" <%= room > 0 ? '' : 'disabled' %>>
                <i class="bi bi-search"></i> 상품 골라 추가
            </button>
            <a href="/admin/banners/hero-slides/add?slot=<%= slot %>"
               class="inline-flex items-center justify-center h-[34px] px-3 text-sm font-medium rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50 no-underline">직접 등록</a>
        </div>
    <% } %>

    <!-- 중앙 슬라이더 (slot=MAIN) -->
    <div class="mb-8">
        <% sectionHeader('MAIN', '중앙 슬라이더 (MAIN)', '메인 히어로 중앙의 큰 상품 슬라이드', mainSlides.length) %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% mainSlides.forEach(function(slide) { renderSlideCard(slide); }) %>
            <% if (mainSlides.length === 0) { %>
                <div class="col-span-full text-center py-10 bg-gray-50 rounded-lg text-gray-500 text-sm">등록된 중앙 슬라이드가 없습니다.</div>
            <% } %>
        </div>
    </div>

    <!-- 우측 카드 (slot=FEATURE) -->
    <div class="mb-4">
        <% sectionHeader('FEATURE', '우측 추천 카드 (FEATURE)', '히어로 우측 고정 추천 상품 카드 (PC 전용, 1개만 노출)', featureSlides.length) %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% featureSlides.forEach(function(slide) { renderSlideCard(slide); }) %>
            <% if (featureSlides.length === 0) { %>
                <div class="col-span-full text-center py-10 bg-gray-50 rounded-lg text-gray-500 text-sm">
                    등록된 우측 카드가 없습니다. <span class="text-gray-400">비워두면 베스트 1위 상품이 자동으로 노출됩니다.</span>
                </div>
            <% } %>
        </div>
    </div>

<% } else { %>
    <!-- ══════ 이미지 배너 슬라이드 (banners, banner_type='MAIN') ══════ -->
    <div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 sm:gap-0">
        <p class="text-sm text-gray-500">
            홈 상단에 가로 전체 이미지 배너로 노출됩니다. 배너 위에 <strong>제목·추가 문구·이동 버튼</strong>을 얹을 수 있습니다(수정 화면).
            <span class="text-gray-400">모바일 이미지를 등록하면 모바일에서 그 이미지를 씁니다. 순서가 빠른 것부터 최대 6개까지 노출됩니다.</span>
        </p>
        <a href="/admin/banners/add?type=MAIN"
            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 no-underline">배너 등록</a>
    </div>

    <%#
      순서·노출은 목록에서 바로 정한다(카드마다 수정 폼을 드나들면 순서를 맞추기 어렵다).
      삭제 폼은 이 폼 **바깥**에 둔다 — 중첩 <form> 은 브라우저가 무시해 삭제가 순서 저장으로 나간다.
    %>
    <form method="POST" action="/admin/banners/hero-slides/banners">
        <div class="mb-4 flex items-center justify-end gap-3">
            <% if (typeof saved !== 'undefined' && saved) { %>
                <span class="text-xs text-emerald-600">저장되었습니다.</span>
            <% } %>
            <button type="submit"
                class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-semibold rounded-md bg-gray-800 text-white hover:bg-gray-900">순서·노출 저장</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% mainBanners.forEach(function (banner, i) { %>
                <div class="bg-white overflow-hidden shadow-sm rounded-lg flex flex-col h-full border border-gray-100">
                    <img src="<%= banner.image_url %>" class="w-full h-40 object-cover" alt="<%= banner.title || '' %>">
                    <div class="p-5 flex-1 flex flex-col">
                        <input type="hidden" name="id" value="<%= banner.id %>">
                        <div class="flex items-center justify-between mb-2 gap-2">
                            <h5 class="text-base font-bold text-gray-900 truncate"><%= banner.title || '(제목 없음)' %></h5>
                            <% if (i >= 6) { %>
                                <span class="px-2 py-0.5 text-[11px] leading-4 font-semibold rounded-full bg-gray-100 text-gray-600 shrink-0">노출 제외</span>
                            <% } %>
                        </div>
                        <p class="text-xs text-gray-500 mb-1">
                            <span class="font-semibold text-gray-700">모바일 이미지:</span>
                            <%= banner.mobile_image_url ? '등록됨' : '없음 (PC 이미지 사용)' %>
                        </p>
                        <p class="text-xs text-gray-500 mb-1 truncate">
                            <span class="font-semibold text-gray-700">배너 문구:</span>
                            <%= banner.overlay_title || banner.overlay_subtitle || banner.overlay_button_text ? (banner.overlay_title || '(제목 없음)') : '없음 (이미지만)' %>
                            <% if (banner.overlay_button_text) { %>
                                <span class="ml-1 align-middle inline-flex items-center gap-1 text-[10px] text-gray-400">
                                    버튼
                                    <span class="inline-block w-2.5 h-2.5 rounded-sm border border-gray-200" style="background-color: <%= banner.overlay_button_color || '#1a7f37' %>;"></span>
                                </span>
                            <% } %>
                        </p>
                        <p class="text-xs text-gray-500 mb-1 truncate">
                            <span class="font-semibold text-gray-700">링크:</span> <%= banner.link_url || '없음' %>
                        </p>
                        <p class="text-xs text-gray-500 mb-3">
                            <span class="font-semibold text-gray-700">게시 기간:</span>
                            <%= banner.start_date ? new Date(banner.start_date).toLocaleDateString() : '설정 안됨' %> ~
                            <%= banner.end_date ? new Date(banner.end_date).toLocaleDateString() : '설정 안됨' %>
                        </p>

                        <div class="mt-auto pt-3 border-t border-gray-100 flex items-center justify-between gap-2">
                            <div class="flex items-center gap-3">
                                <%# 키에 'b' 접두어 — 숫자 키는 qs 가 배열 인덱스로 해석해 값이 어긋난다. %>
                                <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
                                    <span class="font-semibold text-gray-700">순서</span>
                                    <input type="number" name="order[b<%= banner.id %>]" value="<%= banner.display_order || 0 %>"
                                        class="w-16 h-[33px] text-xs border-gray-300 rounded-md">
                                </label>
                                <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
                                    <input type="checkbox" name="active[b<%= banner.id %>]" value="1"
                                        class="h-4 w-4 text-blue-600 border-gray-300 rounded" <%= banner.is_active ? 'checked' : '' %>>
                                    노출
                                </label>
                            </div>
                            <div class="flex gap-2">
                                <a href="/admin/banners/edit/<%= banner.id %>"
                                    class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정</a>
                                <%# 삭제는 폼 밖(하단 별도 form)의 버튼을 이 위치로 연결한다 — form 속성으로 중첩을 피한다. %>
                                <button type="submit" form="del-banner-<%= banner.id %>" onclick="return confirm('삭제하시겠습니까?');"
                                    class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md border border-red-200 bg-red-50 text-red-700 hover:bg-red-100">삭제</button>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
            <% if (mainBanners.length === 0) { %>
                <div class="col-span-full text-center py-10 bg-gray-50 rounded-lg text-gray-500 text-sm">등록된 메인 배너가 없습니다.</div>
            <% } %>
        </div>
    </form>

    <% mainBanners.forEach(function (banner) { %>
        <form id="del-banner-<%= banner.id %>" action="/admin/banners/delete" method="POST" class="hidden">
            <input type="hidden" name="id" value="<%= banner.id %>">
            <input type="hidden" name="return_to" value="/admin/banners/hero-slides?mode=full_banner">
        </form>
    <% }); %>
<% } %>

<% if (isShowcase) { %>
<script>
/*
 * 상품 고르기 — 검색 → 체크 → 일괄 추가.
 * 선택 집합을 Set 으로 들고 있어 검색어를 바꿔도 이미 고른 것이 유지된다.
 * 상품명은 textContent 로만 넣는다(HTML 주입 차단).
 */
(function () {
  var modal = document.getElementById('productPicker');
  if (!modal) return;

  var form     = modal.querySelector('form');
  var queryEl  = document.getElementById('pickerQuery');
  var resultsEl= document.getElementById('pickerResults');
  var countEl  = document.getElementById('pickerCount');
  var submitEl = document.getElementById('pickerSubmit');
  var slotEl   = document.getElementById('pickerSlot');
  var titleEl  = document.getElementById('pickerTitle');
  var picked   = new Map(); // id -> name
  var ROOM     = 0;         // 남은 자리 — 어느 영역의 버튼을 눌렀는지에 따라 바뀐다

  /* 같은 모달을 두 영역(중앙/우측)이 공유한다. 열 때 대상 슬롯·남은 자리를 갈아 끼운다. */
  function open(btn) {
    slotEl.value = btn.getAttribute('data-slot');
    titleEl.textContent = btn.getAttribute('data-title');
    ROOM = Number(btn.getAttribute('data-room')) || 0;
    picked.clear();
    resultsEl.dataset.loaded = '';   // 슬롯이 바뀌면 후보도 다시 받는다
    refreshCount();
    modal.classList.remove('hidden');
    queryEl.focus();
    search();
  }
  function close() { modal.classList.add('hidden'); }

  document.querySelectorAll('.js-open-picker').forEach(function (b) {
    b.addEventListener('click', function () { open(b); });
  });
  document.getElementById('closeProductPicker').addEventListener('click', close);
  document.getElementById('cancelProductPicker').addEventListener('click', close);
  modal.addEventListener('click', function (e) { if (e.target === modal) close(); });

  function refreshCount() {
    countEl.textContent = picked.size + ' / ' + ROOM;
    submitEl.disabled = picked.size === 0;
    // 자리가 다 차면 남은 체크박스를 잠근다 — 담아 놓고 서버에서 잘리는 것보다 낫다.
    var full = picked.size >= ROOM;
    resultsEl.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
      cb.disabled = full && !cb.checked;
      cb.closest('label').classList.toggle('opacity-40', cb.disabled);
    });
  }

  function row(p) {
    var wrap = document.createElement('label');
    wrap.className = 'flex items-center gap-3 p-3 cursor-pointer hover:bg-gray-50';

    var cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.className = 'w-4 h-4 rounded border-gray-300';
    cb.checked = picked.has(p.id);
    cb.addEventListener('change', function () {
      if (cb.checked) picked.set(p.id, p.name); else picked.delete(p.id);
      refreshCount();
    });

    var img = document.createElement('img');
    img.src = p.main_image || '/images/placeholder.png';
    img.className = 'w-10 h-10 object-cover rounded border border-gray-200 bg-gray-50';
    img.alt = '';

    var box = document.createElement('div');
    box.className = 'flex-1 min-w-0';
    var name = document.createElement('p');
    name.className = 'text-sm text-gray-900 truncate';
    name.textContent = p.name;                       // 주입 차단
    var meta = document.createElement('p');
    meta.className = 'text-xs text-gray-400';
    meta.textContent = (p.product_code ? p.product_code + ' · ' : '')
      + Number(p.price || 0).toLocaleString() + '원'
      + (Number(p.stock) > 0 ? '' : ' · 품절');
    box.appendChild(name); box.appendChild(meta);

    wrap.appendChild(cb); wrap.appendChild(img); wrap.appendChild(box);
    return wrap;
  }

  function search() {
    resultsEl.dataset.loaded = '1';
    resultsEl.innerHTML = '<p class="p-4 text-sm text-gray-400">검색 중…</p>';
    fetch('/admin/banners/hero-slides/product-search?q=' + encodeURIComponent(queryEl.value.trim()))
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var list = (data && data.products) || [];
        resultsEl.innerHTML = '';
        if (list.length === 0) {
          resultsEl.innerHTML = '<p class="p-4 text-sm text-gray-400">검색 결과가 없습니다. (이미 등록된 상품은 제외됩니다)</p>';
          return;
        }
        list.forEach(function (p) { resultsEl.appendChild(row(p)); });
        refreshCount();   // 새로 그린 체크박스에도 잠금 상태를 반영한다
        if (data.limited) {
          var more = document.createElement('p');
          more.className = 'p-3 text-xs text-gray-400 text-center';
          more.textContent = '결과가 많아 일부만 표시했습니다. 검색어를 좁혀 주세요.';
          resultsEl.appendChild(more);
        }
      })
      .catch(function () {
        resultsEl.innerHTML = '<p class="p-4 text-sm text-red-500">검색에 실패했습니다. 잠시 후 다시 시도해 주세요.</p>';
      });
  }

  document.getElementById('pickerSearch').addEventListener('click', search);
  queryEl.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') { e.preventDefault(); search(); }
  });

  // 체크박스는 검색 때마다 다시 그려지므로, 제출 직전에 선택 집합을 hidden 으로 펼친다.
  form.addEventListener('submit', function () {
    // 모달을 두 번 연 뒤 제출하면 지난번 hidden 이 남아 엉뚱한 상품이 함께 담긴다.
    form.querySelectorAll('input[name="product_ids"]').forEach(function (el) { el.remove(); });
    picked.forEach(function (_name, id) {
      var h = document.createElement('input');
      h.type = 'hidden'; h.name = 'product_ids'; h.value = id;
      form.appendChild(h);
    });
  });

  refreshCount();
})();
</script>
<% } %>
