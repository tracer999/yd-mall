<%
  /*
   * 톱바 배너·알림 — 배너 관리의 한 탭.
   *
   * 다른 탭(목록 + 등록/수정 폼)과 달리 슬롯이 고정이라 편집 한 장으로 끝난다.
   * 저장 대상은 banners 가 아니라 header_topbar_item (몰별).
   */
  const _no = topbar.notice || {};
  const _d = (v) => (v ? new Date(v).toISOString().slice(0, 10) : '');   // DATE → yyyy-mm-dd
  const _bannerCount = topbar.slots.filter((s) => topbar.banners[s] && topbar.banners[s].is_active).length;
%>

<div class="mb-6">
  <p class="text-sm text-gray-500">스토어프론트 <strong>헤더 최상단 바</strong>에 노출할 배너와 알림을 관리합니다.</p>
</div>

<%- include('./_tabs', { activeTab: 'TOPBAR' }) %>

<% if (saved) { %>
  <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
    <i class="bi bi-check-circle-fill"></i> 저장되었습니다. 스토어프론트에 즉시 반영됩니다.
  </div>
<% } %>

<% if (error) { %>
  <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
    <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
  </div>
<% } %>

<div class="mb-5 px-4 py-3 rounded-lg bg-blue-50 border border-blue-100 text-xs text-blue-800 leading-relaxed">
  <ul class="list-disc pl-4 space-y-0.5">
    <li><strong>배너와 알림이 모두 없으면 톱바 자체가 노출되지 않습니다.</strong></li>
    <li>배너는 <strong>등록 개수에 따라 크기가 달라집니다</strong> — 1개: 한 폭 큰 배너 / 2개: 2단 / 3개: 3단.
        현재 노출 중인 배너 <strong><%= _bannerCount %></strong>개.</li>
    <li>고객은 닫기(×) 버튼으로 톱바를 숨길 수 있습니다. 내용을 바꾸면 닫았던 고객에게도 다시 보입니다.</li>
  </ul>
</div>

<form method="POST" action="/admin/banners/topbar" enctype="multipart/form-data" class="space-y-6">

  <!-- 알림 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 bg-gray-50 flex items-center justify-between">
      <h2 class="text-base font-bold text-gray-800"><i class="bi bi-megaphone mr-1"></i> 알림 메시지</h2>
      <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
        <input type="checkbox" name="notice_is_active" value="1" <%= (!topbar.notice || _no.is_active) ? 'checked' : '' %>
               class="w-4 h-4 rounded border-gray-300"> 노출
      </label>
    </div>
    <div class="p-5 space-y-3">
      <input type="text" name="notice_message" maxlength="200" value="<%= _no.message || '' %>"
             placeholder="예) 첫 구매 10% 쿠폰 증정 — 지금 확인하세요"
             class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
      <p class="text-xs text-gray-400">문구를 비우고 저장하면 알림이 삭제됩니다. (최대 200자)</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">링크 (선택)</label>
          <input type="text" name="notice_link_url" value="<%= _no.link_url || '' %>" placeholder="/events/1"
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
        </div>
        <div class="flex items-end">
          <label class="inline-flex items-center gap-1.5 h-[38px] text-xs text-gray-600">
            <input type="checkbox" name="notice_new_window" value="1" <%= _no.new_window ? 'checked' : '' %>
                   class="w-4 h-4 rounded border-gray-300"> 새 창으로 열기
          </label>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">노출 시작일 (선택)</label>
          <input type="date" name="notice_start_date" value="<%= _d(_no.start_date) %>"
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">노출 종료일 (선택)</label>
          <input type="date" name="notice_end_date" value="<%= _d(_no.end_date) %>"
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
        </div>
      </div>
    </div>
  </div>

  <!-- 배너 3슬롯 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
      <h2 class="text-base font-bold text-gray-800"><i class="bi bi-image mr-1"></i> 배너 (최대 3개)</h2>
      <p class="mt-0.5 text-xs text-gray-500">이미지가 없는 슬롯은 저장 시 비워집니다. 슬롯 순서대로 왼쪽부터 놓입니다.</p>
    </div>

    <div class="p-5 grid grid-cols-1 lg:grid-cols-3 gap-4">
      <% topbar.slots.forEach(function (slot) { %>
        <% const _b = topbar.banners[slot] || {}; %>
        <div class="rounded-lg border border-gray-200 p-4 space-y-3">
          <div class="flex items-center justify-between">
            <h3 class="text-xs font-bold text-gray-700">배너 <%= slot %></h3>
            <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
              <input type="checkbox" name="banner_<%= slot %>_is_active" value="1" <%= (!topbar.banners[slot] || _b.is_active) ? 'checked' : '' %>
                     class="w-4 h-4 rounded border-gray-300"> 노출
            </label>
          </div>

          <% if (_b.image_url) { %>
            <img src="<%= _b.image_url %>" alt="" class="w-full h-20 object-cover rounded border border-gray-100">
            <input type="hidden" name="banner_<%= slot %>_existing_image" value="<%= _b.image_url %>">
            <label class="inline-flex items-center gap-1.5 text-xs text-red-600">
              <input type="checkbox" name="banner_<%= slot %>_delete" value="1" class="w-4 h-4 rounded border-gray-300"> 이 배너 삭제
            </label>
          <% } else { %>
            <div class="w-full h-20 rounded border border-dashed border-gray-200 flex items-center justify-center text-xs text-gray-300">
              등록된 이미지 없음
            </div>
          <% } %>

          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">이미지 <%= _b.image_url ? '교체' : '업로드' %></label>
            <input type="file" name="topbar_banner_<%= slot %>" accept="image/*"
                   class="w-full text-xs text-gray-600 file:mr-2 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-xs file:bg-gray-100 file:text-gray-700">
          </div>

          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">링크 (선택)</label>
            <input type="text" name="banner_<%= slot %>_link_url" value="<%= _b.link_url || '' %>" placeholder="/events/1"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>

          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">대체 텍스트 (선택)</label>
            <input type="text" name="banner_<%= slot %>_alt" maxlength="200" value="<%= _b.message || '' %>"
                   placeholder="이미지 로드 실패·스크린리더용"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>

          <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
            <input type="checkbox" name="banner_<%= slot %>_new_window" value="1" <%= _b.new_window ? 'checked' : '' %>
                   class="w-4 h-4 rounded border-gray-300"> 새 창으로 열기
          </label>

          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">시작일</label>
              <input type="date" name="banner_<%= slot %>_start_date" value="<%= _d(_b.start_date) %>"
                     class="w-full px-2 py-1.5 rounded-md border border-gray-200 text-xs">
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">종료일</label>
              <input type="date" name="banner_<%= slot %>_end_date" value="<%= _d(_b.end_date) %>"
                     class="w-full px-2 py-1.5 rounded-md border border-gray-200 text-xs">
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <div class="flex justify-end">
    <button type="submit" class="inline-flex items-center justify-center h-[38px] px-5 text-sm font-medium rounded-md bg-blue-600 text-white hover:bg-blue-700 uppercase tracking-widest">
      <i class="bi bi-save mr-1.5"></i> 저장
    </button>
  </div>
</form>
