<%
  /*
   * 톱바 배너·알림 — 배너 관리의 한 탭.
   *
   * 다른 탭(목록 + 등록/수정 폼)과 달리 슬롯이 고정이라 편집 한 장으로 끝난다.
   * 저장 대상은 banners 가 아니라 header_topbar_item (몰별).
   */
  const _no = topbar.notice || {};
  const _d = (v) => (v ? new Date(v).toISOString().slice(0, 10) : '');   // DATE → yyyy-mm-dd
  const _bannerCount = topbar.slots.filter((s) => topbar.banners[s] && topbar.banners[s].is_active).length;
%>

<div class="mb-6">
  <p class="text-sm text-gray-500">스토어프론트 <strong>헤더 최상단 바</strong>에 노출할 배너와 알림을 관리합니다.</p>
</div>

<%- include('./_tabs', { activeTab: 'TOPBAR' }) %>

<% if (saved) { %>
  <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
    <i class="bi bi-check-circle-fill"></i> 저장되었습니다. 스토어프론트에 즉시 반영됩니다.
  </div>
<% } %>

<% if (error) { %>
  <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
    <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
  </div>
<% } %>

<%#
  현재 헤더 스킨이 톱바를 그리는지 — 등록만 되고 화면에는 안 나오는 상태를 여기서 드러낸다.
  판정 근거는 services/menu/headerSkins.js 의 rendersTopbar.
%>
<% if (headerSkinRendersTopbar) { %>
  <div class="mb-3 px-4 py-2.5 rounded-lg bg-gray-50 border border-gray-200 text-xs text-gray-600 flex items-start gap-2">
    <i class="bi bi-window-sidebar mt-0.5"></i>
    <span>현재 헤더 스킨 <strong class="text-gray-800"><%= headerSkinLabel %></strong> 은 톱바를 노출합니다.
      스킨은 <a href="/admin/header-settings" class="text-blue-600 hover:underline">쇼핑몰 설정 &gt; Header 설정</a>에서 바꿉니다.</span>
  </div>
<% } else { %>
  <div class="mb-3 px-4 py-3 rounded-lg bg-amber-50 border border-amber-200 text-sm text-amber-900 flex items-start gap-2">
    <i class="bi bi-exclamation-triangle-fill mt-0.5"></i>
    <span><strong>지금 이 몰에서는 톱바가 노출되지 않습니다.</strong>
      현재 헤더 스킨 <strong><%= headerSkinLabel %></strong> 은 톱바를 그리지 않습니다 —
      아래에서 등록·저장해도 스토어프론트에는 나오지 않습니다.
      <a href="/admin/header-settings" class="underline font-medium">쇼핑몰 설정 &gt; Header 설정</a>에서
      톱바를 지원하는 스킨으로 바꾸면 바로 반영됩니다.</span>
  </div>
<% } %>

<div class="mb-5 px-4 py-3 rounded-lg bg-blue-50 border border-blue-100 text-xs text-blue-800 leading-relaxed">
  <ul class="list-disc pl-4 space-y-0.5">
    <li><strong>배너와 알림이 모두 없으면 톱바 자체가 노출되지 않습니다.</strong></li>
    <li><strong>이미지 배너</strong>는 등록 개수에 따라 크기가 달라집니다 — 1개: 한 폭 큰 배너 / 2개: 2단 / 3개: 3단.
        현재 노출 중인 배너 <strong><%= _bannerCount %></strong>개.</li>
    <li><strong>이미지 없이 텍스트만 등록하면</strong> 톱바가 아주 얇은 띠가 되고, 문구는
        <strong>글자 길이만큼만 차지하는 알약</strong>으로 가운데 놓입니다.
        글자 수가 적을수록 크고 진하게 노출됩니다(아래 미리보기 참고).</li>
    <li><strong>이미지가 1순위입니다.</strong> 이미지를 올리지 않았거나 이미지가 열리지 않으면,
        <strong>대체 텍스트</strong>가 이미지 배너와 같은 자리·같은 크기의 <strong>텍스트 배너</strong>로 노출됩니다.
        이미지와 대체 텍스트가 <strong>모두 비면</strong> 그 슬롯은 삭제됩니다.</li>
    <li>고객은 닫기(×) 버튼으로 톱바를 숨길 수 있습니다. 내용을 바꾸면 닫았던 고객에게도 다시 보입니다.</li>
  </ul>
</div>

<form method="POST" action="/admin/banners/topbar" enctype="multipart/form-data" class="space-y-6">

  <!-- 알림 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 bg-gray-50 flex items-center justify-between">
      <h2 class="text-base font-bold text-gray-800"><i class="bi bi-megaphone mr-1"></i> 알림 메시지</h2>
      <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
        <input type="checkbox" name="notice_is_active" value="1" <%= (!topbar.notice || _no.is_active) ? 'checked' : '' %>
               class="w-4 h-4 rounded border-gray-300"> 노출
      </label>
    </div>
    <div class="p-5 space-y-3">
      <input type="text" name="notice_message" maxlength="200" value="<%= _no.message || '' %>"
             placeholder="예) 첫 구매 10% 쿠폰 증정 — 지금 확인하세요"
             class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
      <p class="text-xs text-gray-400">문구를 비우고 저장하면 알림이 삭제됩니다. (최대 200자)</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">링크 (선택)</label>
          <input type="text" name="notice_link_url" value="<%= _no.link_url || '' %>" placeholder="/events/1"
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
        </div>
        <div class="flex items-end">
          <label class="inline-flex items-center gap-1.5 h-[38px] text-xs text-gray-600">
            <input type="checkbox" name="notice_new_window" value="1" <%= _no.new_window ? 'checked' : '' %>
                   class="w-4 h-4 rounded border-gray-300"> 새 창으로 열기
          </label>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">노출 시작일 (선택)</label>
          <input type="date" name="notice_start_date" value="<%= _d(_no.start_date) %>"
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">노출 종료일 (선택)</label>
          <input type="date" name="notice_end_date" value="<%= _d(_no.end_date) %>"
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
        </div>
      </div>
    </div>
  </div>

  <!-- 배너 3슬롯 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
      <h2 class="text-base font-bold text-gray-800"><i class="bi bi-image mr-1"></i> 배너 (최대 3개)</h2>
      <p class="mt-0.5 text-xs text-gray-500">이미지와 대체 텍스트가 모두 없는 슬롯은 저장 시 비워집니다. 슬롯 순서대로 왼쪽부터 놓입니다.</p>
    </div>

    <div class="p-5 grid grid-cols-1 lg:grid-cols-3 gap-4">
      <% topbar.slots.forEach(function (slot) { %>
        <% const _b = topbar.banners[slot] || {}; %>
        <div class="rounded-lg border border-gray-200 p-4 space-y-3" data-tb-slot>
          <div class="flex items-center justify-between">
            <h3 class="text-xs font-bold text-gray-700">배너 <%= slot %></h3>
            <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
              <input type="checkbox" name="banner_<%= slot %>_is_active" value="1" <%= (!topbar.banners[slot] || _b.is_active) ? 'checked' : '' %>
                     class="w-4 h-4 rounded border-gray-300"> 노출
            </label>
          </div>

          <%#
            미리보기 — 실제 노출 우선순위(이미지 → 대체 텍스트)를 그대로 보여 준다.
            이미지 미리보기와 텍스트 배너 미리보기를 둘 다 심어 두고 상태에 따라 하나만 띄운다.
          %>
          <% if (_b.image_url) { %>
            <img data-tb-image src="<%= _b.image_url %>" alt="" class="w-full h-20 object-cover rounded border border-gray-100">
            <input type="hidden" name="banner_<%= slot %>_existing_image" value="<%= _b.image_url %>">
          <% } else { %>
            <img data-tb-image alt="" style="display:none" class="w-full h-20 object-cover rounded border border-gray-100">
          <% } %>

          <%#
            텍스트 배너 미리보기 — 실제 톱바(스트립 모드)와 같은 모양.
            글자 수에 따라 알약 등급이 달라지므로 밴드 높이가 아니라 알약 자체를 보여 준다.
          %>
          <div data-tb-text-preview <%- _b.image_url ? 'style="display:none"' : '' %>
               class="w-full rounded border border-gray-200 bg-slate-800 px-3 py-1.5 flex items-center justify-center min-h-[46px]">
            <span data-tb-text-value class="text-white/40 text-[11px]"><%= _b.message || '대체 텍스트를 입력하면 이렇게 노출됩니다' %></span>
          </div>
          <p data-tb-tier-hint class="text-[11px] text-gray-400 -mt-1"></p>

          <% if (_b.image_url) { %>
            <label class="inline-flex items-center gap-1.5 text-xs text-red-600">
              <input type="checkbox" data-tb-delete name="banner_<%= slot %>_delete" value="1" class="w-4 h-4 rounded border-gray-300"> 이미지 삭제
            </label>
            <p class="text-[11px] text-gray-400 -mt-1">이미지를 지워도 대체 텍스트가 있으면 <strong>텍스트 배너</strong>로 남습니다.</p>
          <% } %>

          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">이미지 <%= _b.image_url ? '교체' : '업로드' %></label>
            <input type="file" data-tb-file name="topbar_banner_<%= slot %>" accept="image/*"
                   class="w-full text-xs text-gray-600 file:mr-2 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-xs file:bg-gray-100 file:text-gray-700">
          </div>

          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">링크 (선택)</label>
            <input type="text" name="banner_<%= slot %>_link_url" value="<%= _b.link_url || '' %>" placeholder="/events/1"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>

          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">대체 텍스트 <span class="text-gray-400">(이미지 없으면 텍스트 배너)</span></label>
            <input type="text" data-tb-alt name="banner_<%= slot %>_alt" maxlength="200" value="<%= _b.message || '' %>"
                   placeholder="예) 여름 특가 최대 50% 할인"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>

          <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
            <input type="checkbox" name="banner_<%= slot %>_new_window" value="1" <%= _b.new_window ? 'checked' : '' %>
                   class="w-4 h-4 rounded border-gray-300"> 새 창으로 열기
          </label>

          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">시작일</label>
              <input type="date" name="banner_<%= slot %>_start_date" value="<%= _d(_b.start_date) %>"
                     class="w-full px-2 py-1.5 rounded-md border border-gray-200 text-xs">
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">종료일</label>
              <input type="date" name="banner_<%= slot %>_end_date" value="<%= _d(_b.end_date) %>"
                     class="w-full px-2 py-1.5 rounded-md border border-gray-200 text-xs">
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <div class="flex justify-end">
    <button type="submit" class="inline-flex items-center justify-center h-[38px] px-5 text-sm font-medium rounded-md bg-blue-600 text-white hover:bg-blue-700 uppercase tracking-widest">
      <i class="bi bi-save mr-1.5"></i> 저장
    </button>
  </div>
</form>

<script>
  /*
   * 슬롯 미리보기 동기화 — 저장하면 어떻게 나올지 그 자리에서 보여 준다.
   * 판정 기준은 서버(bannerController.postTopbar)와 같다: 이미지가 1순위, 없으면 대체 텍스트.
   */
  (function () {
    var PLACEHOLDER = '대체 텍스트를 입력하면 이렇게 노출됩니다';

    /*
     * 알약 등급 — 규칙은 스토어프론트(views/partials/storefront/header/_topbar.ejs)와 같아야 한다.
     * 여기가 어긋나면 미리보기가 거짓말을 한다. 한쪽을 고치면 반드시 다른 쪽도 고칠 것.
     * (색만 다르다 — 관리자 화면에는 스토어 테마 변수 --gh-primary-dark 가 없어 slate 로 대체)
     */
    var PILL_BASE = 'inline-flex max-w-full items-center rounded-full leading-[1.35]';
    var PILL = {
      punch: 'px-3.5 py-[4px] text-[13px] font-extrabold tracking-[-0.01em] bg-white text-slate-800 shadow-[0_1px_2px_rgba(0,0,0,0.28)]',
      base: 'px-3 py-[4px] text-[12px] font-semibold text-white bg-white/[0.14] ring-1 ring-inset ring-white/30',
      long: 'px-2.5 py-[3px] text-[11px] font-medium text-white/85 ring-1 ring-inset ring-white/20'
    };
    var TIER_HINT = {
      punch: '짧은 문구 — 흰 알약으로 가장 강하게 노출됩니다. (공백 제외 12자 이하)',
      base: '보통 길이 — 반투명 알약으로 노출됩니다. (공백 제외 13~28자)',
      long: '긴 문구 — 작고 조용한 알약으로 노출되며, 화면이 좁으면 말줄임됩니다. (공백 제외 29자 이상)'
    };
    function tierOf(s) {
      var n = String(s || '').replace(/\s/g, '').length;
      return n <= 12 ? 'punch' : (n <= 28 ? 'base' : 'long');
    }

    Array.prototype.forEach.call(document.querySelectorAll('[data-tb-slot]'), function (cell) {
      var img = cell.querySelector('[data-tb-image]');
      var textBox = cell.querySelector('[data-tb-text-preview]');
      var textVal = cell.querySelector('[data-tb-text-value]');
      var hint = cell.querySelector('[data-tb-tier-hint]');
      var alt = cell.querySelector('[data-tb-alt]');
      var file = cell.querySelector('[data-tb-file]');
      var del = cell.querySelector('[data-tb-delete]');

      var savedImage = (img && img.getAttribute('src')) || '';
      var pickedUrl = '';   // 이번에 고른 파일의 미리보기 URL

      function sync() {
        // 새로 고른 파일이 최우선, 그다음이 저장된 이미지(삭제 체크하면 없는 것으로 본다).
        var src = pickedUrl || ((del && del.checked) ? '' : savedImage);

        if (img) {
          if (src) { img.src = src; img.style.display = ''; }
          else { img.style.display = 'none'; }
        }
        if (textBox) textBox.style.display = src ? 'none' : '';

        var value = alt ? alt.value.trim() : '';
        var tier = tierOf(value);
        if (textVal) {
          textVal.textContent = value || PLACEHOLDER;
          textVal.className = value
            ? (PILL_BASE + ' ' + PILL[tier] + (tier === 'long' ? ' block truncate' : ''))
            : 'text-[11px] text-white/40';
        }
        if (hint) hint.textContent = (value && !src) ? TIER_HINT[tier] : '';
      }

      if (alt) alt.addEventListener('input', sync);
      if (del) del.addEventListener('change', sync);
      if (file) file.addEventListener('change', function () {
        if (pickedUrl) { URL.revokeObjectURL(pickedUrl); pickedUrl = ''; }
        var picked = file.files && file.files[0];
        if (picked) pickedUrl = URL.createObjectURL(picked);
        sync();
      });

      sync();
    });
  })();
</script>
