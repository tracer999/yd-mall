<%
/* B1 — 카테고리 트리 관리
   탭(상품/테마/브랜드)은 뎁스가 아니라 병렬 분류축이다. 각 탭 안에서 최대 maxDepth 단계까지 계층을 만든다.
   행은 서버에서 이미 부모→자식 순으로 평탄화되어 오고, _depth 로 들여쓰기 한다. */
/* THEME 탭은 폐기했다 — 테마 5(베스트)·6(신규)은 기능 메뉴(/best, /new)와 다른 결과를 내던
   잔재였고, 신상품은 판매시작일 기준 자동 판정으로 바뀌었다. */
const TABS = [
    // 상품(NORMAL) 카테고리는 GNB 메가메뉴에 이미지+설명이 노출되므로 편집 가능하게 한다.
    { key: 'product', type: 'NORMAL', label: '상품 카테고리', nameLabel: '카테고리명', rows: productCategories || [], hasLogo: true,  hasDesc: true,  hasOnboarded: false },
    // 브랜드는 입점일을 관리한다 — 신규 입점 브랜드 판정 기준(services/catalog/newArrival).
    { key: 'brand',   type: 'BRAND',  label: '브랜드 카테고리', nameLabel: '브랜드명',  rows: brandCategories   || [], hasLogo: true,  hasDesc: false, hasOnboarded: true  },
];
const colCount = (tab) => 6 + (tab.hasLogo ? 1 : 0) + (tab.hasDesc ? 1 : 0) + (tab.hasOnboarded ? 1 : 0);
const toDateInput = (v) => v ? new Date(v).toISOString().slice(0, 10) : '';

/* JSON 을 <script> 안에 안전하게 심는다. 카테고리명은 사용자 입력이다. */
const toJs = (v) => JSON.stringify(v)
    .replace(/</g, '\\u003c')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029');
%>

<div class="mb-6 flex justify-between items-center">
    <div>
        <p class="text-sm text-gray-500">상품, 테마, 브랜드 카테고리를 관리합니다. 각 분류 안에서 최대 <%= maxDepth %>단계까지 계층을 만들 수 있습니다.</p>
    </div>
    <button onclick="openModal()"
        class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 gap-2 whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd"
                d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"
                clip-rule="evenodd" />
        </svg>
        카테고리 등록
    </button>
</div>

<% if (error) { %>
    <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700" role="alert">
        <%= error %>
    </div>
<% } %>

<div class="bg-gray-50 border-b border-gray-200 px-1 mb-6">
    <nav class="-mb-px flex space-x-8" aria-label="Tabs">
        <% TABS.forEach(tab => { %>
            <button onclick="switchTab('<%= tab.key %>')" id="tab-<%= tab.key %>" type="button"
                class="whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 focus:ring-blue-500">
                <%= tab.label %>
            </button>
        <% }) %>
    </nav>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <% TABS.forEach(tab => { %>
        <div id="content-<%= tab.key %>" class="p-6 hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full lg:min-w-[1480px] divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-20">순서</th>
                            <% if (tab.hasLogo) { %>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-48"><%= tab.type === 'BRAND' ? '로고' : '이미지' %></th>
                            <% } %>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider min-w-[240px]"><%= tab.nameLabel %></th>
                            <% if (tab.hasDesc) { %>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-64">간략 설명</th>
                            <% } %>
                            <% if (tab.hasOnboarded) { %>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-44">입점일</th>
                            <% } %>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-56">상위 카테고리</th>
                            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-40">노출</th>
                            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-24">상품수</th>
                            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-40">관리</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <% tab.rows.forEach(category => { %>
                            <%
                                const formId = `cat-form-${category.id}`;
                                const indent = (category._depth - 1) * 22;
                                // NORMAL 의 이미지·간략 설명은 메가메뉴 프로모션 영역 전용 → 1뎁스만.
                                // BRAND 로고는 브랜드관/캐러셀용이라 뎁스 제한 없음(어차피 전부 1뎁스).
                                const rowHasLogo = tab.hasLogo && (tab.type !== 'NORMAL' || category._depth === 1);
                                const rowHasDesc = tab.hasDesc && category._depth === 1;
                            %>
                            <tr class="cat-row align-middle <%= category.is_active ? '' : 'bg-gray-50/60' %> <%= category._depth > 1 ? 'hidden' : '' %>"
                                data-cat-id="<%= category.id %>"
                                data-parent-id="<%= category.parent_id || '' %>"
                                data-depth="<%= category._depth %>">
                                <td class="px-4 py-4 whitespace-nowrap">
                                    <form id="<%= formId %>" action="/admin/categories/edit" method="POST"
                                        enctype="multipart/form-data">
                                        <input type="hidden" name="id" value="<%= category.id %>">
                                        <input type="hidden" name="type" value="<%= tab.type %>">
                                        <input type="hidden" name="active_tab" value="<%= tab.key %>">
                                        <% if (tab.hasLogo) { %>
                                            <%# 업로드 필드를 숨긴 행에서도 보낸다. 빠지면 postEdit 가 기존 이미지를 NULL 로 덮는다. %>
                                            <input type="hidden" name="existing_logo" value="<%= category.logo_image_path || '' %>">
                                        <% } %>
                                    </form>
                                    <input form="<%= formId %>" type="number" name="display_order" class="w-20"
                                        value="<%= category.display_order %>">
                                </td>

                                <% if (tab.hasLogo) { %>
                                    <td class="px-4 py-4 whitespace-nowrap">
                                        <% if (!rowHasLogo) { %>
                                            <span class="text-xs text-gray-300">—</span>
                                        <% } else { %>
                                        <div class="flex items-center gap-2">
                                            <div id="preview-container-<%= category.id %>"
                                                class="h-10 w-20 flex-shrink-0 relative overflow-hidden rounded border bg-gray-50 flex items-center justify-center">
                                                <% if (category.logo_image_path) { %>
                                                    <img src="<%= category.logo_image_path %>" alt="Logo" class="max-h-full max-w-full object-contain">
                                                <% } else { %>
                                                    <div class="text-gray-400 text-[10px] bg-gray-100 text-center w-full h-full flex items-center justify-center border-dashed border border-gray-300">NO LOGO</div>
                                                <% } %>
                                            </div>
                                            <input form="<%= formId %>" type="file" name="logo_image"
                                                accept="image/jpeg, image/png, image/webp"
                                                class="brand-logo-upload-btn block w-full text-xs text-gray-500 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:font-medium file:bg-gray-100 file:text-gray-700 hover:file:bg-gray-200"
                                                data-id="<%= category.id %>">
                                        </div>
                                        <% } %>
                                    </td>
                                <% } %>

                                <td class="px-4 py-4 whitespace-nowrap">
                                    <div class="flex items-center" style="padding-left: <%= indent %>px">
                                        <% if (category.childCount > 0) { %>
                                            <button type="button" class="cat-toggle flex-shrink-0 mr-1 w-5 h-5 flex items-center justify-center text-gray-400 hover:text-gray-700"
                                                data-cat-id="<%= category.id %>" aria-expanded="false" title="하위 카테고리 펼치기/접기">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="cat-chevron h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                                                </svg>
                                            </button>
                                        <% } else if (category._depth > 1) { %>
                                            <span class="flex-shrink-0 text-gray-300 mr-1 w-5 h-5 flex items-center justify-center select-none" aria-hidden="true">└</span>
                                        <% } else { %>
                                            <span class="flex-shrink-0 mr-1 w-5 h-5" aria-hidden="true"></span>
                                        <% } %>
                                        <input form="<%= formId %>" type="text" name="name" value="<%= category.name %>" class="flex-1 min-w-[120px]">
                                        <span class="ml-2 text-[11px] text-gray-400 whitespace-nowrap">D<%= category._depth %></span>
                                        <% if (category.childCount > 0) { %>
                                            <span class="ml-1 text-[11px] text-gray-400 whitespace-nowrap">하위 <%= category.childCount %></span>
                                        <% } %>
                                    </div>
                                </td>

                                <% if (tab.hasDesc) { %>
                                    <td class="px-4 py-4">
                                        <% if (rowHasDesc) { %>
                                            <input form="<%= formId %>" type="text" name="description" maxlength="255"
                                                value="<%= category.description || '' %>" placeholder="메가메뉴 우측 영역에 표시될 한 줄 설명"
                                                class="w-full text-sm">
                                        <% } else { %>
                                            <span class="text-xs text-gray-300">—</span>
                                            <%# 값 보존 — 빠지면 postEdit 가 description 을 NULL 로 덮는다. %>
                                            <input form="<%= formId %>" type="hidden" name="description" value="<%= category.description || '' %>">
                                        <% } %>
                                    </td>
                                <% } %>

                                <%# 브랜드 입점일 — 이 날짜로부터 설정 기간 내면 '신규 입점 브랜드'로 노출된다. %>
                                <% if (tab.hasOnboarded) { %>
                                    <td class="px-4 py-4 whitespace-nowrap">
                                        <input form="<%= formId %>" type="date" name="onboarded_at"
                                            value="<%= toDateInput(category.onboarded_at) %>"
                                            class="w-full text-sm">
                                        <% if (typeof isNewBrand === 'function' && isNewBrand(category)) { %>
                                            <span class="mt-1 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-emerald-100 text-emerald-800">신규 입점</span>
                                        <% } %>
                                    </td>
                                <% } %>

                                <td class="px-4 py-4 whitespace-nowrap">
                                    <%# 부모 후보를 행마다 전부 찍으면 브랜드 1354개에서 option 이 백만 단위로 터진다.
                                        현재 값만 렌더하고 나머지는 select 를 열 때 채운다(fillParentSelect). %>
                                    <select form="<%= formId %>" name="parent_id" class="parent-select w-full text-sm"
                                        data-type="<%= tab.type %>" data-cat-id="<%= category.id %>"
                                        data-parent-id="<%= category.parent_id || '' %>">
                                        <option value="">— 최상위 —</option>
                                        <% if (category.parent_id) { %>
                                            <option value="<%= category.parent_id %>" selected><%= category.parentName %></option>
                                        <% } %>
                                    </select>
                                </td>

                                <td class="px-4 py-4 whitespace-nowrap">
                                    <div class="flex items-center justify-center gap-3 text-xs text-gray-600">
                                        <label class="inline-flex items-center gap-1" title="활성화">
                                            <input form="<%= formId %>" type="hidden" name="is_active" value="0">
                                            <input form="<%= formId %>" type="checkbox" name="is_active" value="1" <%= category.is_active ? 'checked' : '' %>>
                                            <span>활성</span>
                                        </label>
                                        <label class="inline-flex items-center gap-1" title="PC 노출">
                                            <input form="<%= formId %>" type="hidden" name="pc_visible" value="0">
                                            <input form="<%= formId %>" type="checkbox" name="pc_visible" value="1" <%= category.pc_visible ? 'checked' : '' %>>
                                            <span>PC</span>
                                        </label>
                                        <label class="inline-flex items-center gap-1" title="모바일 노출">
                                            <input form="<%= formId %>" type="hidden" name="mobile_visible" value="0">
                                            <input form="<%= formId %>" type="checkbox" name="mobile_visible" value="1" <%= category.mobile_visible ? 'checked' : '' %>>
                                            <span>M</span>
                                        </label>
                                    </div>
                                </td>

                                <td class="px-4 py-4 whitespace-nowrap text-right text-sm text-gray-600">
                                    <%= category.productCount %>
                                </td>

                                <td class="px-4 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <div class="flex justify-end gap-2">
                                        <button form="<%= formId %>" type="submit"
                                            class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정</button>
                                        <% if (category.childCount > 0) { %>
                                            <button type="button" disabled
                                                title="하위 카테고리 <%= category.childCount %>개가 있어 삭제할 수 없습니다."
                                                class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md border border-gray-200 bg-gray-50 text-gray-400 cursor-not-allowed">삭제</button>
                                        <% } else { %>
                                            <button type="button"
                                                class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 border border-red-200 bg-red-50 text-red-700 hover:bg-red-100"
                                                onclick="deleteCategory('<%= category.id %>', <%= category.productCount %>)">삭제</button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (tab.rows.length === 0) { %>
                            <tr>
                                <td colspan="<%= colCount(tab) %>" class="px-6 py-10 text-center text-gray-500">등록된 <%= tab.label %>가 없습니다.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <%
                const pi = (pageInfo && pageInfo[tab.type]) || { page: 1, totalPages: 1, total: tab.rows.length, perPage: tab.rows.length };
                const first = pi.total === 0 ? 0 : (pi.page - 1) * pi.perPage + 1;
                const last = Math.min(pi.page * pi.perPage, pi.total);
            %>
            <div class="mt-4 flex items-center justify-between text-sm text-gray-600">
                <div>전체 <%= pi.total %>개 중 <%= first %>–<%= last %>번째</div>
                <% if (pi.totalPages > 1) { %>
                    <%
                        // 현재 페이지 주변 5개만 노출(브랜드는 14페이지까지 간다).
                        const from = Math.max(1, pi.page - 2);
                        const to = Math.min(pi.totalPages, from + 4);
                        const href = (n) => `/admin/categories?tab=${tab.key}&page=${n}`;
                    %>
                    <nav class="flex items-center gap-1" aria-label="페이지">
                        <% if (pi.page > 1) { %>
                            <a href="<%= href(pi.page - 1) %>" class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">이전</a>
                        <% } %>
                        <% if (from > 1) { %>
                            <a href="<%= href(1) %>" class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">1</a>
                            <% if (from > 2) { %><span class="px-1 text-gray-400">…</span><% } %>
                        <% } %>
                        <% for (let n = from; n <= to; n++) { %>
                            <a href="<%= href(n) %>"
                               class="px-2 py-1 rounded border <%= n === pi.page ? 'border-blue-500 bg-blue-50 text-blue-700 font-medium' : 'border-gray-200 hover:bg-gray-50' %>"><%= n %></a>
                        <% } %>
                        <% if (to < pi.totalPages) { %>
                            <% if (to < pi.totalPages - 1) { %><span class="px-1 text-gray-400">…</span><% } %>
                            <a href="<%= href(pi.totalPages) %>" class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50"><%= pi.totalPages %></a>
                        <% } %>
                        <% if (pi.page < pi.totalPages) { %>
                            <a href="<%= href(pi.page + 1) %>" class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">다음</a>
                        <% } %>
                    </nav>
                <% } %>
            </div>
        </div>
    <% }) %>
</div>

<div id="addModal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" role="dialog"
    aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-black/35 backdrop-blur-[1px] transition-opacity z-40" aria-hidden="true"
            onclick="closeModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div
            class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full relative z-50">
            <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">카테고리 등록</h3>
                        <div class="mt-2">
                            <form id="addForm" action="/admin/categories/add" method="POST"
                                enctype="multipart/form-data">
                                <input type="hidden" name="type" id="modal-type-input" value="NORMAL">
                                <input type="hidden" name="active_tab" id="modal-active-tab-input" value="product">
                                <div class="mb-4">
                                    <label class="block mb-2 text-sm font-medium text-gray-900">카테고리명</label>
                                    <input type="text" name="name" required class="w-full">
                                </div>
                                <div class="mb-4 hidden" id="descField">
                                    <label class="block mb-2 text-sm font-medium text-gray-900">간략 설명</label>
                                    <input type="text" name="description" maxlength="255" class="w-full"
                                        placeholder="GNB 메가메뉴에 카테고리명 아래로 표시됩니다 (최대 255자)">
                                </div>
                                <div class="mb-4 hidden" id="onboardedField">
                                    <label class="block mb-2 text-sm font-medium text-gray-900">입점일</label>
                                    <input type="date" name="onboarded_at" class="w-full"
                                        value="<%= new Date().toISOString().slice(0,10) %>">
                                    <p class="mt-1 text-xs text-gray-500">
                                        이 날짜로부터 <strong><%= typeof newBrandDays !== 'undefined' ? newBrandDays : 180 %>일간</strong>
                                        '신규 입점 브랜드'로 노출됩니다.
                                    </p>
                                </div>
                                <div class="mb-4">
                                    <label class="block mb-2 text-sm font-medium text-gray-900">상위 카테고리</label>
                                    <select name="parent_id" id="modal-parent-select" class="w-full">
                                        <option value="">— 최상위 —</option>
                                    </select>
                                    <p class="mt-1 text-xs text-gray-500">최대 <%= maxDepth %>단계까지만 만들 수 있어, 마지막 단계의 카테고리는 상위로 선택되지 않습니다.</p>
                                </div>
                                <div class="mb-4 hidden" id="logoUploadField">
                                    <label class="block mb-2 text-sm font-medium text-gray-900" id="logoUploadLabel">브랜드 로고 파일 업로드</label>
                                    <p class="text-xs text-gray-500 mb-2">정사각형 권장, 최대 2MB 등록 가능</p>
                                    <div id="modal-preview-container"
                                        class="h-16 w-32 mb-2 hidden overflow-hidden rounded border bg-gray-50 items-center justify-center">
                                        <img id="modal-preview-image" src="" alt="Preview"
                                            class="max-h-full max-w-full object-contain">
                                    </div>
                                    <input type="file" name="logo_image" id="modal-logo-upload"
                                        accept="image/jpeg, image/png, image/webp"
                                        class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                                </div>
                                <div class="mb-4">
                                    <label class="block mb-2 text-sm font-medium text-gray-900">출력 순서</label>
                                    <input type="number" name="display_order" id="modal-display-order"
                                        value="<%= nextDisplayOrder ? nextDisplayOrder.NORMAL : 0 %>" class="w-full">
                                </div>
                                <div class="mb-2 flex items-center gap-4 text-sm text-gray-700">
                                    <label class="inline-flex items-center gap-1">
                                        <input type="hidden" name="is_active" value="0">
                                        <input type="checkbox" name="is_active" value="1" checked>
                                        <span>활성</span>
                                    </label>
                                    <label class="inline-flex items-center gap-1">
                                        <input type="hidden" name="pc_visible" value="0">
                                        <input type="checkbox" name="pc_visible" value="1" checked>
                                        <span>PC 노출</span>
                                    </label>
                                    <label class="inline-flex items-center gap-1">
                                        <input type="hidden" name="mobile_visible" value="0">
                                        <input type="checkbox" name="mobile_visible" value="1" checked>
                                        <span>모바일 노출</span>
                                    </label>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <button type="button" onclick="document.getElementById('addForm').submit()"
                    class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 sm:ml-3 sm:w-auto w-full sm:min-w-0">등록</button>
                <button type="button" onclick="closeModal()"
                    class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 mt-3 sm:mt-0 sm:ml-3 w-full sm:w-auto sm:min-w-0">취소</button>
            </div>
        </div>
    </div>
</div>

<form id="deleteForm" action="/admin/categories/delete" method="POST" style="display:none;">
    <input type="hidden" name="id" id="deleteId">
    <input type="hidden" name="active_tab" id="deleteActiveTab">
</form>

<style>
    .cat-chevron { transition: transform .15s ease; }
    .cat-toggle[aria-expanded="true"] .cat-chevron { transform: rotate(90deg); }
</style>

<script>
    let currentTab = '<%- activeTab || "product" %>';
    // 카테고리명이 그대로 들어가므로 스크립트 조기 종료 태그나 U+2028/2029 로 깨지지 않게 이스케이프한다.
    const nextDisplayOrderByType = <%- toJs(nextDisplayOrder || { NORMAL: 0, THEME: 0, BRAND: 0 }) %>;
    const parentOptionsByType = <%- toJs(addParentOptions || {}) %>;
    const typeMap = { product: 'NORMAL', brand: 'BRAND' };

    const tabActiveClass = 'whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm border-blue-500 text-blue-600 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 focus:ring-blue-500';
    const tabInactiveClass = 'whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-0 focus:ring-blue-500';

    function updateModalDisplayOrder() {
        const displayOrderInput = document.getElementById('modal-display-order');
        if (!displayOrderInput) return;
        displayOrderInput.value = nextDisplayOrderByType[typeMap[currentTab] || 'NORMAL'] ?? 0;
    }

    // 상위 선택지는 탭(=분류)마다 다르다. 다른 분류의 카테고리를 부모로 고를 수 없다.
    function updateModalParentOptions() {
        const select = document.getElementById('modal-parent-select');
        if (!select) return;
        const options = parentOptionsByType[typeMap[currentTab] || 'NORMAL'] || [];
        select.innerHTML = '<option value="">— 최상위 —</option>';
        options.forEach(opt => {
            const el = document.createElement('option');
            el.value = opt.id;
            el.textContent = ' '.repeat((opt.depth - 1) * 3) + opt.name;
            select.appendChild(el);
        });
    }

    /*
     * 행별 "상위 카테고리" select 는 현재 값만 서버 렌더된다(응답 폭발 방지).
     * 실제 후보는 select 를 처음 열 때 채운다. 자기 자신/후손 제외는 편의일 뿐,
     * 순환·뎁스 위반의 실제 방어는 서버(postEdit 의 wouldCreateCycle/assertDepthAllowed)가 한다.
     */
    function fillParentSelect(select) {
        if (select.dataset.filled) return;
        select.dataset.filled = '1';

        const options = parentOptionsByType[select.dataset.type] || [];
        const selfId = Number(select.dataset.catId);
        const currentParentId = select.dataset.parentId ? Number(select.dataset.parentId) : null;

        const byId = new Map(options.map(o => [o.id, o]));
        const isSelfOrDescendant = (id) => {
            let cur = id;
            for (let guard = 0; cur != null && guard < 100; guard++) {
                if (cur === selfId) return true;
                const node = byId.get(cur);
                cur = node ? node.parentId : null;
            }
            return false;
        };

        // 후보 목록에 현재 부모가 없으면(있을 수 없지만) 서버가 찍어둔 option 을 지우지 않는다.
        if (currentParentId != null && !byId.has(currentParentId)) return;

        const frag = document.createDocumentFragment();
        options.forEach(opt => {
            if (isSelfOrDescendant(opt.id)) return;
            const el = document.createElement('option');
            el.value = opt.id;
            el.textContent = ' '.repeat((opt.depth - 1) * 3) + opt.name;
            if (opt.id === currentParentId) el.selected = true;
            frag.appendChild(el);
        });

        // 서버가 찍어둔 현재 부모 option 은 중복되므로 걷어내고(첫 '— 최상위 —' 는 유지) 새로 채운다.
        while (select.options.length > 1) select.remove(1);
        select.appendChild(frag);
        if (currentParentId == null) select.value = '';
    }

    document.addEventListener('mousedown', (e) => {
        const select = e.target.closest('select.parent-select');
        if (select) fillParentSelect(select);
    });
    document.addEventListener('focusin', (e) => {
        const select = e.target.closest('select.parent-select');
        if (select) fillParentSelect(select);
    });

    function switchTab(tab) {
        currentTab = tab;
        ['product', 'brand'].forEach(key => {
            document.getElementById('tab-' + key).className = (key === tab) ? tabActiveClass : tabInactiveClass;
            document.getElementById('content-' + key).classList.toggle('hidden', key !== tab);
        });
    }

    function openModal() {
        document.getElementById('modal-type-input').value = typeMap[currentTab] || 'NORMAL';
        document.getElementById('modal-active-tab-input').value = currentTab;

        document.getElementById('logoUploadLabel').textContent =
            currentTab === 'brand' ? '브랜드 로고 파일 업로드' : '카테고리 이미지 업로드';

        updateModalDisplayOrder();
        updateModalParentOptions();
        updateModalMediaFields();
        document.getElementById('addModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    /*
     * 상품 카테고리의 이미지·간략 설명은 GNB 메가메뉴 우측 프로모션 영역 전용이라 1뎁스만 쓴다.
     * → 상위 카테고리를 고르는 순간(=2뎁스 이상) 두 입력을 숨긴다.
     * 브랜드 로고는 브랜드관/캐러셀용이라 뎁스와 무관하게 항상 표시한다.
     */
    function updateModalMediaFields() {
        const parentSelect = document.getElementById('modal-parent-select');
        const isTopLevel = !parentSelect || !parentSelect.value;

        const showImage = currentTab === 'brand' || (currentTab === 'product' && isTopLevel);
        const showDesc = currentTab === 'product' && isTopLevel;
        const showOnboarded = currentTab === 'brand'; // 입점일은 브랜드에만 의미가 있다

        document.getElementById('logoUploadField').classList.toggle('hidden', !showImage);
        document.getElementById('descField').classList.toggle('hidden', !showDesc);
        document.getElementById('onboardedField').classList.toggle('hidden', !showOnboarded);
    }

    document.addEventListener('change', (e) => {
        if (e.target && e.target.id === 'modal-parent-select') updateModalMediaFields();
    });

    function closeModal() {
        document.getElementById('addModal').classList.add('hidden');
        document.body.style.overflow = '';
    }

    function deleteCategory(id, productCount) {
        let message = '정말 삭제하시겠습니까?';
        if (productCount > 0) {
            message = '이 카테고리에 상품 ' + productCount + '개가 연결되어 있습니다.\n삭제하면 해당 상품의 카테고리가 비워집니다. 계속하시겠습니까?';
        }
        if (confirm(message)) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteActiveTab').value = currentTab;
            document.getElementById('deleteForm').submit();
        }
    }

    /*
     * 뎁스별 아코디언.
     * 초기 렌더에서 depth>1 행은 .hidden 으로 접혀 있다(서버에서 부여).
     * 자식 있는 행의 셰브론을 누르면 직계 자식만 펼치고, 접으면 후손 전체를 함께 접는다.
     * 행은 부모→자식 순으로 이미 평탄화돼 있고, data-parent-id 로 부모-자식을 잇는다.
     */
    function catChildRows(catId) {
        return Array.from(document.querySelectorAll('tr.cat-row[data-parent-id="' + catId + '"]'));
    }
    function collapseCatDescendants(catId) {
        catChildRows(catId).forEach(row => {
            row.classList.add('hidden');
            const toggle = row.querySelector('.cat-toggle');
            if (toggle) toggle.setAttribute('aria-expanded', 'false');
            collapseCatDescendants(row.dataset.catId);
        });
    }
    function toggleCategory(toggle) {
        const catId = toggle.dataset.catId;
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        if (expanded) {
            toggle.setAttribute('aria-expanded', 'false');
            collapseCatDescendants(catId);          // 접을 땐 후손 전체를 함께 접는다
        } else {
            toggle.setAttribute('aria-expanded', 'true');
            catChildRows(catId).forEach(row => row.classList.remove('hidden')); // 직계 자식만 편다
        }
    }
    document.addEventListener('click', (e) => {
        const toggle = e.target.closest('.cat-toggle');
        if (toggle) { e.preventDefault(); toggleCategory(toggle); }
    });

    switchTab(currentTab);

    // 브랜드 로고 리스트 내 미리보기 처리
    document.querySelectorAll('.brand-logo-upload-btn').forEach(input => {
        input.addEventListener('change', function (e) {
            const file = e.target.files[0];
            const categoryId = this.getAttribute('data-id');
            const previewContainer = document.getElementById('preview-container-' + categoryId);

            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    previewContainer.innerHTML = '<img src="' + e.target.result + '" class="max-h-full max-w-full object-contain">';
                };
                reader.readAsDataURL(file);
            } else {
                previewContainer.innerHTML = '<div class="text-gray-400 text-[10px] bg-gray-100 text-center w-full h-full flex items-center justify-center border-dashed border border-gray-300">NO LOGO</div>';
            }
        });
    });

    // 등록 모달 내 미리보기 처리
    const modalLogoUpload = document.getElementById('modal-logo-upload');
    const modalPreviewContainer = document.getElementById('modal-preview-container');
    const modalPreviewImage = document.getElementById('modal-preview-image');

    if (modalLogoUpload) {
        modalLogoUpload.addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    modalPreviewImage.src = e.target.result;
                    modalPreviewContainer.classList.remove('hidden');
                    modalPreviewContainer.classList.add('flex');
                };
                reader.readAsDataURL(file);
            } else {
                modalPreviewImage.src = '';
                modalPreviewContainer.classList.add('hidden');
                modalPreviewContainer.classList.remove('flex');
            }
        });
    }
</script>
