<%
/* B1 — 상품 카테고리 관리 (최대 maxDepth 단계 트리)

   브랜드(type='BRAND')는 이 화면에서 빠졌다 → 브랜드 관리(/admin/brands).
   탭은 분류축이 아니라 **범위**다.
     used = 이 몰에 상품이 있는 카테고리 — 트리 + 아코디언(기존 화면 그대로)
     all  = 빈 카테고리 포함 전체       — 평면 목록 + 행 페이징(2,348행을 한 번에 그리지 않기 위해)

   all 탭에는 이미지·설명·상위 위젯이 없다. 대신 그 값들을 hidden 으로 함께 보낸다 —
   postEdit 의 UPDATE 는 "보내지 않은 컬럼은 지운다" 계약이라, 빠뜨리면 수정할 때마다
   로고·설명·상위·노출플래그가 조용히 비워진다. */
const isUsed = viewScope === 'used';
const listUrl = (params) => {
    const sp = new URLSearchParams();
    Object.entries(params).forEach(([k, v]) => { if (v !== null && v !== undefined && v !== '') sp.set(k, v); });
    const s = sp.toString();
    return `/admin/categories${s ? '?' + s : ''}`;
};
const returnUrl = listUrl({ scope: viewScope, page: pageInfo.page > 1 ? pageInfo.page : null });

/* JSON 을 <script> 안에 안전하게 심는다. 카테고리명은 사용자 입력이다. */
const toJs = (v) => JSON.stringify(v)
    .replace(/</g, '\\u003c')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029');
%>

<div class="mb-6 flex justify-between items-center">
    <div>
        <p class="text-sm text-gray-500">상품 카테고리를 관리합니다. 최대 <%= maxDepth %>단계까지 계층을 만들 수 있습니다.</p>
        <p class="mt-0.5 text-xs text-gray-400">
            상품 배정·기본정보 관리는 행마다 <strong>[관리]</strong>(상세 화면). 사용 여부만 여러 건 바꿀 때는 <strong>[사용여부 저장]</strong> 을 쓰세요. 메뉴(GNB) 노출·순서는 <a href="/admin/menu-preview" class="text-indigo-600 hover:underline">메뉴 미리보기</a>에서 관리합니다.<br>
            브랜드는 <a href="/admin/brands" class="text-indigo-600 hover:underline">브랜드 관리</a>로 옮겼습니다.
            카테고리는 전 몰 공통(글로벌)입니다. <strong>[사용 여부]</strong> 는 모든 몰에 적용되는 스위치, <strong>[이 몰 표시]</strong> 는 현재 몰(<%= currentMallName %>) 스토어프론트에서만 숨기고 여는 토글입니다(상품이 있는 항목만 가능, 즉시 저장).
        </p>
    </div>
    <div class="flex items-center gap-2">
    <% if (typeof saved !== 'undefined' && saved) { %>
        <span class="text-xs text-emerald-600 mr-1">저장되었습니다.</span>
    <% } %>
    <%#
      사용여부 일괄 저장 — 체크박스는 행별 수정 폼(form 속성)에 묶여 있어 다른 폼으로 함께 보낼 수 없다.
      그래서 지금 페이지의 행들을 훑어 히든 폼을 만들어 보낸다(제출되는 값 = 화면에 보이는 상태).
    %>
    <button type="button" onclick="saveVisibility()"
        class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 whitespace-nowrap">
        사용여부 저장
    </button>
    <button onclick="openModal()"
        class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 gap-2 whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd"
                d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"
                clip-rule="evenodd" />
        </svg>
        카테고리 등록
    </button>
    </div>
</div>

<% if (error) { %>
    <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700" role="alert">
        <%= error %>
    </div>
<% } %>

<%# 범위 탭 — 서버 왕복(각 탭이 독립 페이징을 쓴다) %>
<div class="bg-gray-50 border-b border-gray-200 px-1 mb-6">
    <nav class="-mb-px flex space-x-8" aria-label="Tabs">
        <%
            const TABS = [
                { key: 'used', label: '사용중 카테고리', count: scopeCounts.used, hint: '이 몰에 상품이 있는 카테고리' },
                { key: 'all',  label: '미사용 포함 전체', count: scopeCounts.all, hint: '빈 카테고리까지 전부 (페이지당 ' + pageInfo.perPage + '건)' },
            ];
        %>
        <% TABS.forEach(t => { const on = t.key === viewScope; %>
            <a href="<%= listUrl({ scope: t.key }) %>" title="<%= t.hint %>"
               class="whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm no-underline transition-colors <%= on ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' %>">
                <%= t.label %>
                <span class="ml-1 text-xs <%= on ? 'text-blue-500' : 'text-gray-400' %>">(<%= Number(t.count).toLocaleString() %>)</span>
            </a>
        <% }) %>
    </nav>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6">
        <% if (!isUsed) { %>
            <p class="mb-4 text-xs text-gray-500 bg-gray-50 border border-gray-200 rounded-md px-3 py-2">
                전체 목록은 계층을 펼치지 않고 <strong>평면 + 경로</strong>로 보여줍니다(<%= Number(pageInfo.total).toLocaleString() %>건을 한 화면에 그리면 느려집니다).
                이미지·설명·상위 카테고리 편집은 <strong>사용중</strong> 탭이나 행별 <strong>[관리]</strong> 화면에서 하세요.
            </p>
        <% } %>
        <div class="overflow-x-auto">
            <table class="min-w-full <%= isUsed ? 'lg:min-w-[1480px]' : '' %> divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-20">순서</th>
                        <% if (isUsed) { %>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-48">이미지</th>
                        <% } %>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider min-w-[240px]">카테고리명</th>
                        <% if (isUsed) { %>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-64">간략 설명</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-56">상위 카테고리</th>
                        <% } else { %>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider min-w-[220px]">경로</th>
                        <% } %>
                        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-32" title="모든 몰 공통(글로벌 카탈로그) 사용 여부 스위치">사용 여부</th>
                        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-32" title="이 몰(<%= currentMallName %>) 스토어프론트에서만 표시 여부">이 몰 표시<br><span class="text-[10px] normal-case text-gray-400"><%= currentMallName %></span></th>
                        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-24">상품수</th>
                        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-40">관리</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <% rows.forEach(category => { %>
                        <%
                            const formId = `cat-form-${category.id}`;
                            const indent = isUsed ? (category._depth - 1) * 22 : 0;
                            // 이미지·간략 설명은 GNB 메가메뉴 프로모션 영역 전용 → 1뎁스만.
                            const rowHasLogo = isUsed && category._depth === 1;
                            const rowHasDesc = isUsed && category._depth === 1;
                        %>
                        <tr class="cat-row align-middle <%= category.is_active ? '' : 'bg-gray-50/60' %> <%= (isUsed && category._depth > 1) ? 'hidden' : '' %>"
                            data-cat-id="<%= category.id %>"
                            data-parent-id="<%= category.parent_id || '' %>"
                            data-depth="<%= category._depth %>">
                            <td class="px-4 py-4 whitespace-nowrap">
                                <form id="<%= formId %>" action="/admin/categories/edit" method="POST"
                                    enctype="multipart/form-data">
                                    <input type="hidden" name="id" value="<%= category.id %>">
                                    <input type="hidden" name="type" value="NORMAL">
                                    <input type="hidden" name="scope" value="<%= viewScope %>">
                                    <input type="hidden" name="return_url" value="<%= returnUrl %>">
                                    <%# 업로드 필드를 숨긴 행에서도 보낸다. 빠지면 postEdit 가 기존 이미지를 NULL 로 덮는다. %>
                                    <input type="hidden" name="existing_logo" value="<%= category.logo_image_path || '' %>">
                                    <% if (!isUsed) { %>
                                        <%# 전체 탭에는 설명·상위 위젯이 없다 → 현재 값을 그대로 되돌려 보내 보존한다. %>
                                        <input type="hidden" name="description" value="<%= category.description || '' %>">
                                        <input type="hidden" name="parent_id" value="<%= category.parent_id || '' %>">
                                    <% } %>
                                </form>
                                <input form="<%= formId %>" type="number" name="display_order" class="w-20"
                                    value="<%= category.display_order %>">
                            </td>

                            <% if (isUsed) { %>
                                <td class="px-4 py-4 whitespace-nowrap">
                                    <% if (!rowHasLogo) { %>
                                        <span class="text-xs text-gray-300">—</span>
                                    <% } else { %>
                                    <div class="flex items-center gap-2">
                                        <div id="preview-container-<%= category.id %>"
                                            class="h-10 w-20 flex-shrink-0 relative overflow-hidden rounded border bg-gray-50 flex items-center justify-center">
                                            <% if (category.logo_image_path) { %>
                                                <img src="<%= category.logo_image_path %>" alt="Logo" class="max-h-full max-w-full object-contain">
                                            <% } else { %>
                                                <div class="text-gray-400 text-[10px] bg-gray-100 text-center w-full h-full flex items-center justify-center border-dashed border border-gray-300">NO IMAGE</div>
                                            <% } %>
                                        </div>
                                        <input form="<%= formId %>" type="file" name="logo_image"
                                            accept="image/jpeg, image/png, image/webp"
                                            class="cat-logo-upload-btn block w-full text-xs text-gray-500 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:font-medium file:bg-gray-100 file:text-gray-700 hover:file:bg-gray-200"
                                            data-id="<%= category.id %>">
                                    </div>
                                    <% } %>
                                </td>
                            <% } %>

                            <td class="px-4 py-4 whitespace-nowrap">
                                <div class="flex items-center" style="padding-left: <%= indent %>px">
                                    <% if (isUsed) { %>
                                        <%# 화살표는 현재 몰에 실제로 보이는 하위가 있을 때만 (visibleChildCount) %>
                                        <% if (category.visibleChildCount > 0) { %>
                                            <button type="button" class="cat-toggle flex-shrink-0 mr-1 w-5 h-5 flex items-center justify-center text-gray-400 hover:text-gray-700"
                                                data-cat-id="<%= category.id %>" aria-expanded="false" title="하위 카테고리 펼치기/접기">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="cat-chevron h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                                                </svg>
                                            </button>
                                        <% } else if (category._depth > 1) { %>
                                            <span class="flex-shrink-0 text-gray-300 mr-1 w-5 h-5 flex items-center justify-center select-none" aria-hidden="true">└</span>
                                        <% } else { %>
                                            <span class="flex-shrink-0 mr-1 w-5 h-5" aria-hidden="true"></span>
                                        <% } %>
                                    <% } %>
                                    <input form="<%= formId %>" type="text" name="name" value="<%= category.name %>" class="flex-1 min-w-[120px]">
                                    <span class="ml-2 text-[11px] text-gray-400 whitespace-nowrap">D<%= category._depth %></span>
                                    <% if (isUsed && category.visibleChildCount > 0) { %>
                                        <span class="ml-1 text-[11px] text-gray-400 whitespace-nowrap">하위 <%= category.visibleChildCount %></span>
                                    <% } %>
                                </div>
                            </td>

                            <% if (isUsed) { %>
                                <td class="px-4 py-4">
                                    <% if (rowHasDesc) { %>
                                        <input form="<%= formId %>" type="text" name="description" maxlength="255"
                                            value="<%= category.description || '' %>" placeholder="메가메뉴 우측 영역에 표시될 한 줄 설명"
                                            class="w-full text-sm">
                                    <% } else { %>
                                        <span class="text-xs text-gray-300">—</span>
                                        <%# 값 보존 — 빠지면 postEdit 가 description 을 NULL 로 덮는다. %>
                                        <input form="<%= formId %>" type="hidden" name="description" value="<%= category.description || '' %>">
                                    <% } %>
                                </td>

                                <td class="px-4 py-4 whitespace-nowrap">
                                    <%# 부모 후보를 행마다 전부 찍으면 option 이 폭발한다.
                                        현재 값만 렌더하고 나머지는 select 를 열 때 채운다(fillParentSelect). %>
                                    <select form="<%= formId %>" name="parent_id" class="parent-select w-full text-sm"
                                        data-cat-id="<%= category.id %>"
                                        data-parent-id="<%= category.parent_id || '' %>">
                                        <option value="">— 최상위 —</option>
                                        <% if (category.parent_id) { %>
                                            <option value="<%= category.parent_id %>" selected><%= category.parentName %></option>
                                        <% } %>
                                    </select>
                                </td>
                            <% } else { %>
                                <td class="px-4 py-4 text-sm text-gray-500">
                                    <%= category.parentPath || '— 최상위 —' %>
                                </td>
                            <% } %>

                            <td class="px-4 py-4 whitespace-nowrap">
                                <div class="flex items-center justify-center gap-3 text-xs text-gray-600">
                                    <label class="inline-flex items-center gap-1" title="사용 여부(전역)">
                                        <input form="<%= formId %>" type="hidden" name="is_active" value="0">
                                        <input form="<%= formId %>" type="checkbox" name="is_active" value="1" <%= category.is_active ? 'checked' : '' %>>
                                        <span>사용</span>
                                    </label>
                                    <%# 메뉴(PC/모바일) 노출은 메뉴 미리보기에서 관리한다. 여기서는 값만 보존한다. %>
                                    <input form="<%= formId %>" type="hidden" name="pc_visible" value="<%= category.pc_visible ? 1 : 0 %>">
                                    <input form="<%= formId %>" type="hidden" name="mobile_visible" value="<%= category.mobile_visible ? 1 : 0 %>">
                                </div>
                            </td>

                            <td class="px-4 py-4 whitespace-nowrap text-center text-sm">
                                <% if (category.validForMall) { %>
                                    <%# 이 몰에 상품이 있어 노출되는 항목만 몰별 표시 override 가능. onchange 즉시 저장. %>
                                    <form action="/admin/categories/mall-visibility" method="POST" class="inline-flex items-center">
                                        <input type="hidden" name="scope" value="<%= viewScope %>">
                                        <input type="hidden" name="return_url" value="<%= returnUrl %>">
                                        <input type="hidden" name="category_id" value="<%= category.id %>">
                                        <input type="hidden" name="visible" value="0">
                                        <label class="inline-flex items-center gap-1 cursor-pointer" title="이 몰에서 표시">
                                            <input type="checkbox" name="visible" value="1"
                                                onchange="this.form.submit()"
                                                <%= category.hiddenForMall ? '' : 'checked' %>>
                                            <span class="text-xs <%= category.hiddenForMall ? 'text-gray-400' : 'text-gray-700' %>"><%= category.hiddenForMall ? '숨김' : '표시' %></span>
                                        </label>
                                    </form>
                                <% } else { %>
                                    <span class="text-xs text-gray-300" title="이 몰에 상품이 없어 스토어프론트에 노출되지 않습니다">—</span>
                                <% } %>
                            </td>

                            <td class="px-4 py-4 whitespace-nowrap text-right text-sm text-gray-600">
                                <%= category.productCount %>
                            </td>

                            <td class="px-4 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex justify-end gap-2">
                                    <%# 상세 화면 — 기본정보 + 상품 배정/제거 %>
                                    <a href="/admin/categories/<%= category.id %>"
                                        class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md border border-indigo-200 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 no-underline"><i class="bi bi-box-arrow-up-right mr-1"></i>관리</a>
                                    <button form="<%= formId %>" type="submit"
                                        class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정</button>
                                    <% if (category.childCount > 0) { %>
                                        <button type="button" disabled
                                            title="하위 카테고리 <%= category.childCount %>개가 있어 삭제할 수 없습니다."
                                            class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md border border-gray-200 bg-gray-50 text-gray-400 cursor-not-allowed">삭제</button>
                                    <% } else { %>
                                        <button type="button"
                                            class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 border border-red-200 bg-red-50 text-red-700 hover:bg-red-100"
                                            onclick="deleteCategory('<%= category.id %>', <%= category.productCount %>)">삭제</button>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                    <% if (rows.length === 0) { %>
                        <tr>
                            <td colspan="<%= isUsed ? 9 : 7 %>" class="px-6 py-10 text-center text-gray-500">
                                <%= isUsed ? '이 몰에 상품이 있는 카테고리가 없습니다. [미사용 포함 전체] 탭에서 전체 카테고리를 볼 수 있습니다.' : '등록된 카테고리가 없습니다.' %>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <%
            const pi = pageInfo;
            const first = pi.total === 0 ? 0 : (pi.page - 1) * pi.perPage + 1;
            const last = Math.min(pi.page * pi.perPage, pi.total);
        %>
        <div class="mt-4 flex items-center justify-between text-sm text-gray-600">
            <div><%= pi.unit %> 전체 <%= Number(pi.total).toLocaleString() %>개 중 <%= first %>–<%= last %>번째</div>
            <% if (pi.totalPages > 1) { %>
                <%
                    // 현재 페이지 주변 5개만 노출.
                    const from = Math.max(1, pi.page - 2);
                    const to = Math.min(pi.totalPages, from + 4);
                    const href = (n) => listUrl({ scope: viewScope, page: n });
                %>
                <nav class="flex items-center gap-1" aria-label="페이지">
                    <% if (pi.page > 1) { %>
                        <a href="<%= href(pi.page - 1) %>" class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">이전</a>
                    <% } %>
                    <% if (from > 1) { %>
                        <a href="<%= href(1) %>" class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">1</a>
                        <% if (from > 2) { %><span class="px-1 text-gray-400">…</span><% } %>
                    <% } %>
                    <% for (let n = from; n <= to; n++) { %>
                        <a href="<%= href(n) %>"
                           class="px-2 py-1 rounded border <%= n === pi.page ? 'border-blue-500 bg-blue-50 text-blue-700 font-medium' : 'border-gray-200 hover:bg-gray-50' %>"><%= n %></a>
                    <% } %>
                    <% if (to < pi.totalPages) { %>
                        <% if (to < pi.totalPages - 1) { %><span class="px-1 text-gray-400">…</span><% } %>
                        <a href="<%= href(pi.totalPages) %>" class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50"><%= pi.totalPages %></a>
                    <% } %>
                    <% if (pi.page < pi.totalPages) { %>
                        <a href="<%= href(pi.page + 1) %>" class="px-2 py-1 rounded border border-gray-200 hover:bg-gray-50">다음</a>
                    <% } %>
                </nav>
            <% } %>
        </div>
    </div>
</div>

<div id="addModal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" role="dialog"
    aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-black/35 backdrop-blur-[1px] transition-opacity z-40" aria-hidden="true"
            onclick="closeModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div
            class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full relative z-50">
            <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">카테고리 등록</h3>
                        <div class="mt-2">
                            <form id="addForm" action="/admin/categories/add" method="POST"
                                enctype="multipart/form-data">
                                <input type="hidden" name="type" value="NORMAL">
                                <input type="hidden" name="scope" value="<%= viewScope %>">
                                <input type="hidden" name="return_url" value="<%= returnUrl %>">
                                <div class="mb-4">
                                    <label class="block mb-2 text-sm font-medium text-gray-900">카테고리명</label>
                                    <input type="text" name="name" required class="w-full">
                                </div>
                                <div class="mb-4" id="descField">
                                    <label class="block mb-2 text-sm font-medium text-gray-900">간략 설명</label>
                                    <input type="text" name="description" maxlength="255" class="w-full"
                                        placeholder="GNB 메가메뉴에 카테고리명 아래로 표시됩니다 (최대 255자)">
                                </div>
                                <div class="mb-4">
                                    <label class="block mb-2 text-sm font-medium text-gray-900">상위 카테고리</label>
                                    <select name="parent_id" id="modal-parent-select" class="w-full">
                                        <option value="">— 최상위 —</option>
                                    </select>
                                    <p class="mt-1 text-xs text-gray-500">최대 <%= maxDepth %>단계까지만 만들 수 있어, 마지막 단계의 카테고리는 상위로 선택되지 않습니다.</p>
                                </div>
                                <div class="mb-4" id="logoUploadField">
