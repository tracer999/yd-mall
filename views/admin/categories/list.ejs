                                    <p class="text-xs text-gray-500 mb-2">정사각형 권장, 최대 2MB 등록 가능</p>
                                    <div id="modal-preview-container"
                                        class="h-16 w-32 mb-2 hidden overflow-hidden rounded border bg-gray-50 items-center justify-center">
                                        <img id="modal-preview-image" src="" alt="Preview"
                                            class="max-h-full max-w-full object-contain">
                                    </div>
                                    <input type="file" name="logo_image" id="modal-logo-upload"
                                        accept="image/jpeg, image/png, image/webp"
                                        class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                                </div>
                                <div class="mb-4">
                                    <label class="block mb-2 text-sm font-medium text-gray-900">출력 순서</label>
                                    <input type="number" name="display_order" id="modal-display-order"
                                        value="<%= nextDisplayOrder %>" class="w-full">
                                </div>
                                <div class="mb-2 flex items-center gap-4 text-sm text-gray-700">
                                    <label class="inline-flex items-center gap-1">
                                        <input type="hidden" name="is_active" value="0">
                                        <input type="checkbox" name="is_active" value="1" checked>
                                        <span>활성</span>
                                    </label>
                                    <label class="inline-flex items-center gap-1">
                                        <input type="hidden" name="pc_visible" value="0">
                                        <input type="checkbox" name="pc_visible" value="1" checked>
                                        <span>PC 노출</span>
                                    </label>
                                    <label class="inline-flex items-center gap-1">
                                        <input type="hidden" name="mobile_visible" value="0">
                                        <input type="checkbox" name="mobile_visible" value="1" checked>
                                        <span>모바일 노출</span>
                                    </label>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <button type="button" onclick="document.getElementById('addForm').submit()"
                    class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 sm:ml-3 sm:w-auto w-full sm:min-w-0">등록</button>
                <button type="button" onclick="closeModal()"
                    class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 mt-3 sm:mt-0 sm:ml-3 w-full sm:w-auto sm:min-w-0">취소</button>
            </div>
        </div>
    </div>
</div>

<form id="deleteForm" action="/admin/categories/delete" method="POST" style="display:none;">
    <input type="hidden" name="id" id="deleteId">
    <input type="hidden" name="scope" value="<%= viewScope %>">
    <input type="hidden" name="return_url" value="<%= returnUrl %>">
</form>

<form id="visibilityForm" action="/admin/categories/visibility" method="POST" style="display:none;"></form>

<style>
    .cat-chevron { transition: transform .15s ease; }
    .cat-toggle[aria-expanded="true"] .cat-chevron { transform: rotate(90deg); }
</style>

<script>
    // 카테고리명이 그대로 들어가므로 스크립트 조기 종료 태그나 U+2028/2029 로 깨지지 않게 이스케이프한다.
    const parentOptions = <%- toJs(parentOptions || []) %>;
    const CURRENT_SCOPE = '<%- viewScope %>';
    const RETURN_URL = <%- toJs(returnUrl) %>;

    /*
     * 사용여부 일괄 저장 — 지금 페이지의 모든 행(접혀 있는 하위 뎁스 포함)을 훑어
     * 사용 여부 체크 상태만 서버로 보낸다. 이름·순서·상위는 보내지 않는다(행별 [수정] 소관).
     */
    function saveVisibility() {
        const form = document.getElementById('visibilityForm');
        if (!form) return;

        const rows = document.querySelectorAll('tr.cat-row');
        if (!rows.length) return alert('저장할 카테고리가 없습니다.');

        form.innerHTML = '';
        const add = (name, value) => {
            const el = document.createElement('input');
            el.type = 'hidden'; el.name = name; el.value = value;
            form.appendChild(el);
        };
        add('scope', CURRENT_SCOPE);
        add('return_url', RETURN_URL);

        rows.forEach(row => {
            const id = row.getAttribute('data-cat-id');
            if (!id) return;
            add('id[]', id);
            // 체크된 것만 보낸다. 서버는 없는 키를 0 으로 읽는다(체크 해제 = 사용 끔).
            // 키의 'c' 접두어는 필수 — 숫자 키는 qs 가 배열 인덱스로 해석해 id 매칭이 깨진다.
            const box = row.querySelector('input[type="checkbox"][name="is_active"]');
            if (box && box.checked) add('active[c' + id + ']', '1');
        });

        form.submit();
    }

    function updateModalParentOptions() {
        const select = document.getElementById('modal-parent-select');
        if (!select) return;
        select.innerHTML = '<option value="">— 최상위 —</option>';
        parentOptions.forEach(opt => {
            const el = document.createElement('option');
            el.value = opt.id;
            el.textContent = ' '.repeat((opt.depth - 1) * 3) + opt.name;
            select.appendChild(el);
        });
    }

    /*
     * 행별 "상위 카테고리" select 는 현재 값만 서버 렌더된다(응답 폭발 방지).
     * 실제 후보는 select 를 처음 열 때 채운다. 자기 자신/후손 제외는 편의일 뿐,
     * 순환·뎁스 위반의 실제 방어는 서버(postEdit 의 wouldCreateCycle/assertDepthAllowed)가 한다.
     */
    function fillParentSelect(select) {
        if (select.dataset.filled) return;
        select.dataset.filled = '1';

        const selfId = Number(select.dataset.catId);
        const currentParentId = select.dataset.parentId ? Number(select.dataset.parentId) : null;

        const byId = new Map(parentOptions.map(o => [o.id, o]));
        const isSelfOrDescendant = (id) => {
            let cur = id;
            for (let guard = 0; cur != null && guard < 100; guard++) {
                if (cur === selfId) return true;
                const node = byId.get(cur);
                cur = node ? node.parentId : null;
            }
            return false;
        };

        // 후보 목록에 현재 부모가 없으면(있을 수 없지만) 서버가 찍어둔 option 을 지우지 않는다.
        if (currentParentId != null && !byId.has(currentParentId)) return;

        const frag = document.createDocumentFragment();
        parentOptions.forEach(opt => {
            if (isSelfOrDescendant(opt.id)) return;
            const el = document.createElement('option');
            el.value = opt.id;
            el.textContent = ' '.repeat((opt.depth - 1) * 3) + opt.name;
            if (opt.id === currentParentId) el.selected = true;
            frag.appendChild(el);
        });

        // 서버가 찍어둔 현재 부모 option 은 중복되므로 걷어내고(첫 '— 최상위 —' 는 유지) 새로 채운다.
        while (select.options.length > 1) select.remove(1);
        select.appendChild(frag);
        if (currentParentId == null) select.value = '';
    }

    document.addEventListener('mousedown', (e) => {
        const select = e.target.closest('select.parent-select');
        if (select) fillParentSelect(select);
    });
    document.addEventListener('focusin', (e) => {
        const select = e.target.closest('select.parent-select');
        if (select) fillParentSelect(select);
    });

    function openModal() {
        updateModalParentOptions();
        updateModalMediaFields();
        document.getElementById('addModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    /*
     * 이미지·간략 설명은 GNB 메가메뉴 우측 프로모션 영역 전용이라 1뎁스만 쓴다.
     * → 상위 카테고리를 고르는 순간(=2뎁스 이상) 두 입력을 숨긴다.
     */
    function updateModalMediaFields() {
        const parentSelect = document.getElementById('modal-parent-select');
        const isTopLevel = !parentSelect || !parentSelect.value;
        document.getElementById('logoUploadField').classList.toggle('hidden', !isTopLevel);
        document.getElementById('descField').classList.toggle('hidden', !isTopLevel);
    }

    document.addEventListener('change', (e) => {
        if (e.target && e.target.id === 'modal-parent-select') updateModalMediaFields();
    });

    function closeModal() {
        document.getElementById('addModal').classList.add('hidden');
        document.body.style.overflow = '';
    }

    function deleteCategory(id, productCount) {
        let message = '정말 삭제하시겠습니까?';
        if (productCount > 0) {
            message = '이 카테고리에 상품 ' + productCount + '개가 연결되어 있습니다.\n삭제하면 해당 상품의 카테고리가 비워집니다. 계속하시겠습니까?';
        }
        if (confirm(message)) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteForm').submit();
        }
    }

    /*
     * 뎁스별 아코디언 (사용중 탭 전용 — 전체 탭은 평면이라 접힘이 없다).
     * 초기 렌더에서 depth>1 행은 .hidden 으로 접혀 있다(서버에서 부여).
     * 자식 있는 행의 셰브론을 누르면 직계 자식만 펼치고, 접으면 후손 전체를 함께 접는다.
     * 행은 부모→자식 순으로 이미 평탄화돼 있고, data-parent-id 로 부모-자식을 잇는다.
     */
    function catChildRows(catId) {
        return Array.from(document.querySelectorAll('tr.cat-row[data-parent-id="' + catId + '"]'));
    }
    function collapseCatDescendants(catId) {
        catChildRows(catId).forEach(row => {
            row.classList.add('hidden');
            const toggle = row.querySelector('.cat-toggle');
            if (toggle) toggle.setAttribute('aria-expanded', 'false');
            collapseCatDescendants(row.dataset.catId);
        });
    }
    function toggleCategory(toggle) {
        const catId = toggle.dataset.catId;
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        if (expanded) {
            toggle.setAttribute('aria-expanded', 'false');
            collapseCatDescendants(catId);          // 접을 땐 후손 전체를 함께 접는다
        } else {
            toggle.setAttribute('aria-expanded', 'true');
            catChildRows(catId).forEach(row => row.classList.remove('hidden')); // 직계 자식만 편다
        }
    }
    document.addEventListener('click', (e) => {
        const toggle = e.target.closest('.cat-toggle');
        if (toggle) { e.preventDefault(); toggleCategory(toggle); }
    });

    // 목록 내 이미지 미리보기 처리
    document.querySelectorAll('.cat-logo-upload-btn').forEach(input => {
        input.addEventListener('change', function (e) {
            const file = e.target.files[0];
            const categoryId = this.getAttribute('data-id');
            const previewContainer = document.getElementById('preview-container-' + categoryId);

            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    previewContainer.innerHTML = '<img src="' + e.target.result + '" class="max-h-full max-w-full object-contain">';
                };
                reader.readAsDataURL(file);
            } else {
                previewContainer.innerHTML = '<div class="text-gray-400 text-[10px] bg-gray-100 text-center w-full h-full flex items-center justify-center border-dashed border border-gray-300">NO IMAGE</div>';
            }
        });
    });

    // 등록 모달 내 미리보기 처리
    const modalLogoUpload = document.getElementById('modal-logo-upload');
    const modalPreviewContainer = document.getElementById('modal-preview-container');
    const modalPreviewImage = document.getElementById('modal-preview-image');

    if (modalLogoUpload) {
        modalLogoUpload.addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    modalPreviewImage.src = e.target.result;
                    modalPreviewContainer.classList.remove('hidden');
                    modalPreviewContainer.classList.add('flex');
                };
                reader.readAsDataURL(file);
            } else {
                modalPreviewImage.src = '';
                modalPreviewContainer.classList.add('hidden');
                modalPreviewContainer.classList.remove('flex');
            }
        });
    }
</script>
