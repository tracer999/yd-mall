<%#
  배포·포팅 관리 (서비스 제공자 전용)
  배포 파이프라인 안내 + 납품 고객(테넌트) 레지스트리. '납품'은 우리가 몰을 납품한 고객 명부이지,
  고객이 납품 후 스스로 만든 몰 현황이 아니다(그건 우리 관심사가 아님).
%>
<%
  function ymd(d) {
    if (!d) return '';
    if (typeof d === 'string') return d.slice(0, 10);
    try { const t = new Date(d.getTime() - d.getTimezoneOffset() * 60000); return t.toISOString().slice(0, 10); }
    catch (e) { return ''; }
  }
%>

<div class="mb-6">
  <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-slate-100 text-slate-600 text-xs font-semibold mb-2">
    <i class="bi bi-hdd-network"></i> 서비스 관리 · 제공자(super_admin) 전용
  </div>
  <p class="text-sm text-gray-500">
    몰을 만들어(빌드) 고객에게 포팅·배포하는 몰 빌더 운영 흐름과 <strong>납품 고객</strong>을 관리합니다.
  </p>
</div>

<% if (saved) { %>
  <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
    <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
  </div>
<% } %>

<!-- 배포 파이프라인 -->
<section class="mb-6 rounded-xl border border-gray-200 overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
    <h2 class="text-base font-bold text-gray-800"><i class="bi bi-rocket-takeoff mr-1.5 text-indigo-500"></i>배포 파이프라인</h2>
    <p class="mt-0.5 text-xs text-gray-500">현재 배포는 Git 기반입니다. 푸시 = 개발 서버 즉시 반영.</p>
  </div>
  <div class="p-5">
    <ol class="flex flex-col sm:flex-row gap-3 text-sm">
      <li class="flex-1 rounded-lg bg-slate-50 border border-slate-200 p-4">
        <div class="text-xs font-bold text-slate-400 mb-1">STEP 1</div>
        <div class="font-semibold text-gray-800"><code class="text-indigo-600">git push origin main</code></div>
      </li>
      <li class="flex-1 rounded-lg bg-slate-50 border border-slate-200 p-4">
        <div class="text-xs font-bold text-slate-400 mb-1">STEP 2</div>
        <div class="font-semibold text-gray-800">GitHub Actions</div>
        <p class="mt-1 text-xs text-gray-500"><code>.github/workflows/deploy.yml</code></p>
      </li>
      <li class="flex-1 rounded-lg bg-slate-50 border border-slate-200 p-4">
        <div class="text-xs font-bold text-slate-400 mb-1">STEP 3</div>
        <div class="font-semibold text-gray-800">서버 동기화 → build → start (PM2)</div>
      </li>
    </ol>
  </div>
</section>

<!-- 납품 고객 레지스트리 -->
<section class="mb-6 rounded-xl border border-gray-200 overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100 bg-gray-50 flex items-center justify-between">
    <div>
      <h2 class="text-base font-bold text-gray-800"><i class="bi bi-people mr-1.5 text-indigo-500"></i>납품 고객</h2>
      <p class="mt-0.5 text-xs text-gray-500">우리가 몰을 납품한 고객(테넌트) 명부와 배정 등급입니다. (고객이 만든 개별 몰은 추적하지 않습니다.)</p>
    </div>
    <a href="/admin/service/customers/new" class="inline-flex items-center h-[36px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 no-underline">
      <i class="bi bi-plus-circle mr-1.5"></i> 납품 고객 등록
    </a>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
          <th class="px-5 py-2.5">고객</th>
          <th class="px-5 py-2.5">담당자 / 연락처</th>
          <th class="px-5 py-2.5">배정 등급</th>
          <th class="px-5 py-2.5 text-center">서브몰 한도</th>
          <th class="px-5 py-2.5">납품일</th>
          <th class="px-5 py-2.5 text-center">상태</th>
          <th class="px-5 py-2.5 w-24 text-right">관리</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% (customers || []).forEach(function (c) { %>
          <tr class="<%= Number(c.is_active) === 1 ? '' : 'bg-gray-50/60' %>">
            <td class="px-5 py-3">
              <span class="font-medium text-gray-900"><%= c.name %></span>
              <% if (c.memo) { %><div class="text-xs text-gray-400 mt-0.5 truncate max-w-xs"><%= c.memo %></div><% } %>
            </td>
            <td class="px-5 py-3 text-gray-600">
              <div><%= c.contact_name || '-' %></div>
              <div class="text-xs text-gray-400"><%= c.contact_email || c.contact_phone || '' %></div>
            </td>
            <td class="px-5 py-3">
              <% if (c.plan_name) { %>
                <span class="text-xs font-semibold px-2 py-0.5 rounded bg-indigo-50 text-indigo-700"><%= c.plan_name %></span>
              <% } else { %>
                <span class="text-xs text-gray-400">미배정</span>
              <% } %>
            </td>
            <td class="px-5 py-3 text-center tabular-nums text-gray-700"><%= c.max_submalls != null ? c.max_submalls : '-' %></td>
            <td class="px-5 py-3 text-gray-600"><%= ymd(c.delivered_at) || '-' %></td>
            <td class="px-5 py-3 text-center">
              <% if (Number(c.is_active) === 1) { %>
                <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-emerald-50 text-emerald-700">활성</span>
              <% } else { %>
                <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-gray-200 text-gray-600">비활성</span>
              <% } %>
            </td>
            <td class="px-5 py-3 text-right whitespace-nowrap">
              <a href="/admin/service/customers/<%= c.id %>/edit" class="text-indigo-600 hover:text-indigo-800 mr-2" title="수정"><i class="bi bi-pencil"></i></a>
              <form method="POST" action="/admin/service/customers/<%= c.id %>/delete" class="inline"
                    onsubmit="return confirm('납품 고객 &quot;<%= c.name %>&quot; 을(를) 삭제할까요?');">
                <button type="submit" class="text-gray-400 hover:text-red-600" title="삭제"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }); %>
        <% if (!customers || customers.length === 0) { %>
          <tr><td colspan="7" class="px-5 py-8 text-center text-gray-400">등록된 납품 고객이 없습니다. 우측 상단에서 등록하세요.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>

<!-- 소스 포팅 / 로드맵 -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
  <section class="rounded-xl border border-gray-200 p-5">
    <h2 class="text-base font-bold text-gray-800 mb-2"><i class="bi bi-diagram-3 mr-1.5 text-indigo-500"></i>포팅 & 프로비저닝</h2>
    <p class="text-sm text-gray-600 mb-3">새 몰은 프리셋 프로비저닝으로 내비게이션·메뉴·테마·홈을 자동 구성해 납품 골격을 만듭니다.</p>
    <div class="flex flex-wrap gap-2">
      <a href="/admin/malls" class="inline-flex items-center h-[34px] px-3 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline"><i class="bi bi-shop mr-1.5"></i>몰 리스트 관리</a>
      <a href="/manual/mall_builder" target="_blank" class="inline-flex items-center h-[34px] px-3 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline"><i class="bi bi-book mr-1.5"></i>몰 빌더 가이드</a>
      <a href="/admin/service/features" class="inline-flex items-center h-[34px] px-3 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline"><i class="bi bi-toggles mr-1.5"></i>등급별 기능 설정</a>
    </div>
  </section>

  <section class="rounded-xl border border-dashed border-gray-300 bg-gray-50/60 p-5">
    <h2 class="text-base font-bold text-gray-700 mb-2"><i class="bi bi-signpost-split mr-1.5 text-gray-400"></i>로드맵</h2>
    <ul class="text-sm text-gray-600 space-y-1.5 list-disc list-inside">
      <li>고객 등급의 <strong>서브몰 개수 한도 강제</strong>(몰 생성 차단)</li>
      <li>등급 entitlement의 <strong>실제 기능 차단</strong>(네이버·도매·AI 연동 게이팅)</li>
      <li>앱 내 <strong>배포/롤백 버튼</strong>·몰 <strong>export/import</strong></li>
      <li>서비스 관리 전용 <strong>인스턴스 완전 분리</strong></li>
    </ul>
    <p class="mt-3 text-xs text-gray-400">현재 단계에서는 인스턴스를 분리하지 않고 이 대메뉴로 기능만 모아 둡니다.</p>
  </section>
</div>
