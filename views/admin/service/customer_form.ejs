<%#
  납품 고객 등록/수정 (서비스 제공자 전용)
  우리가 몰을 납품한 고객(테넌트) 정보 + 배정 등급(service_plan).
%>
<%
  function ymd(d) {
    if (!d) return '';
    if (typeof d === 'string') return d.slice(0, 10);
    try { const t = new Date(d.getTime() - d.getTimezoneOffset() * 60000); return t.toISOString().slice(0, 10); }
    catch (e) { return ''; }
  }
  const isEdit = !!(customer && customer.id);
%>

<div class="mb-6">
  <a href="/admin/service/porting" class="text-sm text-gray-500 hover:text-gray-700 no-underline"><i class="bi bi-arrow-left mr-1"></i>납품 고객 목록</a>
</div>

<form method="POST" action="/admin/service/customers" class="max-w-2xl">
  <% if (isEdit) { %><input type="hidden" name="id" value="<%= customer.id %>"><% } %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100">
    <div class="p-5">
      <label class="block text-sm font-semibold text-gray-700 mb-1">고객(업체)명 <span class="text-red-500">*</span></label>
      <input type="text" name="name" value="<%= customer.name || '' %>" required maxlength="150"
             class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm focus:ring-2 focus:ring-indigo-400 focus:outline-none">
    </div>

    <div class="p-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">담당자</label>
        <input type="text" name="contact_name" value="<%= customer.contact_name || '' %>" maxlength="100"
               class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm">
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">이메일</label>
        <input type="email" name="contact_email" value="<%= customer.contact_email || '' %>" maxlength="255"
               class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm">
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">연락처</label>
        <input type="text" name="contact_phone" value="<%= customer.contact_phone || '' %>" maxlength="50"
               class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm">
      </div>
    </div>

    <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">배정 등급</label>
        <select name="plan_id" class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm bg-white">
          <option value="">미배정</option>
          <% (plans || []).forEach(function (p) { %>
            <option value="<%= p.id %>" <%= Number(customer.plan_id) === Number(p.id) ? 'selected' : '' %>>
              <%= p.name %> (서브몰 <%= p.max_submalls %>개)
            </option>
          <% }); %>
        </select>
        <p class="mt-1 text-xs text-gray-400">등급별 기능은 <a href="/admin/service/features" class="text-indigo-600 hover:underline">등급별 기능 설정</a>에서 정의합니다.</p>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">납품일</label>
        <input type="date" name="delivered_at" value="<%= ymd(customer.delivered_at) %>"
               class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm">
      </div>
    </div>

    <div class="p-5">
      <label class="block text-sm font-semibold text-gray-700 mb-1">메모</label>
      <textarea name="memo" rows="2" maxlength="500"
                class="w-full px-3 py-2 rounded-lg border border-gray-200 text-sm"><%= customer.memo || '' %></textarea>
    </div>

    <div class="p-5">
      <label class="inline-flex items-center gap-2 text-sm text-gray-700">
        <input type="checkbox" name="is_active" value="1" <%= Number(customer.is_active) === 1 ? 'checked' : '' %>
               class="w-4 h-4 rounded border-gray-300 text-emerald-600">
        활성 (납품 유지 중)
      </label>
    </div>
  </div>

  <div class="flex justify-end gap-2 mt-5">
    <a href="/admin/service/porting" class="inline-flex items-center h-[38px] px-4 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">취소</a>
    <button type="submit" class="inline-flex items-center h-[38px] px-5 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
      <i class="bi bi-save mr-1.5"></i> <%= isEdit ? '수정' : '등록' %>
    </button>
  </div>
</form>
