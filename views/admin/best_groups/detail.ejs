<%
  /*
   * 베스트/랭킹 — 탭 상세 (MD 픽 관리 + 미리보기)
   *
   * 미리보기는 **고객이 보는 것과 같은 결과**다(핀 병합 후, 1..N 재번호).
   * 자동 순위는 여기서 못 바꾼다 — 스냅샷은 배치의 것이다. 손대려면 핀을 쓴다.
   */
  const _pins = pins || [];
  const _preview = preview || [];
  const _periodKeys = Object.keys(periods);

  const dtLocal = (v) => v ? new Date(v).toISOString().slice(0, 16) : '';
  const won = (n) => Number(n || 0).toLocaleString();
%>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="mb-6">
    <a href="/admin/best-groups" class="text-sm text-gray-500 hover:text-gray-700">
      <i class="bi bi-chevron-left"></i> 베스트/랭킹 관리
    </a>
    <h1 class="mt-2 text-2xl font-bold text-gray-900"><%= group.name %></h1>
    <p class="mt-1 text-sm text-gray-500">
      <%= group.group_type === 'ALL' ? '몰 전체 상품' : (group.ref_name || '-') %>
      <% if (group.group_type === 'CATEGORY' && group.include_descendants) { %> · 하위 카테고리 포함<% } %>
    </p>
  </div>

  <% if (success) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> <%= success %>
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-center gap-2">
      <i class="bi bi-exclamation-triangle-fill"></i> <%= error %>
    </div>
  <% } %>

  <!-- 탭 설정 -->
  <div class="mb-6 bg-white border border-gray-200 rounded-lg p-5">
    <h2 class="text-base font-semibold text-gray-900 mb-4">탭 설정</h2>
    <form method="POST" action="/admin/best-groups/<%= group.id %>" class="flex flex-wrap items-end gap-3">
      <label class="block">
        <span class="text-xs text-gray-600">탭 이름</span>
        <input type="text" name="name" value="<%= group.name %>" required maxlength="100"
               class="mt-1 w-52 h-[38px] px-3 border border-gray-300 rounded-md text-sm">
      </label>
      <label class="block">
        <span class="text-xs text-gray-600">순서</span>
        <input type="number" name="sort_order" value="<%= group.sort_order %>" min="0"
               class="mt-1 w-20 h-[38px] px-3 border border-gray-300 rounded-md text-sm">
      </label>
      <label class="flex items-center gap-1.5 h-[38px]">
        <input type="checkbox" name="is_active" value="1" <%= group.is_active ? 'checked' : '' %> class="rounded border-gray-300">
        <span class="text-xs text-gray-600">노출</span>
      </label>
      <% if (group.group_type === 'CATEGORY') { %>
        <label class="flex items-center gap-1.5 h-[38px]">
          <input type="checkbox" name="include_descendants" value="1" <%= group.include_descendants ? 'checked' : '' %> class="rounded border-gray-300">
          <span class="text-xs text-gray-600">하위 카테고리 포함</span>
        </label>
      <% } %>
      <button type="submit"
              class="h-[38px] px-4 text-sm font-semibold rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50">
        저장
      </button>
    </form>
  </div>

  <!-- MD 픽 -->
  <div class="mb-6 bg-white border border-gray-200 rounded-lg p-5">
    <h2 class="text-base font-semibold text-gray-900 mb-1">
      <i class="bi bi-pin-angle-fill text-indigo-600"></i> MD 픽 (수동 고정)
    </h2>
    <p class="text-xs text-gray-500 mb-4">
      밀고 싶은 상품을 순위에 강제로 올립니다. <strong>고객 화면에 즉시 반영</strong>되며 집계를 기다리지 않습니다.
      고정 순위를 비우면 자동 1위 앞에 순서대로 붙습니다. 모든 기간 탭(실시간·일간·주간·월간)에 함께 적용됩니다.
    </p>

    <!-- 상품 검색 → 핀 추가 -->
    <form method="POST" action="/admin/best-groups/<%= group.id %>/pins" class="mb-5 p-4 bg-gray-50 rounded-lg">
      <div class="flex flex-wrap items-end gap-3">
        <div class="relative">
          <span class="text-xs text-gray-600">상품 검색</span>
          <input type="text" id="pinSearch" autocomplete="off" placeholder="상품명 또는 상품코드"
                 class="mt-1 w-72 h-[38px] px-3 border border-gray-300 rounded-md text-sm">
          <input type="hidden" name="product_id" id="pinProductId">
          <div id="pinResults"
               class="hidden absolute z-20 top-full left-0 w-72 mt-1 bg-white border border-gray-200 rounded-md shadow-lg max-h-72 overflow-y-auto"></div>
        </div>
        <label class="block">
          <span class="text-xs text-gray-600">고정 순위</span>
          <input type="number" name="pin_rank" min="1" max="200" placeholder="비우면 최상단"
                 class="mt-1 w-28 h-[38px] px-3 border border-gray-300 rounded-md text-sm">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">노출 시작</span>
          <input type="datetime-local" name="start_at"
                 class="mt-1 h-[38px] px-2 border border-gray-300 rounded-md text-sm">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">노출 종료</span>
          <input type="datetime-local" name="end_at"
                 class="mt-1 h-[38px] px-2 border border-gray-300 rounded-md text-sm">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">메모</span>
          <input type="text" name="memo" maxlength="200" placeholder="왜 미는지"
                 class="mt-1 w-40 h-[38px] px-3 border border-gray-300 rounded-md text-sm">
        </label>
        <button type="submit" id="pinSubmit" disabled
                class="h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 disabled:bg-gray-300">
          <i class="bi bi-pin-angle mr-1"></i> 고정
        </button>
      </div>
      <p id="pinPicked" class="mt-2 text-xs text-indigo-700 hidden"></p>
    </form>

    <% if (!_pins.length) { %>
      <p class="py-6 text-center text-sm text-gray-400">고정한 상품이 없습니다. 순위는 전부 자동 산출됩니다.</p>
    <% } else { %>
      <%
        /* <form> 은 <tr> 의 직계 자식이 될 수 없다 — HTML 파서가 통째로 들어낸다.
           그래서 폼은 테이블 **밖**에 두고, 각 입력은 HTML5 form="..." 속성으로 연결한다. */
      %>
      <% _pins.forEach(function (p) { %>
        <form method="POST" action="/admin/best-groups/<%= group.id %>/pins/<%= p.id %>" id="pinf-<%= p.id %>"></form>
        <form method="POST" action="/admin/best-groups/<%= group.id %>/pins/<%= p.id %>/delete" id="pind-<%= p.id %>"
              onsubmit="return confirm('고정을 해제합니다.');"></form>
      <% }); %>

      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-600 text-xs">
          <tr>
            <th class="px-3 py-2 text-left font-medium">상품</th>
            <th class="px-3 py-2 text-left font-medium">고정 순위</th>
            <th class="px-3 py-2 text-left font-medium">순서</th>
            <th class="px-3 py-2 text-left font-medium">노출 기간</th>
            <th class="px-3 py-2 text-left font-medium">메모</th>
            <th class="px-3 py-2 text-center font-medium">활성</th>
            <th class="px-3 py-2"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% _pins.forEach(function (p) { %>
            <tr>
              <td class="px-3 py-2">
                <div class="flex items-center gap-2">
                  <% if (p.main_image) { %>
                    <img src="<%= p.main_image %>" alt="" class="w-9 h-9 object-cover rounded border border-gray-100">
                  <% } %>
                  <div>
                    <p class="text-gray-900 line-clamp-1 max-w-[240px]"><%= p.product_name %></p>
                    <p class="text-xs text-gray-400"><%= won(p.price) %>원
                      <% if (p.product_status !== 'ON') { %>
                        <span class="text-red-500">· <%= p.product_status %></span>
                      <% } %>
                    </p>
                  </div>
                </div>
              </td>
              <td class="px-3 py-2">
                <input form="pinf-<%= p.id %>" type="number" name="pin_rank" value="<%= p.pin_rank || '' %>"
                       min="1" max="200" placeholder="최상단"
                       class="w-24 h-8 px-2 border border-gray-300 rounded text-sm">
              </td>
              <td class="px-3 py-2">
                <input form="pinf-<%= p.id %>" type="number" name="sort_order" value="<%= p.sort_order %>" min="0"
                       class="w-16 h-8 px-2 border border-gray-300 rounded text-sm">
              </td>
              <td class="px-3 py-2">
                <div class="flex flex-col gap-1">
                  <input form="pinf-<%= p.id %>" type="datetime-local" name="start_at" value="<%= dtLocal(p.start_at) %>"
                         class="h-8 px-1 border border-gray-300 rounded text-xs">
                  <input form="pinf-<%= p.id %>" type="datetime-local" name="end_at" value="<%= dtLocal(p.end_at) %>"
                         class="h-8 px-1 border border-gray-300 rounded text-xs">
                </div>
              </td>
              <td class="px-3 py-2">
                <input form="pinf-<%= p.id %>" type="text" name="memo" value="<%= p.memo || '' %>" maxlength="200"
                       class="w-36 h-8 px-2 border border-gray-300 rounded text-sm">
              </td>
              <td class="px-3 py-2 text-center">
                <input form="pinf-<%= p.id %>" type="checkbox" name="is_active" value="1"
                       <%= p.is_active ? 'checked' : '' %> class="rounded border-gray-300">
              </td>
              <td class="px-3 py-2 text-right whitespace-nowrap">
                <button form="pinf-<%= p.id %>" type="submit" class="text-xs text-indigo-600 hover:text-indigo-800 mr-2">저장</button>
                <button form="pind-<%= p.id %>" type="submit" class="text-xs text-red-500 hover:text-red-700">해제</button>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>

  <!-- 미리보기 -->
  <div class="bg-white border border-gray-200 rounded-lg p-5">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-base font-semibold text-gray-900">고객 화면 미리보기</h2>
        <p class="text-xs text-gray-500">
          <%= calculatedAt ? new Date(calculatedAt).toLocaleString('ko-KR') + ' 기준' : '아직 집계되지 않았습니다' %>
          · MD 픽이 반영된 최종 순위입니다
        </p>
      </div>
      <div class="flex gap-1">
        <% _periodKeys.forEach(function (p) { const on = p === period; %>
          <a href="/admin/best-groups/<%= group.id %>?period=<%= p %>"
             class="px-3 py-1.5 text-sm rounded no-underline <%= on ? 'bg-gray-900 text-white font-semibold' : 'text-gray-500 hover:bg-gray-100' %>">
            <%= periods[p].label %>
          </a>
        <% }); %>
      </div>
    </div>

    <% if (!_preview.length) { %>
      <p class="py-10 text-center text-sm text-gray-400">
        집계된 순위가 없습니다. 목록 화면에서 <strong>지금 집계</strong>를 실행하세요.
      </p>
    <% } else { %>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        <% _preview.slice(0, 20).forEach(function (p) { %>
          <div class="border border-gray-100 rounded-lg p-2 <%= p.is_pinned ? 'ring-2 ring-indigo-400' : '' %>">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-bold text-gray-900"><%= String(p.rank_no).padStart(2, '0') %></span>
              <% if (p.is_pinned) { %>
                <span class="text-[10px] font-semibold px-1 py-0.5 bg-indigo-600 text-white rounded">MD</span>
              <% } %>
            </div>
            <% if (p.main_image) { %>
              <img src="<%= p.main_image %>" alt="" class="w-full h-20 object-cover rounded mb-1">
            <% } %>
            <p class="text-xs text-gray-700 line-clamp-2 leading-tight"><%= p.name %></p>
            <% if (!p.is_pinned) { %>
              <p class="mt-1 text-[10px] text-gray-400">
                <%= p.score %>점 · 판매<%= p.sales_count %> · 찜<%= p.like_count %>
              </p>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<script>
(function () {
  const input   = document.getElementById('pinSearch');
  const results = document.getElementById('pinResults');
  const hidden  = document.getElementById('pinProductId');
  const submit  = document.getElementById('pinSubmit');
  const picked  = document.getElementById('pinPicked');
  let timer = null;

  input.addEventListener('input', function () {
    // 상품을 고른 뒤 검색어를 고치면 선택이 무효가 된다. 숨은 id 를 반드시 비운다
    // (안 비우면 화면에 안 보이는 옛 상품이 고정된다).
    hidden.value = '';
    submit.disabled = true;
    picked.classList.add('hidden');

    clearTimeout(timer);
    const q = input.value.trim();
    if (q.length < 2) { results.classList.add('hidden'); return; }

    timer = setTimeout(async function () {
      try {
        const res = await fetch('/admin/best-groups/<%= group.id %>/product-search?q=' + encodeURIComponent(q));
        const data = await res.json();
        if (!data.products.length) {
          results.innerHTML = '<p class="px-3 py-3 text-xs text-gray-400">검색 결과가 없습니다.</p>';
        } else {
          results.innerHTML = data.products.map(function (p) {
            return '<button type="button" class="w-full flex items-center gap-2 px-3 py-2 text-left hover:bg-gray-50"'
              + ' data-id="' + p.id + '" data-name="' + String(p.name).replace(/"/g, '&quot;') + '">'
              + (p.main_image ? '<img src="' + p.main_image + '" class="w-8 h-8 object-cover rounded">' : '')
              + '<span class="text-xs text-gray-700 line-clamp-2">' + p.name + '</span>'
              + '</button>';
          }).join('');
        }
        results.classList.remove('hidden');
      } catch (e) {
        results.classList.add('hidden');
      }
    }, 250);
  });

  results.addEventListener('click', function (e) {
    const btn = e.target.closest('button[data-id]');
    if (!btn) return;
    hidden.value = btn.dataset.id;
    input.value = btn.dataset.name;
    picked.textContent = '선택됨: ' + btn.dataset.name;
    picked.classList.remove('hidden');
    submit.disabled = false;
    results.classList.add('hidden');
  });

  document.addEventListener('click', function (e) {
    if (!results.contains(e.target) && e.target !== input) results.classList.add('hidden');
  });
})();
</script>
