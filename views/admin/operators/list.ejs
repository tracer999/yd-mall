<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 sm:gap-0">
    <p class="text-sm text-gray-500">운영자 계정을 생성하고 역할별 권한을 관리합니다.</p>
    <div class="flex flex-wrap gap-2 w-full sm:w-auto justify-start sm:justify-end">
        <a href="/admin/operators/form"
            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 no-underline">
            <i class="bi bi-plus-lg mr-2"></i>운영자 등록
        </a>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100">
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-gray-500">
            <thead class="text-xs text-gray-700 uppercase bg-gray-50 border-b border-gray-100">
                <tr>
                    <th scope="col" class="px-6 py-3">ID</th>
                    <th scope="col" class="px-6 py-3">사용자명</th>
                    <th scope="col" class="px-6 py-3">역할</th>
                    <th scope="col" class="px-6 py-3">등록일</th>
                    <th scope="col" class="px-6 py-3 text-right">관리</th>
                </tr>
            </thead>
            <tbody>
                <% if(operators.length> 0) { %>
                    <% operators.forEach(function(op) { %>
                        <tr class="bg-white border-b border-gray-100 hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 font-medium text-gray-900">
                                <%= op.id %>
                            </td>
                            <td class="px-6 py-4">
                                <%= op.username %>
                            </td>
                            <td class="px-6 py-4">
                                <% if(op.role==='super_admin' ) { %>
                                    <span
                                        class="bg-purple-100 text-purple-800 text-xs font-medium mr-2 px-2.5 py-0.5 rounded border border-purple-400">최고
                                        관리자</span>
                                    <% } else if(op.role==='admin' ) { %>
                                        <span
                                            class="bg-indigo-100 text-indigo-800 text-xs font-medium mr-2 px-2.5 py-0.5 rounded border border-indigo-400">관리자</span>
                                    <% } else if(op.role==='content_admin' ) { %>
                                        <span
                                            class="bg-blue-100 text-blue-800 text-xs font-medium mr-2 px-2.5 py-0.5 rounded border border-blue-400">컨텐츠
                                            관리자</span>
                                        <% } else if(op.role==='customer_admin' ) { %>
                                            <span
                                                class="bg-green-100 text-green-800 text-xs font-medium mr-2 px-2.5 py-0.5 rounded border border-green-400">고객
                                                관리자</span>
                                            <% } else { %>
                                                <span
                                                    class="bg-gray-100 text-gray-800 text-xs font-medium mr-2 px-2.5 py-0.5 rounded border border-gray-500">
                                                    <%= op.role %>
                                                </span>
                                                <% } %>
                            </td>
                            <td class="px-6 py-4">
                                <%= new Date(op.created_at).toLocaleDateString() %>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    <a href="/admin/operators/form?id=<%= op.id %>"
                                        class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정</a>
                                    <form action="/admin/operators/delete" method="POST" class="inline"
                                        onsubmit="return confirm('정말 삭제하시겠습니까?');">
                                        <input type="hidden" name="id" value="<%= op.id %>">
                                        <button type="submit" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 border border-red-200 bg-red-50 text-red-700 hover:bg-red-100">삭제</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="px-6 py-4 text-center text-gray-500">등록된 운영자가 없습니다.</td>
                                </tr>
                                <% } %>
            </tbody>
        </table>
    </div>
</div>