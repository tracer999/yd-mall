<%
  /*
   * 브랜드 관리 — 목록
   *
   * 브랜드는 categories(type='BRAND') 이고 확장 속성은 brand_profile 에 있다.
   * 상품 수·인기 점수·혜택 수는 brand_stat 집계 캐시에서 읽는다(실시간 집계 아님).
   */
  const q = (obj) => {
    const p = new URLSearchParams();
    Object.entries(obj).forEach(([k, v]) => { if (v !== null && v !== undefined && v !== '') p.set(k, v); });
    const s = p.toString();
    return `/admin/brands${s ? '?' + s : ''}`;
  };
  const f = filters;
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">브랜드 관리</h1>
      <p class="mt-1 text-sm text-gray-500">
        <a href="/brands" target="_blank" class="text-indigo-600 hover:underline">브랜드 허브</a>에 노출되는 브랜드입니다.
        계층·활성은 <a href="/admin/categories" class="text-indigo-600 hover:underline">카테고리 관리</a>에서, 브랜드 전용 속성은 여기서 편집합니다.
      </p>
    </div>
    <form method="post" action="/admin/brands/recalc">
      <button type="submit" class="px-4 py-2 rounded-lg bg-gray-900 text-white text-sm font-semibold hover:bg-gray-800">
        <i class="bi bi-arrow-clockwise"></i> 집계 재계산
      </button>
    </form>
  </div>

  <% if (success) { %>
    <div class="mb-4 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800"><%= error %></div>
  <% } %>

  <div class="mb-4 px-4 py-3 rounded-lg bg-blue-50 border border-blue-100 text-xs text-blue-800">
    상품 수·인기 점수·혜택 수는 집계 캐시입니다.
    <% if (stat && stat.calculated_at) { %>
      마지막 집계: <strong><%= new Date(stat.calculated_at).toLocaleString('ko-KR') %></strong> (브랜드 <%= stat.n %>건)
    <% } else { %>
      아직 집계가 돌지 않았습니다. <strong>집계 재계산</strong>을 눌러주세요.
    <% } %>
  </div>

  <!-- 검색·필터 -->
  <form method="get" action="/admin/brands" class="flex flex-wrap gap-2 mb-5">
    <input type="text" name="q" value="<%= f.q %>" placeholder="브랜드명·영문명·초성(ㄴㅇㅋ)"
           class="flex-1 min-w-60 px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-indigo-500">
    <select name="official" class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
      <option value="">전체</option>
      <option value="1" <%= f.official === 1 ? 'selected' : '' %>>공식 브랜드만</option>
      <option value="0" <%= f.official === 0 ? 'selected' : '' %>>일반 브랜드만</option>
    </select>
    <select name="sort" class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
      <option value="count" <%= f.sort === 'count' ? 'selected' : '' %>>상품 많은순</option>
      <option value="popular" <%= f.sort === 'popular' ? 'selected' : '' %>>인기순</option>
      <option value="name" <%= f.sort === 'name' ? 'selected' : '' %>>가나다순</option>
      <option value="new" <%= f.sort === 'new' ? 'selected' : '' %>>입점 최신순</option>
    </select>
    <button type="submit" class="px-5 py-2 rounded-lg bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700">검색</button>
  </form>

  <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs">
        <tr>
          <th class="px-4 py-3 text-left font-medium">브랜드</th>
          <th class="px-4 py-3 text-left font-medium">대표 카테고리</th>
          <th class="px-4 py-3 text-right font-medium">상품</th>
          <th class="px-4 py-3 text-right font-medium">인기 점수</th>
          <th class="px-4 py-3 text-right font-medium">혜택</th>
          <th class="px-4 py-3 text-center font-medium">입점일</th>
          <th class="px-4 py-3 text-center font-medium">구분</th>
          <th class="px-4 py-3 text-center font-medium">노출</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if (!brands.length) { %>
          <tr><td colspan="8" class="px-4 py-16 text-center text-gray-500">브랜드가 없습니다.</td></tr>
        <% } %>
        <% brands.forEach(function (b) { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3">
              <a href="/admin/brands/<%= b.id %>" class="flex items-center gap-3 group">
                <span class="shrink-0 w-10 h-10 rounded-lg bg-gray-50 border border-gray-100 flex items-center justify-center overflow-hidden">
                  <% if (b.logo_image_path) { %>
                    <img src="<%= b.logo_image_path %>" alt="" class="max-w-full max-h-full object-contain p-1">
                  <% } else { %>
                    <span class="text-xs font-bold text-gray-300"><%= b.name.slice(0, 2) %></span>
                  <% } %>
                </span>
                <span class="min-w-0">
                  <span class="flex items-center gap-1.5">
                    <span class="font-semibold text-gray-900 group-hover:text-indigo-600 truncate"><%= b.name %></span>
                    <% if (b.official_yn) { %>
                      <span class="shrink-0 px-1.5 py-0.5 rounded bg-indigo-50 text-indigo-600 text-[10px] font-semibold">공식</span>
                    <% } %>
                    <% if (b.initial) { %>
                      <span class="shrink-0 text-[10px] text-gray-400"><%= b.initial %></span>
                    <% } %>
                  </span>
                  <% if (b.name_en) { %>
                    <span class="block text-xs text-gray-400 truncate"><%= b.name_en %></span>
                  <% } %>
                </span>
              </a>
            </td>
            <td class="px-4 py-3 text-gray-600"><%= b.top_category_name || '-' %></td>
            <td class="px-4 py-3 text-right tabular-nums <%= (b.product_count || 0) === 0 ? 'text-gray-300' : 'text-gray-900' %>">
              <%= Number(b.product_count || 0).toLocaleString() %>
            </td>
            <td class="px-4 py-3 text-right tabular-nums text-gray-500"><%= Number(b.popularity_score || 0).toLocaleString() %></td>
            <td class="px-4 py-3 text-right tabular-nums">
              <% if (b.benefit_count > 0) { %>
                <span class="text-indigo-600 font-semibold"><%= b.benefit_count %></span>
              <% } else { %><span class="text-gray-300">0</span><% } %>
            </td>
            <td class="px-4 py-3 text-center text-xs text-gray-500">
              <%= b.onboarded_at ? new Date(b.onboarded_at).toISOString().slice(0, 10) : '-' %>
            </td>
            <td class="px-4 py-3 text-center">
              <% if (b.is_seller) { %>
                <span class="px-2 py-0.5 rounded bg-gray-100 text-gray-600 text-xs">입점몰</span>
              <% } else { %>
                <span class="text-xs text-gray-400">브랜드</span>
              <% } %>
            </td>
            <td class="px-4 py-3 text-center">
              <% if (b.is_active) { %>
                <span class="px-2 py-0.5 rounded bg-green-50 text-green-700 text-xs">노출</span>
              <% } else { %>
                <span class="px-2 py-0.5 rounded bg-gray-100 text-gray-500 text-xs">숨김</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <p class="mt-3 text-xs text-gray-500">전체 <%= Number(pagination.total).toLocaleString() %>건</p>

  <% if (pagination.pages > 1) {
       const cur = pagination.page;
       const from = Math.max(1, cur - 2);
       const to = Math.min(pagination.pages, from + 4); %>
    <nav class="flex justify-center items-center gap-1 mt-8">
      <% if (cur > 1) { %>
        <a href="<%= q({ ...f, page: cur - 1 }) %>" class="px-3 py-2 rounded-lg border border-gray-200 text-sm text-gray-600 hover:border-gray-400">‹</a>
      <% } %>
      <% for (let i = from; i <= to; i++) { %>
        <a href="<%= q({ ...f, page: i }) %>"
           class="px-3 py-2 rounded-lg border text-sm <%= i === cur ? 'bg-gray-900 border-gray-900 text-white font-semibold' : 'border-gray-200 text-gray-600 hover:border-gray-400' %>"><%= i %></a>
      <% } %>
      <% if (cur < pagination.pages) { %>
        <a href="<%= q({ ...f, page: cur + 1 }) %>" class="px-3 py-2 rounded-lg border border-gray-200 text-sm text-gray-600 hover:border-gray-400">›</a>
      <% } %>
    </nav>
  <% } %>
</div>
