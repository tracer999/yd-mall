<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 sm:gap-0">
    <p class="text-sm text-gray-500">쿠폰 발급, 지급, 사용 내역을 한 곳에서 관리합니다.</p>
    <div class="flex flex-wrap gap-2 w-full sm:w-auto justify-start sm:justify-end">
        <a href="/admin/coupons/create"
            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700 no-underline uppercase tracking-widest">
            쿠폰 등록
        </a>
        <a href="/admin/coupons/issue"
            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 bg-green-600 text-white hover:bg-green-700 no-underline uppercase tracking-widest">
            쿠폰 지급
        </a>
        <a href="/admin/coupons/usage"
            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 bg-gray-600 text-white hover:bg-gray-700 no-underline uppercase tracking-widest">
            사용 내역
        </a>
    </div>
</div>

<div class="bg-white overflow-hidden shadow-sm rounded-lg">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">쿠폰명</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">타입</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">코드</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">할인액</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">최소주문</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">유효기간</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">발행/지급/잔여</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">관리</th>
            </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
            <% if (coupons.length === 0) { %>
            <tr>
                <td colspan="9" class="px-6 py-8 text-center text-gray-500">등록된 쿠폰이 없습니다.</td>
            </tr>
            <% } else { %>
            <% coupons.forEach(function(c) { %>
            <tr>
                <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= c.name %></td>
                <td class="px-6 py-4 text-sm text-gray-500">
                    <span class="px-2 py-0.5 rounded text-xs <%= c.coupon_type === 'NEW_SIGNUP' ? 'bg-blue-100 text-blue-800' : c.coupon_type === 'EVENT' ? 'bg-green-100 text-green-800' : c.coupon_type === 'SEASON' ? 'bg-amber-100 text-amber-800' : 'bg-purple-100 text-purple-800' %>">
                        <%= c.coupon_type === 'NEW_SIGNUP' ? '가입' : c.coupon_type === 'EVENT' ? '이벤트' : c.coupon_type === 'SEASON' ? '시즌' : '특별' %>
                    </span>
                </td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= c.code || '-' %></td>
                <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= Number(c.discount_amount).toLocaleString() %>원</td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= Number(c.min_order_amount || 0).toLocaleString() %>원</td>
                <td class="px-6 py-4 text-sm text-gray-500">
                    <%= c.valid_from ? new Date(c.valid_from).toLocaleDateString() : '-' %> ~ <%= c.valid_to ? new Date(c.valid_to).toLocaleDateString() : '-' %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-500">
                    <% 
                    var issuedMax = c.max_total_uses != null ? Number(c.max_total_uses) : null;
                    var issuedCnt = Number(c.issued_count || 0);
                    var remain = issuedMax != null ? Math.max(0, issuedMax - issuedCnt) : null;
                    %>
                    <%= issuedMax != null ? issuedMax.toLocaleString() : '무제한' %> / <%= issuedCnt.toLocaleString() %> / <%= remain != null ? remain.toLocaleString() : '무제한' %>
                </td>
                <td class="px-6 py-4">
                    <span class="px-2 py-0.5 text-xs rounded-full <%= c.is_active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' %>">
                        <%= c.is_active ? '활성' : '비활성' %>
                    </span>
                </td>
                <td class="px-6 py-4 text-right text-sm">
                    <div class="flex justify-end gap-2">
                        <a href="/admin/coupons/detail/<%= c.id %>" class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 border border-indigo-200 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 no-underline">상세</a>
                        <a href="/admin/coupons/edit/<%= c.id %>" class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정</a>
                    </div>
                </td>
            </tr>
            <% }); %>
            <% } %>
        </tbody>
    </table>
</div>
