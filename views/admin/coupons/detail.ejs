<div class="flex justify-center">
    <div class="w-full lg:max-w-3xl">
        <div class="mb-6">
            <a href="/admin/coupons" class="text-sm text-gray-500 hover:text-gray-700 mb-2 inline-block">← 쿠폰 목록</a>
        </div>

        <div class="space-y-6">
            <div class="bg-white shadow-sm rounded-xl border border-gray-200">
                <div class="px-6 py-4 border-b border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-800">등록 내용</h3>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div>
                        <div class="text-sm font-medium text-gray-500 mb-1">쿠폰명</div>
                        <div class="text-base text-gray-900"><%= coupon.name %></div>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-gray-500 mb-1">쿠폰 타입</div>
                        <div class="text-base text-gray-900">
                            <span class="px-2 py-0.5 rounded text-sm <%= coupon.coupon_type === 'NEW_SIGNUP' ? 'bg-blue-100 text-blue-800' : coupon.coupon_type === 'EVENT' ? 'bg-green-100 text-green-800' : coupon.coupon_type === 'SEASON' ? 'bg-amber-100 text-amber-800' : 'bg-purple-100 text-purple-800' %>">
                                <%= coupon.coupon_type === 'NEW_SIGNUP' ? '신규가입' : coupon.coupon_type === 'EVENT' ? '이벤트' : coupon.coupon_type === 'SEASON' ? '시즌' : '특별' %>
                            </span>
                        </div>
                    </div>
                    <% if (coupon.coupon_type === 'SPECIAL' && coupon.code) { %>
                    <div>
                        <div class="text-sm font-medium text-gray-500 mb-1">쿠폰 코드</div>
                        <div class="text-base text-gray-900"><%= coupon.code %></div>
                    </div>
                    <% } %>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <div class="text-sm font-medium text-gray-500 mb-1">할인 금액</div>
                            <div class="text-base text-gray-900"><%= Number(coupon.discount_amount || 0).toLocaleString() %>원</div>
                        </div>
                        <div>
                            <div class="text-sm font-medium text-gray-500 mb-1">최소 주문 금액</div>
                            <div class="text-base text-gray-900"><%= Number(coupon.min_order_amount || 0).toLocaleString() %>원</div>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <div class="text-sm font-medium text-gray-500 mb-1">유효 시작일</div>
                            <div class="text-base text-gray-900"><%= coupon.valid_from ? new Date(coupon.valid_from).toLocaleString() : '-' %></div>
                        </div>
                        <div>
                            <div class="text-sm font-medium text-gray-500 mb-1">유효 종료일</div>
                            <div class="text-base text-gray-900"><%= coupon.valid_to ? new Date(coupon.valid_to).toLocaleString() : '-' %></div>
                        </div>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-gray-500 mb-1">총 발급 한도</div>
                        <div class="text-base text-gray-900"><%= coupon.max_total_uses != null ? Number(coupon.max_total_uses).toLocaleString() + '장' : '무제한' %></div>
                    </div>
                    <div>
                        <span class="px-2 py-0.5 text-sm rounded-full <%= coupon.is_active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' %>">
                            <%= coupon.is_active ? '활성' : '비활성' %>
                        </span>
                    </div>
                </div>
            </div>

            <div class="bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                    <h3 class="text-lg font-semibold text-gray-800">지급 리스트</h3>
                    <a href="/admin/coupons/edit/<%= coupon.id %>" class="inline-flex items-center justify-center h-[33px] px-3 text-xs font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">수정</a>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">사용자 ID</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">이름</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">이메일</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">지급일</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">사용여부</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">사용일/주문번호</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% if (!recipients || recipients.length === 0) { %>
                            <tr>
                                <td colspan="6" class="px-6 py-8 text-center text-gray-500">지급된 회원이 없습니다.</td>
                            </tr>
                            <% } else { %>
                            <% recipients.forEach(function(r) { %>
                            <tr>
                                <td class="px-6 py-4 text-sm text-gray-900"><%= r.user_id %></td>
                                <td class="px-6 py-4 text-sm text-gray-900"><%= r.user_name || '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-900"><%= r.email || '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-500"><%= r.issued_at ? new Date(r.issued_at).toLocaleString() : '-' %></td>
                                <td class="px-6 py-4">
                                    <% if (r.used_at) { %>
                                    <span class="px-2 py-0.5 text-xs rounded-full bg-green-100 text-green-800">사용</span>
                                    <% } else { %>
                                    <span class="px-2 py-0.5 text-xs rounded-full bg-gray-100 text-gray-600">미사용</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    <% if (r.used_at) { %>
                                    <%= r.used_at ? new Date(r.used_at).toLocaleString() : '-' %> <% if (r.order_number) { %>· <%= r.order_number %><% } %>
                                    <% } else { %>-<% } %>
                                </td>
                            </tr>
                            <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
