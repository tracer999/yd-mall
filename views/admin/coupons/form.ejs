<%
  /*
   * 쿠폰 등록·수정 (쿠폰 문서 §8-2)
   *
   * 축이 셋이다 — 목적(coupon_type) · 발급 방식(issue_method) · 상태(status).
   * 발급 방식에 따라 필드를 동적으로 노출한다: CODE → 쿠폰 코드 / DOWNLOAD → 수령기간·선착순 수량.
   * 옛 폼은 `coupon_type='SPECIAL'` 일 때만 code 를 보여줬다. 그 조건을 issue_method 로 옮겼다.
   */
  const dtLocal = (v) => {
    if (!v) return '';
    const d = new Date(v);
    // toISOString 은 UTC 로 민다. 로컬 시각을 그대로 보여주려면 오프셋을 빼야 한다.
    return new Date(d.getTime() - d.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
  };
  const method = coupon ? coupon.issue_method : 'ADMIN';
  const benefit = coupon ? coupon.benefit_type : 'FIXED';
  const scopeText = coupon && coupon.scope_json
    ? (typeof coupon.scope_json === 'string' ? coupon.scope_json : JSON.stringify(coupon.scope_json, null, 2))
    : '';
%>
<div class="flex justify-center">
    <div class="w-full lg:max-w-3xl">
        <div class="mb-6">
            <a href="/admin/coupons" class="text-sm text-gray-500 hover:text-gray-700 mb-2 inline-block">← 쿠폰 목록</a>
        </div>

        <% if (error) { %>
            <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800"><%= error %></div>
        <% } %>

        <form action="<%= coupon ? '/admin/coupons/edit/' + coupon.id : '/admin/coupons' %>" method="POST" class="space-y-6">

            <!-- 기본 정보 -->
            <div class="bg-white shadow-sm rounded-xl border border-gray-200">
                <div class="px-6 py-4 border-b border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-800">기본 정보</h3>
                </div>
                <div class="px-6 py-5 space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">쿠폰명 <span class="text-red-500">*</span></label>
                        <input type="text" name="name" required
                            value="<%= coupon ? coupon.name : '' %>" placeholder="예: 신규 가입 3,000원 할인">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">한 줄 소개 (요약)</label>
                        <input type="text" name="summary" maxlength="255"
                            value="<%= coupon && coupon.summary ? coupon.summary : '' %>" placeholder="예: 여름맞이 전상품 특가 쿠폰!">
                        <p class="text-xs text-gray-400 mt-1">쿠폰존 카드에 혜택 아래로 노출됩니다.</p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">썸네일 이미지</label>
                        <div class="flex items-start gap-4">
                            <div id="thumbPreview" class="w-24 h-24 shrink-0 rounded-lg border border-gray-200 bg-gray-50 flex items-center justify-center overflow-hidden">
                                <% if (coupon && coupon.thumbnail_url) { %>
                                    <img src="<%= coupon.thumbnail_url %>" alt="" class="w-full h-full object-cover">
                                <% } else { %>
                                    <span class="text-2xl text-gray-300">🎟️</span>
                                <% } %>
                            </div>
                            <div class="flex-1 min-w-0">
                                <input type="hidden" name="thumbnail_url" id="thumbnailUrl" value="<%= coupon && coupon.thumbnail_url ? coupon.thumbnail_url : '' %>">
                                <input type="file" id="thumbFile" accept="image/*" class="block w-full text-sm text-gray-600 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:text-sm file:bg-gray-100 file:text-gray-700 hover:file:bg-gray-200">
                                <p id="thumbHint" class="text-xs text-gray-400 mt-1">JPG·PNG 이미지를 올리면 자동 업로드됩니다.</p>
                                <button type="button" id="thumbClear" class="text-xs text-red-500 hover:underline mt-1 <%= coupon && coupon.thumbnail_url ? '' : 'hidden' %>">이미지 제거</button>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">목적 (분류)</label>
                            <select name="coupon_type">
                                <option value="NEW_SIGNUP" <%= (coupon && coupon.coupon_type === 'NEW_SIGNUP') ? 'selected' : '' %>>신규가입</option>
                                <option value="EVENT" <%= (coupon && coupon.coupon_type === 'EVENT') ? 'selected' : '' %>>이벤트</option>
                                <option value="SEASON" <%= (coupon && coupon.coupon_type === 'SEASON') ? 'selected' : '' %>>시즌</option>
                                <option value="SPECIAL" <%= (coupon && coupon.coupon_type === 'SPECIAL') ? 'selected' : '' %>>특별</option>
                            </select>
                            <p class="text-xs text-gray-400 mt-1">분류 라벨입니다. 동작은 발급 방식이 결정합니다.</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">몰</label>
                            <select name="mall_id">
                                <option value="">전 몰 공용</option>
                                <% malls.forEach(function (m) { %>
                                    <option value="<%= m.id %>" <%= (coupon && Number(coupon.mall_id) === Number(m.id)) ? 'selected' : '' %>><%= m.name %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">상태</label>
                            <select name="status">
                                <option value="DRAFT" <%= (coupon && coupon.status === 'DRAFT') ? 'selected' : '' %>>작성중 (노출 안 함)</option>
                                <option value="ACTIVE" <%= (!coupon || coupon.status === 'ACTIVE') ? 'selected' : '' %>>진행중</option>
                                <option value="PAUSED" <%= (coupon && coupon.status === 'PAUSED') ? 'selected' : '' %>>일시중지</option>
                                <option value="ENDED" <%= (coupon && coupon.status === 'ENDED') ? 'selected' : '' %>>종료</option>
                            </select>
                            <p class="text-xs text-gray-400 mt-1">쿠폰은 삭제하지 않고 종료합니다.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 상세 소개 -->
            <div class="bg-white shadow-sm rounded-xl border border-gray-200">
                <div class="px-6 py-4 border-b border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-800">상세 소개</h3>
                    <p class="text-xs text-gray-400 mt-0.5">쿠폰존 상세 페이지(<code>/coupon/:id</code>)에 노출됩니다.</p>
                </div>
                <div class="px-6 py-5 space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">상세 본문</label>
                        <textarea name="detail_content" id="detailEditor"><%= coupon && coupon.detail_content ? coupon.detail_content : '' %></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">유의사항</label>
                        <textarea name="notice" id="noticeEditor"><%= coupon && coupon.notice ? coupon.notice : '' %></textarea>
                    </div>
                </div>
            </div>

            <!-- 혜택 -->
            <div class="bg-white shadow-sm rounded-xl border border-gray-200">
                <div class="px-6 py-4 border-b border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-800">혜택</h3>
                </div>
                <div class="px-6 py-5 space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">혜택 유형</label>
                        <select name="benefit_type" id="benefitType">
                            <option value="FIXED" <%= benefit === 'FIXED' ? 'selected' : '' %>>정액 할인 (원)</option>
                            <option value="PERCENT" <%= benefit === 'PERCENT' ? 'selected' : '' %>>정률 할인 (%)</option>
                            <option value="SHIPPING_FREE" <%= benefit === 'SHIPPING_FREE' ? 'selected' : '' %>>무료배송</option>
                            <option value="SHIPPING_FIXED" <%= benefit === 'SHIPPING_FIXED' ? 'selected' : '' %>>배송비 정액 할인 (원)</option>
                        </select>
                        <p class="text-xs text-gray-400 mt-1">
                            배송비 쿠폰은 주문 쿠폰과 <strong>함께</strong> 사용됩니다. 배송비보다 많이 할인되지 않습니다.
                        </p>
                    </div>

                    <div id="fixedFields" class="<%= (benefit === 'FIXED' || benefit === 'SHIPPING_FIXED') ? '' : 'hidden' %>">
                        <label class="block text-sm font-medium text-gray-700 mb-2">할인 금액 (원)</label>
                        <input type="text" name="discount_amount" class="coupon-num-input text-right"
                            value="<%= coupon ? Number(coupon.discount_amount || 0).toLocaleString() : '0' %>" placeholder="0">
                    </div>

                    <div id="percentFields" class="<%= benefit === 'PERCENT' ? '' : 'hidden' %> grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">할인율 (%)</label>
                            <input type="text" name="discount_rate" class="text-right"
                                value="<%= coupon && coupon.discount_rate ? Math.round(Number(coupon.discount_rate)) : '' %>" placeholder="10">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">최대 할인액 (원) <span class="text-red-500">*</span></label>
                            <input type="text" name="max_discount_amount" class="coupon-num-input text-right"
                                value="<%= coupon && coupon.max_discount_amount ? Number(coupon.max_discount_amount).toLocaleString() : '' %>" placeholder="20,000">
                            <p class="text-xs text-gray-400 mt-1">없으면 고액 주문에서 할인이 무한정 커집니다.</p>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">최소 주문 금액 (원)</label>
                        <input type="text" name="min_order_amount" class="coupon-num-input text-right"
                            value="<%= coupon ? Number(coupon.min_order_amount || 0).toLocaleString() : '0' %>" placeholder="0">
                    </div>
                </div>
            </div>

            <!-- 적용 대상 -->
            <div class="bg-white shadow-sm rounded-xl border border-gray-200">
                <div class="px-6 py-4 border-b border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-800">적용 대상</h3>
                </div>
                <div class="px-6 py-5 space-y-5">
                    <p class="text-xs text-gray-500">
                        비우면 <strong>전 상품</strong>에 적용됩니다. 카테고리·브랜드를 지정하면 해당 상품에만 적용되고, 쿠폰존에서 그 분류로 조회됩니다.
                    </p>

                    <!-- 카테고리 (include) -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">적용 카테고리</label>
                        <input type="text" id="categorySearch" autocomplete="off" placeholder="카테고리명 검색"
                            class="w-full border-gray-300 rounded-md text-sm">
                        <div id="categoryResults" class="hidden mt-1 border border-gray-200 rounded-md bg-white shadow-sm max-h-48 overflow-y-auto text-sm"></div>
                        <div id="categoryChips" class="flex flex-wrap gap-2 mt-2"></div>
                    </div>

                    <!-- 브랜드 (include) -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">적용 브랜드</label>
                        <input type="text" id="brandSearch" autocomplete="off" placeholder="브랜드명 검색"
                            class="w-full border-gray-300 rounded-md text-sm">
                        <div id="brandResults" class="hidden mt-1 border border-gray-200 rounded-md bg-white shadow-sm max-h-48 overflow-y-auto text-sm"></div>
                        <div id="brandChips" class="flex flex-wrap gap-2 mt-2"></div>
                    </div>

                    <!-- 뱃지 제외 (exclude) -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">제외할 상품 뱃지</label>
                        <p class="text-xs text-gray-500 mb-2">체크한 뱃지가 붙은 상품은 이 쿠폰에서 제외됩니다.</p>
                        <div class="flex flex-wrap gap-3" id="badgeExclude">
                            <% ['BEST','NEW','RECOMMEND','DEADLINE_SALE','GREENHUB_SPECIAL'].forEach(function (b) { %>
                                <label class="inline-flex items-center gap-1.5 text-sm text-gray-700">
                                    <input type="checkbox" class="badge-exclude rounded border-gray-300" value="<%= b %>">
                                    <span><%= b %></span>
                                </label>
                            <% }); %>
                        </div>
                    </div>

                    <!-- picker 가 직렬화해 넣는다. 사용자가 직접 JSON 을 쓰지 않는다. -->
                    <input type="hidden" name="scope_json" id="scopeJson" value="<%= scopeText %>">
                </div>
            </div>

            <!-- 발급 -->
            <div class="bg-white shadow-sm rounded-xl border border-gray-200">
                <div class="px-6 py-4 border-b border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-800">발급</h3>
                </div>
                <div class="px-6 py-5 space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">발급 방식</label>
                        <select name="issue_method" id="issueMethod">
                            <option value="AUTO_SIGNUP" <%= method === 'AUTO_SIGNUP' ? 'selected' : '' %>>가입 시 자동지급</option>
                            <option value="ADMIN" <%= method === 'ADMIN' ? 'selected' : '' %>>관리자 수동지급</option>
                            <option value="CODE" <%= method === 'CODE' ? 'selected' : '' %>>쿠폰 코드 입력</option>
                            <option value="DOWNLOAD" <%= method === 'DOWNLOAD' ? 'selected' : '' %>>쿠폰존 다운로드</option>
                        </select>
                    </div>

                    <div id="codeField" class="<%= method === 'CODE' ? '' : 'hidden' %>">
                        <label class="block text-sm font-medium text-gray-700 mb-2">쿠폰 코드</label>
                        <p class="text-xs text-gray-500 mb-2">고객이 쿠폰존에서 입력하는 코드입니다.</p>
                        <input type="text" name="code" value="<%= coupon && coupon.code ? coupon.code : '' %>" placeholder="예: WELCOME2026">
                    </div>

                    <div id="downloadFields" class="<%= method === 'DOWNLOAD' ? '' : 'hidden' %> space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">수령 시작</label>
                                <input type="datetime-local" name="download_start_at" value="<%= dtLocal(coupon && coupon.download_start_at) %>">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">수령 종료</label>
                                <input type="datetime-local" name="download_end_at" value="<%= dtLocal(coupon && coupon.download_end_at) %>">
                            </div>
                        </div>
                        <p class="text-xs text-gray-500 -mt-2">수령 기간과 아래의 사용 기간은 다릅니다. "7월에 받아서 8월까지 쓴다"가 가능합니다.</p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">선착순 수령 수량</label>
                        <p class="text-xs text-gray-500 mb-2">비우면 무제한. 이 한도를 넘으면 더 이상 <strong>발급</strong>되지 않습니다.</p>
                        <input type="text" name="issue_limit" class="coupon-num-input text-right"
                            value="<%= coupon && coupon.issue_limit ? Number(coupon.issue_limit).toLocaleString() : '' %>" placeholder="무제한">
                        <% if (coupon) { %>
                            <p class="text-xs text-gray-400 mt-1">현재 발급 수: <%= Number(coupon.issued_count || 0).toLocaleString() %></p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- 사용 조건 -->
            <div class="bg-white shadow-sm rounded-xl border border-gray-200">
                <div class="px-6 py-4 border-b border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-800">사용 조건</h3>
                </div>
                <div class="px-6 py-5 space-y-5">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">사용 시작일</label>
                            <input type="datetime-local" name="valid_from" value="<%= dtLocal(coupon && coupon.valid_from) %>">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">사용 종료일</label>
                            <input type="datetime-local" name="valid_to" value="<%= dtLocal(coupon && coupon.valid_to) %>">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">발급 후 N일 (상대 유효기간)</label>
                        <p class="text-xs text-gray-500 mb-2">
                            값이 있으면 "받은 날부터 N일"이 개인별 만료일이 됩니다. 비우면 위의 사용 종료일을 씁니다.
                        </p>
                        <input type="text" name="valid_days" class="coupon-num-input text-right"
                            value="<%= coupon && coupon.valid_days ? coupon.valid_days : '' %>" placeholder="예: 7">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">전체 사용 한도</label>
                        <p class="text-xs text-gray-500 mb-2">
                            결제에 <strong>사용</strong>될 수 있는 총 횟수입니다. 위의 발급 수량과 다른 축입니다. 비우면 무제한.
                        </p>
                        <input type="text" name="max_total_uses" class="coupon-num-input text-right"
                            value="<%= coupon && coupon.max_total_uses ? Number(coupon.max_total_uses).toLocaleString() : '' %>" placeholder="무제한">
                    </div>
                </div>
            </div>

            <div class="flex justify-end gap-2">
                <a href="/admin/coupons" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">취소</a>
                <button type="submit" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700">
                    <%= coupon ? '수정' : '등록' %>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
(function() {
    const methodSelect = document.getElementById('issueMethod');
    const codeField = document.getElementById('codeField');
    const downloadFields = document.getElementById('downloadFields');
    if (methodSelect) {
        methodSelect.addEventListener('change', function() {
            codeField.classList.toggle('hidden', this.value !== 'CODE');
            downloadFields.classList.toggle('hidden', this.value !== 'DOWNLOAD');
        });
    }

    // SHIPPING_FREE 는 배송비 전액이므로 금액 입력이 없다.
    const benefitSelect = document.getElementById('benefitType');
    const fixedFields = document.getElementById('fixedFields');
    const percentFields = document.getElementById('percentFields');
    if (benefitSelect) {
        benefitSelect.addEventListener('change', function() {
            fixedFields.classList.toggle('hidden', this.value !== 'FIXED' && this.value !== 'SHIPPING_FIXED');
            percentFields.classList.toggle('hidden', this.value !== 'PERCENT');
        });
    }

    function formatNumber(num) {
        if (num === '' || num === null || num === undefined) return '';
        var n = parseInt(String(num).replace(/[^0-9]/g, ''), 10);
        return isNaN(n) ? '' : n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }
    function unformatNumber(str) {
        if (!str) return '';
        return String(str).replace(/,/g, '');
    }

    var numInputs = document.querySelectorAll('.coupon-num-input');
    numInputs.forEach(function(input) {
        input.addEventListener('input', function() {
            var val = this.value;
            var formatted = formatNumber(val);
            if (formatted !== val) this.value = formatted;
        });
    });

    document.querySelector('form').addEventListener('submit', function() {
        numInputs.forEach(function(input) {
            input.value = unformatNumber(input.value);
        });
    });
})();
</script>

<!-- 상세 에디터 -->
<% if (tinymceKey) { %>
<script src="https://cdn.tiny.cloud/1/<%= tinymceKey %>/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
<script>
    tinymce.init({
        selector: '#detailEditor, #noticeEditor',
        plugins: 'image link lists table code',
        toolbar: 'undo redo | blocks | bold italic | alignleft aligncenter alignright | bullist numlist | link image | code',
        height: 320,
        menubar: false,
        images_upload_url: '/admin/uploads/tinymce',
        setup: function (editor) {
            // 제출 직전 에디터 내용을 textarea 로 동기화
            editor.on('init', function () {
                editor.getElement().form.addEventListener('submit', function () { editor.save(); });
            });
        },
    });
</script>
<% } else { %>
<script>
    ['detailEditor', 'noticeEditor'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) { el.rows = 8; el.className = 'w-full border-gray-300 rounded-md shadow-sm text-sm'; }
    });
</script>
<% } %>

<!-- 썸네일 업로드 + 적용대상 picker -->
<script>
(function () {
    // ── 썸네일 업로드 (공용 /admin/uploads/tinymce 재사용)
    const thumbFile = document.getElementById('thumbFile');
    const thumbUrl = document.getElementById('thumbnailUrl');
    const thumbPreview = document.getElementById('thumbPreview');
    const thumbHint = document.getElementById('thumbHint');
    const thumbClear = document.getElementById('thumbClear');

    function setThumb(url) {
        thumbUrl.value = url || '';
        if (url) {
            thumbPreview.innerHTML = '<img src="' + url + '" alt="" class="w-full h-full object-cover">';
            thumbClear.classList.remove('hidden');
        } else {
            thumbPreview.innerHTML = '<span class="text-2xl text-gray-300">🎟️</span>';
            thumbClear.classList.add('hidden');
        }
    }
    if (thumbFile) {
        thumbFile.addEventListener('change', function () {
            const file = this.files && this.files[0];
            if (!file) return;
            const fd = new FormData();
            fd.append('file', file);
            thumbHint.textContent = '업로드 중...';
            fetch('/admin/uploads/tinymce', { method: 'POST', body: fd })
                .then((r) => r.json())
                .then((data) => {
                    if (data.location) { setThumb(data.location); thumbHint.textContent = '업로드 완료'; }
                    else { thumbHint.textContent = '업로드 실패: ' + (data.error || '오류'); }
                })
                .catch(() => { thumbHint.textContent = '업로드 실패'; });
        });
    }
    if (thumbClear) thumbClear.addEventListener('click', function () { setThumb(''); thumbFile.value = ''; });

    // ── 적용대상 picker
    const scopeInput = document.getElementById('scopeJson');
    let scope = {};
    try { scope = scopeInput.value ? JSON.parse(scopeInput.value) : {}; } catch (e) { scope = {}; }
    scope.include = scope.include || {};
    scope.exclude = scope.exclude || {};

    // 선택된 대상: id -> name
    const picked = { category: new Map(), brand: new Map() };

    function chip(kind, id, name) {
        const el = document.createElement('span');
        el.className = 'inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-blue-50 text-blue-700 text-xs';
        el.innerHTML = '<span></span><button type="button" class="text-blue-400 hover:text-blue-700">&times;</button>';
        el.querySelector('span').textContent = name;
        el.querySelector('button').addEventListener('click', function () {
            picked[kind].delete(id);
            renderChips(kind);
        });
        return el;
    }
    function renderChips(kind) {
        const box = document.getElementById(kind + 'Chips');
        box.innerHTML = '';
        picked[kind].forEach(function (name, id) { box.appendChild(chip(kind, id, name)); });
    }

    function wireSearch(kind, type) {
        const input = document.getElementById(kind + 'Search');
        const results = document.getElementById(kind + 'Results');
        let timer = null;
        input.addEventListener('input', function () {
            const q = this.value.trim();
            clearTimeout(timer);
            if (!q) { results.classList.add('hidden'); return; }
            timer = setTimeout(function () {
                fetch('/admin/coupons/search-targets?type=' + type + '&q=' + encodeURIComponent(q))
                    .then((r) => r.json())
                    .then((rows) => {
                        results.innerHTML = '';
                        if (!rows.length) { results.classList.add('hidden'); return; }
                        rows.forEach(function (row) {
                            const item = document.createElement('div');
                            item.className = 'px-3 py-2 hover:bg-gray-50 cursor-pointer';
                            item.textContent = row.name;
                            item.addEventListener('click', function () {
                                picked[kind].set(row.id, row.name);
                                renderChips(kind);
                                input.value = '';
                                results.classList.add('hidden');
                            });
                            results.appendChild(item);
                        });
                        results.classList.remove('hidden');
                    });
            }, 200);
        });
        document.addEventListener('click', function (e) {
            if (!results.contains(e.target) && e.target !== input) results.classList.add('hidden');
        });
    }
    wireSearch('category', 'NORMAL');
    wireSearch('brand', 'BRAND');

    // 뱃지 제외 프리필
    const excludeBadges = new Set(Array.isArray(scope.exclude.badges) ? scope.exclude.badges : []);
    document.querySelectorAll('.badge-exclude').forEach(function (cb) {
        cb.checked = excludeBadges.has(cb.value);
    });

    // 기존 카테고리/브랜드 프리필 — id 를 이름으로 해석
    const prefillCat = Array.isArray(scope.include.categoryIds) ? scope.include.categoryIds : [];
    const prefillBrand = Array.isArray(scope.include.brandIds) ? scope.include.brandIds : [];
    const allIds = prefillCat.concat(prefillBrand);
    if (allIds.length) {
        fetch('/admin/coupons/resolve-targets?ids=' + allIds.join(','))
            .then((r) => r.json())
            .then((rows) => {
                const nameMap = {};
                rows.forEach(function (row) { nameMap[row.id] = row.name; });
                prefillCat.forEach(function (id) { picked.category.set(Number(id), nameMap[id] || ('#' + id)); });
                prefillBrand.forEach(function (id) { picked.brand.set(Number(id), nameMap[id] || ('#' + id)); });
                renderChips('category');
                renderChips('brand');
            });
    }

    // 제출 시 scope_json 직렬화 (사용자가 JSON 을 직접 쓰지 않는다)
    document.querySelector('form').addEventListener('submit', function () {
        const include = {};
        const exclude = {};
        // 손대지 않는 키(productIds 등)는 원본 scope 에서 보존
        if (Array.isArray(scope.include.productIds) && scope.include.productIds.length) include.productIds = scope.include.productIds;
        if (Array.isArray(scope.include.badges) && scope.include.badges.length) include.badges = scope.include.badges;
        if (Array.isArray(scope.exclude.productIds) && scope.exclude.productIds.length) exclude.productIds = scope.exclude.productIds;
        if (Array.isArray(scope.exclude.categoryIds) && scope.exclude.categoryIds.length) exclude.categoryIds = scope.exclude.categoryIds;
        if (Array.isArray(scope.exclude.brandIds) && scope.exclude.brandIds.length) exclude.brandIds = scope.exclude.brandIds;

        const catIds = Array.from(picked.category.keys());
        const brandIds = Array.from(picked.brand.keys());
        if (catIds.length) include.categoryIds = catIds;
        if (brandIds.length) include.brandIds = brandIds;

        const badges = Array.from(document.querySelectorAll('.badge-exclude'))
            .filter((cb) => cb.checked).map((cb) => cb.value);
        if (badges.length) exclude.badges = badges;

        const result = {};
        if (Object.keys(include).length) result.include = include;
        if (Object.keys(exclude).length) result.exclude = exclude;
        scopeInput.value = Object.keys(result).length ? JSON.stringify(result) : '';
    });
})();
</script>
