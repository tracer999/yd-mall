<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <a href="/admin/coupons" class="text-sm text-gray-500 hover:text-gray-700">← 쿠폰 목록</a>
</div>

<form method="GET" action="/admin/coupons/usage" class="mb-6 p-4 bg-gray-50 rounded-lg flex flex-wrap gap-4 items-end">
    <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">회원</label>
        <select name="user_id">
            <option value="">전체</option>
            <% if (users && users.length) { %>
            <% users.forEach(function(u) { %>
            <option value="<%= u.id %>" <%= filters && String(filters.user_id) === String(u.id) ? 'selected' : '' %>><%= u.email %></option>
            <% }); %>
            <% } %>
        </select>
    </div>
    <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">쿠폰</label>
        <select name="coupon_id">
            <option value="">전체</option>
            <% if (coupons && coupons.length) { %>
            <% coupons.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= filters && String(filters.coupon_id) === String(c.id) ? 'selected' : '' %>><%= c.name %></option>
            <% }); %>
            <% } %>
        </select>
    </div>
    <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">시작일</label>
        <input type="date" name="from" value="<%= filters && filters.from ? filters.from : '' %>">
    </div>
    <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">종료일</label>
        <input type="date" name="to" value="<%= filters && filters.to ? filters.to : '' %>">
    </div>
    <button type="submit" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700">검색</button>
</form>

<div class="bg-white overflow-hidden shadow-sm rounded-lg overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase w-52">회원</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase w-64">쿠폰</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase w-32">할인액</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase w-24">지급유형</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase w-40">사용일</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase w-64">주문번호</th>
            </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
            <% if (!usages || usages.length === 0) { %>
            <tr>
                <td colspan="6" class="px-6 py-8 text-center text-gray-500">내역이 없습니다.</td>
            </tr>
            <% } else { %>
            <% usages.forEach(function(u) { %>
            <tr>
                <td class="px-6 py-4 text-sm">
                    <div class="flex items-center gap-3">
                        <div class="h-10 w-10 flex-shrink-0">
                            <% if (u.user_picture) { %>
                                <img src="<%= u.user_picture %>" alt="프로필" class="h-10 w-10 rounded-full object-cover border border-gray-200">
                            <% } else { %>
                                <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500"><i class="bi bi-person-fill"></i></div>
                            <% } %>
                        </div>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="font-medium text-gray-900"><%= u.user_name || u.email || '-' %></span>
                                <% if (u.user_google_id) { %>
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-red-50 text-[11px] font-semibold text-red-600 border border-red-100">Google</span>
                                <% } else if (u.user_kakao_id) { %>
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-yellow-100 text-[11px] font-semibold text-yellow-800 border border-yellow-200">Kakao</span>
                                <% } %>
                            </div>
                            <div class="text-xs text-gray-500"><%= u.user_phone || u.email || '-' %></div>
                        </div>
                    </div>
                </td>
                <td class="px-6 py-4 text-sm text-gray-900"><%= u.coupon_name %></td>
                <td class="px-6 py-4 text-sm text-gray-900"><%= Number(u.discount_amount || 0).toLocaleString() %>원</td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= u.issued_by === 'AUTO' ? '자동' : u.issued_by === 'ADMIN' ? '관리자' : '코드' %></td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= u.used_at ? new Date(u.used_at).toLocaleString() : '-' %></td>
                <td class="px-6 py-4 text-sm text-gray-500">
                    <% if (u.order_id && u.order_number) { %>
                        <a href="/admin/sales/<%= u.order_id %>" class="text-blue-600 hover:text-blue-800 hover:underline"><%= u.order_number %></a>
                    <% } else { %>
                        <%= u.order_number || '-' %>
                    <% } %>
                </td>
            </tr>
            <% }); %>
            <% } %>
        </tbody>
    </table>
</div>
