<%
  /*
   * 특가 카테고리 — 목록
   *
   * 삭제는 `deal` 이 참조 중이면 막힌다(FK ON DELETE RESTRICT). 운영 중 종료는 "사용" 토글로.
   */
  const _cats = categories || [];
  const scheduleLabel = (v) => (scheduleTypes.find(s => s.value === v) || {}).label || v;
  const BADGE_CLASS = {
    rose: 'bg-rose-100 text-rose-700', amber: 'bg-amber-100 text-amber-700',
    emerald: 'bg-emerald-100 text-emerald-700', sky: 'bg-sky-100 text-sky-700',
    indigo: 'bg-indigo-100 text-indigo-700', violet: 'bg-violet-100 text-violet-700',
    slate: 'bg-slate-100 text-slate-700',
  };
%>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">특가 카테고리</h1>
      <p class="mt-1 text-sm text-gray-500">
        쇼핑특가 페이지의 탭을 이루는 분류입니다. <strong>타임 특가</strong> 카테고리를 고르면 특가 등록 폼에서 시간창·요일이 필수가 됩니다.
      </p>
    </div>
    <a href="/admin/deal-categories/new"
       class="inline-flex items-center h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 no-underline">
      <i class="bi bi-plus-lg mr-1.5"></i> 카테고리 등록
    </a>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
            <th class="px-4 py-2.5 w-14">ID</th>
            <th class="px-4 py-2.5 w-32">코드</th>
            <th class="px-4 py-2.5">카테고리명</th>
            <th class="px-4 py-2.5 w-28">스케줄</th>
            <th class="px-4 py-2.5 w-28">뱃지</th>
            <th class="px-4 py-2.5 w-20 text-center">정렬</th>
            <th class="px-4 py-2.5 w-28 text-center">특가</th>
            <th class="px-4 py-2.5 w-20 text-center">사용</th>
            <th class="px-4 py-2.5 w-40 text-center">관리</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (_cats.length === 0) { %>
            <tr><td colspan="9" class="px-6 py-16 text-center text-gray-500">등록된 특가 카테고리가 없습니다.</td></tr>
          <% } %>
          <% _cats.forEach(function (c) { %>
            <tr class="<%= c.is_active ? '' : 'bg-gray-50/60' %>">
              <td class="px-4 py-3 text-gray-400"><%= c.id %></td>
              <td class="px-4 py-3">
                <code class="text-xs px-1.5 py-0.5 rounded bg-gray-100 text-gray-700"><%= c.code %></code>
              </td>
              <td class="px-4 py-3">
                <a href="/admin/deal-categories/<%= c.id %>" class="font-medium text-gray-900 hover:text-indigo-600"><%= c.name %></a>
                <% if (c.description) { %>
                  <div class="text-xs text-gray-400 truncate max-w-md"><%= c.description %></div>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <% if (c.schedule_type === 'TIME') { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-amber-50 text-amber-700">타임</span>
                <% } else { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-slate-100 text-slate-700">기간</span>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <% if (c.badge_text) { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded <%= BADGE_CLASS[c.badge_color] || BADGE_CLASS.rose %>"><%= c.badge_text %></span>
                <% } else { %>
                  <span class="text-xs text-gray-300">없음</span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-center text-gray-500"><%= c.sort_order %></td>
              <td class="px-4 py-3 text-center text-gray-600">
                <% if (Number(c.deal_count) === 0) { %>
                  <span class="text-xs text-gray-300">없음</span>
                <% } else { %>
                  <a href="/admin/deals?category_id=<%= c.id %>" class="text-xs text-indigo-600 hover:underline">
                    <%= c.deal_count %>건<% if (Number(c.running_count) > 0) { %> <span class="text-emerald-600">(진행 <%= c.running_count %>)</span><% } %>
                  </a>
                <% } %>
              </td>
              <td class="px-4 py-3 text-center">
                <% if (c.is_active) { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-green-50 text-green-700">ON</span>
                <% } else { %>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-gray-200 text-gray-600">OFF</span>
                <% } %>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1.5">
                  <a href="/admin/deal-categories/<%= c.id %>"
                     class="text-xs px-2 py-1 rounded border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">수정</a>
                  <form method="POST" action="/admin/deal-categories/<%= c.id %>/toggle">
                    <button type="submit" class="text-xs px-2 py-1 rounded border border-gray-200 text-gray-700 hover:bg-gray-50">
                      <%= c.is_active ? '끄기' : '켜기' %>
                    </button>
                  </form>
                  <% if (Number(c.deal_count) === 0) { %>
                    <form method="POST" action="/admin/deal-categories/<%= c.id %>/delete"
                          onsubmit="return confirm('카테고리 &quot;<%= c.name %>&quot; 을(를) 삭제합니다.');">
                      <button type="submit" class="text-xs px-2 py-1 rounded border border-red-200 text-red-600 hover:bg-red-50">삭제</button>
                    </form>
                  <% } else { %>
                    <span class="text-xs px-2 py-1 rounded border border-gray-100 text-gray-300 cursor-not-allowed"
                          title="사용 중인 특가가 <%= c.deal_count %>건 있어 삭제할 수 없습니다">삭제</span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <p class="mt-4 text-xs text-gray-400">
    카테고리의 <strong>사용</strong>을 끄면 그 카테고리에 속한 특가가 <strong>전부 즉시 노출·적용 중단</strong>됩니다(삭제 대신 쓰는 안전한 종료 수단).
    특가가 걸린 카테고리는 삭제할 수 없습니다.
  </p>
</div>
