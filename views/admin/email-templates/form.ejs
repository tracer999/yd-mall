<%
  /* 이메일 템플릿 편집 — 제목·본문·발송여부 + 미리보기 + 테스트 발송 */
  const def = tpl.def;
  const isLayout = tpl.key === '_layout';
%>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="mb-6">
    <a href="/admin/email-templates?mall=<%= mallId %>" class="text-sm text-gray-500 hover:text-gray-700 no-underline">
      <i class="bi bi-arrow-left"></i> 이메일 템플릿 목록
    </a>
    <h1 class="mt-2 text-2xl font-bold text-gray-900"><%= def.label %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= def.description %></p>
    <p class="mt-1 text-xs text-gray-400">
      <%= currentMall.name %> · 발송 시점: <%= def.when %><%= def.recipient ? ' · 받는 사람: ' + def.recipient : '' %>
    </p>
  </div>

  <% if (message) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> <%= message %>
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- 편집 -->
    <form method="POST" action="/admin/email-templates/<%= encodeURIComponent(tpl.key) %>" id="tplForm"
          class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-200 p-5">
      <input type="hidden" name="mall_id" value="<%= mallId %>">

      <div class="flex items-center justify-between mb-4">
        <label class="inline-flex items-center gap-2 text-sm text-gray-700">
          <input type="checkbox" name="is_enabled" value="1" <%= tpl.isEnabled ? 'checked' : '' %>
                 class="rounded border-gray-300 text-indigo-600">
          <%= isLayout ? '머리말·꼬리말 사용' : '이 안내 메일 발송' %>
        </label>
        <span class="text-xs <%= tpl.isCustomized ? 'text-indigo-600' : 'text-gray-400' %>">
          <%= tpl.isCustomized ? '기본 문구에서 수정된 상태입니다.' : '기본 문구를 그대로 쓰고 있습니다.' %>
        </span>
      </div>
      <% if (isLayout && def.disableHint) { %>
        <p class="-mt-2 mb-4 text-[11px] text-gray-400"><%= def.disableHint %></p>
      <% } %>

      <% if (!isLayout) { %>
        <div class="mb-4">
          <label class="block text-xs font-medium text-gray-600 mb-1">메일 제목</label>
          <input type="text" name="subject" id="subjectInput" value="<%= tpl.subject || '' %>" required
                 class="block w-full text-sm border-gray-300 rounded-md">
          <p class="mt-1 text-[11px] text-gray-400">아래 [넣을 수 있는 정보]를 클릭하면 커서 위치에 삽입됩니다.</p>
        </div>
      <% } %>

      <div class="mb-4">
        <label class="block text-xs font-medium text-gray-600 mb-1">메일 내용</label>
        <textarea name="body" id="bodyInput" rows="20"
                  class="block w-full text-sm border-gray-300 rounded-md font-mono"><%= tpl.body || '' %></textarea>
      </div>

      <div class="flex flex-wrap items-center justify-between gap-3 pt-4 border-t border-gray-100">
        <div class="flex items-center gap-2">
          <button type="button" id="previewBtn"
                  class="h-[38px] px-4 text-sm font-medium rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">
            미리보기 새로고침
          </button>
          <button type="submit"
                  class="h-[38px] px-5 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
            저장
          </button>
        </div>
      </div>
    </form>

    <!-- 사이드 -->
    <div class="space-y-5">

      <!-- 변수 칩 -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <h2 class="text-sm font-semibold text-gray-900">넣을 수 있는 정보</h2>
        <p class="mt-1 text-[11px] text-gray-400">
          클릭하면 커서 위치에 들어갑니다. 메일이 나갈 때 실제 주문 정보로 바뀝니다.
        </p>
        <div class="mt-3 flex flex-wrap gap-1.5">
          <% variables.forEach(function (v) { %>
            <button type="button" class="var-chip px-2 py-1 rounded text-[11px] bg-gray-100 text-gray-700 hover:bg-indigo-100 hover:text-indigo-700"
                    data-token="<%= v.token %>" title="{{<%= v.token %>}}">
              <%= v.label %>
            </button>
          <% }); %>
        </div>
      </div>

      <!-- 테스트 발송 -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <h2 class="text-sm font-semibold text-gray-900">테스트 발송</h2>
        <p class="mt-1 text-[11px] text-gray-400">지금 화면의 내용을 예시 주문 정보로 채워 실제로 보내 봅니다.</p>
        <div class="mt-3 flex gap-2">
          <input type="email" id="testEmail" placeholder="받는 사람 이메일"
                 class="flex-1 text-sm border-gray-300 rounded-md">
          <button type="button" id="testBtn"
                  class="h-[38px] px-3 text-xs font-semibold rounded-md bg-gray-800 text-white hover:bg-gray-900 whitespace-nowrap">
            보내기
          </button>
        </div>
        <p id="testResult" class="mt-2 text-[11px]"></p>
      </div>

      <!-- 기본값 복원 -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <h2 class="text-sm font-semibold text-gray-900">기본 문구로 되돌리기</h2>
        <p class="mt-1 text-[11px] text-gray-400">수정한 내용을 버리고 처음 제공된 문구로 되돌립니다.</p>
        <form method="POST" action="/admin/email-templates/<%= encodeURIComponent(tpl.key) %>/reset" class="mt-3"
              onsubmit="return confirm('수정한 내용이 사라집니다. 되돌릴까요?');">
          <input type="hidden" name="mall_id" value="<%= mallId %>">
          <button type="submit" class="h-[34px] px-3 text-xs font-medium rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">
            되돌리기
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- 미리보기 -->
  <div class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-sm font-semibold text-gray-900">미리보기</h2>
      <span id="previewSubject" class="text-xs text-gray-500 truncate max-w-[60%]"></span>
    </div>
    <iframe id="previewFrame" class="w-full bg-white" style="height:640px;border:0;"></iframe>
  </div>
</div>

<% if (tinymceKey) { %>
<script src="https://cdn.tiny.cloud/1/<%= tinymceKey %>/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
<% } %>
<script>
(function () {
  var TPL_KEY = <%- JSON.stringify(tpl.key) %>;
  var MALL_ID = <%- JSON.stringify(mallId) %>;
  var useTiny = <%- tinymceKey ? 'true' : 'false' %> && typeof tinymce !== 'undefined';
  var lastFocus = 'body'; // 'subject' | 'body'

  var subjectInput = document.getElementById('subjectInput');
  var bodyInput = document.getElementById('bodyInput');

  if (subjectInput) subjectInput.addEventListener('focus', function () { lastFocus = 'subject'; });

  function getBody() {
    if (useTiny && tinymce.get('bodyInput')) return tinymce.get('bodyInput').getContent();
    return bodyInput.value;
  }

  function insertToken(token) {
    var text = '{{' + token + '}}';
    if (lastFocus === 'subject' && subjectInput) {
      var s = subjectInput.selectionStart || 0;
      var e = subjectInput.selectionEnd || 0;
      subjectInput.value = subjectInput.value.slice(0, s) + text + subjectInput.value.slice(e);
      subjectInput.focus();
      subjectInput.setSelectionRange(s + text.length, s + text.length);
      return;
    }
    if (useTiny && tinymce.get('bodyInput')) {
      tinymce.get('bodyInput').execCommand('mceInsertContent', false, text);
      return;
    }
    var st = bodyInput.selectionStart || 0;
    var en = bodyInput.selectionEnd || 0;
    bodyInput.value = bodyInput.value.slice(0, st) + text + bodyInput.value.slice(en);
    bodyInput.focus();
    bodyInput.setSelectionRange(st + text.length, st + text.length);
  }

  document.querySelectorAll('.var-chip').forEach(function (btn) {
    btn.addEventListener('click', function () { insertToken(btn.dataset.token); });
  });

  function payload() {
    var fd = new URLSearchParams();
    fd.set('mall_id', MALL_ID);
    fd.set('subject', subjectInput ? subjectInput.value : '');
    fd.set('body', getBody());
    return fd;
  }

  function refreshPreview() {
    fetch('/admin/email-templates/' + encodeURIComponent(TPL_KEY) + '/preview', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: payload().toString()
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.error) { document.getElementById('previewSubject').textContent = data.error; return; }
        document.getElementById('previewSubject').textContent = data.subject || '';
        document.getElementById('previewFrame').srcdoc = data.html || '';
      })
      .catch(function (e) { document.getElementById('previewSubject').textContent = '미리보기 실패: ' + e.message; });
  }

  document.getElementById('previewBtn').addEventListener('click', refreshPreview);

  document.getElementById('testBtn').addEventListener('click', function () {
    var out = document.getElementById('testResult');
    var to = document.getElementById('testEmail').value.trim();
    if (!to) { out.textContent = '받는 사람 주소를 입력하세요.'; out.className = 'mt-2 text-[11px] text-red-600'; return; }
    out.textContent = '보내는 중...'; out.className = 'mt-2 text-[11px] text-gray-500';
    var fd = payload();
    fd.set('test_email', to);
    fetch('/admin/email-templates/' + encodeURIComponent(TPL_KEY) + '/test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: fd.toString()
    })
      .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
      .then(function (res) {
        if (!res.ok || res.d.error) { out.textContent = res.d.error || '발송 실패'; out.className = 'mt-2 text-[11px] text-red-600'; return; }
        out.textContent = '테스트 메일을 보냈습니다.'; out.className = 'mt-2 text-[11px] text-green-600';
      })
      .catch(function (e) { out.textContent = '발송 실패: ' + e.message; out.className = 'mt-2 text-[11px] text-red-600'; });
  });

  // 저장 시 TinyMCE 내용을 textarea 에 반영
  document.getElementById('tplForm').addEventListener('submit', function () {
    if (useTiny && tinymce.get('bodyInput')) tinymce.get('bodyInput').save();
  });

  if (useTiny) {
    tinymce.init({
      selector: '#bodyInput',
      branding: false,
      height: 520,
      menubar: false,
      // 이메일 HTML 은 인라인 스타일로 버틴다. TinyMCE 가 style 속성을 지우면 레이아웃이 깨진다.
      valid_elements: '*[*]',
      extended_valid_elements: '*[*]',
      verify_html: false,
      // {{token}} 의 중괄호가 엔티티로 바뀌면 치환이 조용히 실패한다. 최소 인코딩만 한다.
      entity_encoding: 'raw',
      plugins: 'code link lists table charmap searchreplace visualblocks',
      toolbar: 'undo redo | blocks | bold italic underline | forecolor backcolor | alignleft aligncenter alignright | bullist numlist | link table | removeformat | code',
      setup: function (ed) {
        ed.on('focus', function () { lastFocus = 'body'; });
        ed.on('init', refreshPreview);
      }
    });
  } else {
    bodyInput.addEventListener('focus', function () { lastFocus = 'body'; });
    refreshPreview();
  }
})();
</script>
