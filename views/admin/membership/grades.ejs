<div class="mb-6 flex justify-between items-center gap-4">
  <p class="text-sm text-gray-500">등급 순위·표시정보와 등급별 혜택을 관리합니다. 순위 1이 최상위입니다.</p>
  <a href="/admin/membership/grades/new" class="inline-flex items-center justify-center h-[38px] px-4 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 no-underline">등급 등록</a>
</div>

<% if (success) { %><div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800"><%= success %></div><% } %>
<% if (error) { %><div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800"><%= error %></div><% } %>

<div class="bg-white overflow-hidden shadow-sm rounded-lg overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50"><tr>
      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">순위</th>
      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">등급</th>
      <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">기본</th>
      <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">회원</th>
      <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">할인율</th>
      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">적립</th>
      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">배송</th>
      <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">상태</th>
      <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">관리</th>
    </tr></thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% if (!grades || grades.length===0) { %>
      <tr><td colspan="9" class="px-6 py-10 text-center">
        <p class="text-sm text-gray-500">등록된 등급이 없습니다.</p>
        <p class="mt-1 text-xs text-gray-400">등급이 없으면 고객 화면의 멤버십 안내가 기본 예시 등급표로 표시됩니다.</p>
        <form action="/admin/membership/grades/seed-defaults" method="POST" class="mt-4"
              onsubmit="return confirm('기본 등급 4종(베이직·실버·골드·VIP)과 승급 기준을 불러올까요?');">
          <button type="submit" class="inline-flex items-center justify-center h-[38px] px-4 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700">기본 등급 불러오기</button>
        </form>
      </td></tr>
      <% } else { grades.forEach(function(g){ %>
      <tr>
        <td class="px-4 py-4 text-sm text-gray-500"><%= g.rank_order %></td>
        <td class="px-4 py-4 text-sm font-medium">
          <span class="inline-flex items-center gap-1.5">
            <span class="inline-block w-2.5 h-2.5 rounded-full" style="background:<%= g.color || '#9ca3af' %>"></span>
            <%= g.grade_name %> <span class="text-xs text-gray-400">(<%= g.grade_code %>)</span>
          </span>
        </td>
        <td class="px-4 py-4 text-center"><% if (Number(g.is_default)===1) { %><span class="px-2 py-0.5 text-xs rounded-full bg-blue-100 text-blue-700">기본</span><% } %></td>
        <td class="px-4 py-4 text-sm text-right text-gray-900"><%= Number(g.member_count||0).toLocaleString() %></td>
        <td class="px-4 py-4 text-sm text-right"><%= Number(g.discount_rate||0) %>%</td>
        <td class="px-4 py-4 text-sm text-gray-600"><% if (g.point_rate!=null) { %><%= g.point_rate_mode==='REPLACE'?'대체 ':'추가 +' %><%= Number(g.point_rate) %>%<% } else { %><span class="text-gray-300">-</span><% } %></td>
        <td class="px-4 py-4 text-xs text-gray-600"><% if (Number(g.free_shipping)===1) { %>무료배송<% } else if (g.free_ship_threshold!=null) { %><%= Number(g.free_ship_threshold).toLocaleString() %>↑ 무료<% } else { %><span class="text-gray-300">-</span><% } %></td>
        <td class="px-4 py-4 text-center"><% if (Number(g.is_active)===1) { %><span class="px-2 py-0.5 text-xs rounded-full bg-green-100 text-green-700">사용</span><% } else { %><span class="px-2 py-0.5 text-xs rounded-full bg-gray-100 text-gray-500">중지</span><% } %></td>
        <td class="px-4 py-4 text-right text-sm whitespace-nowrap">
          <a href="/admin/membership/grades/<%= g.id %>/edit" class="text-blue-600 hover:underline">수정</a>
          <form action="/admin/membership/grades/<%= g.id %>/delete" method="POST" class="inline" onsubmit="return confirm('이 등급을 삭제할까요? 소속 회원·이력이 있으면 삭제되지 않습니다.');">
            <button type="submit" class="ml-2 text-red-600 hover:underline">삭제</button>
          </form>
        </td>
      </tr>
      <% }); } %>
    </tbody>
  </table>
</div>
