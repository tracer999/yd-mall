<% var g = grade || {}; var isEdit = !!grade; %>
<div class="mb-6"><a href="/admin/membership/grades" class="text-sm text-gray-500 hover:text-gray-700 no-underline">← 등급 관리</a></div>

<% if (error) { %><div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800"><%= error %></div><% } %>

<form action="<%= isEdit ? '/admin/membership/grades/' + g.id : '/admin/membership/grades' %>" method="POST" class="space-y-8 max-w-3xl">

  <section>
    <h2 class="text-sm font-semibold text-gray-900 mb-4 pb-2 border-b">기본 정보</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">등급명 <span class="text-red-500">*</span></label>
        <input type="text" name="grade_name" required value="<%= g.grade_name || '' %>" class="w-full border rounded-lg px-3 h-[38px]">
      </div>
      <div>
        <%#
          등급 코드는 시스템 내부 식별자다. 사용자가 지어낼 필요가 없다(§33).
          - 등록: 비워 두면 서버가 등급명에서 만든다. 직접 정하고 싶을 때만 펼쳐서 입력.
          - 수정: 이미 다른 데이터가 이 코드를 참조하므로 바꿀 수 없다(기존 동작 유지).
        %>
        <% if (isEdit) { %>
          <label class="block text-sm font-medium text-gray-700 mb-1">등급 코드</label>
          <input type="text" name="grade_code" readonly value="<%= g.grade_code || '' %>"
                 class="w-full border rounded-lg px-3 h-[38px] bg-gray-100 text-gray-500">
          <p class="mt-1 text-xs text-gray-400">등록 후에는 바꿀 수 없습니다.</p>
        <% } else { %>
          <label class="block text-sm font-medium text-gray-700 mb-1">등급 코드</label>
          <div class="h-[38px] flex items-center text-sm text-gray-500">
            등급명에서 자동으로 만들어집니다.
            <button type="button" id="gradeCodeToggle" class="ml-2 text-indigo-600 hover:underline">직접 지정</button>
          </div>
          <input type="text" name="grade_code" id="gradeCodeInput" value="" hidden
                 placeholder="영문 대문자·숫자 (예: SILVER)"
                 class="w-full border rounded-lg px-3 h-[38px]">
        <% } %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">순위 (1이 최상위)</label>
        <input type="number" name="rank_order" value="<%= g.rank_order != null ? g.rank_order : 100 %>" class="w-full border rounded-lg px-3 h-[38px]">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">노출 색상</label>
        <input type="color" name="color" value="<%= g.color || '#9ca3af' %>" class="w-full border rounded-lg px-1 h-[38px]">
      </div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-gray-700 mb-1">설명</label>
        <input type="text" name="description" value="<%= g.description || '' %>" class="w-full border rounded-lg px-3 h-[38px]">
      </div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-gray-700 mb-1">마이페이지 안내 문구</label>
        <input type="text" name="mypage_note" value="<%= g.mypage_note || '' %>" class="w-full border rounded-lg px-3 h-[38px]">
      </div>
    </div>
    <div class="flex flex-wrap gap-6 mt-4">
      <label class="inline-flex items-center gap-2 text-sm"><input type="checkbox" name="is_default" value="1" <%= Number(g.is_default)===1?'checked':'' %>> 기본 가입 등급</label>
      <label class="inline-flex items-center gap-2 text-sm"><input type="checkbox" name="is_active" value="1" <%= (!isEdit||Number(g.is_active)===1)?'checked':'' %>> 사용</label>
      <label class="inline-flex items-center gap-2 text-sm"><input type="checkbox" name="is_auto_evaluation" value="1" <%= (!isEdit||Number(g.is_auto_evaluation)===1)?'checked':'' %>> 자동 평가 대상</label>
    </div>
  </section>

  <section>
    <h2 class="text-sm font-semibold text-gray-900 mb-2 pb-2 border-b">등급 혜택</h2>
    <div class="flex flex-wrap gap-x-6 gap-y-2 mb-1">
      <label class="inline-flex items-center gap-2 text-sm font-medium"><input type="checkbox" name="discount_enabled" value="1" <%= (!isEdit || Number(g.discount_enabled)===1)?'checked':'' %>> 할인 사용</label>
      <label class="inline-flex items-center gap-2 text-sm font-medium"><input type="checkbox" name="point_enabled" value="1" <%= (!isEdit || Number(g.point_enabled)===1)?'checked':'' %>> 적립 사용</label>
      <label class="inline-flex items-center gap-2 text-sm font-medium"><input type="checkbox" name="shipping_enabled" value="1" <%= (!isEdit || Number(g.shipping_enabled)===1)?'checked':'' %>> 배송 혜택 사용</label>
    </div>
    <p class="text-xs text-gray-500 mb-4">체크 해제한 혜택은 아래 값이 설정돼 있어도 <b>결제에 적용되지 않습니다</b>. (쿠폰팩·생일 쿠폰은 아래에서 연결/해제로 관리)</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">주문 정률 할인 (%)</label>
        <input type="number" step="0.01" name="discount_rate" value="<%= g.discount_rate != null ? Number(g.discount_rate) : 0 %>" class="w-full border rounded-lg px-3 h-[38px]">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">할인 최대액 (원, 비우면 무제한)</label>
        <input type="number" name="max_discount_amount" value="<%= g.max_discount_amount != null ? g.max_discount_amount : '' %>" class="w-full border rounded-lg px-3 h-[38px]">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">할인 최소 주문금액 (원)</label>
        <input type="number" name="min_order_amount" value="<%= g.min_order_amount != null ? g.min_order_amount : 0 %>" class="w-full border rounded-lg px-3 h-[38px]">
      </div>
      <div></div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">등급 적립률 (%, 비우면 없음)</label>
        <input type="number" step="0.01" name="point_rate" value="<%= g.point_rate != null ? Number(g.point_rate) : '' %>" class="w-full border rounded-lg px-3 h-[38px]">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">적립 방식</label>
        <select name="point_rate_mode" class="w-full border rounded-lg px-3 h-[38px]">
          <option value="ADD" <%= g.point_rate_mode!=='REPLACE'?'selected':'' %>>기본 적립률에 가산</option>
          <option value="REPLACE" <%= g.point_rate_mode==='REPLACE'?'selected':'' %>>기본 적립률 대체</option>
        </select>
      </div>
      <div>
        <label class="inline-flex items-center gap-2 text-sm mt-6"><input type="checkbox" name="free_shipping" value="1" <%= Number(g.free_shipping)===1?'checked':'' %>> 상시 무료배송 (지역할증 제외)</label>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">무료배송 문턱 override (원, 비우면 몰 기본)</label>
        <input type="number" name="free_ship_threshold" value="<%= g.free_ship_threshold != null ? g.free_ship_threshold : '' %>" class="w-full border rounded-lg px-3 h-[38px]">
      </div>
    </div>
  </section>

  <section>
    <h2 class="text-sm font-semibold text-gray-900 mb-1 pb-2 border-b">등급 진입 시 지급 쿠폰 (쿠폰팩)</h2>
    <p class="text-xs text-gray-500 mb-3">회원이 이 등급으로 <b>승급</b>하거나 관리자가 이 등급으로 <b>수동 상향</b>할 때 아래 쿠폰이 자동 발급됩니다. (이미 미사용 보유 중이면 건너뜀)</p>
    <% var _linked = (typeof linkedCouponIds !== 'undefined' && linkedCouponIds) ? linkedCouponIds.map(Number) : []; %>
    <% var _coupons = (typeof mallCoupons !== 'undefined' && mallCoupons) ? mallCoupons : []; %>
    <% if (_coupons.length === 0) { %>
      <p class="text-sm text-gray-400">연결할 수 있는 활성 쿠폰이 없습니다. <a href="/admin/coupons" class="text-blue-600 hover:underline">쿠폰 관리</a>에서 먼저 쿠폰을 만드세요.</p>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-64 overflow-y-auto border rounded-lg p-3">
        <% _coupons.forEach(function(c){ %>
          <label class="inline-flex items-center gap-2 text-sm py-1">
            <input type="checkbox" name="entry_coupon_ids" value="<%= c.id %>" <%= _linked.indexOf(Number(c.id)) >= 0 ? 'checked' : '' %>>
            <span><%= c.name %> <span class="text-xs text-gray-400">#<%= c.id %></span></span>
          </label>
        <% }); %>
      </div>
    <% } %>
  </section>

  <section>
    <h2 class="text-sm font-semibold text-gray-900 mb-1 pb-2 border-b">생일 지급 쿠폰</h2>
    <p class="text-xs text-gray-500 mb-3">이 등급 회원의 <b>생일 당일</b>에 아래 쿠폰이 자동 발급됩니다(연 1회). 일일 배치가 처리합니다.</p>
    <% var _bday = (typeof birthdayCouponIds !== 'undefined' && birthdayCouponIds) ? birthdayCouponIds.map(Number) : []; %>
    <% if (_coupons.length === 0) { %>
      <p class="text-sm text-gray-400">연결할 수 있는 활성 쿠폰이 없습니다.</p>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-64 overflow-y-auto border rounded-lg p-3">
        <% _coupons.forEach(function(c){ %>
          <label class="inline-flex items-center gap-2 text-sm py-1">
            <input type="checkbox" name="birthday_coupon_ids" value="<%= c.id %>" <%= _bday.indexOf(Number(c.id)) >= 0 ? 'checked' : '' %>>
            <span><%= c.name %> <span class="text-xs text-gray-400">#<%= c.id %></span></span>
          </label>
        <% }); %>
      </div>
    <% } %>
  </section>

  <section>
    <h2 class="text-sm font-semibold text-gray-900 mb-1 pb-2 border-b">정기(월) 지급 쿠폰</h2>
    <p class="text-xs text-gray-500 mb-3">이 등급 회원에게 <b>매월 1회</b> 아래 쿠폰이 자동 발급됩니다. 월 배치가 처리합니다.</p>
    <% var _periodic = (typeof periodicCouponIds !== 'undefined' && periodicCouponIds) ? periodicCouponIds.map(Number) : []; %>
    <% if (_coupons.length === 0) { %>
      <p class="text-sm text-gray-400">연결할 수 있는 활성 쿠폰이 없습니다.</p>
    <% } else { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-64 overflow-y-auto border rounded-lg p-3">
        <% _coupons.forEach(function(c){ %>
          <label class="inline-flex items-center gap-2 text-sm py-1">
            <input type="checkbox" name="periodic_coupon_ids" value="<%= c.id %>" <%= _periodic.indexOf(Number(c.id)) >= 0 ? 'checked' : '' %>>
            <span><%= c.name %> <span class="text-xs text-gray-400">#<%= c.id %></span></span>
          </label>
        <% }); %>
      </div>
    <% } %>
  </section>

  <div class="flex justify-end gap-2 pt-2">
    <a href="/admin/membership/grades" class="inline-flex items-center h-[38px] px-4 rounded-lg text-sm bg-gray-100 text-gray-700 no-underline">취소</a>
    <button type="submit" class="inline-flex items-center h-[38px] px-5 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700">저장</button>
  </div>
</form>

<script>
(function () {
  // "직접 지정"을 눌렀을 때만 등급 코드 입력칸을 보인다. 기본은 서버 자동 생성.
  var toggle = document.getElementById('gradeCodeToggle');
  var input = document.getElementById('gradeCodeInput');
  if (!toggle || !input) return;
  toggle.addEventListener('click', function () {
    input.hidden = false;
    toggle.closest('div').hidden = true;
    input.focus();
  });
})();
</script>
