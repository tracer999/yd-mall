<div class="mb-6"><a href="/admin/membership" class="text-sm text-gray-500 hover:text-gray-700 no-underline">← 멤버십 대시보드</a></div>

<section class="mb-10">
  <h2 class="font-semibold text-gray-900 mb-3">평가 실행 이력</h2>
  <div class="bg-white overflow-hidden shadow-sm rounded-lg overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50"><tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">시작</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">유형</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">상태</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">대상</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">승급</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">강등</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">유지</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">메시지</th>
      </tr></thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if (!runs || runs.length===0) { %>
        <tr><td colspan="8" class="px-6 py-8 text-center text-gray-500">평가 실행 기록이 없습니다.</td></tr>
        <% } else { runs.forEach(function(r){ %>
        <tr>
          <td class="px-4 py-3 text-sm text-gray-500"><%= new Date(r.started_at).toLocaleString('ko-KR') %></td>
          <td class="px-4 py-3 text-center text-xs"><%= r.mode %></td>
          <td class="px-4 py-3 text-center">
            <% var cls = r.status==='SUCCESS'?'bg-green-100 text-green-700':(r.status==='FAILED'?'bg-red-100 text-red-700':'bg-gray-100 text-gray-600'); %>
            <span class="px-2 py-0.5 text-xs rounded-full <%= cls %>"><%= r.status %></span>
          </td>
          <td class="px-4 py-3 text-sm text-right"><%= r.target_count %></td>
          <td class="px-4 py-3 text-sm text-right text-green-600"><%= r.upgrade_count %></td>
          <td class="px-4 py-3 text-sm text-right text-red-600"><%= r.downgrade_count %></td>
          <td class="px-4 py-3 text-sm text-right text-gray-500"><%= r.maintain_count %></td>
          <td class="px-4 py-3 text-xs text-gray-500"><%= r.message || '' %></td>
        </tr>
        <% }); } %>
      </tbody>
    </table>
  </div>
</section>

<section>
  <h2 class="font-semibold text-gray-900 mb-3">등급 변경 이력 (최근 200건)</h2>
  <div class="bg-white overflow-hidden shadow-sm rounded-lg overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50"><tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">일시</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">회원</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">변경</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">유형</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">인정금액</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">주체/사유</th>
      </tr></thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if (!history || history.length===0) { %>
        <tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">변경 이력이 없습니다.</td></tr>
        <% } else { history.forEach(function(h){ %>
        <tr>
          <td class="px-4 py-3 text-sm text-gray-500"><%= new Date(h.effective_at).toLocaleString('ko-KR') %></td>
          <td class="px-4 py-3 text-sm"><%= h.user_name || '-' %><br><span class="text-xs text-gray-400"><%= h.email %></span></td>
          <td class="px-4 py-3 text-sm text-center"><span class="text-gray-400"><%= h.from_name || '-' %></span> → <span class="font-medium"><%= h.to_name || '-' %></span></td>
          <td class="px-4 py-3 text-xs"><%= h.change_type %></td>
          <td class="px-4 py-3 text-sm text-right"><%= h.recognized_amount != null ? Number(h.recognized_amount).toLocaleString() : '-' %></td>
          <td class="px-4 py-3 text-xs text-gray-500"><%= h.changed_by %><% if (h.reason_text) { %> · <%= h.reason_text %><% } %></td>
        </tr>
        <% }); } %>
      </tbody>
    </table>
  </div>
</section>
