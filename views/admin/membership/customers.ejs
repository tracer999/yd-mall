<% if (success) { %><div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800"><%= success %></div><% } %>
<% if (error) { %><div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800"><%= error %></div><% } %>

<form method="GET" action="/admin/membership/customers" class="mb-6 p-4 bg-gray-50 rounded-lg flex flex-wrap gap-3 items-end">
  <div class="flex-1 min-w-[200px]">
    <label class="block text-xs text-gray-500 mb-1">회원 검색</label>
    <input type="text" name="q" value="<%= filters.q %>" placeholder="이름·이메일·연락처" class="w-full border rounded-lg px-3 h-[38px]">
  </div>
  <div>
    <label class="block text-xs text-gray-500 mb-1">등급</label>
    <select name="grade_id" class="border rounded-lg px-3 h-[38px]">
      <option value="">전체</option>
      <% grades.forEach(function(g){ %><option value="<%= g.id %>" <%= String(filters.grade_id)===String(g.id)?'selected':'' %>><%= g.grade_name %></option><% }); %>
    </select>
  </div>
  <div>
    <label class="inline-flex items-center gap-2 text-sm h-[38px]"><input type="checkbox" name="locked" value="1" <%= filters.locked==='1'?'checked':'' %>> 고정만</label>
  </div>
  <button type="submit" class="inline-flex items-center h-[38px] px-4 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700">검색</button>
</form>

<p class="text-sm text-gray-500 mb-3">총 <%= Number(total).toLocaleString() %>명</p>

<div class="bg-white overflow-hidden shadow-sm rounded-lg overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50"><tr>
      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">회원</th>
      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">현재 등급</th>
      <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">인정금액</th>
      <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">건수</th>
      <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">고정</th>
      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">등급 변경</th>
    </tr></thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% if (!rows || rows.length===0) { %>
      <tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">회원이 없습니다.</td></tr>
      <% } else { rows.forEach(function(r){ %>
      <tr>
        <td class="px-4 py-3 text-sm"><%= r.user_name || '-' %><br><span class="text-xs text-gray-400"><%= r.email %></span></td>
        <td class="px-4 py-3 text-sm">
          <% if (r.grade_name) { %><span class="inline-flex items-center gap-1.5"><span class="inline-block w-2 h-2 rounded-full" style="background:<%= r.color||'#9ca3af' %>"></span><%= r.grade_name %></span><% } else { %><span class="text-gray-400">미지정</span><% } %>
        </td>
        <td class="px-4 py-3 text-sm text-right"><%= Number(r.recognized_amount||0).toLocaleString() %></td>
        <td class="px-4 py-3 text-sm text-right"><%= Number(r.recognized_order_count||0) %></td>
        <td class="px-4 py-3 text-center">
          <form action="/admin/membership/customers/lock" method="POST" class="inline">
            <input type="hidden" name="user_id" value="<%= r.user_id %>">
            <input type="hidden" name="lock" value="<%= Number(r.is_locked)===1?'0':'1' %>">
            <% if (Number(r.is_locked)===1) { %>
              <button type="submit" class="px-2 py-0.5 text-xs rounded-full bg-amber-100 text-amber-700 hover:bg-amber-200" title="<%= r.lock_reason || '' %>">고정됨 · 해제</button>
            <% } else { %>
              <button type="submit" class="px-2 py-0.5 text-xs rounded-full bg-gray-100 text-gray-500 hover:bg-gray-200">고정</button>
            <% } %>
          </form>
        </td>
        <td class="px-4 py-3">
          <form action="/admin/membership/customers/change-grade" method="POST" class="flex items-center gap-1.5">
            <input type="hidden" name="user_id" value="<%= r.user_id %>">
            <select name="to_grade_id" class="border rounded px-2 h-[32px] text-sm">
              <% grades.forEach(function(g){ %><option value="<%= g.id %>" <%= Number(r.current_grade_id)===Number(g.id)?'selected':'' %>><%= g.grade_name %></option><% }); %>
            </select>
            <input type="text" name="reason_text" placeholder="사유" class="border rounded px-2 h-[32px] text-sm w-24">
            <button type="submit" class="px-3 h-[32px] text-xs rounded bg-gray-800 text-white hover:bg-gray-900">변경</button>
          </form>
        </td>
      </tr>
      <% }); } %>
    </tbody>
  </table>
</div>

<% var totalPages = Math.ceil(total/limit); if (totalPages > 1) { %>
<div class="mt-4 flex justify-center gap-1">
  <% function qs(pg){ var o = Object.assign({}, filters, {page: pg}); return '/admin/membership/customers?' + Object.keys(o).filter(function(k){return o[k]!=='';}).map(function(k){return k+'='+encodeURIComponent(o[k]);}).join('&'); } %>
  <% for (var i=1;i<=totalPages && i<=20;i++){ %>
    <a href="<%= qs(i) %>" class="px-3 py-1.5 text-sm rounded <%= i===page?'bg-blue-600 text-white':'bg-gray-100 text-gray-600 hover:bg-gray-200' %> no-underline"><%= i %></a>
  <% } %>
</div>
<% } %>
