<%
  /* 몰 관리 (P5 Phase 2) — 목록 */
  const _malls = malls || [];
%>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">몰 관리</h1>
      <p class="mt-1 text-sm text-gray-500">
        운영 중인 몰을 정의합니다. 편집 대상 몰은 우측 상단 <strong>몰 선택기</strong>로 전환합니다.
        스토어프론트는 <code>?mall=&lt;코드/id&gt;</code>로 접속합니다.
      </p>
    </div>
    <a href="/admin/malls/new"
       class="inline-flex items-center h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 no-underline">
      <i class="bi bi-plus-lg mr-1.5"></i> 몰 등록
    </a>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
            <th class="px-4 py-2.5 w-14">ID</th>
            <th class="px-4 py-2.5 w-28">코드</th>
            <th class="px-4 py-2.5">이름</th>
            <th class="px-4 py-2.5">데이터</th>
            <th class="px-4 py-2.5 w-24 text-center">기본/활성</th>
            <th class="px-4 py-2.5 w-40">스토어 링크</th>
            <th class="px-4 py-2.5 w-28 text-center">관리</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% _malls.forEach(function (m) {
               const deletable = !m.is_default && m.counts.categories === 0 && m.counts.products === 0; %>
            <tr class="<%= m.is_active ? '' : 'bg-gray-50/60' %>">
              <td class="px-4 py-3 text-gray-400"><%= m.id %></td>
              <td class="px-4 py-3"><code class="text-xs text-gray-600"><%= m.code %></code></td>
              <td class="px-4 py-3">
                <a href="/admin/malls/<%= m.id %>" class="font-medium text-gray-900 hover:text-indigo-600"><%= m.name %></a>
                <% if (m.domain) { %><div class="text-[11px] text-gray-400"><%= m.domain %></div><% } %>
              </td>
              <td class="px-4 py-3 text-gray-500 text-xs">카테고리 <%= m.counts.categories %> · 상품 <%= m.counts.products %></td>
              <td class="px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-1">
                  <% if (m.is_default) { %><span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-indigo-50 text-indigo-700">기본</span><% } %>
                  <% if (m.is_active) { %><span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-green-50 text-green-700">ON</span>
                  <% } else { %><span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-gray-200 text-gray-600">OFF</span><% } %>
                </div>
              </td>
              <td class="px-4 py-3">
                <a href="/?mall=<%= m.code %>" target="_blank" class="text-xs text-indigo-600 hover:underline">?mall=<%= m.code %> ↗</a>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1.5">
                  <a href="/admin/malls/<%= m.id %>" class="text-xs px-2 py-1 rounded border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">수정</a>
                  <% if (deletable) { %>
                    <form method="POST" action="/admin/malls/<%= m.id %>/delete" onsubmit="return confirm('몰 &quot;<%= m.name %>&quot; 을(를) 삭제합니다. 몰별 설정(내비·메뉴·테마)도 함께 지워집니다.');">
                      <button type="submit" class="text-xs px-2 py-1 rounded border border-red-200 text-red-600 hover:bg-red-50">삭제</button>
                    </form>
                  <% } else { %>
                    <span class="text-xs px-2 py-1 rounded border border-gray-100 text-gray-300 cursor-not-allowed"
                          title="<%= m.is_default ? '기본몰은 삭제 불가' : '데이터가 있어 삭제 불가' %>">삭제</span>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <p class="mt-4 text-xs text-gray-400">
    기본몰은 삭제·비활성할 수 없습니다(몰 해석기 폴백 대상). 데이터(카테고리·상품)가 있는 몰도 삭제할 수 없습니다 —
    <code>mall_id</code> 참조에 외래키가 없어 몰만 지우면 고아 데이터가 남기 때문입니다. 먼저 데이터를 비우세요.
  </p>
</div>
