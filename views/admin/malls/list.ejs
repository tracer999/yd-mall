<%
  /* 몰 관리 (P5 Phase 2 · 몰 빌더 P4) — 목록
   *
   * '선택' 버튼은 `?adminMall=<id>` 로 이 화면에 되돌아온다.
   * 전환 자체는 middleware/adminMallContext 가 처리한다(세션 adminMallId 저장) —
   * 상단 몰 선택기와 **완전히 같은 경로**다. 여기서 따로 세션을 건드리지 않는다.
   */
  const _malls = malls || [];
  const _editingId = (typeof adminMallId !== 'undefined' && adminMallId) ? Number(adminMallId) : null;
  const _editingMall = _malls.find(function (m) { return Number(m.id) === _editingId; }) || null;
%>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">몰 관리</h1>
      <p class="mt-1 text-sm text-gray-500">
        운영 중인 몰을 정의합니다. <strong>선택</strong>을 누르면 그 몰이 편집 대상이 됩니다
        (우측 상단 <strong>몰 선택기</strong>와 같은 동작).
        스토어프론트는 <code>?mall=&lt;코드/id&gt;</code>로 접속합니다.
      </p>
    </div>
    <a href="/admin/malls/new"
       class="inline-flex items-center h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 no-underline">
      <i class="bi bi-plus-lg mr-1.5"></i> 몰 등록
    </a>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
    </div>
  <% } %>
  <% if (selected && _editingMall) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-indigo-50 border border-indigo-200 text-sm text-indigo-900 flex items-start gap-2">
      <i class="bi bi-shop mt-0.5"></i>
      <span>
        이제 <strong><%= _editingMall.name %></strong> 을(를) 편집합니다.
        카테고리·상품·메뉴·테마·페이지 빌더가 모두 이 몰 기준으로 동작합니다.
        (상단 몰 선택기도 이 몰로 바뀝니다)
      </span>
    </div>
  <% } %>

  <% if (provisioned) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-start gap-2">
      <i class="bi bi-check-circle-fill mt-0.5"></i>
      <span>
        <strong><%= provisioned %></strong> 몰을 만들고 초기 구성을 채웠습니다 — GNB 메뉴 · 헤더 정책 · 테마 · 메인 화면 골격.
        이제 <strong>카테고리·상품</strong>을 등록하면 스토어가 보입니다.
      </span>
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
            <th class="px-4 py-2.5 w-14">ID</th>
            <th class="px-4 py-2.5 w-28">코드</th>
            <th class="px-4 py-2.5">이름</th>
            <th class="px-4 py-2.5">데이터</th>
            <th class="px-4 py-2.5 w-24 text-center">기본/활성</th>
            <th class="px-4 py-2.5 w-40">스토어 링크</th>
            <th class="px-4 py-2.5 w-44 text-center">관리</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% _malls.forEach(function (m) {
               /* 기본몰만 삭제 불가. 그 외는 데이터가 있어도 강제 삭제 가능(몰 빌더 성격).
                  데이터가 없으면 바로 confirm, 있으면 강제 삭제 모달로 코드 재입력을 받는다. */
               const deletable = !m.is_default;
               const hasData = m.counts.categories > 0 || m.counts.products > 0;
               const editing = Number(m.id) === _editingId;
               /* 몰 해석기(getMalls)는 활성 몰만 캐시한다 → 비활성 몰은 ?adminMall 로 선택해도 무시된다.
                  버튼을 내주면 눌러도 아무 일이 안 일어나므로 아예 잠근다. */
               const selectable = Boolean(m.is_active) && !editing; %>
            <tr class="<%= m.is_active ? '' : 'bg-gray-50/60' %> <%= editing ? 'bg-indigo-50/40' : '' %>">
              <td class="px-4 py-3 text-gray-400"><%= m.id %></td>
              <td class="px-4 py-3"><code class="text-xs text-gray-600"><%= m.code %></code></td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-1.5">
                  <a href="/admin/malls/<%= m.id %>" class="font-medium text-gray-900 hover:text-indigo-600"><%= m.name %></a>
                  <%# 헤더·GNB 스킨 (navigation_config 기준 = 실제 렌더 기준) %>
                  <% if (m.isDrawer) { %>
                    <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-purple-50 text-purple-700" title="햄버거 드로어 + 아코디언 카테고리">
                      <i class="bi bi-list mr-0.5"></i>드로어형
                    </span>
                  <% } else { %>
                    <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-sky-50 text-sky-700" title="카테고리 버튼 + 평면 GNB (3단 헤더)">기본형</span>
                  <% } %>
                  <% if (editing) { %>
                    <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-indigo-100 text-indigo-700"><i class="bi bi-pencil-fill mr-0.5"></i>편집중</span>
                  <% } %>
                </div>
                <% if (m.domain) { %><div class="text-[11px] text-gray-400"><%= m.domain %></div><% } %>
              </td>
              <td class="px-4 py-3 text-gray-500 text-xs">카테고리 <%= m.counts.categories %> · 상품 <%= m.counts.products %></td>
              <td class="px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-1">
                  <% if (m.is_default) { %><span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-indigo-50 text-indigo-700">기본</span><% } %>
                  <% if (m.is_active) { %><span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-green-50 text-green-700">ON</span>
                  <% } else { %><span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-gray-200 text-gray-600">OFF</span><% } %>
                </div>
              </td>
              <td class="px-4 py-3">
                <a href="/?mall=<%= m.code %>" target="_blank" class="text-xs text-indigo-600 hover:underline">?mall=<%= m.code %> ↗</a>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1.5">
                  <%# 편집 몰 전환 — 상단 몰 선택기와 같은 경로(?adminMall=<id> → 세션 고정) %>
                  <% if (editing) { %>
                    <span class="text-xs px-2 py-1 rounded bg-indigo-600 text-white font-semibold">편집중</span>
                  <% } else if (selectable) { %>
                    <a href="/admin/malls?adminMall=<%= m.id %>&selected=1"
                       class="text-xs px-2 py-1 rounded border border-indigo-200 text-indigo-700 hover:bg-indigo-50 no-underline font-semibold">선택</a>
                  <% } else { %>
                    <span class="text-xs px-2 py-1 rounded border border-gray-100 text-gray-300 cursor-not-allowed"
                          title="비활성 몰은 편집 대상으로 선택할 수 없습니다. 먼저 활성화하세요.">선택</span>
                  <% } %>
                  <a href="/admin/malls/<%= m.id %>" class="text-xs px-2 py-1 rounded border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">수정</a>
                  <% if (!deletable) { %>
                    <span class="text-xs px-2 py-1 rounded border border-gray-100 text-gray-300 cursor-not-allowed"
                          title="기본몰은 삭제 불가 — 다른 몰을 기본몰로 지정한 뒤 삭제하세요.">삭제</span>
                  <% } else if (!hasData) { %>
                    <%# 데이터 없는 몰: 가벼운 confirm 후 바로 삭제 %>
                    <form method="POST" action="/admin/malls/<%= m.id %>/delete" onsubmit="return confirm('몰 &quot;<%= m.name %>&quot; 을(를) 삭제합니다. 몰별 설정(내비·메뉴·테마)도 함께 지워집니다.');">
                      <button type="submit" class="text-xs px-2 py-1 rounded border border-red-200 text-red-600 hover:bg-red-50">삭제</button>
                    </form>
                  <% } else { %>
                    <%# 데이터 있는 몰: 강제 삭제 모달(코드 재입력)로 유도 %>
                    <button type="button"
                            class="js-force-del text-xs px-2 py-1 rounded border border-red-200 text-red-600 hover:bg-red-50"
                            data-mall-id="<%= m.id %>" data-mall-name="<%= m.name %>" data-mall-code="<%= m.code %>"
                            data-cats="<%= m.counts.categories %>" data-prods="<%= m.counts.products %>">삭제</button>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <p class="mt-4 text-xs text-gray-400">
    기본몰은 삭제·비활성할 수 없습니다(몰 해석기 폴백 대상). 그 외 몰은 데이터(카테고리·상품)가 있어도
    <strong>강제 삭제</strong>할 수 있습니다 — 몰을 만들고 지우고 다시 만드는 <strong>몰 빌더</strong> 작업을 위한 것입니다.
    강제 삭제는 딸린 데이터(상품·카테고리·리뷰·장바구니·메뉴·테마·페이지 등)를 함께 지우며, 되돌릴 수 없으므로 삭제 창에서 몰 코드 재입력으로 확인합니다.
  </p>
</div>

<%# ─────────── 강제 삭제 확인 모달 (데이터 있는 몰) ─────────── %>
<div id="forceDelModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
  <div class="bg-white rounded-xl shadow-xl max-w-md w-full p-6">
    <h3 class="text-lg font-bold text-red-700 flex items-center gap-2">
      <i class="bi bi-exclamation-octagon-fill"></i> 몰 강제 삭제
    </h3>
    <p class="mt-3 text-sm text-gray-700">
      <strong id="fdName" class="text-gray-900"></strong> 을(를) 삭제합니다.
      이 몰에 딸린 <strong class="text-red-600">모든 데이터가 영구 삭제</strong>됩니다:
    </p>
    <ul class="mt-2 text-sm text-gray-600 list-disc pl-5 space-y-0.5">
      <li>카테고리 <strong id="fdCats">0</strong>개 · 상품 <strong id="fdProds">0</strong>개 (딸린 리뷰·장바구니·이미지 포함)</li>
      <li>몰 전용 설정: 내비·GNB 메뉴·테마·페이지·배너·딜·이벤트·쿠폰 등</li>
    </ul>
    <p class="mt-3 text-xs text-gray-500">주문 이력은 지워지지 않고 상품 링크만 끊깁니다. <strong>되돌릴 수 없습니다.</strong></p>
    <form method="POST" id="fdForm" class="mt-4">
      <input type="hidden" name="force" value="1">
      <label class="block text-sm text-gray-700 mb-1">
        확인을 위해 몰 코드 <code class="text-red-600 font-semibold" id="fdCodeHint"></code> 를 그대로 입력하세요
      </label>
      <input type="text" name="confirm_code" id="fdCodeInput" autocomplete="off" spellcheck="false"
             class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-2 focus:ring-red-200 focus:border-red-400"
             placeholder="몰 코드 입력">
      <div class="mt-4 flex justify-end gap-2">
        <button type="button" id="fdCancel"
                class="px-4 py-2 text-sm rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50">취소</button>
        <button type="submit" id="fdSubmit" disabled
                class="px-4 py-2 text-sm rounded-md bg-red-600 text-white font-semibold hover:bg-red-700 disabled:opacity-40 disabled:cursor-not-allowed">
          강제 삭제
        </button>
      </div>
    </form>
  </div>
</div>

<script>
(function () {
  var modal = document.getElementById('forceDelModal');
  if (!modal) return;
  var form = document.getElementById('fdForm');
  var codeInput = document.getElementById('fdCodeInput');
  var submitBtn = document.getElementById('fdSubmit');
  var expectCode = '';

  function openModal(btn) {
    expectCode = (btn.getAttribute('data-mall-code') || '').toLowerCase();
    document.getElementById('fdName').textContent = btn.getAttribute('data-mall-name') || '';
    document.getElementById('fdCats').textContent = btn.getAttribute('data-cats') || '0';
    document.getElementById('fdProds').textContent = btn.getAttribute('data-prods') || '0';
    document.getElementById('fdCodeHint').textContent = btn.getAttribute('data-mall-code') || '';
    form.action = '/admin/malls/' + btn.getAttribute('data-mall-id') + '/delete';
    codeInput.value = '';
    submitBtn.disabled = true;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    codeInput.focus();
  }
  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  var buttons = document.querySelectorAll('.js-force-del');
  for (var i = 0; i < buttons.length; i++) {
    (function (b) { b.addEventListener('click', function () { openModal(b); }); })(buttons[i]);
  }
  codeInput.addEventListener('input', function () {
    submitBtn.disabled = codeInput.value.trim().toLowerCase() !== expectCode;
  });
  document.getElementById('fdCancel').addEventListener('click', closeModal);
  modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeModal(); });
})();
</script>
