<%
  /* 고객센터 FAQ 관리 — 목록 */
  const _faqs = faqs || [];
%>

<div class="w-full">

  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">고객센터 관리</h1>
      <p class="mt-1 text-sm text-gray-500">
        스토어프론트 <a href="/cs" target="_blank" class="text-indigo-600 hover:underline">고객센터</a>에 노출되는 FAQ 입니다.
        <strong>BEST</strong> 로 지정한 항목이 상단 "자주 묻는 질문"에 나옵니다.
      </p>
    </div>
    <a href="/admin/faqs/new"
       class="inline-flex items-center h-[38px] px-4 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 no-underline">
      <i class="bi bi-plus-lg mr-1.5"></i> FAQ 등록
    </a>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
    </div>
  <% } %>

  <div class="mb-5 flex flex-wrap gap-1.5">
    <a href="/admin/faqs" class="px-3 py-1.5 text-sm rounded-md no-underline <%= !selectedCategory ? 'bg-indigo-600 text-white' : 'bg-white border border-gray-200 text-gray-600 hover:bg-gray-50' %>">전체</a>
    <% categories.forEach(function (c) { %>
      <a href="/admin/faqs?category_id=<%= c.id %>"
         class="px-3 py-1.5 text-sm rounded-md no-underline <%= selectedCategory === c.id ? 'bg-indigo-600 text-white' : 'bg-white border border-gray-200 text-gray-600 hover:bg-gray-50' %>"><%= c.name %></a>
    <% }); %>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
            <th class="px-4 py-2.5 w-14">ID</th>
            <th class="px-4 py-2.5 w-32">분류</th>
            <th class="px-4 py-2.5">질문</th>
            <th class="px-4 py-2.5 w-16 text-center">순서</th>
            <th class="px-4 py-2.5 w-16 text-center">조회</th>
            <th class="px-4 py-2.5 w-24 text-center">상태</th>
            <th class="px-4 py-2.5 w-28 text-center">관리</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (!_faqs.length) { %>
            <tr><td colspan="7" class="px-6 py-16 text-center text-gray-500">등록된 FAQ 가 없습니다.</td></tr>
          <% } %>
          <% _faqs.forEach(function (f) { %>
            <tr class="<%= f.is_active ? '' : 'bg-gray-50/60' %>">
              <td class="px-4 py-3 text-gray-400"><%= f.id %></td>
              <td class="px-4 py-3 text-gray-600 text-xs"><%= f.category_name || '미분류' %></td>
              <td class="px-4 py-3">
                <a href="/admin/faqs/<%= f.id %>" class="text-gray-900 hover:text-indigo-600"><%= f.question %></a>
              </td>
              <td class="px-4 py-3 text-center text-gray-500 text-xs"><%= f.sort_order %></td>
              <td class="px-4 py-3 text-center text-gray-500 text-xs"><%= f.view_count %></td>
              <td class="px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-1">
                  <% if (f.is_best) { %><span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-amber-50 text-amber-700">BEST</span><% } %>
                  <% if (f.is_active) { %>
                    <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-green-50 text-green-700">ON</span>
                  <% } else { %>
                    <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-gray-200 text-gray-600">OFF</span>
                  <% } %>
                </div>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1.5">
                  <a href="/admin/faqs/<%= f.id %>" class="text-xs px-2 py-1 rounded border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">수정</a>
                  <form method="POST" action="/admin/faqs/<%= f.id %>/delete"
                        onsubmit="return confirm('이 FAQ 를 삭제합니다.');">
                    <button type="submit" class="text-xs px-2 py-1 rounded border border-red-200 text-red-600 hover:bg-red-50">삭제</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
