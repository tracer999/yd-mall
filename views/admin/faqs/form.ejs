<%
  /*
   * FAQ 등록/수정
   *
   * answer 는 HTML 이다. 저장 시 서버가 htmlSanitizer.sanitize() 를 걸고,
   * 렌더 시 csController 가 한 번 더 건다(이중 방어).
   */
  const isNew = !faq.id;
  const action = isNew ? '/admin/faqs' : `/admin/faqs/${faq.id}`;
%>

<div class="w-full">

  <div class="mb-6">
    <a href="/admin/faqs" class="text-sm text-gray-500 hover:text-gray-700 no-underline">
      <i class="bi bi-chevron-left"></i> 고객센터 관리
    </a>
    <h1 class="mt-2 text-2xl font-bold text-gray-900"><%= title %></h1>
  </div>

  <form method="POST" action="<%= action %>" class="space-y-6">

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="p-5 space-y-5">

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1.5">분류</label>
            <select name="category_id" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
              <option value="">미분류</option>
              <% categories.forEach(function (c) { %>
                <option value="<%= c.id %>" <%= Number(faq.category_id) === c.id ? 'selected' : '' %>><%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">노출 순서</label>
            <input type="number" name="sort_order" value="<%= faq.sort_order %>" min="0" max="9999"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">질문</label>
          <input type="text" name="question" value="<%= faq.question %>" maxlength="255" required
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">답변</label>
          <textarea id="editor" name="answer" rows="12"
                    class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm"><%= faq.answer %></textarea>
          <p class="mt-1 text-xs text-gray-400">
            허용되지 않는 태그·속성(스크립트, 이벤트 핸들러 등)은 저장 시 자동으로 제거됩니다.
          </p>
        </div>

        <div class="flex flex-wrap gap-5">
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="is_active" value="1" <%= faq.is_active ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300">
            노출
          </label>
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="is_best" value="1" <%= faq.is_best ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300">
            자주 묻는 질문(BEST) 에 노출
          </label>
        </div>

      </div>
    </div>

    <div class="flex justify-end gap-2">
      <a href="/admin/faqs" class="inline-flex items-center h-[38px] px-4 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">취소</a>
      <button type="submit" class="inline-flex items-center h-[38px] px-5 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
        <i class="bi bi-save mr-1.5"></i> 저장
      </button>
    </div>
  </form>
</div>

<% if (tinymceKey) { %>
<script src="https://cdn.tiny.cloud/1/<%= tinymceKey %>/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
<script>
  tinymce.init({
    selector: '#editor',
    height: 400,
    menubar: false,
    plugins: 'lists link table code',
    toolbar: 'undo redo | bold italic underline | bullist numlist | link table | code',
    branding: false,
  });
</script>
<% } %>
