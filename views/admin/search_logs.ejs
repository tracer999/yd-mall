<div class="bg-white rounded-lg shadow-sm">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
        <div>
            <h1 class="text-lg font-semibold text-gray-800">검색 로그</h1>
            <p class="mt-1 text-sm text-gray-500">사용자들이 어떤 검색어로 상품을 검색했는지 확인할 수 있습니다.</p>
        </div>
        <a href="/admin" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">
            ← 대시보드로 돌아가기
        </a>
    </div>
    <div class="px-6 py-4 border-b border-gray-100 bg-white flex items-center justify-between gap-4">
        <form method="get" class="flex flex-wrap items-center gap-2 text-xs text-gray-600">
            <span class="font-medium mr-1">기간 필터</span>
            <input type="date" name="start_date" value="<%= filters && filters.startDate ? filters.startDate : '' %>" />
            <span class="mx-1">~</span>
            <input type="date" name="end_date" value="<%= filters && filters.endDate ? filters.endDate : '' %>" />
            <button type="submit"
                class="ml-2 inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700">
                적용
            </button>
            <a href="/admin/search-logs" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-100 no-underline text-gray-500 hover:text-gray-700">
                전체보기
            </a>
        </form>
        <% if (filters && (filters.startDate || filters.endDate)) { %>
            <div class="text-xs text-gray-500">
                현재 필터:
                <% if (filters.startDate) { %>
                    <span class="ml-1">시작 <span class="font-medium"><%= filters.startDate %></span></span>
                <% } %>
                <% if (filters.endDate) { %>
                    <span class="ml-1">종료 <span class="font-medium"><%= filters.endDate %></span></span>
                <% } %>
            </div>
        <% } %>
    </div>
    <div class="px-6 py-4 overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">검색일시</th>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">사용자</th>
                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">검색어</th>
                    <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">결과 개수</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                <% if (logs && logs.length > 0) { %>
                    <% logs.forEach(log => { %>
                        <tr class="hover:bg-gray-50">
                            <td class="px-3 py-2 whitespace-nowrap text-gray-700"><%= log.id %></td>
                            <td class="px-3 py-2 whitespace-nowrap text-gray-700">
                                <%= log.created_at.toISOString().replace('T',' ').substring(0, 19) %>
                            </td>
                            <td class="px-3 py-2 whitespace-nowrap text-gray-700">
                                <% if (log.user_email) { %>
                                    <span class="font-medium"><%= log.user_name || '이름 없음' %></span>
                                    <span class="text-gray-500 text-xs ml-1">(<%= log.user_email %>)</span>
                                <% } else { %>
                                    <span class="text-gray-500 text-xs">비회원</span>
                                <% } %>
                            </td>
                            <td class="px-3 py-2 text-gray-800 max-w-xs truncate" title="<%= log.keyword %>"><%= log.keyword %></td>
                            <td class="px-3 py-2 text-right whitespace-nowrap">
                                <% if (log.result_count === 0) { %>
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600">
                                        0 건
                                    </span>
                                <% } else { %>
                                    <span class="text-gray-800"><%= log.result_count %> 건</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="px-3 py-6 text-center text-gray-500 text-sm">검색 로그가 없습니다.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        <div class="mt-4 flex items-center justify-between text-xs text-gray-600">
            <div>
                총 <span class="font-semibold"><%= pagination.totalCount %></span>건 / 페이지 <span class="font-semibold"><%= pagination.page %></span> / <span class="font-semibold"><%= pagination.totalPages %></span>
            </div>
            <div class="inline-flex space-x-1">
                <% if (pagination.page > 1) { %>
                    <a href="?page=<%= pagination.page - 1 %><% if (filters && filters.startDate) { %>&start_date=<%= filters.startDate %><% } %><% if (filters && filters.endDate) { %>&end_date=<%= filters.endDate %><% } %>" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">이전</a>
                <% } else { %>
                    <span class="px-3 py-1 border border-gray-200 rounded-md text-gray-300 cursor-default">이전</span>
                <% } %>

                <% if (pagination.page < pagination.totalPages) { %>
                    <a href="?page=<%= pagination.page + 1 %><% if (filters && filters.startDate) { %>&start_date=<%= filters.startDate %><% } %><% if (filters && filters.endDate) { %>&end_date=<%= filters.endDate %><% } %>" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">다음</a>
                <% } else { %>
                    <span class="px-3 py-1 border border-gray-200 rounded-md text-gray-300 cursor-default">다음</span>
                <% } %>
            </div>
        </div>
    </div>
</div>
