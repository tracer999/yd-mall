<p class="text-sm text-gray-500 mb-6">메인 페이지의 베스트 상품, 신상품, 카테고리별 섹션의 진열 방식과 노출 상품을 관리합니다.</p>

<% sections.forEach(section => {
    const label = sectionLabels[section.section_key] || section.section_key;
    const isCategory = section.section_key === 'category';
    const isManual = section.display_mode === 'manual';
    const products = sectionProducts[section.section_key] || [];
%>
<div class="bg-white shadow-sm rounded-lg mb-6 overflow-hidden">
    <!-- 섹션 헤더 -->
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
        <form method="POST" action="/admin/display/section/update" class="flex flex-col sm:flex-row sm:items-center gap-3">
            <input type="hidden" name="section_key" value="<%= section.section_key %>">

            <h3 class="text-base font-bold text-gray-900 mr-auto"><%= label %></h3>

            <div class="flex items-center gap-3 flex-wrap">
                <% if (!isCategory) { %>
                <label class="text-sm text-gray-600 font-medium">진열방식</label>
                <select name="display_mode" class="border border-gray-300 rounded-md text-sm px-3 py-1.5 focus:ring-blue-500 focus:border-blue-500">
                    <option value="auto" <%= section.display_mode === 'auto' ? 'selected' : '' %>>자동</option>
                    <option value="manual" <%= section.display_mode === 'manual' ? 'selected' : '' %>>수동</option>
                </select>
                <% } else { %>
                <input type="hidden" name="display_mode" value="auto">
                <% } %>

                <label class="text-sm text-gray-600 font-medium">노출수</label>
                <select name="max_count" class="border border-gray-300 rounded-md text-sm px-3 py-1.5 focus:ring-blue-500 focus:border-blue-500">
                    <% [4,6,8,10,12,16,20].forEach(n => { %>
                    <option value="<%= n %>" <%= section.max_count === n ? 'selected' : '' %>><%= n %>개</option>
                    <% }); %>
                </select>

                <button type="submit"
                    class="inline-flex items-center px-4 py-1.5 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition">
                    저장
                </button>
            </div>
        </form>
    </div>

    <!-- 섹션 본문 -->
    <div class="p-6">
        <% if (isCategory) { %>
            <p class="text-sm text-gray-500">
                <i class="bi bi-info-circle mr-1"></i>
                상품이 1개 이상인 카테고리를 탭으로 자동 노출합니다. 카테고리별 최대 <strong><%= section.max_count %></strong>개 상품이 표시됩니다.
            </p>
        <% } else if (!isManual) { %>
            <p class="text-sm text-gray-500">
                <i class="bi bi-info-circle mr-1"></i>
                <strong><%= section.section_key === 'best' ? 'BEST' : 'NEW' %></strong> 뱃지가 지정된 상품을 최신순으로 최대 <strong><%= section.max_count %></strong>개 자동 노출합니다.
            </p>
        <% } else { %>
            <!-- 수동 모드: 상품 검색 + 리스트 -->
            <div class="mb-4">
                <div class="relative">
                    <input type="text" id="search-<%= section.section_key %>" placeholder="상품명으로 검색..."
                        class="w-full sm:w-96 border border-gray-300 rounded-md text-sm px-4 py-2 focus:ring-blue-500 focus:border-blue-500"
                        autocomplete="off">
                    <div id="search-results-<%= section.section_key %>"
                        class="hidden absolute z-30 left-0 right-0 sm:right-auto sm:w-96 mt-1 bg-white border border-gray-200 rounded-lg shadow-lg max-h-60 overflow-y-auto">
                    </div>
                </div>
            </div>

            <% if (products.length === 0) { %>
                <p class="text-sm text-gray-400 py-4 text-center border border-dashed border-gray-200 rounded-lg">
                    수동 진열 상품이 없습니다. 위 검색창에서 상품을 추가해주세요.
                </p>
            <% } else { %>
                <div id="product-list-<%= section.section_key %>" class="space-y-2">
                    <% products.forEach((p, idx) => { %>
                    <div class="flex items-center gap-3 bg-gray-50 border border-gray-200 rounded-lg px-4 py-3" data-id="<%= p.display_id %>">
                        <span class="text-sm font-bold text-gray-400 w-6 text-center"><%= idx + 1 %></span>
                        <img src="<%= p.main_image || '/images/placeholder.png' %>" class="w-10 h-10 object-contain rounded border border-gray-100" alt="">
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-900 truncate"><%= p.name %></p>
                            <p class="text-xs text-gray-500"><%= Number(p.price).toLocaleString() %>원
                                <% if (p.product_badge) { %>
                                <span class="ml-1 px-1.5 py-0.5 rounded text-[10px] font-bold
                                    <%= p.product_badge === 'BEST' ? 'bg-red-100 text-red-700' : p.product_badge === 'NEW' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                                    <%= p.product_badge %></span>
                                <% } %>
                            </p>
                        </div>
                        <div class="flex items-center gap-1">
                            <button type="button" onclick="moveProduct('<%= section.section_key %>', this, -1)"
                                class="p-1.5 text-gray-400 hover:text-gray-700 hover:bg-gray-200 rounded transition" title="위로">
                                <i class="bi bi-chevron-up"></i>
                            </button>
                            <button type="button" onclick="moveProduct('<%= section.section_key %>', this, 1)"
                                class="p-1.5 text-gray-400 hover:text-gray-700 hover:bg-gray-200 rounded transition" title="아래로">
                                <i class="bi bi-chevron-down"></i>
                            </button>
                            <form method="POST" action="/admin/display/products/remove" class="inline"
                                onsubmit="return confirm('이 상품을 진열 목록에서 제거하시겠습니까?')">
                                <input type="hidden" name="display_id" value="<%= p.display_id %>">
                                <button type="submit" class="p-1.5 text-red-400 hover:text-red-600 hover:bg-red-50 rounded transition" title="삭제">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                    <% }); %>
                </div>
            <% } %>
        <% } %>
    </div>
</div>
<% }); %>

<script>
// 상품 검색 (디바운스)
document.querySelectorAll('[id^="search-"]').forEach(input => {
    const sectionKey = input.id.replace('search-', '');
    const resultsEl = document.getElementById('search-results-' + sectionKey);
    let timer;

    input.addEventListener('input', () => {
        clearTimeout(timer);
        const q = input.value.trim();
        if (q.length < 1) { resultsEl.classList.add('hidden'); return; }
        timer = setTimeout(async () => {
            try {
                const resp = await fetch('/admin/display/products/search?q=' + encodeURIComponent(q) + '&section_key=' + sectionKey);
                const data = await resp.json();
                if (!data.products || data.products.length === 0) {
                    resultsEl.innerHTML = '<p class="px-4 py-3 text-sm text-gray-400">검색 결과가 없습니다.</p>';
                } else {
                    resultsEl.innerHTML = data.products.map(p => `
                        <form method="POST" action="/admin/display/products/add" class="block">
                            <input type="hidden" name="section_key" value="${sectionKey}">
                            <input type="hidden" name="product_id" value="${p.id}">
                            <button type="submit" class="w-full flex items-center gap-3 px-4 py-2.5 hover:bg-blue-50 text-left transition">
                                <img src="${p.main_image || '/images/placeholder.png'}" class="w-8 h-8 object-contain rounded border border-gray-100" alt="">
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-gray-900 truncate">${p.name}</p>
                                    <p class="text-xs text-gray-500">${Number(p.price).toLocaleString()}원</p>
                                </div>
                                <span class="text-xs text-blue-600 font-medium flex-shrink-0">추가</span>
                            </button>
                        </form>
                    `).join('');
                }
                resultsEl.classList.remove('hidden');
            } catch (e) { console.error(e); }
        }, 300);
    });

    input.addEventListener('blur', () => {
        setTimeout(() => resultsEl.classList.add('hidden'), 200);
    });
    input.addEventListener('focus', () => {
        if (resultsEl.innerHTML.trim()) resultsEl.classList.remove('hidden');
    });
});

// 순서 이동
function moveProduct(sectionKey, btn, dir) {
    const list = document.getElementById('product-list-' + sectionKey);
    if (!list) return;
    const item = btn.closest('[data-id]');
    const items = Array.from(list.children);
    const idx = items.indexOf(item);
    const targetIdx = idx + dir;
    if (targetIdx < 0 || targetIdx >= items.length) return;

    if (dir === -1) list.insertBefore(item, items[targetIdx]);
    else list.insertBefore(items[targetIdx], item);

    // 번호 갱신
    Array.from(list.children).forEach((el, i) => {
        const numEl = el.querySelector('span');
        if (numEl) numEl.textContent = i + 1;
    });

    // 서버 저장
    const order = Array.from(list.children).map(el => parseInt(el.dataset.id));
    fetch('/admin/display/products/reorder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ section_key: sectionKey, order })
    }).catch(err => console.error(err));
}
</script>
