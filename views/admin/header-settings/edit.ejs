<%
  /*
   * Header 설정 (B5) — navigation_config
   *
   * 실제 렌더에 영향을 주는 값은 max_gnb_items · max_custom_items · category_max_depth 셋이다.
   * 나머지(검색창 노출)는 컬럼만 있고 렌더가 아직 소비하지 않으므로 잠근다.
   */
  const _layouts = headerLayoutTypes || [];
%>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Header 설정</h1>
    <p class="mt-1 text-sm text-gray-500">
      스토어프론트 상단 헤더의 <strong>레이아웃과 메뉴 슬롯 정책</strong>을 관리합니다.
      개별 메뉴의 ON/OFF 는 <a href="/admin/feature-menus" class="text-indigo-600 hover:underline">일반 메뉴 관리</a> ·
      <a href="/admin/system-menus" class="text-indigo-600 hover:underline">시스템 메뉴 설정</a>에서 조정합니다.
    </p>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다. 스토어프론트에 즉시 반영됩니다.
    </div>
  <% } %>

  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i>
      <span><%= error %></span>
    </div>
  <% } %>

  <form method="POST" action="/admin/header-settings" class="space-y-6">

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">레이아웃</h2>
      </div>
      <div class="p-5 space-y-5">

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">헤더 레이아웃</label>
          <select name="header_layout_type" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
            <% _layouts.forEach(function (o) { %>
              <option value="<%= o.value %>" <%= config.header_layout_type === o.value ? 'selected' : '' %>
                      <%= o.supported ? '' : 'disabled' %>>
                <%= o.label %><%= o.supported ? '' : ' — 미지원' %>
              </option>
            <% }); %>
          </select>
          <p class="mt-1 text-xs text-gray-400">현재 제공되는 레이아웃은 1종입니다.</p>
        </div>

      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">메뉴 슬롯</h2>
        <p class="mt-0.5 text-xs text-gray-500">GNB 는 [카테고리 버튼] + [기능 메뉴] + [커스텀 메뉴] 순으로 채워지고, 총량을 넘으면 뒤에서 잘립니다.</p>
      </div>
      <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-5">

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">GNB 최대 노출 수</label>
          <input type="number" name="max_gnb_items" value="<%= config.max_gnb_items %>"
                 min="<%= limits.max_gnb_items.min %>" max="<%= limits.max_gnb_items.max %>"
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          <p class="mt-1 text-xs text-gray-400">카테고리 버튼 제외. <%= limits.max_gnb_items.min %>~<%= limits.max_gnb_items.max %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">커스텀 메뉴 슬롯</label>
          <input type="number" name="max_custom_items" value="<%= config.max_custom_items %>"
                 min="<%= limits.max_custom_items.min %>" max="<%= limits.max_custom_items.max %>"
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          <p class="mt-1 text-xs text-gray-400">GNB 총량에 포함됩니다. 총량보다 크면 총량으로 맞춰집니다.</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">카테고리 최대 뎁스</label>
          <input type="number" name="category_max_depth" value="<%= config.category_max_depth %>"
                 min="<%= limits.category_max_depth.min %>" max="<%= limits.category_max_depth.max %>"
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          <p class="mt-1 text-xs text-gray-400">
            현재 데이터의 최대 뎁스는 <strong><%= maxCategoryDepth %></strong> 입니다.
            이보다 낮추면 하위 카테고리가 숨겨지므로 저장이 거부됩니다.
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">검색창</label>
          <label class="inline-flex items-center gap-2 h-[38px] text-sm text-gray-600">
            <input type="checkbox" name="use_search_bar" value="1" <%= config.use_search_bar ? 'checked' : '' %>
                   class="w-4 h-4 rounded border-gray-300">
            헤더에 검색창 사용
          </label>
          <p class="mt-1 text-xs text-gray-400">
            현재 검색창 노출은 시스템 메뉴의 <code>HEADER_SEARCH</code> 로 제어됩니다(필수 메뉴).
          </p>
        </div>

      </div>
    </div>

    <div class="flex justify-end gap-2">
      <a href="/admin/header-settings" class="inline-flex items-center h-[38px] px-4 text-sm font-medium rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">
        되돌리기
      </a>
      <button type="submit" class="inline-flex items-center h-[38px] px-5 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
        <i class="bi bi-save mr-1.5"></i> 저장
      </button>
    </div>
  </form>
</div>
