<%
  /*
   * 메뉴 미리보기 (B7)
   *
   * navigationService.getNavigation() 의 결과를 그대로 그린다 — 스토어프론트와 같은 데이터.
   * PC/모바일 필터는 서버가 아니라 여기(뷰)에서 한다. 실제 헤더와 같은 방식.
   */
  const isMobile = opts.device === 'mobile';
  const visible = (m) => isMobile ? Number(m.mobileVisible) : Number(m.pcVisible);
  const q = (device, login) => `/admin/menu-preview?device=${device}&login=${login}`;

  const gnbShown = (nav.gnb || []).filter(visible);
  const utilShown = (nav.headerUtil || []).filter(visible);
  const railShown = (nav.rightRail || []).filter(visible);

  /*
   * GNB 조립 방식(navigation_config.nav_mode). 미리보기는 조립을 재구현하지 않으므로
   * getNavigation 이 알아서 분기해 준다 — 여기서는 **모형의 모양만** 두 가지로 나눈다.
   *   split   카테고리 버튼 + 평면 메뉴
   *   unified 카테고리 1뎁스가 GNB 항목이 되고 하위 뎁스가 children 으로 달린다
   */
  const isUnified = nav.config.nav_mode === 'unified';
  const catCount = Number(nav.gnbCategoryCount) || 0;

  function renderTree(nodes, depth) {
    let html = '';
    (nodes || []).forEach(function (n) {
      const vis = isMobile ? n.mobile_visible : n.pc_visible;
      if (!vis) return;
      html += `<li class="py-0.5" style="padding-left:${depth * 14}px">`
           +  `<span class="text-gray-700">${depth ? '└ ' : ''}${escapeHtml(n.name)}</span>`
           +  `<code class="ml-1.5 text-[10px] text-gray-300">d${n.depth}</code></li>`;
      if (n.children && n.children.length) html += renderTree(n.children, depth + 1);
    });
    return html;
  }
  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
  }
%>

<div class="w-full">

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">메뉴 미리보기</h1>
    <p class="mt-1 text-sm text-gray-500">
      스토어프론트와 <strong>같은 조립 로직</strong>(<code>navigationService.getNavigation</code>)으로 뽑은 결과입니다.
      설정 변경은 <a href="/admin/feature-menus" class="text-indigo-600 hover:underline">일반 메뉴 관리</a> ·
      <a href="/admin/system-menus" class="text-indigo-600 hover:underline">시스템 메뉴 설정</a> ·
      <a href="/admin/header-settings" class="text-indigo-600 hover:underline">Header 설정</a>에서 합니다.
    </p>
  </div>

  <%# ── 조건 토글 ───────────────────────────────── %>
  <div class="mb-6 flex flex-wrap items-center gap-2">
    <div class="inline-flex rounded-md border border-gray-200 overflow-hidden">
      <a href="<%= q('pc', opts.isLoggedIn ? 1 : 0) %>"
         class="px-3 py-1.5 text-sm no-underline <%= !isMobile ? 'bg-indigo-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">
        <i class="bi bi-display mr-1"></i> PC
      </a>
      <a href="<%= q('mobile', opts.isLoggedIn ? 1 : 0) %>"
         class="px-3 py-1.5 text-sm no-underline <%= isMobile ? 'bg-indigo-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">
        <i class="bi bi-phone mr-1"></i> 모바일
      </a>
    </div>
    <div class="inline-flex rounded-md border border-gray-200 overflow-hidden">
      <a href="<%= q(opts.device, 0) %>"
         class="px-3 py-1.5 text-sm no-underline <%= !opts.isLoggedIn ? 'bg-gray-700 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">비로그인</a>
      <a href="<%= q(opts.device, 1) %>"
         class="px-3 py-1.5 text-sm no-underline <%= opts.isLoggedIn ? 'bg-gray-700 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">로그인</a>
    </div>
  </div>

  <%# ── 헤더 모형 ───────────────────────────────── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-6">
    <div class="px-5 py-4 border-b border-gray-100 bg-gray-50 flex items-center justify-between">
      <h2 class="text-base font-bold text-gray-800">
        헤더
        <span class="ml-1.5 align-middle text-[10px] font-bold px-1.5 py-0.5 rounded <%= isUnified ? 'bg-emerald-100 text-emerald-700' : 'bg-gray-200 text-gray-600' %>">
          <%= isUnified ? '드로어형 · 통합 메뉴' : '기본형 · 카테고리 분리' %>
        </span>
      </h2>
      <span class="text-xs text-gray-400">
        GNB <%= gnbShown.length %>개 노출 / 상한 <%= maxGnb %><% if (isUnified && catCount) { %> (카테고리 <%= catCount %>개 포함)<% } %>
      </span>
    </div>

    <div class="p-5">
      <div class="rounded-lg border border-dashed border-gray-300 <%= isMobile ? 'max-w-sm' : '' %> mx-auto">
        <div class="px-4 py-3 flex items-center justify-between gap-4 border-b border-gray-100">
          <span class="font-bold text-gray-900">로고</span>
          <div class="flex items-center gap-2 flex-wrap justify-end">
            <% utilShown.forEach(function (m) { %>
              <span class="text-xs px-2 py-1 rounded bg-gray-100 text-gray-700" title="<%= m.path || '(client)' %>"><%= m.name %></span>
            <% }); %>
            <% if (!utilShown.length) { %><span class="text-xs text-gray-300">헤더 유틸 없음</span><% } %>
          </div>
        </div>

        <div class="px-4 py-3 flex items-center gap-2 flex-wrap">
          <% if (nav.categoryButton) { %>
            <span class="text-sm font-semibold px-2.5 py-1 rounded bg-indigo-600 text-white">
              <i class="bi bi-list mr-1"></i><%= nav.categoryButton.name %>
            </span>
          <% } %>
          <%# unified 에선 카테고리도 GNB 항목이다(kind='category'). 색으로 구분하고 하위 뎁스 수를 함께 보여준다. %>
          <% gnbShown.forEach(function (m) { %>
            <% const isCat = m.kind === 'category'; %>
            <% const kids = (m.children || []).filter(visible).length; %>
            <span class="text-sm px-2.5 py-1 rounded <%= isCat ? 'bg-emerald-50 text-emerald-700'
                                                        : (m.isCustom ? 'bg-purple-50 text-purple-700' : 'text-gray-700 hover:bg-gray-50') %>"
                  title="<%= m.path %>">
              <%= m.name %>
              <% if (kids) { %><i class="bi bi-chevron-down text-[9px] ml-0.5"></i><span class="text-[10px] text-emerald-500 ml-0.5">하위 <%= kids %></span><% } %>
              <% if (m.badgeType) { %><sup class="text-[9px] font-bold text-red-500 ml-0.5"><%= m.badgeType %></sup><% } %>
              <% if (m.isCustom) { %><sup class="text-[9px] text-purple-400 ml-0.5">커스텀</sup><% } %>
            </span>
          <% }); %>
          <% if (!gnbShown.length) { %><span class="text-xs text-gray-300">GNB 없음</span><% } %>
        </div>
      </div>

      <%#
        절단 경고. unified 는 규칙이 다르다 — 카테고리는 자르지 않고(자르면 스토어가 반토막 난다)
        남는 슬롯만큼만 기능/커스텀 메뉴를 남긴다. 그래서 "무엇이 잘렸는지"의 문구가 갈린다.
      %>
      <% if (gnbTruncated > 0) { %>
        <p class="mt-3 text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded px-3 py-2">
          <i class="bi bi-scissors mr-1"></i>
          <% if (isUnified) { %>
            일반 메뉴가 상한(<%= maxGnb %>)을 넘어 <strong><%= gnbTruncated %>개</strong>가 잘렸습니다.
            (카테고리는 통합 메뉴의 본체라 절단 대상이 아닙니다 — 상한에 포함되지 않습니다.)
            Header 설정에서 상한을 올리거나 아래 목록에서 일부를 끄세요.
          <% } else { %>
            GNB 상한(<%= maxGnb %>)을 넘어 <strong><%= gnbTruncated %>개</strong>가 잘렸습니다.
            Header 설정에서 상한을 올리거나 일반 메뉴 관리에서 일부를 끄세요.
          <% } %>
        </p>
      <% } %>
      <% if (isUnified) { %>
        <p class="mt-3 text-xs text-gray-400">
          통합형(<code>unified</code>)은 카테고리 1뎁스와 일반 메뉴가 <strong>하나의 순서 축</strong>에 놓입니다.
          PC 는 한 줄 GNB(하위 뎁스는 마우스 오버 드롭다운), 모바일은 좌측 드로어에 <strong>같은 순서</strong>로 담깁니다.
          순서·노출은 아래 <strong>GNB 구성</strong>에서 정합니다.
        </p>
      <% } %>
      <% if (isMobile) { %>
        <p class="mt-3 text-xs text-gray-400">모바일에서는 <code>mobile_visible</code> 이 켜진 항목만 표시됩니다. 우측 유틸 레일은 노출되지 않습니다.</p>
      <% } %>
    </div>
  </div>

  <%#
    ── GNB 구성 ────────────────────────────────
    unified — 카테고리 1뎁스 + 일반 메뉴가 하나의 순서 축을 공유한다.
    split   — 일반 메뉴만. 카테고리는 별도 패널이라 GNB 순서와 무관하므로 목록에 없다.
    행 순서(=DOM 순서)가 곧 저장 순서다. order[] 히든 인풋이 그 순서대로 전송된다.
    저장은 원본 테이블을 고치므로 카테고리 관리·일반 메뉴 관리와 값이 그대로 연동된다.
  %>
  <% if (gnbItems.length) { %>
    <form method="post" action="/admin/menu-preview/gnb" class="mb-6 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <input type="hidden" name="device" value="<%= opts.device %>">
      <input type="hidden" name="login" value="<%= opts.isLoggedIn ? 1 : 0 %>">

      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50 flex items-center justify-between gap-4">
        <div>
          <h2 class="text-base font-bold text-gray-800">GNB 구성
            <span class="text-gray-400 font-normal"><%= isUnified ? '(카테고리 + 일반 메뉴 통합)' : '(일반 메뉴 — 카테고리는 별도 패널)' %></span>
          </h2>
          <p class="mt-0.5 text-xs text-gray-500">
            행을 끌어 순서를 바꾸고, 기기별 노출을 켜고 끕니다. 저장하면 스토어프론트와
            <%= isUnified ? '카테고리 관리·일반 메뉴 관리' : '일반 메뉴 관리' %> 화면에 그대로 반영됩니다.
          </p>
        </div>
        <div class="flex items-center gap-2">
          <% if (saved) { %><span class="text-xs text-emerald-600"><i class="bi bi-check2-circle mr-1"></i>저장됨</span><% } %>
          <button type="submit" class="px-4 py-2 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">저장</button>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
              <th class="px-4 py-2.5 w-10"></th>
              <th class="px-4 py-2.5 w-12">순서</th>
              <th class="px-4 py-2.5">항목</th>
              <th class="px-4 py-2.5 w-24">종류</th>
              <th class="px-4 py-2.5 w-16 text-center">사용</th>
              <th class="px-4 py-2.5 w-16 text-center">PC</th>
              <th class="px-4 py-2.5 w-20 text-center">모바일</th>
            </tr>
          </thead>
          <tbody id="gnb-rows" class="divide-y divide-gray-100">
            <% if (!gnbItems.length) { %>
              <tr><td colspan="7" class="px-6 py-10 text-center text-gray-500">GNB 항목이 없습니다.</td></tr>
            <% } %>
            <% gnbItems.forEach(function (it) { %>
              <tr draggable="true" class="gnb-row bg-white cursor-move hover:bg-gray-50">
                <td class="px-4 py-2.5 text-gray-300"><i class="bi bi-grip-vertical"></i></td>
                <td class="px-4 py-2.5 text-xs text-gray-400 gnb-seq"></td>
                <td class="px-4 py-2.5">
                  <input type="hidden" name="order[]" value="<%= it.key %>">
                  <span class="text-gray-900"><%= it.name %></span>
                  <% if (it.kind === 'category') { %>
                    <code class="ml-1.5 text-[10px] text-gray-400">1뎁스 · 하위 자동</code>
                  <% } %>
                </td>
                <td class="px-4 py-2.5">
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded
                    <%= it.kind === 'category' ? 'bg-emerald-50 text-emerald-700'
                       : it.kind === 'custom' ? 'bg-purple-50 text-purple-700' : 'bg-gray-100 text-gray-600' %>">
                    <%= it.kind === 'category' ? '카테고리' : (it.kind === 'custom' ? '커스텀' : '기능') %>
                  </span>
                </td>
                <td class="px-4 py-2.5 text-center">
                  <% if (it.canDisable) { %>
                    <input type="checkbox" name="enabled[<%= it.key %>]" value="1" <%= it.isEnabled ? 'checked' : '' %>>
                  <% } else { %>
                    <%# 카테고리의 is_active 는 여기서 끄지 않는다 — GNB 밖(상품 목록 등)까지 죽는다. %>
                    <span class="text-[10px] text-gray-300" title="카테고리 관리에서 비활성화">항상</span>
                  <% } %>
                </td>
                <td class="px-4 py-2.5 text-center">
                  <input type="checkbox" name="pc[<%= it.key %>]" value="1" <%= it.pcVisible ? 'checked' : '' %>>
                </td>
                <td class="px-4 py-2.5 text-center">
                  <input type="checkbox" name="mo[<%= it.key %>]" value="1" <%= it.mobileVisible ? 'checked' : '' %>>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-500">
        <% if (!isUnified) { %>
          기본형(<code>split</code>)은 카테고리가 GNB 최좌측 <strong>버튼 하나</strong>에 매달린 별도 패널이라, 카테고리 항목은 이 목록에 없습니다.
          카테고리 순서·노출은 <a href="/admin/categories" class="text-indigo-600 hover:underline">카테고리 관리</a>에서 정합니다.<br>
        <% } %>
        카테고리 자체(이름·활성·하위 뎁스)는 <a href="/admin/categories" class="text-indigo-600 hover:underline">카테고리 관리</a>,
        메뉴 추가·링크는 <a href="/admin/feature-menus" class="text-indigo-600 hover:underline">일반 메뉴 관리</a> ·
        <a href="/admin/custom-menus" class="text-indigo-600 hover:underline">커스텀 메뉴</a>에서 합니다.
      </div>
    </form>

    <script>
      (function () {
        var tbody = document.getElementById('gnb-rows');
        if (!tbody) return;
        var dragged = null;

        function renumber() {
          Array.prototype.forEach.call(tbody.querySelectorAll('.gnb-row'), function (row, i) {
            var cell = row.querySelector('.gnb-seq');
            if (cell) cell.textContent = String(i + 1);
          });
        }

        tbody.addEventListener('dragstart', function (e) {
          dragged = e.target.closest('.gnb-row');
          if (dragged) dragged.classList.add('opacity-40');
        });
        tbody.addEventListener('dragend', function () {
          if (dragged) dragged.classList.remove('opacity-40');
          dragged = null;
          renumber();
        });
        tbody.addEventListener('dragover', function (e) {
          e.preventDefault(); // 이걸 막지 않으면 drop 이 발생하지 않는다
          var over = e.target.closest('.gnb-row');
          if (!over || !dragged || over === dragged) return;
          var rect = over.getBoundingClientRect();
          var after = (e.clientY - rect.top) > rect.height / 2;
          tbody.insertBefore(dragged, after ? over.nextSibling : over);
        });

        renumber();
      })();
    </script>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <%# ── 카테고리 트리 ─────────────────────────── %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">카테고리 드롭다운</h2>
        <p class="mt-0.5 text-xs text-gray-500">
          NORMAL · 활성 · 최대 <%= nav.config.category_max_depth %>뎁스
        </p>
      </div>
      <div class="p-5">
        <% if (!nav.categoryTree.length) { %>
          <p class="py-6 text-center text-sm text-gray-500">노출할 카테고리가 없습니다.</p>
        <% } else { %>
          <ul class="text-sm"><%- renderTree(nav.categoryTree, 0) %></ul>
        <% } %>
      </div>
    </div>

    <%# ── 우측 레일 ─────────────────────────────── %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">우측 유틸 레일</h2>
        <p class="mt-0.5 text-xs text-gray-500">넓은 화면(≥1600px)에서만 노출됩니다.</p>
      </div>
      <div class="p-5">
        <% if (!railShown.length) { %>
          <p class="py-6 text-center text-sm text-gray-500">노출할 항목이 없습니다.</p>
        <% } else { %>
          <div class="flex flex-col items-end gap-1.5">
            <% railShown.forEach(function (m) { %>
              <span class="text-xs px-2.5 py-1.5 rounded border border-gray-200 text-gray-700" title="<%= m.path || '(client)' %>"><%= m.name %></span>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <%# ── 제외된 항목과 사유 ─────────────────────── %>
  <div class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
      <h2 class="text-base font-bold text-gray-800">노출되지 않는 메뉴 <span class="text-gray-400 font-normal">(<%= excluded.length %>개)</span></h2>
      <p class="mt-0.5 text-xs text-gray-500">왜 안 보이는지 확인하세요. 현재 조건: <strong><%= opts.isLoggedIn ? '로그인' : '비로그인' %></strong></p>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
            <th class="px-4 py-2.5 w-40">위치</th>
            <th class="px-4 py-2.5">메뉴</th>
            <th class="px-4 py-2.5">사유</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (!excluded.length) { %>
            <tr><td colspan="3" class="px-6 py-10 text-center text-gray-500">모든 메뉴가 노출되고 있습니다.</td></tr>
          <% } %>
          <% excluded.forEach(function (m) { %>
            <tr>
              <td class="px-4 py-2.5 text-gray-500 text-xs"><%= m.positionLabel %></td>
              <td class="px-4 py-2.5">
                <span class="text-gray-900"><%= m.name %></span>
                <code class="ml-1.5 text-[10px] text-gray-400"><%= m.feature_code %></code>
              </td>
              <td class="px-4 py-2.5">
                <span class="text-xs px-2 py-0.5 rounded <%= m.module_ready ? 'bg-gray-100 text-gray-600' : 'bg-amber-50 text-amber-800' %>"><%= m.reason %></span>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
