<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= title %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= subtitle %></p>
  </div>

  <% if (msg) { %>
    <div class="mb-4 rounded-md bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800"><%= msg %></div>
  <% } %>
  <% if (error) { %>
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800"><%= error %></div>
  <% } %>

  <!-- ============ 1. 네이버 수집 카테고리 리소스 ============ -->
  <section class="mb-8">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-lg font-semibold text-gray-900">
        <i class="bi bi-diagram-3 text-emerald-600 mr-1"></i> 네이버 카테고리 리소스
      </h2>
      <form method="post" action="/admin/resources/naver/refresh">
        <button type="submit"
          class="inline-flex items-center gap-1.5 rounded-md bg-emerald-600 px-3.5 py-2 text-sm font-medium text-white hover:bg-emerald-700">
          <i class="bi bi-arrow-repeat"></i> 지금 업데이트
        </button>
      </form>
    </div>

    <% var nc = naverStatus && naverStatus.counts ? naverStatus.counts : {}; %>
    <% if (naverStatus && !naverStatus.hasActiveCredential) { %>
      <div class="mb-3 rounded-md bg-amber-50 border border-amber-200 px-4 py-2.5 text-xs text-amber-800">
        <i class="bi bi-exclamation-triangle mr-1"></i>
        ACTIVE 네이버 자격증명이 없어 [지금 업데이트]가 건너뜁니다.
        <a href="/admin/sourcing/connections" class="underline font-medium">공급처/채널 연결</a>에서 등록·검증하세요.
      </div>
    <% } %>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="bg-white shadow-sm rounded-lg p-4">
        <div class="text-xs text-gray-500">전체 적재</div>
        <div class="mt-1 text-2xl font-bold text-gray-900"><%= Number(nc.total || 0).toLocaleString() %></div>
      </div>
      <div class="bg-white shadow-sm rounded-lg p-4">
        <div class="text-xs text-gray-500">활성</div>
        <div class="mt-1 text-2xl font-bold text-gray-900"><%= Number(nc.active_total || 0).toLocaleString() %></div>
      </div>
      <div class="bg-white shadow-sm rounded-lg p-4">
        <div class="text-xs text-gray-500">활성 리프(선택가능)</div>
        <div class="mt-1 text-2xl font-bold text-emerald-700"><%= Number(nc.active_leaf || 0).toLocaleString() %></div>
      </div>
      <div class="bg-white shadow-sm rounded-lg p-4">
        <div class="text-xs text-gray-500">마지막 수집</div>
        <div class="mt-1 text-sm font-medium text-gray-700">
          <%= nc.last_fetched_at ? new Date(nc.last_fetched_at).toLocaleString('ko-KR') : '없음' %>
        </div>
      </div>
    </div>

    <!-- 리프 검색 브라우징 -->
    <div class="mt-4 bg-white shadow-sm rounded-lg p-4">
      <div class="relative" id="res-naver-widget">
        <input type="text" id="res_naver_search" autocomplete="off"
          class="w-full text-sm"
          placeholder="🔎 네이버 카테고리 검색 (예: 홍삼, 마스크팩)">
        <div id="res_naver_results"
          class="hidden absolute z-20 mt-1 w-full max-h-72 overflow-auto bg-white border rounded-md shadow-lg text-sm"></div>
      </div>
      <p class="text-[11px] text-gray-400 mt-1">활성 리프 카테고리를 검색합니다. 이 리소스는 상품 등록 시 참고용이며 몰 카테고리에 자동 반영되지 않습니다.</p>
    </div>

    <p class="mt-2 text-xs text-gray-400">
      상세 현황·자동 수집 주기는
      <a href="/admin/sourcing/naver-taxonomy" class="underline">외부몰 연동 · 네이버 카테고리 리소스</a>에서 설정합니다.
    </p>
  </section>

  <!-- ============ 2. 네이버 수집 브랜드 리소스 ============ -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">
      <i class="bi bi-tags text-indigo-600 mr-1"></i> 네이버 브랜드 리소스
    </h2>
    <div class="bg-white shadow-sm rounded-lg p-4 flex items-center gap-6">
      <div>
        <div class="text-xs text-gray-500">활성 브랜드</div>
        <div class="mt-1 text-2xl font-bold text-gray-900"><%= Number(naverBrandCount || 0).toLocaleString() %></div>
      </div>
      <p class="text-xs text-gray-500">
        브랜드는 카탈로그 API 구조 확정 후 수집 예정인 <b>골격</b> 단계입니다. (현재 0건일 수 있습니다)
      </p>
    </div>
  </section>

  <!-- ============ 3. 샘플 상품 ============ -->
  <section>
    <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
      <h2 class="text-lg font-semibold text-gray-900">
        <i class="bi bi-box-seam text-amber-600 mr-1"></i> 샘플 상품
        <span class="ml-1 text-sm font-normal text-gray-400">(<%= Number(sampleTotal || 0).toLocaleString() %>건 중 최근 <%= sampleLimit %>건)</span>
      </h2>
      <form method="get" action="/admin/resources" class="flex items-center gap-2 text-sm">
        <label class="text-gray-500">몰</label>
        <select name="mall" class="border rounded px-2 py-1 text-sm" onchange="this.form.submit()">
          <% (malls || []).forEach(function(m){ %>
            <option value="<%= m.id %>" <%= Number(m.id) === Number(selectedMallId) ? 'selected' : '' %>>
              <%= m.name %><%= m.is_default ? ' (기본몰)' : '' %>
            </option>
          <% }) %>
        </select>
      </form>
    </div>

    <% if (!sampleProducts || !sampleProducts.length) { %>
      <div class="bg-white shadow-sm rounded-lg p-10 text-center text-sm text-gray-400">이 몰에 상품이 없습니다.</div>
    <% } else { %>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        <% sampleProducts.forEach(function(p){ var img = p.thumbnail_image || p.main_image; %>
          <a href="/admin/products/edit/<%= p.id %>"
             class="block bg-white shadow-sm rounded-lg overflow-hidden hover:shadow-md transition">
            <div class="aspect-square bg-gray-100 flex items-center justify-center overflow-hidden">
              <% if (img) { %>
                <img src="<%= img %>" alt="" class="w-full h-full object-cover" loading="lazy">
              <% } else { %>
                <i class="bi bi-image text-3xl text-gray-300"></i>
              <% } %>
            </div>
            <div class="p-3">
              <div class="text-xs text-gray-400 truncate"><%= p.category_name || '미분류' %></div>
              <div class="mt-0.5 text-sm font-medium text-gray-800 line-clamp-2"><%= p.name %></div>
              <div class="mt-1 text-sm font-semibold text-gray-900"><%= Number(p.price || 0).toLocaleString() %>원</div>
            </div>
          </a>
        <% }) %>
      </div>
      <p class="mt-3 text-xs text-gray-400">
        전체 상품은 <a href="/admin/products" class="underline">상품 관리</a>에서 확인·편집합니다.
      </p>
    <% } %>
  </section>
</div>

<!-- 네이버 리프 카테고리 검색 -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var search = document.getElementById('res_naver_search');
    var results = document.getElementById('res_naver_results');
    if (!search || !results) return;
    var timer = null;

    function hide() { results.classList.add('hidden'); results.innerHTML = ''; }

    function render(list) {
      if (!list || !list.length) {
        results.innerHTML = '<div class="px-3 py-2 text-gray-400">검색 결과가 없습니다.</div>';
        results.classList.remove('hidden');
        return;
      }
      results.innerHTML = '';
      list.forEach(function (item) {
        var row = document.createElement('div');
        row.className = 'px-3 py-2 border-b last:border-0';
        var path = document.createElement('div');
        path.className = 'text-gray-700';
        path.textContent = item.whole_category_name || item.name;
        var idline = document.createElement('div');
        idline.className = 'text-[11px] text-gray-400';
        idline.textContent = 'ID ' + item.naver_category_id;
        row.appendChild(path); row.appendChild(idline);
        results.appendChild(row);
      });
      results.classList.remove('hidden');
    }

    function run() {
      var q = search.value.trim();
      if (q.length < 1) { hide(); return; }
      fetch('/admin/resources/naver/search?q=' + encodeURIComponent(q) + '&limit=30', { headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.ok ? r.json() : { success: false }; })
        .then(function (j) { render(j && j.success ? j.data : []); })
        .catch(function () { hide(); });
    }

    search.addEventListener('input', function () { clearTimeout(timer); timer = setTimeout(run, 250); });
    document.addEventListener('click', function (e) {
      var w = document.getElementById('res-naver-widget');
      if (w && !w.contains(e.target)) hide();
    });
  });
</script>
