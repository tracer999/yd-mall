<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <p class="text-sm text-gray-500">포인트 지급·차감 내역을 확인하고 정산합니다.</p>
    <div class="flex flex-wrap gap-2 w-full sm:w-auto justify-start sm:justify-end">
        <a href="/admin/points/grant"
            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 bg-green-600 text-white hover:bg-green-700 no-underline uppercase tracking-widest">
            포인트 지급
        </a>
        <a href="/admin/points/deduct"
            class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 bg-red-600 text-white hover:bg-red-700 no-underline uppercase tracking-widest">
            포인트 차감
        </a>
    </div>
</div>

<% if (success) { %>
<div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800"><%= success %></div>
<% } %>
<% if (error) { %>
<div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800"><%= error %></div>
<% } %>

<form method="GET" action="/admin/points" class="mb-6 p-4 bg-gray-50 rounded-lg flex flex-wrap gap-4 items-end">
    <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">시작일</label>
        <input type="date" name="from" value="<%= filters && filters.from ? filters.from : '' %>">
    </div>
    <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">종료일</label>
        <input type="date" name="to" value="<%= filters && filters.to ? filters.to : '' %>">
    </div>
    <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-600 mb-1">회원 검색 (이름, 전화번호, 생년월일)</label>
        <input type="text" name="q" value="<%= filters && filters.q ? filters.q : '' %>"
            placeholder="예: 홍길동, 010-1234, 1981-09-09">
    </div>
    <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">거래유형</label>
        <select name="transaction_type">
            <option value="">전체</option>
            <option value="PURCHASE_ACCUMULATE" <%= filters && filters.transaction_type === 'PURCHASE_ACCUMULATE' ? 'selected' : '' %>>구매적립</option>
            <option value="PURCHASE_USE" <%= filters && filters.transaction_type === 'PURCHASE_USE' ? 'selected' : '' %>>구매사용</option>
            <option value="ADMIN_GRANT" <%= filters && filters.transaction_type === 'ADMIN_GRANT' ? 'selected' : '' %>>관리자지급</option>
            <option value="ADMIN_DEDUCT" <%= filters && filters.transaction_type === 'ADMIN_DEDUCT' ? 'selected' : '' %>>관리자차감</option>
        </select>
    </div>
    <button type="submit" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700">검색</button>
</form>

<div class="bg-white overflow-hidden shadow-sm rounded-lg overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">일시</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">회원</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">금액</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">유형</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">사유</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">보유잔액</th>
            </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
            <% if (!transactions || transactions.length === 0) { %>
            <tr>
                <td colspan="6" class="px-6 py-8 text-center text-gray-500">내역이 없습니다.</td>
            </tr>
            <% } else { %>
            <% transactions.forEach(function(t) { %>
            <tr>
                <td class="px-6 py-4 text-sm text-gray-500"><%= t.created_at ? new Date(t.created_at).toLocaleString('ko-KR') : '-' %></td>
                <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                    <div class="flex-shrink-0">
                        <% if (t.picture) { %>
                        <img src="<%= t.picture %>" alt="프로필" class="h-8 w-8 rounded-full object-cover border border-gray-200">
                        <% } else if (t.google_id) { %>
                        <div class="h-8 w-8 rounded-full bg-red-50 flex items-center justify-center text-red-600">
                            <i class="bi bi-google text-sm"></i>
                        </div>
                        <% } else if (t.kakao_id) { %>
                        <div class="h-8 w-8 rounded-full bg-yellow-100 flex items-center justify-center text-yellow-700">
                            <i class="bi bi-chat-dots-fill text-sm"></i>
                        </div>
                        <% } else { %>
                        <div class="h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center text-xs text-gray-500">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <% } %>
                    </div>
                    <div>
                        <div class="flex items-center gap-2">
                            <div class="text-sm font-medium text-gray-900"><%= t.user_name || t.email || '-' %></div>
                            <% if (t.google_id) { %>
                            <span class="inline-flex items-center px-1.5 py-0.5 rounded-full bg-red-50 text-[10px] font-semibold text-red-600 border border-red-100">Google</span>
                            <% } else if (t.kakao_id) { %>
                            <span class="inline-flex items-center px-1.5 py-0.5 rounded-full bg-yellow-100 text-[10px] font-semibold text-yellow-800 border border-yellow-200">Kakao</span>
                            <% } %>
                        </div>
                        <div class="text-xs text-gray-500"><%= t.phone || '-' %></div>
                    </div>
                </div>
            </td>
                <td class="px-6 py-4 text-sm font-medium <%= t.amount >= 0 ? 'text-green-600' : 'text-red-600' %>">
                    <%= t.amount >= 0 ? '+' : '' %><%= Number(t.amount).toLocaleString() %>P
                </td>
                <td class="px-6 py-4 text-sm text-gray-500">
                    <%= t.transaction_type === 'PURCHASE_ACCUMULATE' ? '구매적립' : t.transaction_type === 'PURCHASE_USE' ? '구매사용' : t.transaction_type === 'ADMIN_GRANT' ? '관리자지급' : '관리자차감' %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= t.description || '-' %></td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= Number(t.points_balance || 0).toLocaleString() %>P</td>
            </tr>
            <% }); %>
            <% } %>
        </tbody>
    </table>
</div>
