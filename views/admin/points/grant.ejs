<div class="flex justify-center">
    <div class="w-full">
        <div class="mb-6">
            <a href="/admin/points" class="text-sm text-gray-500 hover:text-gray-700 mb-2 inline-block">← 포인트 관리</a>
        </div>

        <% if (success) { %>
        <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800"><%= success %></div>
        <% } %>
        <% if (error) { %>
        <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800"><%= error %></div>
        <% } %>

        <% if (grantResult) { %>
        <div class="mb-6 bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-800">포인트 지급 결과</h3>
            </div>
            <div class="p-6 space-y-6">
                <% if (grantResult.granted && grantResult.granted.length) { %>
                <div>
                    <h4 class="text-sm font-medium text-green-700 mb-2">✓ 지급 완료 (<%= grantResult.granted.length %>명)</h4>
                    <ul class="text-sm text-gray-700 space-y-1">
                        <% grantResult.granted.forEach(function(item) { %>
                        <li>ID <%= item.id %> · <%= item.user && item.user.name ? item.user.name : '-' %> · <%= item.user && item.user.phone ? item.user.phone : '-' %> — <%= Number(item.amount).toLocaleString() %>P</li>
                        <% }); %>
                    </ul>
                </div>
                <% } %>
            </div>
        </div>
        <% } %>

        <div class="bg-white shadow-sm rounded-xl border border-gray-200">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="text-lg font-semibold text-gray-800">포인트 지급</h3>
                <p class="text-sm text-gray-500 mt-1">선택한 회원들에게 동일한 포인트를 일괄 지급합니다.</p>
            </div>
            <form action="/admin/points/grant" method="POST" class="p-6 space-y-5">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">지급 포인트 <span class="text-red-500">*</span></label>
                    <input type="text" name="amount" min="1" required data-number-format="thousands"
                        class="text-right"
                        placeholder="지급할 포인트">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">사유 (선택)</label>
                    <input type="text" name="description" placeholder="예: 이벤트 보상">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">회원 선택 <span class="text-red-500">*</span></label>
                    <div id="user_ids_hiddenWrap" class="hidden"></div>
                    <div class="flex flex-wrap gap-2 items-center">
                        <button type="button" id="openUserSearchBtn" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-100">
                            <i class="bi bi-search mr-2"></i>회원 검색
                        </button>
                        <span id="selectedUserDisplay" class="text-sm text-gray-600 hidden"></span>
                    </div>
                </div>

                <div class="flex justify-end gap-2 pt-2">
                    <a href="/admin/points" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">취소</a>
                    <button type="submit" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 bg-green-600 text-white hover:bg-green-700">지급하기</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
(function() {
    document.querySelector('form').addEventListener('submit', function(e) {
        var ids = document.querySelectorAll('input[name="user_ids[]"]');
        if (!ids || ids.length === 0) {
            e.preventDefault();
            alert('회원을 검색하여 선택해 주세요.');
        }
    });
})();
document.getElementById('openUserSearchBtn')?.addEventListener('click', function() {
    if (typeof openUserSearchModal === 'function') openUserSearchModal();
});
</script>

<div id="pointGrantUserModal" class="fixed inset-0 z-[100] hidden" aria-hidden="true" data-user-search-modal data-modal-id="pointGrantUserModal" data-input-name="user_ids" data-display-el-id="selectedUserDisplay" data-hidden-wrap-id="user_ids_hiddenWrap" data-multi-select="true">
  <input type="hidden" id="pointGrantUserModal-selectedJson" value="">
  <div class="fixed inset-0 bg-gray-500/60 backdrop-blur-sm modal-overlay" data-modal-close="pointGrantUserModal"></div>
  <div class="fixed inset-0 flex items-center justify-center p-4 pointer-events-none">
    <div class="bg-white rounded-xl shadow-xl max-h-[90vh] w-full max-w-2xl pointer-events-auto flex flex-col" role="dialog" aria-modal="true" aria-labelledby="pointGrantUserModal-title">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h3 id="pointGrantUserModal-title" class="text-lg font-semibold text-gray-800">회원 검색</h3>
        <button type="button" class="p-2 text-gray-400 hover:text-gray-600 rounded-lg hover:bg-gray-100" data-modal-close="pointGrantUserModal" aria-label="닫기">
          <i class="bi bi-x-lg text-lg"></i>
        </button>
      </div>
      <div class="p-6 flex flex-col gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">이메일, 이름, 연락처, 생년월일 검색 (예: 1981-08-10)</label>
          <div class="flex gap-2">
            <input type="text" id="pointGrantUserModal-searchInput" placeholder="검색어 입력" class="flex-1 min-w-0 rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-4 py-2.5">
            <button type="button" id="pointGrantUserModal-searchBtn" class="flex-shrink-0 inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700">검색</button>
          </div>
        </div>
        <div id="pointGrantUserModal-results" class="border border-gray-200 rounded-lg overflow-hidden max-h-80 overflow-y-auto">
          <p class="text-sm text-gray-500 p-4 text-center" id="pointGrantUserModal-emptyMsg">검색어를 입력하고 검색하세요.</p>
          <ul id="pointGrantUserModal-resultList" class="divide-y divide-gray-100 hidden"></ul>
        </div>
        <div id="pointGrantUserModal-confirmArea" class="hidden pt-2 border-t border-gray-200">
          <button type="button" class="w-full inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 bg-blue-600 text-white hover:bg-blue-700" onclick="document.getElementById('pointGrantUserModal').dispatchEvent(new CustomEvent('confirm-multi-select'))">선택 완료</button>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/user-search-modal.js"></script>
