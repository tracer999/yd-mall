<div class="flex justify-center">
    <div class="w-full lg:max-w-2xl">
        <div class="mb-6">
            <a href="/admin/points" class="text-sm text-gray-500 hover:text-gray-700 mb-2 inline-block">← 포인트 관리</a>
        </div>

        <% if (error) { %>
        <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800"><%= error %></div>
        <% } %>

        <form action="/admin/points/deduct" method="POST" class="bg-white shadow-sm rounded-xl border border-gray-200 p-6 space-y-5">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">회원 선택 <span class="text-red-500">*</span></label>
                <select name="user_id" required>
                    <option value="">회원 선택</option>
                    <% if (users && users.length) { %>
                    <% users.forEach(function(u) { %>
                    <option value="<%= u.id %>"><%= u.email %> (<%= u.name || '-' %>, 현재 <%= Number(u.points_balance || 0).toLocaleString() %>P)</option>
                    <% }); %>
                    <% } %>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">차감 포인트 <span class="text-red-500">*</span></label>
                <input type="number" name="amount" min="1" required placeholder="차감할 포인트">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">사유 (선택)</label>
                <input type="text" name="description" placeholder="예: 부정 사용 적발">
            </div>
            <div class="flex gap-2 pt-2">
                <button type="submit" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 bg-red-600 text-white hover:bg-red-700">차감하기</button>
                <a href="/admin/points" class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 no-underline">취소</a>
            </div>
        </form>
    </div>
</div>
