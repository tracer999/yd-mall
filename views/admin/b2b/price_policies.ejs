<%
const won = n => Number(n || 0).toLocaleString('ko-KR');
const dd = v => (v ? new Date(v).toLocaleDateString('ko-KR') : '제한 없음');
const tabs = [['','전체'],['CUSTOMER_CONTRACT','거래처 계약가'],['TIER','등급가']];
const inputCls = 'mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500';
%>

<% if (message) { %><div class="mb-4 rounded-md bg-green-50 border border-green-200 p-3 text-sm text-green-800"><%= message %></div><% } %>
<% if (error) { %><div class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800"><%= error %></div><% } %>

<div class="mb-6 rounded-lg border border-blue-200 bg-blue-50 p-4 text-sm text-blue-900">
  <p class="font-semibold mb-1">가격은 위에서부터 먼저 잡히는 층이 이깁니다 (더 싼 값을 고르는 게 아닙니다).</p>
  <ol class="list-decimal list-inside space-y-0.5 text-blue-800">
    <li>확정 견적가 <span class="text-xs text-blue-600">— 견적 관리</span></li>
    <li><strong>거래처 계약가</strong> <span class="text-xs text-blue-600">— 이 화면</span></li>
    <li><strong>등급가</strong> <span class="text-xs text-blue-600">— 이 화면</span></li>
    <li>수량 구간가 <span class="text-xs text-blue-600">— 상품 [B2B 판매]</span></li>
    <li>기본 B2B가 <span class="text-xs text-blue-600">— 상품 [B2B 판매]</span></li>
  </ol>
  <p class="mt-2 text-xs text-blue-700">어느 층이든 <strong>판매가보다 비싼 단가는 적용되지 않습니다.</strong></p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
    <div class="mb-4 flex flex-wrap gap-1">
      <% tabs.forEach(function(t) { %>
        <a href="/admin/b2b/price-policies<%= t[0] ? '?type=' + t[0] : '' %>"
           class="px-3 py-1.5 text-sm rounded-md no-underline <%= type === t[0] ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100' %>"><%= t[1] %></a>
      <% }); %>
    </div>

    <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100">
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-gray-500">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 border-b border-gray-100">
            <tr>
              <th class="px-6 py-3">정책명</th>
              <th class="px-6 py-3">유형 / 대상</th>
              <th class="px-6 py-3 text-center">품목</th>
              <th class="px-6 py-3">적용 기간</th>
              <th class="px-6 py-3">상태</th>
              <th class="px-6 py-3 text-right">관리</th>
            </tr>
          </thead>
          <tbody>
            <% if (rows.length > 0) { %>
              <% rows.forEach(function(r) { %>
                <tr class="bg-white border-b border-gray-100 hover:bg-gray-50">
                  <td class="px-6 py-4 font-medium text-gray-900">
                    <a href="/admin/b2b/price-policies/<%= r.id %>" class="text-blue-700 hover:underline no-underline"><%= r.name %></a>
                    <% if (r.priority) { %><p class="text-xs text-gray-400 font-normal">우선순위 <%= r.priority %></p><% } %>
                  </td>
                  <td class="px-6 py-4">
                    <span class="text-xs px-2 py-0.5 rounded border <%= r.policy_type === 'CUSTOMER_CONTRACT' ? 'bg-purple-100 text-purple-800 border-purple-400' : 'bg-indigo-100 text-indigo-800 border-indigo-400' %>">
                      <%= TYPE_LABEL[r.policy_type] %>
                    </span>
                    <p class="text-xs text-gray-500 mt-1">
                      <%= r.policy_type === 'TIER' ? (r.tier_name || '등급 미지정') : (r.company_count + '개 거래처 배정') %>
                    </p>
                  </td>
                  <td class="px-6 py-4 text-center"><%= r.item_count %></td>
                  <td class="px-6 py-4 text-xs"><%= dd(r.valid_from) %> ~ <%= dd(r.valid_to) %></td>
                  <td class="px-6 py-4">
                    <% if (r.status === 'ACTIVE') { %>
                      <span class="text-xs px-2 py-0.5 rounded border bg-green-100 text-green-800 border-green-400">사용</span>
                    <% } else { %>
                      <span class="text-xs px-2 py-0.5 rounded border bg-gray-100 text-gray-600 border-gray-400">미사용</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <div class="flex justify-end gap-2">
                      <a href="/admin/b2b/price-policies/<%= r.id %>"
                         class="inline-flex items-center justify-center h-[34px] px-3 text-sm font-medium rounded-md border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">단가 관리</a>
                      <form action="/admin/b2b/price-policies/delete" method="POST" onsubmit="return confirm('정책과 등록된 단가가 모두 삭제됩니다. 진행할까요?');">
                        <input type="hidden" name="id" value="<%= r.id %>">
                        <button type="submit" class="h-[34px] px-3 text-sm font-medium rounded-md border border-red-200 bg-red-50 text-red-700 hover:bg-red-100">삭제</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr><td colspan="6" class="px-6 py-12 text-center text-gray-400">
                등록된 가격 정책이 없습니다. 오른쪽에서 만들어 주세요.<br>
                <span class="text-xs">정책이 없어도 기본 전용가·수량 구간가는 정상 동작합니다.</span>
              </td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">정책 추가</h3>
      <form action="/admin/b2b/price-policies/save" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">정책명 <span class="text-red-500">*</span></label>
          <input type="text" name="name" required placeholder="A거래처 2026 계약가" class="<%= inputCls %>">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">유형 <span class="text-red-500">*</span></label>
          <select name="policy_type" id="policyType" onchange="document.getElementById('tierRow').style.display = this.value === 'TIER' ? '' : 'none';" class="<%= inputCls %>">
            <option value="CUSTOMER_CONTRACT">거래처 계약가 — 특정 거래처에만</option>
            <option value="TIER">등급가 — 해당 등급 전체에</option>
          </select>
        </div>
        <div id="tierRow" style="display:none">
          <label class="block text-sm font-medium text-gray-700">적용 등급</label>
          <select name="tier_id" class="<%= inputCls %>">
            <option value="">선택하세요</option>
            <% tiers.forEach(function(t) { %><option value="<%= t.id %>"><%= t.tier_name %></option><% }); %>
          </select>
          <% if (tiers.length === 0) { %>
            <p class="mt-1 text-xs text-amber-700">등록된 등급이 없습니다. <a href="/admin/b2b/tiers" class="underline">등급 만들기</a></p>
          <% } %>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700">적용 시작</label>
            <input type="date" name="valid_from" class="<%= inputCls %>">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">적용 종료</label>
            <input type="date" name="valid_to" class="<%= inputCls %>">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">우선순위</label>
          <input type="number" name="priority" value="0" class="<%= inputCls %>">
          <p class="mt-1 text-xs text-gray-500">같은 층에 정책이 겹치면 큰 값이 이깁니다.</p>
        </div>
        <button type="submit" class="w-full h-[38px] text-sm font-semibold rounded-md bg-blue-600 text-white hover:bg-blue-700">만들기</button>
        <p class="text-xs text-gray-500">만든 뒤 상세 화면에서 상품별 단가를 등록합니다.</p>
      </form>
    </div>
  </div>
</div>
