<%
const tabs = [
  { key: '', label: '전체' },
  { key: 'REQUESTED', label: '접수' },
  { key: 'UNDER_REVIEW', label: '검토 중' },
  { key: 'AWAIT_DEPOSIT', label: '입금 대기' },
  { key: 'PAID', label: '입금확인' },
  { key: 'SHIPPED', label: '출고' },
  { key: 'CANCELLED', label: '취소/반려' },
];
const tone = {
  amber: 'bg-amber-100 text-amber-800 border-amber-400',
  blue: 'bg-blue-100 text-blue-800 border-blue-400',
  green: 'bg-green-100 text-green-800 border-green-400',
  gray: 'bg-gray-100 text-gray-700 border-gray-400',
};
const won = n => Number(n || 0).toLocaleString('ko-KR');
const qs = o => {
  const p = new URLSearchParams();
  const st = o.stage !== undefined ? o.stage : stage;
  if (st) p.set('stage', st);
  if (keyword) p.set('q', keyword);
  if (o.page && o.page > 1) p.set('page', o.page);
  const s = p.toString();
  return '/admin/b2b/orders' + (s ? '?' + s : '');
};
const totalPages = Math.max(1, Math.ceil(total / pageSize));
%>

<% if (message) { %><div class="mb-4 rounded-md bg-green-50 border border-green-200 p-3 text-sm text-green-800"><%= message %></div><% } %>
<% if (error) { %><div class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800"><%= error %></div><% } %>

<% if (overdue.length > 0) { %>
  <div class="mb-6 rounded-xl border-2 border-red-200 bg-red-50 p-4">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-sm font-bold text-red-900">입금 기한이 지난 주문 <%= overdue.length %>건이 재고를 잡고 있습니다.</p>
        <p class="text-xs text-red-800 mt-1">
          승인 시점에 재고를 차감하므로, 회수하지 않으면 그 수량은 계속 판매할 수 없습니다.
        </p>
      </div>
    </div>
    <form action="/admin/b2b/orders/cancel-overdue" method="POST" class="mt-3"
          onsubmit="return confirm('선택한 주문을 취소하고 재고를 되돌립니다. 진행할까요?');">
      <div class="bg-white rounded-lg border border-red-200 divide-y divide-red-100 mb-3">
        <% overdue.forEach(function(o) { %>
          <label class="flex items-center gap-3 px-3 py-2 text-sm cursor-pointer">
            <input type="checkbox" name="order_ids" value="<%= o.id %>" checked class="rounded border-gray-300">
            <span class="font-medium text-gray-900"><%= o.order_number %></span>
            <span class="text-gray-600"><%= o.company_name %></span>
            <span class="text-gray-500"><%= won(o.total_amount) %>원</span>
            <span class="ml-auto text-red-700 font-medium"><%= o.overdue_days %>일 초과</span>
          </label>
        <% }); %>
      </div>
      <button type="submit" class="h-[38px] px-4 text-sm font-medium rounded-md bg-red-600 text-white hover:bg-red-700">
        선택 주문 취소 · 재고 회수
      </button>
    </form>
  </div>
<% } %>

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
  <div class="flex flex-wrap gap-1">
    <% tabs.forEach(function(t) { %>
      <a href="<%= qs({ stage: t.key }) %>"
         class="px-3 py-1.5 text-sm rounded-md no-underline transition-colors <%= stage === t.key ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100' %>">
        <%= t.label %><% if (stageCounts[t.key]) { %> <span class="ml-1 text-xs opacity-80">(<%= stageCounts[t.key] %>)</span><% } %>
      </a>
    <% }); %>
  </div>
  <form action="/admin/b2b/orders" method="GET" class="flex gap-2 w-full sm:w-auto">
    <% if (stage) { %><input type="hidden" name="stage" value="<%= stage %>"><% } %>
    <input type="text" name="q" value="<%= keyword %>" placeholder="주문번호·상호·발주번호"
           class="h-[38px] px-3 text-sm border border-gray-300 rounded-md w-full sm:w-64">
    <button type="submit" class="h-[38px] px-4 text-sm font-medium rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">검색</button>
  </form>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100">
  <div class="overflow-x-auto">
    <table class="w-full text-sm text-left text-gray-500">
      <thead class="text-xs text-gray-700 uppercase bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="px-6 py-3">주문번호</th>
          <th class="px-6 py-3">거래처</th>
          <th class="px-6 py-3 text-right">공급가/부가세</th>
          <th class="px-6 py-3 text-right">주문금액</th>
          <th class="px-6 py-3">단계</th>
          <th class="px-6 py-3">입금기한</th>
          <th class="px-6 py-3">계산서</th>
          <th class="px-6 py-3 text-right">관리</th>
        </tr>
      </thead>
      <tbody>
        <% if (rows.length > 0) { %>
          <% rows.forEach(function(r) { %>
            <tr class="bg-white border-b border-gray-100 hover:bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">
                <%= r.order_number %>
                <% if (r.purchase_order_number) { %><p class="text-xs text-gray-400 font-normal">PO: <%= r.purchase_order_number %></p><% } %>
              </td>
              <td class="px-6 py-4"><%= r.company_name %></td>
              <td class="px-6 py-4 text-right text-xs">
                <%= won(r.supply_amount) %> / <%= won(r.vat_amount) %>
              </td>
              <td class="px-6 py-4 text-right font-semibold text-gray-900"><%= won(r.total_amount) %>원</td>
              <td class="px-6 py-4">
                <span class="text-xs font-medium px-2.5 py-0.5 rounded border <%= tone[r.stage.tone] %>"><%= r.stage.label %></span>
              </td>
              <td class="px-6 py-4 text-xs">
                <% if (r.payment_due_at && r.payment_status === 'PENDING' && r.status !== 'CANCELLED') { %>
                  <span class="<%= new Date(r.payment_due_at) < new Date() ? 'text-red-600 font-semibold' : '' %>">
                    <%= new Date(r.payment_due_at).toLocaleDateString('ko-KR') %>
                  </span>
                <% } else { %>-<% } %>
              </td>
              <td class="px-6 py-4 text-xs">
                <%= { NOT_ISSUED:'미발행', REQUESTED:'요청', ISSUED:'발행', CANCELLED:'취소' }[r.tax_invoice_status] %>
              </td>
              <td class="px-6 py-4 text-right">
                <a href="/admin/b2b/orders/<%= r.id %>"
                   class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">상세</a>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="8" class="px-6 py-12 text-center text-gray-400">
            <%= keyword || stage ? '조건에 맞는 주문이 없습니다.' : 'B2B 주문이 아직 없습니다.' %>
          </td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPages > 1) { %>
  <div class="mt-4 flex justify-center gap-1">
    <% for (let i = 1; i <= totalPages; i++) { %>
      <a href="<%= qs({ page: i }) %>" class="px-3 py-1.5 text-sm rounded-md no-underline <%= i === page ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100' %>"><%= i %></a>
    <% } %>
  </div>
<% } %>
