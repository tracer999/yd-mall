<%
const won = n => Number(n || 0).toLocaleString('ko-KR');
const dt = v => (v ? new Date(v).toLocaleString('ko-KR') : '-');
const dateVal = v => (v ? new Date(v).toISOString().slice(0,10) : '');
const cls = {
  REQUESTED:'bg-amber-100 text-amber-800 border-amber-400', UNDER_REVIEW:'bg-blue-100 text-blue-800 border-blue-400',
  SELLER_PROPOSED:'bg-blue-100 text-blue-800 border-blue-400', BUYER_COUNTERED:'bg-amber-100 text-amber-800 border-amber-400',
  BUYER_ACCEPTED:'bg-green-100 text-green-800 border-green-400', SELLER_ACCEPTED:'bg-green-100 text-green-800 border-green-400',
  CONVERTED_TO_ORDER:'bg-green-100 text-green-800 border-green-400', REJECTED:'bg-red-100 text-red-800 border-red-400',
  EXPIRED:'bg-gray-100 text-gray-600 border-gray-400', CANCELLED:'bg-gray-100 text-gray-600 border-gray-400',
  DRAFT:'bg-gray-100 text-gray-600 border-gray-400',
}[quote.status];
// 가능한 전이는 서비스가 판정한 것만 쓴다.
const canReview  = actions.includes('UNDER_REVIEW');
const canPropose = actions.includes('SELLER_PROPOSED');
const canAccept  = actions.includes('SELLER_ACCEPTED');
const canReject  = actions.includes('REJECTED');
const canConvert = actions.includes('CONVERTED_TO_ORDER');
const inputCls = 'w-full text-right border-gray-300 rounded-md text-sm h-[34px] px-2';
%>

<% if (message) { %><div class="mb-4 rounded-md bg-green-50 border border-green-200 p-3 text-sm text-green-800"><%= message %></div><% } %>
<% if (error) { %><div class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800"><%= error %></div><% } %>

<div class="mb-6 flex justify-between items-center">
  <a href="/admin/b2b/quotes" class="text-sm text-gray-500 hover:text-gray-700 no-underline">&larr; 목록으로</a>
  <div class="flex items-center gap-2">
    <a href="/admin/b2b/quotes/<%= quote.id %>/pdf" target="_blank" rel="noopener"
       class="text-sm px-3 py-2 rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50 no-underline">견적서 미리보기</a>
    <form action="/admin/b2b/quotes/<%= quote.id %>/issue-pdf" method="POST" class="inline">
      <button type="submit" class="text-sm px-3 py-2 rounded-md bg-gray-800 text-white hover:bg-gray-900">견적서 발행·보관</button>
    </form>
    <span class="text-xs px-2.5 py-1 rounded border <%= cls %>"><%= STATUS[quote.status] %></span>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <!-- 기본 정보 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4 text-sm">
      <div class="grid grid-cols-2 gap-y-2">
        <div><span class="text-gray-500">견적번호</span> <strong><%= quote.quote_number %></strong> <span class="text-xs text-gray-400">v<%= quote.version %></span></div>
        <div><span class="text-gray-500">요청일</span> <%= dt(quote.created_at) %></div>
        <div><span class="text-gray-500">거래처</span> <%= quote.company_name %> (<%= quote.business_number %>)</div>
        <div><span class="text-gray-500">요청자</span> <%= quote.requester_name || '-' %> / <%= quote.requester_email || '-' %></div>
      </div>
    </div>

    <!-- 품목·가격 제안 -->
    <form action="/admin/b2b/quotes/<%= quote.id %>/action" method="POST">
      <input type="hidden" name="action" value="propose">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-3 border-b border-gray-100">
          <h3 class="text-sm font-bold text-gray-900">품목 · 가격</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-xs text-gray-600 border-b">
              <tr>
                <th class="text-left px-4 py-2">품목</th>
                <th class="text-right px-4 py-2">정가</th>
                <th class="text-right px-4 py-2">고객 희망</th>
                <th class="text-right px-4 py-2 w-24">수량</th>
                <th class="text-right px-4 py-2 w-32">제안 단가</th>
                <th class="text-left px-4 py-2 w-40">메모</th>
                <th class="text-right px-4 py-2">합계</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(function(it) { const eff = effectiveUnitPrice(it); %>
                <tr class="border-b border-gray-50">
                  <td class="px-4 py-2">
                    <input type="hidden" name="item_id" value="<%= it.id %>">
                    <span class="font-medium text-gray-900"><%= it.product_name_snapshot %></span>
                    <% if (it.sku_snapshot) { %><p class="text-xs text-gray-400"><%= it.sku_snapshot %></p><% } %>
                    <% if (it.final_unit_price != null) { %><p class="text-xs text-green-700">확정 <%= won(it.final_unit_price) %>원</p><% } %>
                  </td>
                  <td class="px-4 py-2 text-right text-gray-400"><%= won(it.catalog_unit_price) %></td>
                  <td class="px-4 py-2 text-right <%= it.requested_unit_price != null ? 'text-amber-700 font-semibold' : 'text-gray-300' %>">
                    <%= it.requested_unit_price != null ? won(it.requested_unit_price) : '-' %>
                  </td>
                  <td class="px-4 py-2">
                    <% if (canPropose) { %><input type="number" name="quantity" value="<%= it.quantity %>" min="1" class="<%= inputCls %>">
                    <% } else { %><input type="hidden" name="quantity" value="<%= it.quantity %>"><div class="text-right"><%= won(it.quantity) %></div><% } %>
                  </td>
                  <td class="px-4 py-2">
                    <% if (canPropose) { %><input type="number" name="proposed_price" value="<%= it.proposed_unit_price != null ? it.proposed_unit_price : '' %>" min="0" class="<%= inputCls %>">
                    <% } else { %><input type="hidden" name="proposed_price" value="<%= it.proposed_unit_price != null ? it.proposed_unit_price : '' %>"><div class="text-right"><%= it.proposed_unit_price != null ? won(it.proposed_unit_price) : '-' %></div><% } %>
                  </td>
                  <td class="px-4 py-2">
                    <% if (canPropose) { %><input type="text" name="item_note" value="<%= it.item_note || '' %>" class="w-full border-gray-300 rounded-md text-sm h-[34px] px-2">
                    <% } else { %><input type="hidden" name="item_note" value="<%= it.item_note || '' %>"><span class="text-xs text-gray-500"><%= it.item_note || '' %></span><% } %>
                  </td>
                  <td class="px-4 py-2 text-right font-semibold"><%= won(eff * it.quantity) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <div class="px-6 py-4 border-t border-gray-100 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-gray-700">배송비</label>
            <input type="number" name="shipping_amount" value="<%= quote.shipping_amount || 0 %>" min="0" <%= canPropose ? '' : 'disabled' %>
                   class="mt-1 w-full h-[34px] px-2 text-sm border border-gray-300 rounded-md">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700">전체 할인</label>
            <input type="number" name="discount_amount" value="<%= quote.discount_amount || 0 %>" min="0" <%= canPropose ? '' : 'disabled' %>
                   class="mt-1 w-full h-[34px] px-2 text-sm border border-gray-300 rounded-md">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700">유효기간</label>
            <input type="date" name="valid_until" value="<%= dateVal(quote.valid_until) %>" <%= canPropose ? '' : 'disabled' %>
                   class="mt-1 w-full h-[34px] px-2 text-sm border border-gray-300 rounded-md">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700">결제 조건</label>
            <input type="text" name="payment_terms" value="<%= quote.payment_terms || '' %>" placeholder="선결제(무통장 입금)" <%= canPropose ? '' : 'disabled' %>
                   class="mt-1 w-full h-[34px] px-2 text-sm border border-gray-300 rounded-md">
          </div>
          <div class="sm:col-span-2">
            <label class="block text-xs font-medium text-gray-700">납기 조건</label>
            <input type="text" name="delivery_terms" value="<%= quote.delivery_terms || '' %>" placeholder="주문 확정 후 7일 이내 출고" <%= canPropose ? '' : 'disabled' %>
                   class="mt-1 w-full h-[34px] px-2 text-sm border border-gray-300 rounded-md">
          </div>
          <div class="sm:col-span-2">
            <label class="block text-xs font-medium text-gray-700">제안 메시지</label>
            <textarea name="message" rows="2" <%= canPropose ? '' : 'disabled' %>
                      class="mt-1 w-full px-2 py-1 text-sm border border-gray-300 rounded-md"></textarea>
          </div>
        </div>

        <div class="px-6 py-3 bg-gray-50 border-t text-sm">
          <div class="flex justify-between"><span class="text-gray-600">공급가액</span><span><%= won(quote.supply_amount) %>원</span></div>
          <div class="flex justify-between"><span class="text-gray-600">부가세</span><span><%= won(quote.vat_amount) %>원</span></div>
          <div class="flex justify-between font-bold text-base pt-2 mt-2 border-t border-gray-200">
            <span>합계</span><span class="text-blue-700"><%= won(quote.final_total) %>원</span>
          </div>
        </div>

        <% if (canPropose) { %>
          <div class="px-6 py-4 border-t border-gray-100">
            <button type="submit" class="w-full h-[42px] rounded-md bg-blue-600 text-white font-semibold hover:bg-blue-700">이 조건으로 제안하기</button>
          </div>
        <% } %>
      </div>
    </form>

    <!-- 메시지 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">협상 메시지</h3>
      <div class="space-y-3 mb-4">
        <% messages.forEach(function(m) { %>
          <div class="flex <%= m.sender_type === 'SELLER' ? 'justify-end' : 'justify-start' %>">
            <div class="max-w-[75%] rounded-lg px-3 py-2 text-sm <%= m.visibility === 'INTERNAL' ? 'bg-yellow-50 border border-yellow-200 text-yellow-900' : (m.sender_type === 'SELLER' ? 'bg-blue-50 text-blue-900' : 'bg-gray-100 text-gray-800') %>">
              <% if (m.visibility === 'INTERNAL') { %><p class="text-[11px] font-bold mb-0.5">내부 메모 (고객에게 보이지 않음)</p><% } %>
              <p class="whitespace-pre-line"><%= m.message %></p>
              <p class="text-[11px] text-gray-400 mt-1"><%= m.sender_type === 'SELLER' ? '판매자' : '거래처' %> · <%= dt(m.created_at) %></p>
            </div>
          </div>
        <% }); %>
        <% if (messages.length === 0) { %><p class="text-sm text-gray-400">메시지가 없습니다.</p><% } %>
      </div>
      <form action="/admin/b2b/quotes/<%= quote.id %>/action" method="POST" class="space-y-2">
        <input type="hidden" name="action" value="message">
        <input type="text" name="message" required placeholder="메시지 입력" class="block w-full border-gray-300 rounded-md text-sm h-[38px] px-3">
        <div class="flex items-center justify-between">
          <label class="flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="internal" value="1" class="rounded border-gray-300">내부 메모로 남기기
          </label>
          <button type="submit" class="px-4 py-2 rounded-md border border-gray-300 text-sm hover:bg-gray-50">보내기</button>
        </div>
      </form>
    </div>
  </div>

  <!-- 우측: 진행·이력 -->
  <div class="space-y-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">진행</h3>
      <% if (canReview) { %>
        <form action="/admin/b2b/quotes/<%= quote.id %>/action" method="POST" class="mb-2">
          <input type="hidden" name="action" value="review">
          <button type="submit" class="w-full h-[38px] text-sm font-medium rounded-md border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100">검토 시작</button>
        </form>
      <% } %>
      <% if (canAccept) { %>
        <form action="/admin/b2b/quotes/<%= quote.id %>/action" method="POST" class="mb-2"
              onsubmit="return confirm('고객 제안 조건으로 수락합니다. 단가가 확정됩니다.');">
          <input type="hidden" name="action" value="accept">
          <button type="submit" class="w-full h-[38px] text-sm font-medium rounded-md bg-green-600 text-white hover:bg-green-700">고객 제안 수락</button>
        </form>
      <% } %>
      <% if (canReject) { %>
        <form action="/admin/b2b/quotes/<%= quote.id %>/action" method="POST" class="mb-2"
              onsubmit="return confirm('견적을 반려하시겠습니까?');">
          <input type="hidden" name="action" value="reject">
          <input type="text" name="message" placeholder="반려 사유" required class="mb-2 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md">
          <button type="submit" class="w-full h-[38px] text-sm font-medium rounded-md border border-red-200 bg-red-50 text-red-700 hover:bg-red-100">견적 반려</button>
        </form>
      <% } %>
      <% if (!canReview && !canPropose && !canAccept && !canReject && !canConvert) { %>
        <p class="text-sm text-gray-500">이 상태에서 가능한 작업이 없습니다.</p>
      <% } %>
    </div>

    <% if (canConvert) { %>
      <div class="bg-white rounded-xl shadow-sm border-2 border-blue-200 px-6 py-4">
        <h3 class="text-sm font-bold text-gray-900 mb-1">주문 전환</h3>
        <% if (!convertible.ok) { %>
          <p class="text-sm text-red-700"><%= convertible.error %></p>
        <% } else { %>
          <p class="text-xs text-gray-500 mb-3">확정 단가 그대로 B2B 주문이 만들어집니다(접수 상태). 재고는 승인 때 차감됩니다.</p>
          <form action="/admin/b2b/quotes/<%= quote.id %>/convert" method="POST"
                onsubmit="return confirm('이 견적을 주문으로 전환합니다.');">
            <button type="submit" class="w-full h-[38px] text-sm font-semibold rounded-md bg-blue-700 text-white hover:bg-blue-800">주문으로 전환</button>
          </form>
        <% } %>
      </div>
    <% } %>

    <% if (quote.converted_order_id) { %>
      <div class="bg-green-50 border border-green-200 rounded-xl px-6 py-4 text-sm text-green-900">
        주문으로 전환됨 —
        <a href="/admin/b2b/orders/<%= quote.converted_order_id %>" class="underline">주문 보기</a>
      </div>
    <% } %>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">변경 이력</h3>
      <ol class="space-y-2 text-sm">
        <% revisions.forEach(function(r) { %>
          <li>
            <div class="flex gap-2">
              <span class="text-xs font-mono text-gray-400">v<%= r.revision_number %></span>
              <span class="text-gray-700 flex-1"><%= r.summary || STATUS[r.status_after] %></span>
            </div>
            <p class="text-[11px] text-gray-400 ml-7"><%= dt(r.created_at) %>
              <% if (r.pdf_path) { %> · <span class="text-blue-600">견적서 보관됨</span><% } %>
            </p>
          </li>
        <% }); %>
      </ol>
    </div>
  </div>
</div>
