<%
const s = setting || {};
const won = (n) => Number(n || 0).toLocaleString('ko-KR');
const isOption = product.product_type === 'OPTION';
const skuVaries = skuStat && skuStat.cnt > 1 && skuStat.min_price !== skuStat.max_price;
const inputCls = 'mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500';
%>

<% if (message) { %>
  <div class="mb-4 rounded-md bg-green-50 border border-green-200 p-3 text-sm text-green-800"><%= message %></div>
<% } %>
<% if (error) { %>
  <div class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800"><%= error %></div>
<% } %>

<div class="mb-6 flex justify-between items-center">
  <a href="/admin/products/edit/<%= product.id %>" class="text-sm text-gray-500 hover:text-gray-700 no-underline">&larr; 상품 수정으로</a>
  <span class="text-sm text-gray-500">판매가 <strong class="text-gray-900"><%= won(product.price) %>원</strong>
    <span class="text-xs text-gray-400">(공급가 <%= won(taxSplit.supply) %> + VAT <%= won(taxSplit.vat) %>)</span>
  </span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- 판매 설정 -->
  <div class="lg:col-span-2 space-y-6">
    <form action="/admin/products/b2b/<%= product.id %>" method="POST"
          class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4 space-y-5">

      <label class="flex items-center gap-2 text-sm font-medium text-gray-900">
        <input type="checkbox" name="is_b2b_sale" value="1" <%= s.is_b2b_sale ? 'checked' : '' %> class="rounded border-gray-300">
        이 상품을 B2B(사업자)에게 판매
      </label>
      <p class="text-xs text-gray-500 -mt-3">
        끄면 사업자에게도 일반 판매가로 보입니다. 전용가·최소수량은 켠 상태에서만 적용됩니다.
      </p>

      <div>
        <label class="block text-sm font-medium text-gray-700">판매 채널</label>
        <select name="sales_channel" class="<%= inputCls %>">
          <option value="BOTH" <%= (s.sales_channel || 'BOTH') === 'BOTH' ? 'selected' : '' %>>공통 — 일반·사업자 모두 노출</option>
          <option value="B2C_ONLY" <%= s.sales_channel === 'B2C_ONLY' ? 'selected' : '' %>>B2C 전용 — 사업자에게도 일반가로만</option>
          <option value="B2B_ONLY" <%= s.sales_channel === 'B2B_ONLY' ? 'selected' : '' %>>B2B 전용 — 일반 사용자에게 숨김(목록·상세 404)</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700">기본 B2B 전용가 (부가세 포함)</label>
        <input type="number" name="b2b_price" min="0" value="<%= s.b2b_price != null ? s.b2b_price : '' %>" class="<%= inputCls %>"
               placeholder="비워 두면 전용가 없음">
        <p class="mt-1 text-xs text-gray-500">
          판매가(<%= won(product.price) %>원)보다 <strong>낮아야</strong> 적용됩니다. 화면에는 공급가 + VAT 로 분리 표시됩니다.
        </p>
        <% if (isOption || skuVaries) { %>
          <p class="mt-1 text-xs text-amber-700">
            이 상품은 옵션(SKU)별 판매가가 다릅니다(<%= won(skuStat.min_price) %>~<%= won(skuStat.max_price) %>원).
            1단계 전용가는 <strong>상품 단위</strong>라 어떤 옵션을 골라도 같은 전용가가 적용됩니다.
          </p>
        <% } %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700">과세 구분</label>
        <select name="tax_type" class="<%= inputCls %>">
          <option value="TAXABLE" <%= (product.tax_type || 'TAXABLE') === 'TAXABLE' ? 'selected' : '' %>>과세 (세금계산서)</option>
          <option value="TAX_FREE" <%= product.tax_type === 'TAX_FREE' ? 'selected' : '' %>>면세 (계산서)</option>
          <option value="ZERO_RATED" <%= product.tax_type === 'ZERO_RATED' ? 'selected' : '' %>>영세율</option>
        </select>
        <p class="mt-1 text-xs text-gray-500">공급가·부가세 계산과 세금계산서 서식을 가릅니다. 외부 채널 등록에도 함께 쓰입니다.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">최소 주문수량</label>
          <input type="number" name="min_order_qty" min="1" value="<%= s.min_order_qty || 1 %>" class="<%= inputCls %>">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">주문 단위</label>
          <input type="number" name="order_unit" min="1" value="<%= s.order_unit || 1 %>" class="<%= inputCls %>">
          <p class="mt-1 text-xs text-gray-500">예: 최소 10 · 단위 5 → 10, 15, 20…</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">최대 주문수량</label>
          <input type="number" name="max_order_qty" min="1" value="<%= s.max_order_qty != null ? s.max_order_qty : '' %>" class="<%= inputCls %>" placeholder="제한 없음">
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">거래 방식</label>
          <select name="transaction_mode" class="<%= inputCls %>">
            <option value="DIRECT_ORDER" <%= s.transaction_mode === 'DIRECT_ORDER' ? 'selected' : '' %>>즉시 주문</option>
            <option value="QUOTE_OPTIONAL" <%= (s.transaction_mode || 'QUOTE_OPTIONAL') === 'QUOTE_OPTIONAL' ? 'selected' : '' %>>견적 선택 가능</option>
            <option value="QUOTE_REQUIRED" <%= s.transaction_mode === 'QUOTE_REQUIRED' ? 'selected' : '' %>>견적 필수</option>
          </select>
          <p class="mt-1 text-xs text-gray-500">견적 도메인은 3단계입니다. 지금 "견적 필수"로 두면 주문 버튼이 잠깁니다.</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">견적 필수 수량</label>
          <input type="number" name="quote_required_qty" min="1" value="<%= s.quote_required_qty != null ? s.quote_required_qty : '' %>" class="<%= inputCls %>" placeholder="없음">
          <p class="mt-1 text-xs text-gray-500">이 수량 이상이면 견적을 거칩니다.</p>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700">전용가 공개 범위</label>
        <select name="price_visibility" class="<%= inputCls %>">
          <option value="APPROVED_ONLY" <%= (s.price_visibility || 'APPROVED_ONLY') === 'APPROVED_ONLY' ? 'selected' : '' %>>승인된 기업회원만</option>
          <option value="PUBLIC" <%= s.price_visibility === 'PUBLIC' ? 'selected' : '' %>>승인 전 사업자에게도 공개</option>
          <option value="HIDDEN" <%= s.price_visibility === 'HIDDEN' ? 'selected' : '' %>>비공개 (가격 문의)</option>
        </select>
        <p class="mt-1 text-xs text-gray-500">어떤 경우에도 일반 회원·비로그인에게는 전용가가 보이지 않습니다.</p>
      </div>

      <button type="submit" class="h-[42px] px-6 text-sm font-semibold rounded-md bg-blue-600 text-white hover:bg-blue-700">저장</button>
    </form>
  </div>

  <!-- 수량별 가격 -->
  <div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">수량별 가격</h3>

      <% if (volumes.length > 0) { %>
        <table class="w-full text-sm mb-4">
          <thead class="text-xs text-gray-500 border-b border-gray-100">
            <tr><th class="text-left py-1">수량</th><th class="text-right py-1">단가</th><th class="text-right py-1">등급</th><th></th></tr>
          </thead>
          <tbody>
            <% volumes.forEach(function(v) { %>
              <tr class="border-b border-gray-50">
                <td class="py-2"><%= v.min_quantity %>개~</td>
                <td class="py-2 text-right font-semibold"><%= won(v.unit_price) %>원</td>
                <td class="py-2 text-right text-xs text-gray-500">
                  <%= v.tier_id ? (tiers.find(t => t.id === v.tier_id) || {}).tier_name || '-' : '전체' %>
                </td>
                <td class="py-2 text-right">
                  <form action="/admin/products/b2b/<%= product.id %>/volume/delete" method="POST" onsubmit="return confirm('삭제하시겠습니까?');">
                    <input type="hidden" name="id" value="<%= v.id %>">
                    <button type="submit" class="text-xs text-red-600 hover:underline">삭제</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <p class="text-sm text-gray-400 mb-4">등록된 수량별 가격이 없습니다.</p>
      <% } %>

      <form action="/admin/products/b2b/<%= product.id %>/volume" method="POST" class="space-y-3 pt-3 border-t border-gray-100">
        <div>
          <label class="block text-sm font-medium text-gray-700">이 수량 이상</label>
          <input type="number" name="min_quantity" min="1" required class="<%= inputCls %>" placeholder="50">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">단가 (부가세 포함)</label>
          <input type="number" name="unit_price" min="1" required class="<%= inputCls %>">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">적용 등급</label>
          <select name="tier_id" class="<%= inputCls %>">
            <option value="">전체 사업자</option>
            <% tiers.forEach(function(t) { %>
              <option value="<%= t.id %>"><%= t.tier_name %></option>
            <% }); %>
          </select>
        </div>
        <button type="submit" class="w-full h-[38px] px-4 text-sm font-medium rounded-md border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100">추가</button>
      </form>

      <p class="mt-3 text-xs text-gray-500">
        수량이 여러 구간에 걸리면 <strong>가장 큰 기준 수량</strong>이 이깁니다. 같은 수량이면 등급 전용가가 전체가를 이깁니다.
      </p>
    </div>
  </div>
</div>
