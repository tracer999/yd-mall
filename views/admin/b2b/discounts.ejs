<%
const pct = n => Number(n || 0).toFixed(2).replace(/\.00$/, '');
%>

<% if (message) { %><div class="mb-4 rounded-md bg-green-50 border border-green-200 p-3 text-sm text-green-800"><%= message %></div><% } %>
<% if (error) { %><div class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800"><%= error %></div><% } %>

<div class="mb-6 rounded-lg border border-blue-200 bg-blue-50 p-4 text-sm text-blue-900">
  <p class="font-semibold mb-1">전용가는 두 가지를 더해서 정합니다.</p>
  <p class="text-blue-800">
    <strong>상품 할인율</strong>(상품 등록/수정 화면의 <code>B2B 판매</code> 섹션) +
    <strong>거래처 추가 할인율</strong>(이 화면) = 최종 할인율
  </p>
  <p class="mt-2 text-xs text-blue-700">
    예) 판매가 10,000원 · 상품 할인율 30% · 이 거래처 추가 5% → <strong>35% 할인 = 6,500원</strong><br>
    수량이나 거래 조건에 따라 값을 더 조정해야 하면 <a href="/admin/b2b/quotes" class="underline">견적</a>에서 협의하세요.
  </p>
</div>

<div class="mb-4 flex justify-end">
  <form action="/admin/b2b/discounts" method="GET" class="flex gap-2 w-full sm:w-auto">
    <input type="text" name="q" value="<%= keyword %>" placeholder="상호·사업자번호"
           class="h-[38px] px-3 text-sm border border-gray-300 rounded-md w-full sm:w-64">
    <button type="submit" class="h-[38px] px-4 text-sm font-medium rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">검색</button>
  </form>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100">
  <div class="overflow-x-auto">
    <table class="w-full text-sm text-left text-gray-500">
      <thead class="text-xs text-gray-700 uppercase bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="px-6 py-3">거래처</th>
          <th class="px-6 py-3">사업자번호</th>
          <th class="px-6 py-3">과세구분</th>
          <th class="px-6 py-3 w-56">추가 할인율 (%)</th>
        </tr>
      </thead>
      <tbody>
        <% if (rows.length > 0) { %>
          <% rows.forEach(function(r) { %>
            <tr class="bg-white border-b border-gray-100 hover:bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">
                <a href="/admin/b2b/members/<%= r.id %>" class="text-blue-700 hover:underline no-underline"><%= r.company_name %></a>
              </td>
              <td class="px-6 py-4"><%= r.business_number %></td>
              <td class="px-6 py-4 text-xs">
                <%= { TAXABLE:'과세', TAX_FREE:'면세', ZERO_RATED:'영세율' }[r.tax_type || 'TAXABLE'] %>
              </td>
              <td class="px-6 py-4">
                <form action="/admin/b2b/discounts" method="POST" class="flex items-center gap-2">
                  <input type="hidden" name="id" value="<%= r.id %>">
                  <input type="number" name="extra_discount_rate" value="<%= pct(r.extra_discount_rate) %>"
                         min="0" max="99" step="0.01"
                         class="w-24 h-[34px] px-2 text-right text-sm border border-gray-300 rounded-md">
                  <span class="text-gray-400 text-sm">%</span>
                  <button type="submit" class="h-[34px] px-3 text-sm font-medium rounded-md border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100">저장</button>
                </form>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="4" class="px-6 py-12 text-center text-gray-400">
            <%= keyword ? '조건에 맞는 거래처가 없습니다.' : '승인된 거래처가 없습니다. 먼저 기업회원을 승인하세요.' %>
          </td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<p class="mt-3 text-xs text-gray-500">
  추가 할인이 필요 없는 거래처는 <strong>0</strong> 으로 두면 상품 할인율만 적용됩니다.
</p>
