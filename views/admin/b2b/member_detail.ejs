<%
const badge = {
  PENDING: 'bg-amber-100 text-amber-800 border-amber-400',
  UNDER_REVIEW: 'bg-blue-100 text-blue-800 border-blue-400',
  APPROVED: 'bg-green-100 text-green-800 border-green-400',
  SUSPENDED: 'bg-red-100 text-red-800 border-red-400',
  REJECTED: 'bg-gray-100 text-gray-700 border-gray-400',
};
// 전이표(services/b2b/businessProfileService.ALLOWED_TRANSITIONS)와 같은 규칙.
// 화면이 규칙을 재조립하는 게 아니라, 여기서는 "지금 누를 수 있는 버튼"만 고른다.
const ALLOWED = {
  PENDING: ['UNDER_REVIEW', 'APPROVED', 'REJECTED'],
  UNDER_REVIEW: ['APPROVED', 'REJECTED', 'PENDING'],
  APPROVED: ['SUSPENDED'],
  SUSPENDED: ['APPROVED', 'REJECTED'],
  REJECTED: ['UNDER_REVIEW', 'APPROVED'],
};
const actions = ALLOWED[profile.status] || [];
const btnStyle = {
  APPROVED: 'bg-green-600 text-white hover:bg-green-700',
  REJECTED: 'bg-red-50 text-red-700 border border-red-200 hover:bg-red-100',
  SUSPENDED: 'bg-red-50 text-red-700 border border-red-200 hover:bg-red-100',
  UNDER_REVIEW: 'bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100',
  PENDING: 'bg-gray-50 text-gray-700 border border-gray-200 hover:bg-gray-100',
};
const needsReason = (s) => s === 'REJECTED' || s === 'SUSPENDED';
const dateVal = (d) => (d ? new Date(d).toISOString().slice(0, 10) : '');
const row = (k, v) => `<div class="flex py-3 border-b border-gray-100 last:border-0"><dt class="w-40 shrink-0 text-sm text-gray-500">${k}</dt><dd class="text-sm text-gray-900">${v || '-'}</dd></div>`;
%>

<% if (message) { %>
  <div class="mb-4 rounded-md bg-green-50 border border-green-200 p-3 text-sm text-green-800"><%= message %></div>
<% } %>
<% if (error) { %>
  <div class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800"><%= error %></div>
<% } %>

<div class="mb-6 flex justify-between items-center">
  <a href="/admin/b2b/members" class="text-sm text-gray-500 hover:text-gray-700 no-underline">&larr; 목록으로</a>
  <span class="text-xs font-medium px-2.5 py-1 rounded border <%= badge[profile.status] %>"><%= STATUS_LABEL[profile.status] %></span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- 신청 내용 -->
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-2">신청 내용</h3>
      <p class="text-xs text-gray-500 mb-3">오른쪽의 사업자등록증을 열어 아래 값과 대조하세요.</p>
      <dl>
        <%- row('상호', profile.company_name) %>
        <%- row('사업자등록번호', formatBusinessNumber(profile.business_number)) %>
        <%- row('대표자명', profile.representative_name) %>
        <%- row('업태 / 종목', [profile.business_type, profile.business_category].filter(Boolean).join(' / ')) %>
        <%- row('사업장 주소', [profile.company_zipcode ? '(' + profile.company_zipcode + ')' : '', profile.company_address, profile.company_detailed_address].filter(Boolean).join(' ')) %>
        <%- row('세금계산서 이메일', profile.tax_invoice_email) %>
        <%- row('담당자', [profile.manager_name, profile.manager_phone].filter(Boolean).join(' / ')) %>
        <%- row('신청 계정', [profile.user_name, profile.email].filter(Boolean).join(' / ')) %>
        <%- row('신청일', profile.applied_at ? new Date(profile.applied_at).toLocaleString('ko-KR') : '') %>
        <% if (profile.approved_at) { %><%- row('승인일', new Date(profile.approved_at).toLocaleString('ko-KR')) %><% } %>
        <% if (profile.reject_reason) { %><%- row('반려/정지 사유', profile.reject_reason) %><% } %>
      </dl>
    </div>

    <!-- 거래 조건 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">거래 조건</h3>
      <form action="/admin/b2b/members/<%= profile.id %>/update" method="POST" class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">거래처 등급</label>
            <select name="tier_id" class="mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="">등급 없음</option>
              <% tiers.forEach(function(t) { %>
                <option value="<%= t.id %>" <%= profile.tier_id === t.id ? 'selected' : '' %>><%= t.tier_name %></option>
              <% }); %>
            </select>
            <% if (tiers.length === 0) { %>
              <p class="mt-1 text-xs text-amber-700">등록된 등급이 없습니다. <a href="/admin/b2b/tiers" class="underline">등급 만들기</a></p>
            <% } %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">계약 시작</label>
            <input type="date" name="contract_valid_from" value="<%= dateVal(profile.contract_valid_from) %>"
                   class="mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">계약 종료</label>
            <input type="date" name="contract_valid_to" value="<%= dateVal(profile.contract_valid_to) %>"
                   class="mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md">
            <p class="mt-1 text-xs text-gray-500">비워 두면 무기한</p>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">관리자 메모</label>
          <textarea name="admin_note" rows="3"
                    class="mt-1 block w-full px-3 py-2 text-sm border border-gray-300 rounded-md"><%= profile.admin_note || '' %></textarea>
        </div>
        <button type="submit" class="h-[38px] px-4 text-sm font-medium rounded-md bg-blue-600 text-white hover:bg-blue-700">저장</button>
      </form>
    </div>
  </div>

  <!-- 등록증 + 상태 처리 -->
  <div class="space-y-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">사업자등록증</h3>
      <% if (profile.license_file) { %>
        <a href="/admin/b2b/members/<%= profile.id %>/license" target="_blank" rel="noopener"
           class="inline-flex items-center justify-center w-full h-[42px] px-4 text-sm font-medium rounded-md bg-gray-800 text-white hover:bg-gray-900 no-underline">
          <i class="bi bi-file-earmark-text mr-2"></i>등록증 열기
        </a>
        <p class="mt-2 text-xs text-gray-500 break-all"><%= profile.license_original_name || '' %></p>
      <% } else { %>
        <p class="text-sm text-amber-700">첨부된 등록증이 없습니다. 승인 전에 신청자에게 요청하세요.</p>
      <% } %>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">승인 처리</h3>
      <% if (actions.length === 0) { %>
        <p class="text-sm text-gray-500">현재 상태에서 변경할 수 있는 항목이 없습니다.</p>
      <% } else { %>
        <% actions.forEach(function(s) { %>
          <form action="/admin/b2b/members/<%= profile.id %>/status" method="POST" class="mb-3"
                onsubmit="return confirm('<%= STATUS_LABEL[s] %> 처리하시겠습니까?');">
            <input type="hidden" name="status" value="<%= s %>">
            <% if (needsReason(s)) { %>
              <input type="text" name="reason" placeholder="사유 (신청자에게 안내됩니다)" required
                     class="mb-2 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md">
            <% } %>
            <button type="submit"
                    class="w-full h-[38px] px-4 text-sm font-medium rounded-md <%= btnStyle[s] %>"><%= STATUS_LABEL[s] %></button>
          </form>
        <% }); %>
        <p class="mt-2 text-xs text-gray-500">승인·반려·정지 시 신청 계정 이메일로 결과가 발송됩니다.</p>
      <% } %>
    </div>
  </div>
</div>
