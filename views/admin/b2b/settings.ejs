<% if (message) { %>
  <div class="mb-4 rounded-md bg-green-50 border border-green-200 p-3 text-sm text-green-800"><%= message %></div>
<% } %>

<div class="mb-4 rounded-md bg-blue-50 border border-blue-200 p-4 text-sm text-blue-900">
  <p class="font-medium">B2B 는 모든 몰에서 기본 동작합니다.</p>
  <p class="mt-1 text-blue-800">
    몰별 on/off 설정은 없습니다. 아래 값을 한 번도 저장하지 않아도 괄호 안의 기본값으로 동작하므로,
    새로 만든 몰에서도 바로 사용할 수 있습니다.
  </p>
</div>

<form action="/admin/b2b/settings" method="POST" class="max-w-2xl space-y-6">
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4 space-y-4">
    <h3 class="text-sm font-bold text-gray-900">가격 · 할인</h3>

    <div>
      <label class="block text-sm font-medium text-gray-700">B2B 가격 표기</label>
      <select name="tax_display" class="mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md">
        <option value="EXCLUSIVE" <%= settings.taxDisplay === 'EXCLUSIVE' ? 'selected' : '' %>>공급가 별도 (공급가 + VAT 분리 표시)</option>
        <option value="INCLUSIVE" <%= settings.taxDisplay === 'INCLUSIVE' ? 'selected' : '' %>>부가세 포함가로 표시</option>
      </select>
      <p class="mt-1 text-xs text-gray-500">기본값: 공급가 별도</p>
    </div>

    <div>
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <input type="checkbox" name="allow_coupon_stacking" value="1" <%= settings.allowCouponStacking ? 'checked' : '' %> class="rounded border-gray-300">
        기업 주문에도 쿠폰·포인트 사용 허용
      </label>
      <p class="mt-1 text-xs text-gray-500">
        기본값: 불허. 전용가는 이미 계약가라 쿠폰·포인트를 얹으면 마진 관리가 어려워집니다.
      </p>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700">B2B 무료배송 기준액</label>
      <input type="number" name="free_ship_threshold" min="0" value="<%= settings.freeShipThreshold != null ? settings.freeShipThreshold : '' %>"
             class="mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md" placeholder="비워 두면 기본 배송정책 적용">
      <p class="mt-1 text-xs text-gray-500">기본값: 비움(일반 배송정책을 그대로 따름)</p>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4 space-y-4">
    <h3 class="text-sm font-bold text-gray-900">주문 · 결제</h3>

    <div>
      <label class="block text-sm font-medium text-gray-700">입금 기한(일)</label>
      <input type="number" name="payment_due_days" min="1" value="<%= settings.paymentDueDays %>"
             class="mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md">
      <p class="mt-1 text-xs text-amber-700">
        기본값: <%= defaults.paymentDueDays %>일. <strong>주문 승인 시 재고를 차감</strong>하므로,
        이 기간이 길수록 미입금 주문이 재고를 오래 잡습니다.
      </p>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700">입금 계좌 안내</label>
      <input type="text" name="bank_account_info" value="<%= settings.bankAccountInfo %>"
             class="mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md"
             placeholder="국민은행 000000-00-000000 (주)와이디데이터">
      <p class="mt-1 text-xs text-gray-500">주문 승인 안내와 사업자 정보 화면에 그대로 노출됩니다.</p>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700">견적 기본 유효기간(일)</label>
      <input type="number" name="quote_valid_days" min="1" value="<%= settings.quoteValidDays %>"
             class="mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md">
      <p class="mt-1 text-xs text-gray-500">기본값: <%= defaults.quoteValidDays %>일 (견적 기능은 3단계)</p>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4 space-y-4">
    <h3 class="text-sm font-bold text-gray-900">가입 승인</h3>
    <div>
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <input type="checkbox" name="auto_approve" value="1" <%= settings.autoApprove ? 'checked' : '' %> class="rounded border-gray-300">
        사업자 가입 즉시 자동 승인
      </label>
      <p class="mt-1 text-xs text-red-700">
        기본값: 사용 안 함. 켜면 <strong>사업자등록증을 확인하지 않고</strong> 전용가가 열립니다. 테스트 용도로만 쓰세요.
      </p>
    </div>
  </div>

  <button type="submit" class="h-[42px] px-6 text-sm font-semibold rounded-md bg-blue-600 text-white hover:bg-blue-700">저장</button>
</form>
