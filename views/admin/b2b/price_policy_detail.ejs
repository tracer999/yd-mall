<%
const won = n => Number(n || 0).toLocaleString('ko-KR');
const dd = v => (v ? new Date(v).toLocaleDateString('ko-KR') : '제한 없음');
const dateVal = v => (v ? new Date(v).toISOString().slice(0,10) : '');
const inputCls = 'mt-1 block w-full h-[38px] px-3 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500';
const isContract = policy.policy_type === 'CUSTOMER_CONTRACT';
/** 이 품목의 실제 적용 단가 — 고정단가 우선, 없으면 판매가 대비 할인율 */
const effective = (it) => (it.fixed_price != null
  ? Number(it.fixed_price)
  : Math.floor(Number(it.list_price) * (1 - Number(it.discount_rate) / 100)));
%>

<% if (message) { %><div class="mb-4 rounded-md bg-green-50 border border-green-200 p-3 text-sm text-green-800"><%= message %></div><% } %>
<% if (error) { %><div class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800"><%= error %></div><% } %>

<% if (csvResult && csvResult.failures && csvResult.failures.length) { %>
  <div class="mb-4 rounded-md bg-amber-50 border border-amber-200 p-4 text-sm">
    <p class="font-semibold text-amber-900 mb-2">
      CSV 등록: <%= csvResult.okCount %>건 성공 · <%= csvResult.failures.length %>건 실패
    </p>
    <ul class="text-xs text-amber-800 space-y-0.5 max-h-48 overflow-y-auto">
      <% csvResult.failures.forEach(function(f) { %><li>· <%= f %></li><% }); %>
    </ul>
  </div>
<% } %>

<div class="mb-6 flex justify-between items-center">
  <a href="/admin/b2b/price-policies" class="text-sm text-gray-500 hover:text-gray-700 no-underline">&larr; 목록으로</a>
  <span class="text-xs px-2.5 py-1 rounded border <%= isContract ? 'bg-purple-100 text-purple-800 border-purple-400' : 'bg-indigo-100 text-indigo-800 border-indigo-400' %>">
    <%= TYPE_LABEL[policy.policy_type] %><%= policy.tier_name ? ' · ' + policy.tier_name : '' %>
  </span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <!-- 등록된 단가 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-3 border-b border-gray-100 flex items-center justify-between">
        <h3 class="text-sm font-bold text-gray-900">상품별 단가 (<%= items.length %>건)</h3>
        <span class="text-xs text-gray-500">판매가보다 비싼 단가는 적용되지 않습니다</span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-xs text-gray-600 border-b">
            <tr>
              <th class="text-left px-4 py-2">상품</th>
              <th class="text-right px-4 py-2">판매가</th>
              <th class="text-right px-4 py-2">설정</th>
              <th class="text-right px-4 py-2">적용 단가</th>
              <th class="text-right px-4 py-2"></th>
            </tr>
          </thead>
          <tbody>
            <% if (items.length > 0) { %>
              <% items.forEach(function(it) { const eff = effective(it); const bad = eff >= Number(it.list_price); %>
                <tr class="border-b border-gray-50 <%= bad ? 'bg-red-50' : '' %>">
                  <td class="px-4 py-2">
                    <span class="font-medium text-gray-900"><%= it.product_name %></span>
                    <p class="text-xs text-gray-400"><%= it.product_code || ('ID ' + it.product_id) %> · 몰 <%= it.mall_id %></p>
                  </td>
                  <td class="px-4 py-2 text-right text-gray-500"><%= won(it.list_price) %>원</td>
                  <td class="px-4 py-2 text-right text-xs">
                    <%= it.fixed_price != null ? '고정 ' + won(it.fixed_price) + '원' : it.discount_rate + '% 할인' %>
                  </td>
                  <td class="px-4 py-2 text-right font-semibold <%= bad ? 'text-red-700' : 'text-blue-800' %>">
                    <%= won(eff) %>원
                    <% if (bad) { %><p class="text-[11px] font-normal">판매가 이상 — 미적용</p><% } %>
                  </td>
                  <td class="px-4 py-2 text-right">
                    <form action="/admin/b2b/price-policies/<%= policy.id %>/items/delete" method="POST" onsubmit="return confirm('삭제하시겠습니까?');">
                      <input type="hidden" name="item_id" value="<%= it.id %>">
                      <button type="submit" class="text-xs text-red-600 hover:underline">삭제</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr><td colspan="5" class="px-4 py-10 text-center text-gray-400">등록된 단가가 없습니다. 오른쪽에서 상품을 검색해 추가하세요.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- CSV 일괄 등록 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-1">CSV 일괄 등록</h3>
      <p class="text-xs text-gray-500 mb-3">
        엑셀에서 두 개 열(<strong>상품코드 또는 상품ID</strong>, <strong>단가 또는 할인율</strong>)을 복사해 붙여넣으세요.
        할인율은 <code>30%</code> 처럼 % 를 붙입니다. 헤더줄은 자동으로 건너뜁니다.
      </p>
      <form action="/admin/b2b/price-policies/<%= policy.id %>/items/csv" method="POST">
        <textarea name="csv" rows="6" placeholder="AB-1001,77000&#10;AB-1002,30%&#10;754,13900"
                  class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-md font-mono"></textarea>
        <button type="submit" class="mt-3 h-[38px] px-4 text-sm font-medium rounded-md border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100">일괄 등록</button>
        <span class="ml-2 text-xs text-gray-500">이미 있는 상품은 단가만 갱신됩니다.</span>
      </form>
    </div>
  </div>

  <div class="space-y-6">
    <!-- 상품 추가 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">상품 단가 추가</h3>
      <form action="/admin/b2b/price-policies/<%= policy.id %>/items" method="POST" class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700">상품 검색</label>
          <input type="text" id="prodSearch" placeholder="상품명 또는 상품코드" autocomplete="off" class="<%= inputCls %>">
          <div id="prodResults" class="mt-1 border border-gray-200 rounded-md divide-y divide-gray-100 hidden max-h-60 overflow-y-auto"></div>
          <input type="hidden" name="product_id" id="prodId">
          <p id="prodPicked" class="mt-2 text-sm text-blue-800 hidden"></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">단가 방식</label>
          <select name="price_mode" id="priceMode" class="<%= inputCls %>"
                  onchange="document.getElementById('fixedRow').style.display=this.value==='fixed'?'':'none';document.getElementById('rateRow').style.display=this.value==='rate'?'':'none';">
            <option value="fixed">고정 단가</option>
            <option value="rate">판매가 대비 할인율</option>
          </select>
        </div>
        <div id="fixedRow">
          <label class="block text-sm font-medium text-gray-700">고정 단가 (부가세 포함)</label>
          <input type="number" name="fixed_price" min="0" class="<%= inputCls %>">
        </div>
        <div id="rateRow" style="display:none">
          <label class="block text-sm font-medium text-gray-700">할인율 (%)</label>
          <input type="number" name="discount_rate" min="1" max="99" step="0.01" class="<%= inputCls %>">
          <p class="mt-1 text-xs text-gray-500">상품 판매가가 바뀌면 단가도 함께 움직입니다.</p>
        </div>
        <button type="submit" class="w-full h-[38px] text-sm font-semibold rounded-md bg-blue-600 text-white hover:bg-blue-700">단가 등록</button>
      </form>
    </div>

    <!-- 적용 대상 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">적용 대상</h3>
      <% if (!isContract) { %>
        <p class="text-sm text-gray-600">
          등급 <strong><%= policy.tier_name || '(미지정)' %></strong> 의 모든 거래처에 자동 적용됩니다.
        </p>
        <p class="mt-2 text-xs text-gray-500">거래처의 등급은 <a href="/admin/b2b/members" class="underline">기업회원 승인</a> 화면에서 바꿉니다.</p>
      <% } else { %>
        <% if (companies.length > 0) { %>
          <ul class="mb-3 space-y-2">
            <% companies.forEach(function(c) { %>
              <li class="flex items-center justify-between text-sm">
                <span><%= c.company_name %> <span class="text-xs text-gray-400"><%= c.business_number %></span></span>
                <form action="/admin/b2b/price-policies/<%= policy.id %>/assign" method="POST">
                  <input type="hidden" name="business_profile_id" value="<%= c.id %>">
                  <input type="hidden" name="action" value="unassign">
                  <button type="submit" class="text-xs text-red-600 hover:underline">해제</button>
                </form>
              </li>
            <% }); %>
          </ul>
        <% } else { %>
          <p class="mb-3 text-sm text-gray-400">아직 배정된 거래처가 없습니다. 배정해야 이 단가가 적용됩니다.</p>
        <% } %>
        <form action="/admin/b2b/price-policies/<%= policy.id %>/assign" method="POST" class="space-y-2">
          <select name="business_profile_id" class="<%= inputCls %>">
            <option value="">거래처 선택</option>
            <% assignable.forEach(function(a) { %>
              <option value="<%= a.id %>" <%= a.price_policy_id === policy.id ? 'disabled' : '' %>>
                <%= a.company_name %><%= (a.price_policy_id && a.price_policy_id !== policy.id) ? ' (다른 정책 적용중)' : '' %>
              </option>
            <% }); %>
          </select>
          <button type="submit" class="w-full h-[38px] text-sm font-medium rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">거래처 배정</button>
          <p class="text-xs text-gray-500">거래처는 계약가 정책을 하나만 가질 수 있습니다. 배정하면 이전 정책은 교체됩니다.</p>
        </form>
      <% } %>
    </div>

    <!-- 정책 설정 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 px-6 py-4">
      <h3 class="text-sm font-bold text-gray-900 mb-3">정책 설정</h3>
      <form action="/admin/b2b/price-policies/save" method="POST" class="space-y-3">
        <input type="hidden" name="id" value="<%= policy.id %>">
        <input type="hidden" name="policy_type" value="<%= policy.policy_type %>">
        <div>
          <label class="block text-sm font-medium text-gray-700">정책명</label>
          <input type="text" name="name" value="<%= policy.name %>" required class="<%= inputCls %>">
        </div>
        <% if (!isContract) { %>
          <div>
            <label class="block text-sm font-medium text-gray-700">적용 등급</label>
            <select name="tier_id" class="<%= inputCls %>">
              <% tiers.forEach(function(t) { %>
                <option value="<%= t.id %>" <%= policy.tier_id === t.id ? 'selected' : '' %>><%= t.tier_name %></option>
              <% }); %>
            </select>
          </div>
        <% } %>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700">적용 시작</label>
            <input type="date" name="valid_from" value="<%= dateVal(policy.valid_from) %>" class="<%= inputCls %>">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">적용 종료</label>
            <input type="date" name="valid_to" value="<%= dateVal(policy.valid_to) %>" class="<%= inputCls %>">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700">우선순위</label>
            <input type="number" name="priority" value="<%= policy.priority %>" class="<%= inputCls %>">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">상태</label>
            <select name="status" class="<%= inputCls %>">
              <option value="ACTIVE" <%= policy.status === 'ACTIVE' ? 'selected' : '' %>>사용</option>
              <option value="INACTIVE" <%= policy.status === 'INACTIVE' ? 'selected' : '' %>>미사용</option>
            </select>
          </div>
        </div>
        <button type="submit" class="w-full h-[38px] text-sm font-medium rounded-md bg-gray-800 text-white hover:bg-gray-900">저장</button>
      </form>
    </div>
  </div>
</div>

<script>
  // 상품 검색 — 관리자가 보고 있는 몰 기준. 선택하면 hidden 에 id 를 박는다.
  (function () {
    const input = document.getElementById('prodSearch');
    const box = document.getElementById('prodResults');
    const idEl = document.getElementById('prodId');
    const picked = document.getElementById('prodPicked');
    let timer = null;

    input.addEventListener('input', function () {
      clearTimeout(timer);
      const q = this.value.trim();
      if (q.length < 1) { box.classList.add('hidden'); box.innerHTML = ''; return; }
      timer = setTimeout(async function () {
        try {
          const res = await fetch('/admin/b2b/price-policies/product-search?q=' + encodeURIComponent(q));
          const data = await res.json();
          box.innerHTML = '';
          if (!data.products.length) {
            box.innerHTML = '<div class="px-3 py-2 text-sm text-gray-400">검색 결과가 없습니다</div>';
          } else {
            data.products.forEach(function (p) {
              const row = document.createElement('button');
              row.type = 'button';
              row.className = 'w-full text-left px-3 py-2 hover:bg-gray-50';
              row.innerHTML = '<span class="text-sm text-gray-900">' + p.name + '</span>'
                + '<span class="block text-xs text-gray-400">' + (p.product_code || ('ID ' + p.id))
                + ' · ' + Number(p.price).toLocaleString() + '원</span>';
              row.onclick = function () {
                idEl.value = p.id;
                picked.textContent = '선택: ' + p.name + ' (판매가 ' + Number(p.price).toLocaleString() + '원)';
                picked.classList.remove('hidden');
                box.classList.add('hidden');
                input.value = p.name;
              };
              box.appendChild(row);
            });
          }
          box.classList.remove('hidden');
        } catch (e) { /* 검색 실패는 조용히 무시 — 입력을 막지 않는다 */ }
      }, 250);
    });
  })();
</script>
