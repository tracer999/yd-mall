<%
const tabs = [
  { key: null, label: '전체' },
  { key: 'PENDING', label: '심사 대기' },
  { key: 'UNDER_REVIEW', label: '심사 중' },
  { key: 'APPROVED', label: '승인' },
  { key: 'SUSPENDED', label: '정지' },
  { key: 'REJECTED', label: '반려' },
];
const badge = {
  PENDING: 'bg-amber-100 text-amber-800 border-amber-400',
  UNDER_REVIEW: 'bg-blue-100 text-blue-800 border-blue-400',
  APPROVED: 'bg-green-100 text-green-800 border-green-400',
  SUSPENDED: 'bg-red-100 text-red-800 border-red-400',
  REJECTED: 'bg-gray-100 text-gray-700 border-gray-400',
};
const qs = (over) => {
  const p = new URLSearchParams();
  const s = over.status !== undefined ? over.status : status;
  if (s) p.set('status', s);
  if (keyword) p.set('q', keyword);
  if (over.page && over.page > 1) p.set('page', over.page);
  const str = p.toString();
  return '/admin/b2b/members' + (str ? '?' + str : '');
};
const totalPages = Math.max(1, Math.ceil(total / pageSize));
%>

<% if (message) { %>
  <div class="mb-4 rounded-md bg-green-50 border border-green-200 p-3 text-sm text-green-800"><%= message %></div>
<% } %>
<% if (error) { %>
  <div class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800"><%= error %></div>
<% } %>

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
  <div class="flex flex-wrap gap-1">
    <% tabs.forEach(function(t) { %>
      <a href="<%= qs({ status: t.key }) %>"
         class="px-3 py-1.5 text-sm rounded-md no-underline transition-colors <%= (status || null) === t.key ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100' %>">
        <%= t.label %><% if (t.key && countMap[t.key]) { %> <span class="ml-1 text-xs opacity-80">(<%= countMap[t.key] %>)</span><% } %>
      </a>
    <% }); %>
  </div>

  <form action="/admin/b2b/members" method="GET" class="flex gap-2 w-full sm:w-auto">
    <% if (status) { %><input type="hidden" name="status" value="<%= status %>"><% } %>
    <input type="text" name="q" value="<%= keyword %>" placeholder="상호·사업자번호·이메일"
           class="h-[38px] px-3 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 w-full sm:w-64">
    <button type="submit" class="h-[38px] px-4 text-sm font-medium rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">검색</button>
  </form>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100">
  <div class="overflow-x-auto">
    <table class="w-full text-sm text-left text-gray-500">
      <thead class="text-xs text-gray-700 uppercase bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="px-6 py-3">상호</th>
          <th class="px-6 py-3">사업자번호</th>
          <th class="px-6 py-3">대표자</th>
          <th class="px-6 py-3">신청 계정</th>
          <th class="px-6 py-3">등급</th>
          <th class="px-6 py-3">상태</th>
          <th class="px-6 py-3">신청일</th>
          <th class="px-6 py-3 text-right">관리</th>
        </tr>
      </thead>
      <tbody>
        <% if (rows.length > 0) { %>
          <% rows.forEach(function(r) { %>
            <tr class="bg-white border-b border-gray-100 hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4 font-medium text-gray-900"><%= r.company_name %></td>
              <td class="px-6 py-4"><%= formatBusinessNumber(r.business_number) %></td>
              <td class="px-6 py-4"><%= r.representative_name %></td>
              <td class="px-6 py-4"><%= r.email || '-' %></td>
              <td class="px-6 py-4"><%= r.tier_name || '-' %></td>
              <td class="px-6 py-4">
                <span class="text-xs font-medium px-2.5 py-0.5 rounded border <%= badge[r.status] || '' %>"><%= STATUS_LABEL[r.status] %></span>
              </td>
              <td class="px-6 py-4"><%= r.applied_at ? new Date(r.applied_at).toLocaleDateString('ko-KR') : '-' %></td>
              <td class="px-6 py-4 text-right">
                <a href="/admin/b2b/members/<%= r.id %>"
                   class="inline-flex items-center justify-center h-[38px] px-4 text-sm font-medium rounded-md border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100 no-underline">검토</a>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="8" class="px-6 py-12 text-center text-gray-400">
            <%= keyword || status ? '조건에 맞는 신청이 없습니다.' : '사업자 회원 신청이 아직 없습니다.' %>
          </td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPages > 1) { %>
  <div class="mt-4 flex justify-center gap-1">
    <% for (let i = 1; i <= totalPages; i++) { %>
      <a href="<%= qs({ page: i }) %>"
         class="px-3 py-1.5 text-sm rounded-md no-underline <%= i === page ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100' %>"><%= i %></a>
    <% } %>
  </div>
<% } %>
