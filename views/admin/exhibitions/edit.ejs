<%
  /*
   * 기획전 등록/수정
   *
   * 폼이 3개다. HTML 은 form 중첩을 허용하지 않으므로 반드시 형제로 둔다.
   *   #basicForm    기본정보·이미지·전시설정  → POST /admin/exhibitions/{add|:id/edit}  (multipart)
   *   #sectionsForm 내부 탭(섹션) 일괄 저장    → POST /admin/exhibitions/:id/sections
   *   #productsForm 상품 매핑 일괄 저장        → POST /admin/exhibitions/:id/products
   *
   * 상품 개별 삭제는 #productsForm 안에서 `formaction` 으로 목적지만 바꿔 보낸다
   * (form 을 중첩하지 않기 위한 표준 우회).
   *
   * 신규 등록 시에는 섹션·상품 패널을 숨긴다 — exhibition_id 가 없으면 매달 곳이 없다.
   */
  const isNew = !exhibition.id;
  const action = isNew ? '/admin/exhibitions/add' : `/admin/exhibitions/${exhibition.id}/edit`;
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');
  const _cfg = config || {};

  const PHASE_CLS = {
    UPCOMING: 'bg-blue-50 text-blue-700',
    ONGOING: 'bg-indigo-50 text-indigo-700',
    ENDED: 'bg-gray-100 text-gray-500',
  };

  const IMAGES = [
    { field: 'list_thumbnail',   column: 'list_thumbnail_url',    label: '목록 썸네일',      hint: '기획전 목록 카드에 쓰입니다. 정사각형 권장.' },
    // 기획전 상세는 상단 이미지 배너를 걸지 않는다(그 자리는 추천 상품 영역). 전문관만 노출된다.
    { field: 'pc_hero_image',    column: 'pc_hero_image_url',     label: 'PC 대표 이미지',   hint: '전문관 상세 상단에만 쓰입니다. 기획전 상세에는 노출되지 않고 공유 미리보기 대체 이미지로만 쓰입니다.' },
    { field: 'mobile_hero_image',column: 'mobile_hero_image_url', label: '모바일 대표 이미지', hint: '전문관 상세용. 없으면 PC 이미지를 그대로 씁니다.' },
    { field: 'og_image',         column: 'og_image_url',          label: 'OG 이미지',        hint: '카카오·페이스북 공유 미리보기.' },
  ];
%>

<div class="w-full">

  <div class="mb-6">
    <a href="/admin/exhibitions" class="text-sm text-gray-500 hover:text-gray-700 no-underline">
      <i class="bi bi-chevron-left"></i> 기획전 목록
    </a>
    <div class="mt-2 flex flex-wrap items-center gap-3">
      <h1 class="text-2xl font-bold text-gray-900"><%= title %></h1>
      <% if (!isNew && phase) { %>
        <span class="text-[11px] font-bold px-2 py-1 rounded <%= PHASE_CLS[phase] %>"><%= phaseLabels[phase] %></span>
      <% } %>
      <% if (!isNew && exhibition.status === 'PUBLISHED') { %>
        <a href="/exhibition/<%= encodeURIComponent(exhibition.slug) %>" target="_blank" rel="noopener"
           class="text-xs text-indigo-600 hover:text-indigo-800 no-underline">
          고객 화면에서 보기 <i class="bi bi-box-arrow-up-right"></i>
        </a>
      <% } %>
    </div>
  </div>

  <% if (saved) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800 flex items-center gap-2">
      <i class="bi bi-check-circle-fill"></i> 저장되었습니다.
    </div>
  <% } %>
  <% if (typeof notice !== 'undefined' && notice) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-blue-50 border border-blue-200 text-sm text-blue-800 flex items-center gap-2">
      <i class="bi bi-info-circle-fill"></i> <%= notice %>
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800 flex items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill mt-0.5"></i><span><%= error %></span>
    </div>
  <% } %>

  <%# ══════════ 1. 기본정보 · 이미지 · 전시설정 ══════════ %>
  <form id="basicForm" method="POST" action="<%= action %>" enctype="multipart/form-data" class="space-y-6">

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">기본 정보</h2>
      </div>
      <div class="p-5 space-y-5">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">기획전명 <span class="text-red-500">*</span></label>
            <input type="text" name="title" value="<%= exhibition.title %>" maxlength="200" required
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              고객 화면 주소 <span class="text-xs font-normal text-gray-400">(비우면 기획전명에서 자동 생성)</span>
            </label>
            <div class="flex items-center gap-1">
              <span class="text-xs text-gray-400 shrink-0">/exhibition/</span>
              <input type="text" name="slug" value="<%= exhibition.slug %>" maxlength="200"
                     class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
            </div>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">짧은 설명</label>
          <input type="text" name="summary" value="<%= exhibition.summary || '' %>" maxlength="500"
                 placeholder="목록 카드와 상세 헤더에 한 줄로 노출됩니다."
                 class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">
            상세 설명
          </label>
          <textarea name="description" rows="5" data-rich
                    class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm"><%= exhibition.description || '' %></textarea>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">기획전 유형</label>
            <select name="exhibition_type" id="exhibitionType" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
              <% types.forEach(function (t) { %>
                <option value="<%= t.value %>" <%= exhibition.exhibition_type === t.value ? 'selected' : '' %>><%= t.label %></option>
              <% }); %>
            </select>
            <p class="mt-1 text-xs text-gray-400">유형을 고르면 오른쪽에 그 유형에 필요한 설정이 나타납니다.</p>
          </div>

          <%#
            유형별 편성 범위 — 유형을 고르면 "무엇을 담을 수 있는 기획전인가"가 정해진다.
            여기서 고른 브랜드·카테고리가 아래 [상품 선택] 팝업의 검색 범위를 잠근다
            (서버도 같은 값으로 강제한다 — exhibitionController.scopeOf).
          %>
          <div class="sm:col-span-2">
            <%# ── 브랜드 유형 ── 브랜드가 1,300개가 넘어 select 로 못 쓴다. 눌러서 목록을 보고 고르는 검색형. %>
            <div data-type-panel="BRAND" class="hidden">
              <label class="block text-sm font-medium text-gray-700 mb-1.5">
                대상 브랜드 <span class="text-red-500">*</span>
              </label>
              <div class="relative">
                <input type="text" id="brandPicker" autocomplete="off"
                       placeholder="클릭해서 목록에서 고르거나, 브랜드명·초성으로 검색"
                       value="<%= typeof ownedBrandName !== 'undefined' && ownedBrandName ? ownedBrandName : '' %>"
                       class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
                <button type="button" id="brandClear"
                        class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-300 hover:text-gray-600 <%= exhibition.brand_category_id ? '' : 'hidden' %>">
                  <i class="bi bi-x-circle-fill text-sm"></i>
                </button>
                <div id="brandSuggest"
                     class="hidden absolute z-20 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-lg max-h-60 overflow-y-auto"></div>
              </div>
              <p class="mt-1 text-xs text-gray-400">
                <strong>브랜드 위크</strong>로 브랜드관·브랜드 허브 상단에 노출되고, 상품 선택 팝업이
                <strong>이 브랜드 상품만</strong> 보여줍니다.
              </p>
            </div>

            <%# ── 카테고리 유형 ── 3뎁스 종속 셀렉트. 대분류만 골라도 하위 상품까지 잡는다. %>
            <div data-type-panel="CATEGORY" class="hidden">
              <label class="block text-sm font-medium text-gray-700 mb-1.5">
                대상 카테고리 <span class="text-red-500">*</span>
              </label>
              <div class="flex flex-col sm:flex-row gap-2" data-cat-cascade="scope">
                <select data-lv="1" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm"><option value="">대분류</option></select>
                <select data-lv="2" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm" disabled><option value="">중분류</option></select>
                <select data-lv="3" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm" disabled><option value="">소분류</option></select>
              </div>
              <p class="mt-1 text-xs text-gray-400">
                고른 분류의 <strong>하위 분류까지</strong> 대상입니다. 대분류만 골라도 그 아래 상품이 모두 후보가 됩니다.
              </p>
            </div>

            <%# ── 그 외 유형 ── 범위를 잠그지 않는다. %>
            <div data-type-panel="FREE" class="hidden">
              <label class="block text-sm font-medium text-gray-700 mb-1.5">편성 범위</label>
              <div class="px-3 py-2.5 rounded-md bg-gray-50 border border-gray-200 text-sm text-gray-500">
                <i class="bi bi-check2-circle text-gray-400"></i>
                이 유형은 <strong>전체 상품</strong>에서 자유롭게 담을 수 있습니다.
                상품 선택 팝업에서 브랜드·카테고리로 좁혀 찾으세요.
              </div>
            </div>

            <%# 실제 저장값. 패널이 숨겨지면 값도 비워 유형과 어긋나지 않게 한다. %>
            <input type="hidden" name="brand_category_id" id="brandCategoryId" value="<%= exhibition.brand_category_id || '' %>">
            <input type="hidden" name="scope_category_id" id="scopeCategoryId" value="<%= _cfg.category_id || '' %>">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">상태</label>
            <select name="status" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
              <% statuses.forEach(function (s) { %>
                <option value="<%= s.value %>" <%= exhibition.status === s.value ? 'selected' : '' %>><%= s.label %></option>
              <% }); %>
            </select>
            <p class="mt-1 text-xs text-gray-400">고객 화면에는 <strong>발행</strong>만 노출됩니다.</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">상세 템플릿</label>
            <select name="detail_template_type" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
              <% templates.forEach(function (t) { %>
                <option value="<%= t.value %>" <%= exhibition.detail_template_type === t.value ? 'selected' : '' %>><%= t.label %></option>
              <% }); %>
            </select>
            <p class="mt-1 text-xs text-gray-400">현재는 기본 탭형만 렌더됩니다.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">시작일 <span class="text-red-500">*</span></label>
            <input type="datetime-local" name="start_at" value="<%= exhibition.start_at_input %>" required
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              종료일 <span class="text-xs font-normal text-gray-400">(비우면 무기한)</span>
            </label>
            <input type="datetime-local" name="end_at" value="<%= exhibition.end_at_input %>"
                   class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
          </div>
        </div>
        <p class="text-xs text-gray-400 -mt-2">
          예정 · 진행중 · 종료 배지는 이 기간에서 자동으로 계산됩니다. 따로 지정하지 않습니다.
        </p>

        <div class="flex flex-wrap gap-5">
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="list_visible" value="1" <%= exhibition.list_visible ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300">
            기획전 목록에 노출
          </label>
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="search_visible" value="1" <%= exhibition.search_visible ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300">
            사이트 검색 노출
          </label>
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="share_enabled" value="1" <%= exhibition.share_enabled ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300">
            공유 버튼 노출
          </label>
        </div>

      </div>
    </div>

    <%# ── 이미지 ─────────────────────────────────────── %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">이미지</h2>
      </div>
      <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-5">
        <% IMAGES.forEach(function (img) { %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5"><%= img.label %></label>
            <% if (exhibition[img.column]) { %>
              <div class="mb-2 flex items-center gap-3">
                <img src="<%= exhibition[img.column] %>" alt="" class="h-20 rounded border border-gray-100 object-contain bg-gray-50">
                <label class="inline-flex items-center gap-1.5 text-xs text-red-600">
                  <input type="checkbox" name="<%= img.field %>_clear" value="1" class="w-3.5 h-3.5 rounded border-gray-300">
                  삭제
                </label>
              </div>
            <% } %>
            <input type="file" name="<%= img.field %>" accept="image/*"
                   class="w-full text-sm text-gray-600 file:mr-3 file:px-3 file:py-1.5 file:rounded file:border-0 file:text-xs file:bg-gray-100 file:text-gray-700">
            <p class="mt-1 text-xs text-gray-400"><%= img.hint %></p>
          </div>
        <% }); %>
      </div>
    </div>

    <%# ── 전시 설정 ──────────────────────────────────── %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
        <h2 class="text-base font-bold text-gray-800">전시 설정</h2>
      </div>
      <div class="p-5 space-y-5">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">종료 후 접근</label>
            <select name="ended_access_policy" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
              <% endedAccessPolicies.forEach(function (p) { %>
                <option value="<%= p.value %>" <%= exhibition.ended_access_policy === p.value ? 'selected' : '' %>><%= p.label %></option>
              <% }); %>
            </select>
            <p class="mt-1 text-xs text-gray-400">차단을 고르면 종료 후 목록에서도 사라집니다.</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">종료 후 구매</label>
            <select name="ended_purchase_policy" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
              <% endedPurchasePolicies.forEach(function (p) { %>
                <option value="<%= p.value %>" <%= exhibition.ended_purchase_policy === p.value ? 'selected' : '' %>><%= p.label %></option>
              <% }); %>
            </select>
          </div>
        </div>

        <label class="inline-flex items-center gap-2 text-sm text-gray-700">
          <input type="checkbox" name="hide_sold_out" value="1" <%= _cfg.hide_sold_out ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300">
          품절 상품 숨김 <span class="text-xs text-gray-400">(끄면 SOLD OUT 표시로 노출)</span>
        </label>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">
            상단 추천 영역 제목 <span class="text-xs font-normal text-gray-400">(비우면 '추천 상품')</span>
          </label>
          <input type="text" name="recommend_title" value="<%= _cfg.recommend_title || '' %>" maxlength="50"
                 placeholder="추천 상품"
                 class="w-full sm:w-80 px-3 py-2 rounded-md border border-gray-200 text-sm">
          <p class="mt-1 text-xs text-gray-400">
            상세 화면 맨 위에 나오는 영역의 제목입니다. 아래 상품 연결에서 <strong>추천</strong>을 켠 상품만 이 영역에 노출됩니다.
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">
            안내 · 유의사항 <span class="text-xs font-normal text-gray-400">(상세 하단에 노출)</span>
          </label>
          <textarea name="notice" rows="4" data-rich
                    class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm"><%= _cfg.notice || '' %></textarea>
        </div>

      </div>
    </div>

    <div class="flex items-center justify-end gap-2">
      <a href="/admin/exhibitions" class="px-4 py-2 text-sm rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50 no-underline">취소</a>
      <button type="submit" class="px-5 py-2 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
        <%= isNew ? '등록하고 계속 편집' : '기본 정보 저장' %>
      </button>
    </div>
  </form>

  <% if (isNew) { %>
    <div class="mt-8 px-5 py-6 rounded-xl border border-dashed border-gray-300 bg-gray-50 text-center">
      <p class="text-sm text-gray-500">
        <i class="bi bi-info-circle"></i>
        먼저 기본 정보를 저장하면 <strong>내부 탭(섹션)</strong>과 <strong>상품 연결</strong>을 편집할 수 있습니다.
      </p>
    </div>
  <% } else { %>

  <%# ══════════ 2. 내부 탭(섹션) ══════════ %>
  <div class="mt-8 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 bg-gray-50 flex items-center justify-between">
      <div>
        <h2 class="text-base font-bold text-gray-800">내부 탭 (섹션)</h2>
        <p class="mt-0.5 text-xs text-gray-500">
          상세 화면의 탭입니다. <strong>전체</strong> 탭은 항상 자동으로 맨 앞에 붙습니다.
        </p>
      </div>
      <button type="button" id="addSectionBtn"
              class="text-xs px-3 py-1.5 rounded border border-gray-200 text-gray-700 hover:bg-gray-50">
        <i class="bi bi-plus-lg"></i> 섹션 추가
      </button>
    </div>

    <form id="sectionsForm" method="POST" action="/admin/exhibitions/<%= exhibition.id %>/sections">
      <div class="p-5">
        <div id="sectionList" class="space-y-3">
          <% sections.forEach(function (s, i) { %>
            <div class="section-row rounded-lg border border-gray-200 p-4" data-index="<%= i %>">
              <input type="hidden" name="sections[<%= i %>][id]" value="<%= s.id %>">
              <div class="grid grid-cols-1 sm:grid-cols-12 gap-3 items-start">
                <div class="sm:col-span-3">
                  <label class="block text-xs text-gray-500 mb-1">표시명</label>
                  <input type="text" name="sections[<%= i %>][section_name]" value="<%= s.section_name %>" maxlength="100"
                         class="w-full px-2.5 py-1.5 rounded border border-gray-200 text-sm">
                </div>
                <%#
                  섹션 코드는 탭 주소(?tab=)로 쓰이는 식별자다. 사용자가 지어내지 않는다(§33).
                  서버가 표시명에서 만들며(exhibitionController: `section_code || name`),
                  기존 행은 값을 그대로 실어 보내 주소가 바뀌지 않게 한다.
                %>
                <div class="sm:col-span-3">
                  <input type="hidden" name="sections[<%= i %>][section_code]" value="<%= s.section_code %>">
                  <label class="block text-xs text-gray-500 mb-1">탭 주소</label>
                  <p class="px-2.5 py-1.5 text-sm text-gray-400 truncate" title="<%= s.section_code %>">?tab=<%= s.section_code %></p>
                </div>
                <div class="sm:col-span-2">
                  <label class="block text-xs text-gray-500 mb-1">유형</label>
                  <select name="sections[<%= i %>][section_type]" data-section-type
                          class="w-full px-2.5 py-1.5 rounded border border-gray-200 text-sm">
                    <% sectionTypes.forEach(function (t) { %>
                      <option value="<%= t.value %>" <%= s.section_type === t.value ? 'selected' : '' %>><%= t.label %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="sm:col-span-3 flex items-center gap-3 pt-5">
                  <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
                    <input type="checkbox" name="sections[<%= i %>][is_tab]" value="1" <%= s.is_tab ? 'checked' : '' %> class="w-3.5 h-3.5 rounded border-gray-300">
                    탭 노출
                  </label>
                  <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
                    <input type="checkbox" name="sections[<%= i %>][is_active]" value="1" <%= s.is_active ? 'checked' : '' %> class="w-3.5 h-3.5 rounded border-gray-300">
                    사용
                  </label>
                </div>
                <div class="sm:col-span-1 pt-5 text-right">
                  <label class="inline-flex items-center gap-1 text-xs text-red-600">
                    <input type="checkbox" name="sections[<%= i %>][_delete]" value="1" class="w-3.5 h-3.5 rounded border-gray-300">
                    삭제
                  </label>
                </div>
              </div>
              <div class="mt-3 <%= s.section_type === 'HTML' ? '' : 'hidden' %>" data-html-panel>
                <label class="block text-xs text-gray-500 mb-1">내용</label>
                <textarea name="sections[<%= i %>][html]" rows="3" data-rich
                          class="w-full px-2.5 py-1.5 rounded border border-gray-200 text-sm"><%= (s.config && s.config.html) || '' %></textarea>
              </div>
            </div>
          <% }); %>
        </div>

        <% if (sections.length === 0) { %>
          <p id="sectionEmpty" class="py-8 text-center text-sm text-gray-500">
            섹션이 없습니다. 섹션 없이도 상품을 담으면 <strong>전체</strong> 탭 하나로 노출됩니다.
          </p>
        <% } %>

        <div class="mt-4 px-3 py-2 rounded bg-amber-50 border border-amber-200 text-xs text-amber-800">
          <i class="bi bi-exclamation-triangle-fill"></i>
          섹션을 삭제하면 <strong>그 섹션에 배정된 상품 연결도 함께 사라집니다</strong>. 상품을 남기려면
          먼저 아래 상품 목록에서 섹션을 <em>전체 탭</em> 으로 옮기세요.
        </div>
      </div>

      <div class="px-5 py-3 border-t border-gray-100 bg-gray-50 text-right">
        <button type="submit" class="px-4 py-2 text-sm font-semibold rounded-md bg-gray-800 text-white hover:bg-gray-900">
          섹션 저장
        </button>
      </div>
    </form>
  </div>

  <%# ══════════ 3. 상품 연결 ══════════ %>
  <div class="mt-8 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 bg-gray-50">
      <h2 class="text-base font-bold text-gray-800">상품 연결 <span class="text-gray-400 font-normal">(<%= products.length %>개)</span></h2>
      <p class="mt-0.5 text-xs text-gray-500">
        섹션을 지정하지 않은 상품은 <strong>전체</strong> 탭에만 노출됩니다.
      </p>
      <p class="mt-1 text-xs text-gray-500">
        <strong>상단 추천</strong>을 켠 상품은 상세 화면 <strong>맨 위 추천 영역</strong>에 크게 나옵니다(최대 8개).
        아래 목록에서도 그대로 보입니다.
        <span id="recommendCount" class="ml-1 font-semibold text-indigo-600"></span>
      </p>
    </div>

    <%#
      상품 담기 — 검색어를 외워 한 건씩 담던 방식을 팝업 다중 선택으로 바꿨다.
      담을 섹션을 먼저 고르고 [상품 선택]을 누르면, 그 섹션 기준으로 이미 담긴 상품이 표시된다.
    %>
    <div class="p-5 border-b border-gray-100 bg-gray-50/40">
      <div class="flex flex-col sm:flex-row sm:items-end gap-3">
        <div class="sm:w-64">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">담을 위치</label>
          <select id="exhTargetSection" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
            <option value="">전체 탭 (섹션 미배정)</option>
            <% sections.filter(s => s.is_active).forEach(function (s) { %>
              <option value="<%= s.id %>"><%= s.section_name %></option>
            <% }); %>
          </select>
        </div>
        <button type="button" id="openProductPicker"
                class="px-4 py-2 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700">
          <i class="bi bi-search"></i> 상품 선택
        </button>
        <p class="text-xs text-gray-500 sm:pb-2.5">
          <% if (scope.brandId) { %>
            <i class="bi bi-lock-fill text-gray-400"></i>
            <strong>브랜드 기획전</strong>입니다 — <strong><%= ownedBrandName || '지정 브랜드' %></strong> 상품만 담을 수 있습니다.
          <% } else if (scope.categoryId) { %>
            <i class="bi bi-lock-fill text-gray-400"></i>
            <strong>카테고리 기획전</strong>입니다 — 지정한 카테고리와 그 하위 상품만 담을 수 있습니다.
          <% } else if (exhibition.exhibition_type === 'BRAND') { %>
            <i class="bi bi-exclamation-triangle-fill text-amber-500"></i>
            브랜드 기획전인데 <strong>대상 브랜드가 비어 있습니다</strong>. 위에서 지정하면 그 브랜드 상품만 보입니다.
          <% } else if (exhibition.exhibition_type === 'CATEGORY') { %>
            <i class="bi bi-exclamation-triangle-fill text-amber-500"></i>
            카테고리 기획전인데 <strong>대상 카테고리가 비어 있습니다</strong>. 위에서 지정하면 그 범위만 보입니다.
          <% } else { %>
            팝업에서 브랜드·카테고리로 좁혀 여러 상품을 한 번에 담을 수 있습니다.
          <% } %>
        </p>
      </div>
    </div>

    <form id="productsForm" method="POST" action="/admin/exhibitions/<%= exhibition.id %>/products">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs font-semibold text-gray-500 bg-gray-50/60">
              <th class="px-3 py-2.5 w-16">순서</th>
              <th class="px-3 py-2.5 w-16">이미지</th>
              <th class="px-3 py-2.5">상품명</th>
              <th class="px-3 py-2.5 w-40">섹션</th>
              <th class="px-3 py-2.5 w-28">배지</th>
              <th class="px-3 py-2.5 w-52">MD 코멘트</th>
              <%# '고정'(목록 안에서 위로)과 '추천'(상단 별도 영역)은 다른 기능이라 열을 나눈다 %>
              <th class="px-3 py-2.5 w-20 text-center">상단<br>추천</th>
              <th class="px-3 py-2.5 w-32 text-center">노출 / 구매 / 고정</th>
              <th class="px-3 py-2.5 w-16 text-center">삭제</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% if (products.length === 0) { %>
              <tr><td colspan="9" class="px-6 py-12 text-center text-gray-500">담긴 상품이 없습니다.</td></tr>
            <% } %>
            <% products.forEach(function (p, i) { %>
              <tr>
                <td class="px-3 py-2.5">
                  <%# hidden input 을 tr 직속에 두면 브라우저가 테이블 밖으로 밀어낸다. 반드시 td 안. %>
                  <input type="hidden" name="products[<%= i %>][mapping_id]" value="<%= p.id %>">
                  <input type="number" name="products[<%= i %>][sort_order]" value="<%= p.sort_order %>" min="0"
                         class="w-16 px-2 py-1 rounded border border-gray-200 text-sm">
                </td>
                <td class="px-3 py-2.5">
                  <img src="<%= p.main_image || '/images/placeholder.png' %>" alt=""
                       class="w-10 h-10 rounded object-cover bg-gray-100">
                </td>
                <td class="px-3 py-2.5">
                  <div class="text-gray-900 truncate max-w-xs" title="<%= p.name %>"><%= p.name %></div>
                  <div class="text-xs text-gray-400">
                    <%= won(p.price) %>원
                    <% if (p.product_status !== 'ON') { %>
                      <span class="ml-1 px-1 rounded bg-gray-100 text-gray-500"><%= p.product_status %></span>
                    <% } %>
                  </div>
                </td>
                <td class="px-3 py-2.5">
                  <select name="products[<%= i %>][section_id]" class="w-full px-2 py-1 rounded border border-gray-200 text-sm">
                    <option value="">전체 탭</option>
                    <% sections.forEach(function (s) { %>
                      <option value="<%= s.id %>" <%= Number(p.section_id) === Number(s.id) ? 'selected' : '' %>><%= s.section_name %></option>
                    <% }); %>
                  </select>
                </td>
                <td class="px-3 py-2.5">
                  <input type="text" name="products[<%= i %>][display_badge]" value="<%= p.display_badge || '' %>" maxlength="50"
                         placeholder="단독" class="w-full px-2 py-1 rounded border border-gray-200 text-sm">
                </td>
                <td class="px-3 py-2.5">
                  <input type="text" name="products[<%= i %>][display_comment]" value="<%= p.display_comment || '' %>" maxlength="200"
                         placeholder="MD 한마디" class="w-full px-2 py-1 rounded border border-gray-200 text-sm">
                </td>
                <td class="px-3 py-2.5 text-center">
                  <label title="상세 화면 맨 위 추천 영역에 노출합니다 (최대 8개)">
                    <input type="checkbox" name="products[<%= i %>][is_recommended]" value="1"
                           <%= p.is_recommended ? 'checked' : '' %>
                           class="w-4 h-4 rounded border-gray-300 recommend-check">
                  </label>
                </td>
                <td class="px-3 py-2.5">
                  <div class="flex items-center justify-center gap-2">
                    <label title="노출"><input type="checkbox" name="products[<%= i %>][visible]" value="1" <%= p.visible ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300"></label>
                    <label title="구매 허용"><input type="checkbox" name="products[<%= i %>][purchase_enabled]" value="1" <%= p.purchase_enabled ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300"></label>
                    <label title="이 목록 안에서 위로 고정 (추천 영역과 다릅니다)"><input type="checkbox" name="products[<%= i %>][is_fixed]" value="1" <%= p.is_fixed ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300"></label>
                  </div>
                </td>
                <td class="px-3 py-2.5 text-center">
                  <%# form 중첩 대신 formaction 으로 목적지만 바꾼다 %>
                  <button type="submit"
                          formaction="/admin/exhibitions/<%= exhibition.id %>/products/<%= p.id %>/delete"
                          formnovalidate
                          onclick="return confirm('이 상품을 기획전에서 제외합니다.');"
                          class="text-xs px-2 py-1 rounded border border-red-200 text-red-600 hover:bg-red-50">제외</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (products.length > 0) { %>
        <div class="px-5 py-3 border-t border-gray-100 bg-gray-50 text-right">
          <button type="submit" class="px-4 py-2 text-sm font-semibold rounded-md bg-gray-800 text-white hover:bg-gray-900">
            상품 설정 저장
          </button>
        </div>
      <% } %>
    </form>
  </div>

  <%# ══════════ 상품 선택 팝업 ══════════
      #productsForm 밖의 최상위 형제다 — form 중첩이 되지 않도록 반드시 여기에 둔다. %>
  <div id="productPickerModal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="absolute inset-0 bg-black/40" data-picker-close></div>

    <form method="POST" action="/admin/exhibitions/<%= exhibition.id %>/products/add"
          class="relative mx-auto my-6 w-full max-w-5xl px-4">
      <input type="hidden" name="section_id" id="pickerSectionId" value="">

      <div class="bg-white rounded-xl shadow-2xl flex flex-col max-h-[calc(100vh-3rem)]">

        <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
          <div>
            <h3 class="text-base font-bold text-gray-800">상품 선택</h3>
            <p class="mt-0.5 text-xs text-gray-500">
              담을 위치: <strong id="pickerSectionLabel" class="text-gray-700">전체 탭</strong>
              <span class="text-gray-300">·</span>
              체크한 상품을 한 번에 담습니다.
            </p>
          </div>
          <button type="button" data-picker-close class="text-gray-400 hover:text-gray-700">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>

        <%# ── 필터 ── 유형이 범위를 잠갔으면 그 조건은 바꿀 수 없다(서버도 강제). %>
        <div class="px-5 py-4 border-b border-gray-100 bg-gray-50/60 space-y-3">
          <div class="flex flex-col sm:flex-row gap-2">
            <input type="text" id="pickerQuery" placeholder="상품명 · 상품코드로 검색 (비워두면 전체)"
                   class="flex-1 px-3 py-2 rounded-md border border-gray-200 text-sm">
            <button type="button" id="pickerSearchBtn"
                    class="px-4 py-2 text-sm rounded-md border border-gray-200 bg-white text-gray-700 hover:bg-gray-50">
              검색
            </button>
          </div>

          <% if (scope.brandId) { %>
            <div class="px-3 py-2 rounded-md bg-white border border-gray-200 text-sm text-gray-600">
              <i class="bi bi-lock-fill text-gray-400"></i>
              브랜드 <strong class="text-gray-900"><%= ownedBrandName || '지정 브랜드' %></strong> 상품만 표시됩니다.
            </div>
          <% } else { %>
            <div class="relative">
              <input type="hidden" id="pickerBrandId" value="">
              <input type="text" id="pickerBrandPicker" autocomplete="off"
                     placeholder="브랜드로 좁히기 — 클릭해서 목록에서 고르거나 검색"
                     class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm">
              <button type="button" id="pickerBrandClear"
                      class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-300 hover:text-gray-600 hidden">
                <i class="bi bi-x-circle-fill text-sm"></i>
              </button>
              <div id="pickerBrandSuggest"
                   class="hidden absolute z-20 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-lg max-h-60 overflow-y-auto"></div>
            </div>
          <% } %>

          <div class="flex flex-col sm:flex-row gap-2" data-cat-cascade="picker"
               data-root="<%= scope.categoryId || '' %>">
            <select data-lv="1" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm"><option value="">대분류</option></select>
            <select data-lv="2" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm" disabled><option value="">중분류</option></select>
            <select data-lv="3" class="w-full px-3 py-2 rounded-md border border-gray-200 text-sm" disabled><option value="">소분류</option></select>
          </div>
          <% if (scope.categoryId) { %>
            <p class="text-xs text-gray-500">
              <i class="bi bi-lock-fill text-gray-400"></i>
              카테고리 기획전이라 <strong>지정한 카테고리 안</strong>에서만 좁힐 수 있습니다.
            </p>
          <% } %>
        </div>

        <%# ── 결과 ── %>
        <div class="px-5 py-2.5 border-b border-gray-100 flex items-center justify-between text-xs text-gray-500">
          <label class="inline-flex items-center gap-2">
            <input type="checkbox" id="pickerCheckAll" class="w-4 h-4 rounded border-gray-300">
            <span>이 목록 전체 선택</span>
          </label>
          <span>
            <span class="text-gray-400">검색·필터를 바꾸면 선택이 초기화됩니다</span>
            <span class="text-gray-300 mx-1">·</span>
            <span id="pickerTotal">—</span>
          </span>
        </div>

        <div id="pickerResults" class="flex-1 overflow-y-auto divide-y divide-gray-100 min-h-[12rem]">
          <p class="py-16 text-center text-sm text-gray-400">불러오는 중…</p>
        </div>

        <div id="pickerMoreWrap" class="px-5 py-3 border-t border-gray-100 text-center hidden">
          <button type="button" id="pickerMore"
                  class="px-4 py-2 text-sm rounded-md border border-gray-200 text-gray-600 hover:bg-gray-50">
            더 보기
          </button>
        </div>

        <div class="px-5 py-3 border-t border-gray-100 bg-gray-50 flex items-center justify-between">
          <p class="text-sm text-gray-600"><strong id="pickerCount" class="text-indigo-600">0</strong>개 선택됨</p>
          <div class="flex items-center gap-2">
            <button type="button" data-picker-close
                    class="px-4 py-2 text-sm rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50">취소</button>
            <button type="submit" id="pickerSubmit" disabled
                    class="px-5 py-2 text-sm font-semibold rounded-md bg-indigo-600 text-white hover:bg-indigo-700 disabled:opacity-40 disabled:cursor-not-allowed">
              선택한 상품 담기
            </button>
          </div>
        </div>
      </div>
    </form>
  </div>

  <% } %>

  <%# 유형별 설정·상품 팝업이 함께 쓰는 카테고리 트리(NORMAL, 최대 3뎁스) %>
  <script id="exh-cat-tree" type="application/json"><%- JSON.stringify((productCategories || []).map(function (c) {
    return { id: c.id, name: c.name, parent_id: c.parent_id, depth: c.depth };
  })) %></script>
</div>

<script>
(function () {
  const exhibitionId = <%- JSON.stringify(exhibition.id) %>;

  /* HTML 유형 섹션에서만 HTML 입력창을 보인다. */
  function bindSectionType(row) {
    const sel = row.querySelector('[data-section-type]');
    const panel = row.querySelector('[data-html-panel]');
    if (!sel || !panel) return;
    const sync = () => panel.classList.toggle('hidden', sel.value !== 'HTML');
    sel.addEventListener('change', sync);
    sync();
  }
  document.querySelectorAll('.section-row').forEach(bindSectionType);

  /* 섹션 행 추가 — 인덱스는 기존 행 수부터 이어 붙인다(서버는 배열 순서를 sort_order 로 쓴다). */
  const addBtn = document.getElementById('addSectionBtn');
  const list = document.getElementById('sectionList');
  addBtn && addBtn.addEventListener('click', () => {
    const i = list.querySelectorAll('.section-row').length + 1000; // 기존 인덱스와 충돌하지 않게
    const row = document.createElement('div');
    row.className = 'section-row rounded-lg border border-indigo-200 bg-indigo-50/30 p-4';
    row.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-12 gap-3 items-start">
        <div class="sm:col-span-3">
          <label class="block text-xs text-gray-500 mb-1">표시명</label>
          <input type="text" name="sections[${i}][section_name]" maxlength="100" placeholder="MD추천"
                 class="w-full px-2.5 py-1.5 rounded border border-gray-200 text-sm">
        </div>
        <div class="sm:col-span-3">
          <input type="hidden" name="sections[${i}][section_code]" value="">
          <label class="block text-xs text-gray-500 mb-1">탭 주소</label>
          <p class="px-2.5 py-1.5 text-sm text-gray-400">표시명에서 자동 생성</p>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-xs text-gray-500 mb-1">유형</label>
          <select name="sections[${i}][section_type]" data-section-type class="w-full px-2.5 py-1.5 rounded border border-gray-200 text-sm">
            <% sectionTypes.forEach(function (t) { %>
              <option value="<%= t.value %>"><%= t.label %></option>
            <% }); %>
          </select>
        </div>
        <div class="sm:col-span-3 flex items-center gap-3 pt-5">
          <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
            <input type="checkbox" name="sections[${i}][is_tab]" value="1" checked class="w-3.5 h-3.5 rounded border-gray-300"> 탭 노출
          </label>
          <label class="inline-flex items-center gap-1.5 text-xs text-gray-600">
            <input type="checkbox" name="sections[${i}][is_active]" value="1" checked class="w-3.5 h-3.5 rounded border-gray-300"> 사용
          </label>
        </div>
        <div class="sm:col-span-1 pt-5 text-right">
          <button type="button" class="text-xs text-gray-400 hover:text-red-600" data-remove-row>제거</button>
        </div>
      </div>
      <div class="mt-3 hidden" data-html-panel>
        <label class="block text-xs text-gray-500 mb-1">내용</label>
        <textarea name="sections[${i}][html]" rows="3" data-rich class="w-full px-2.5 py-1.5 rounded border border-gray-200 text-sm"></textarea>
      </div>`;
    list.appendChild(row);
    bindSectionType(row);
    // 새로 추가된 행의 내용 입력칸도 에디터로 바꾼다(페이지 로드 후 생긴 요소라 직접 붙여야 한다).
    if (window.ydRichEditor) row.querySelectorAll('textarea[data-rich]').forEach(window.ydRichEditor.attach);
    const empty = document.getElementById('sectionEmpty');
    if (empty) empty.style.display = 'none';
  });

  list && list.addEventListener('click', (e) => {
    if (e.target.closest('[data-remove-row]')) e.target.closest('.section-row').remove();
  });

  /* 상단 추천 개수 — 8개까지만 화면에 나가므로 넘기면 그 자리에서 알려준다. */
  const RECOMMEND_MAX = 8;
  const recommendLabel = document.getElementById('recommendCount');
  if (recommendLabel) {
    const checks = document.querySelectorAll('.recommend-check');
    const syncRecommend = () => {
      const n = [...checks].filter(c => c.checked).length;
      if (!n) { recommendLabel.textContent = ''; return; }
      recommendLabel.textContent = n > RECOMMEND_MAX
        ? `현재 ${n}개 선택 — 앞의 ${RECOMMEND_MAX}개만 노출됩니다`
        : `현재 ${n}개 선택`;
      recommendLabel.classList.toggle('text-red-600', n > RECOMMEND_MAX);
      recommendLabel.classList.toggle('text-indigo-600', n <= RECOMMEND_MAX);
    };
    checks.forEach(c => c.addEventListener('change', syncRecommend));
    syncRecommend();
  }
})();
</script>

<script>
/*
 * 공용 위젯 — 유형별 설정과 상품 선택 팝업이 같은 것을 두 번 만들지 않도록 팩토리로 둔다.
 *   ydExhBrandPicker  브랜드 검색형 선택. 브랜드가 1,300개가 넘어 select 를 못 쓴다.
 *                     빈 입력으로 열면 서버가 '이 몰에 상품이 있는 브랜드'를 준다(셀렉트처럼 목록부터 보인다).
 *   ydExhCascade      카테고리 3뎁스 종속 셀렉트. root 를 주면 그 아래에서만 고른다.
 */
window.ydExh = (function () {
  let CAT_TREE = [];
  try { CAT_TREE = JSON.parse(document.getElementById('exh-cat-tree').textContent || '[]'); } catch (e) { CAT_TREE = []; }
  const byId = {};
  CAT_TREE.forEach(function (c) { byId[c.id] = c; });
  const childrenOf = (pid) => CAT_TREE.filter(c => (pid == null || pid === '')
    ? (c.parent_id == null)
    : String(c.parent_id) === String(pid));

  /** 브랜드 검색형 선택. onPick(id|'') 로 바깥에 알린다. */
  function brandPicker(opts) {
    const { input, hidden, box, clear, onPick } = opts;
    if (!input || !box) return null;
    let timer = null;
    const close = () => box.classList.add('hidden');
    const notify = () => onPick && onPick(hidden ? hidden.value : '');

    async function load(q) {
      try {
        const res = await fetch('/admin/brands/search.json?q=' + encodeURIComponent(q || ''));
        const rows = (await res.json()).brands || [];
        if (!rows.length) {
          box.innerHTML = '<div class="px-3 py-3 text-sm text-gray-400">'
            + (q ? '검색 결과가 없습니다.' : '이 몰에 상품이 등록된 브랜드가 없습니다.') + '</div>';
        } else {
          box.innerHTML = rows.map(function (b) {
            const name = String(b.name || '');
            const esc = (s) => String(s).replace(/[&<>"']/g, (ch) => ({
              '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]));
            return '<button type="button" data-id="' + b.id + '" data-name="' + esc(name) + '" '
                 + 'class="w-full text-left px-3 py-2 hover:bg-gray-50 flex items-center gap-2">'
                 + '<span class="text-sm text-gray-900">' + esc(name) + '</span>'
                 + (b.name_en ? '<span class="text-xs text-gray-400">' + esc(b.name_en) + '</span>' : '')
                 + '<span class="ml-auto text-xs text-gray-400">상품 ' + Number(b.product_count || 0).toLocaleString() + '</span>'
                 + '</button>';
          }).join('');
        }
        box.classList.remove('hidden');
      } catch (e) { close(); }
    }

    // 클릭만 해도 목록이 열린다 — "브랜드명을 알아야 고를 수 있는" 상태를 만들지 않는다.
    input.addEventListener('focus', function () { if (!input.value.trim()) load(''); });
    input.addEventListener('input', function () {
      if (hidden) hidden.value = '';   // 텍스트를 고치면 선택이 풀린다
      if (clear) clear.classList.add('hidden');
      notify();
      clearTimeout(timer);
      timer = setTimeout(() => load(input.value.trim()), 200);
    });

    box.addEventListener('click', function (e) {
      const btn = e.target.closest('button[data-id]');
      if (!btn) return;
      if (hidden) hidden.value = btn.dataset.id;
      input.value = btn.dataset.name;
      if (clear) clear.classList.remove('hidden');
      close();
      notify();
    });

    if (clear) clear.addEventListener('click', function () {
      if (hidden) hidden.value = '';
      input.value = '';
      clear.classList.add('hidden');
      close();
      notify();
    });

    document.addEventListener('click', function (e) {
      if (!box.contains(e.target) && e.target !== input) close();
    });

    return { close };
  }

  /**
   * 카테고리 종속 셀렉트.
   * @param {HTMLElement} root  data-lv=1..3 select 를 가진 컨테이너
   * @param {{rootId?:string|number, onChange?:Function}} opts rootId 를 주면 그 하위만 고른다
   * @returns {{value:Function, preselect:Function}} value() = 가장 깊이 고른 id('' 가능)
   */
  function cascade(root, opts) {
    opts = opts || {};
    const sels = [1, 2, 3].map(n => root.querySelector('[data-lv="' + n + '"]'));
    if (sels.some(s => !s)) return { value: () => '', preselect: () => {} };
    const PH = ['대분류', '중분류', '소분류'];
    const rootId = opts.rootId ? String(opts.rootId) : null;

    function fill(sel, parentId, ph) {
      sel.innerHTML = '';
      const o0 = document.createElement('option');
      o0.value = ''; o0.textContent = ph;
      sel.appendChild(o0);
      childrenOf(parentId).forEach(function (c) {
        const o = document.createElement('option');
        o.value = String(c.id); o.textContent = c.name;
        sel.appendChild(o);
      });
      // 고를 것이 없으면 비활성 — 3뎁스가 없는 분류에서 빈 셀렉트를 열게 두지 않는다.
      sel.disabled = sel.options.length <= 1;
    }
    function clearFrom(idx) {
      for (let i = idx; i < 3; i++) {
        sels[i].innerHTML = '<option value="">' + PH[i] + '</option>';
        sels[i].value = '';
        sels[i].disabled = true;
      }
    }
    function value() {
      for (let i = 2; i >= 0; i--) if (sels[i].value) return sels[i].value;
      return rootId || '';
    }

    sels.forEach(function (sel, idx) {
      sel.addEventListener('change', function () {
        clearFrom(idx + 1);
        if (idx < 2 && sel.value) fill(sels[idx + 1], sel.value, PH[idx + 1]);
        opts.onChange && opts.onChange(value());
      });
    });

    function chainOf(id) {
      const out = [];
      let cur = byId[id];
      while (cur) { out.unshift(cur); cur = (cur.parent_id != null) ? byId[cur.parent_id] : null; }
      return out;
    }

    /** 저장된 id 로 체인을 되살린다. rootId 아래 상대 경로로 그린다. */
    function preselect(id) {
      fill(sels[0], rootId, PH[0]);
      clearFrom(1);
      if (!id || !byId[id]) return;
      let chain = chainOf(id);
      if (rootId) {
        const at = chain.findIndex(c => String(c.id) === rootId);
        chain = at >= 0 ? chain.slice(at + 1) : [];
      }
      chain = chain.slice(0, 3);
      for (let i = 0; i < chain.length; i++) {
        sels[i].value = String(chain[i].id);
        if (i < 2) fill(sels[i + 1], chain[i].id, PH[i + 1]);
      }
    }

    fill(sels[0], rootId, PH[0]);
    return { value, preselect };
  }

  return { brandPicker, cascade, childrenOf };
})();
</script>

<script>
/*
 * 유형별 설정 — 유형을 고르면 그 유형에 필요한 것만 보인다.
 *
 * 숨겨진 패널의 값은 비운다. 브랜드 기획전으로 저장했다가 테마로 바꿨는데 브랜드 귀속이
 * 남아 있으면, 화면에 보이지 않는 조건이 상품 편성 범위를 계속 잠근다.
 */
(function () {
  const typeSel = document.getElementById('exhibitionType');
  if (!typeSel) return;
  const brandHidden = document.getElementById('brandCategoryId');
  const catHidden = document.getElementById('scopeCategoryId');
  const panels = {};
  document.querySelectorAll('[data-type-panel]').forEach(function (el) { panels[el.dataset.typePanel] = el; });

  const brandInput = document.getElementById('brandPicker');
  window.ydExh.brandPicker({
    input: brandInput,
    hidden: brandHidden,
    box: document.getElementById('brandSuggest'),
    clear: document.getElementById('brandClear'),
  });

  const scopeBox = document.querySelector('[data-cat-cascade="scope"]');
  const scopeCascade = scopeBox && window.ydExh.cascade(scopeBox, {
    onChange: function (v) { if (catHidden) catHidden.value = v || ''; },
  });
  if (scopeCascade && catHidden && catHidden.value) scopeCascade.preselect(Number(catHidden.value));

  function sync() {
    const t = typeSel.value;
    const active = (t === 'BRAND' || t === 'CATEGORY') ? t : 'FREE';
    Object.keys(panels).forEach(function (k) { panels[k].classList.toggle('hidden', k !== active); });
    // 유형과 맞지 않는 값은 제출하지 않는다.
    if (active !== 'BRAND' && brandHidden) brandHidden.value = '';
    if (active !== 'CATEGORY' && catHidden) catHidden.value = '';
  }
  typeSel.addEventListener('change', sync);
  sync();
})();
</script>

<script>
/* 상품 선택 팝업 — 필터는 서버가 유형에 맞게 다시 강제한다(여기 값은 편의일 뿐). */
(function () {
  const modal = document.getElementById('productPickerModal');
  if (!modal) return;

  const exhibitionId = <%- JSON.stringify(exhibition.id) %>;
  const targetSection = document.getElementById('exhTargetSection');
  const sectionHidden = document.getElementById('pickerSectionId');
  const sectionLabel = document.getElementById('pickerSectionLabel');
  const results = document.getElementById('pickerResults');
  const totalEl = document.getElementById('pickerTotal');
  const countEl = document.getElementById('pickerCount');
  const submitBtn = document.getElementById('pickerSubmit');
  const checkAll = document.getElementById('pickerCheckAll');
  const moreWrap = document.getElementById('pickerMoreWrap');
  const moreBtn = document.getElementById('pickerMore');
  const queryInput = document.getElementById('pickerQuery');
  const brandHidden = document.getElementById('pickerBrandId');

  let page = 1, loading = false, hasMore = false;

  const catBox = modal.querySelector('[data-cat-cascade="picker"]');
  const catCascade = window.ydExh.cascade(catBox, { rootId: catBox.dataset.root || null, onChange: reload });

  const brandInput = document.getElementById('pickerBrandPicker');
  if (brandInput) {
    window.ydExh.brandPicker({
      input: brandInput,
      hidden: brandHidden,
      box: document.getElementById('pickerBrandSuggest'),
      clear: document.getElementById('pickerBrandClear'),
      onPick: reload,
    });
  }

  function refreshCount() {
    const n = results.querySelectorAll('input[name="product_ids[]"]:checked').length;
    countEl.textContent = n;
    submitBtn.disabled = n === 0;
  }

  function row(p) {
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, (ch) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]));
    const el = document.createElement('label');
    el.className = 'flex items-center gap-3 px-5 py-2.5 cursor-pointer hover:bg-gray-50'
      + (p.already_added ? ' opacity-50 cursor-not-allowed' : '');
    el.innerHTML =
      '<input type="checkbox" name="product_ids[]" value="' + Number(p.id) + '" '
        + (p.already_added ? 'disabled' : '') + ' class="w-4 h-4 rounded border-gray-300 shrink-0">'
      + '<img src="' + esc(p.main_image || '/images/placeholder.png') + '" alt="" '
        + 'class="w-10 h-10 rounded object-cover bg-gray-100 shrink-0">'
      + '<span class="flex-1 min-w-0">'
        + '<span class="block text-sm text-gray-900 truncate">' + esc(p.name) + '</span>'
        + '<span class="block text-xs text-gray-400 truncate">'
          + (p.brand_name ? esc(p.brand_name) + ' · ' : '')
          + (p.category_name ? esc(p.category_name) + ' · ' : '')
          + Number(p.price || 0).toLocaleString('ko-KR') + '원'
          + (p.status !== 'ON' ? ' · ' + esc(p.status) : '')
        + '</span>'
      + '</span>'
      + (p.already_added ? '<span class="text-xs text-gray-400 shrink-0">담김</span>' : '');
    return el;
  }

  async function load(append) {
    if (loading) return;
    loading = true;
    if (!append) {
      results.innerHTML = '<p class="py-16 text-center text-sm text-gray-400">불러오는 중…</p>';
      checkAll.checked = false;
    }
    const params = new URLSearchParams({ page: String(page) });
    if (queryInput.value.trim()) params.set('q', queryInput.value.trim());
    if (brandHidden && brandHidden.value) params.set('brandId', brandHidden.value);
    const cat = catCascade.value();
    if (cat) params.set('categoryId', cat);
    if (sectionHidden.value) params.set('sectionId', sectionHidden.value);

    try {
      const res = await fetch('/admin/exhibitions/' + exhibitionId + '/product-search?' + params.toString());
      const data = await res.json();
      if (!append) results.innerHTML = '';
      (data.products || []).forEach(p => results.append(row(p)));
      if (!results.children.length) {
        results.innerHTML = '<p class="py-16 text-center text-sm text-gray-400">조건에 맞는 상품이 없습니다.</p>';
      }
      totalEl.textContent = '전체 ' + Number(data.total || 0).toLocaleString('ko-KR') + '개';
      hasMore = Boolean(data.hasMore);
      moreWrap.classList.toggle('hidden', !hasMore);
    } catch (e) {
      results.innerHTML = '<p class="py-16 text-center text-sm text-red-500">상품을 불러오지 못했습니다.</p>';
      moreWrap.classList.add('hidden');
    } finally {
      loading = false;
      refreshCount();
    }
  }

  function reload() { page = 1; load(false); }

  document.getElementById('openProductPicker').addEventListener('click', function () {
    // 담을 위치를 팝업으로 넘긴다 — '이미 담김' 판정 기준이 섹션이라 열 때 확정해야 한다.
    sectionHidden.value = targetSection ? targetSection.value : '';
    sectionLabel.textContent = targetSection && targetSection.selectedIndex >= 0
      ? targetSection.options[targetSection.selectedIndex].text : '전체 탭';
    modal.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
    reload();
  });

  function close() {
    modal.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }
  modal.querySelectorAll('[data-picker-close]').forEach(el => el.addEventListener('click', close));
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
  });

  document.getElementById('pickerSearchBtn').addEventListener('click', reload);
  queryInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') { e.preventDefault(); reload(); }  // 폼 제출로 새지 않게
  });

  moreBtn.addEventListener('click', function () { page += 1; load(true); });

  checkAll.addEventListener('change', function () {
    results.querySelectorAll('input[name="product_ids[]"]:not([disabled])')
      .forEach(cb => { cb.checked = checkAll.checked; });
    refreshCount();
  });
  results.addEventListener('change', refreshCount);
})();
</script>

