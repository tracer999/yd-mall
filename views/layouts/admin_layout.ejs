<!DOCTYPE html>
<html lang="ko">

<head>
  <% 
    // 사용자 레이아웃(main_layout.ejs)과 동일한 방식으로 브랜드 색상을 계산
    const fallbackMain = '#76A764';
    const fallbackDark = '#5A824B';
    const fallbackLight = '#F0F7EE';

    const ensureHex = (value, fallback) => {
      if (!value || typeof value !== 'string') return fallback;
      const trimmed = value.trim();
      if (!trimmed) return fallback;
      return trimmed.startsWith('#') ? trimmed : `#${trimmed}`;
    };

    const brandMain = ensureHex(siteSettings && siteSettings.brand_main_color, fallbackMain);
    const brandDark = ensureHex(siteSettings && siteSettings.brand_dark_color, fallbackDark);
    const brandLight = ensureHex(siteSettings && siteSettings.brand_light_color, fallbackLight);
  %>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <% if (siteSettings && (siteSettings.favicon_url || siteSettings.logo_url)) { %>
    <link rel="icon" href="<%= siteSettings.favicon_url || siteSettings.logo_url %>" />
    <link rel="apple-touch-icon" href="<%= siteSettings.favicon_url || siteSettings.logo_url %>" />
  <% } %>
  <title>YD-MALL Admin</title>
  <!-- Tailwind CSS -->
  <link href="/css/style.css" rel="stylesheet" />
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
  <!-- Pretendard Font -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />

  <style>
    :root {
      /* site_settings 의 브랜드 컬러를 그대로 반영 (main_layout.ejs와 동일한 기준) */
      --admin-key-main: <%= brandMain %>;
      --admin-key-strong: <%= brandDark %>;
      --admin-key-soft: <%= brandLight %>;
      /* 하단 바 등에 쓸 중간 톤: 메인과 연한색의 중간값 */
      --admin-key-soft-strong: color-mix(in srgb, var(--admin-key-main) 40%, var(--admin-key-soft) 60%);
    }

    body,
    html {
      height: 100%;
      overflow-x: hidden;
      font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    }

    .sidebar-link {
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .sidebar-link:hover {
      background: rgba(255, 255, 255, 0.1);
      transform: translateX(4px);
      box-shadow:
        0 4px 6px -1px rgba(0, 0, 0, 0.1),
        0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .sidebar-link.active {
      background: linear-gradient(90deg, var(--admin-key-main) 0%, var(--admin-key-strong) 100%);
      box-shadow: 0 10px 15px -3px color-mix(in srgb, var(--admin-key-main) 60%, transparent);
      transform: none;
    }

    /* 사이드바 전체 배경 (톤1) */
    .admin-sidebar-bg {
      background-color: var(--admin-key-soft);
    }

    /* 로고 영역/경계선 톤 */
    .admin-sidebar-border {
      border-color: color-mix(in srgb, var(--admin-key-soft) 70%, #ffffff 30%);
    }

    /* 하단 프로필 바 (톤2) */
    .admin-sidebar-bottom {
      background-color: var(--admin-key-soft-strong);
      border-top: 1px solid color-mix(in srgb, var(--admin-key-soft-strong) 70%, #ffffff 30%);
    }

    /* 접기 버튼용 키컬러 버튼 */
    .admin-key-btn {
      background-color: var(--admin-key-main);
      color: #ffffff;
    }

    .admin-key-btn:hover {
      background-color: var(--admin-key-strong);
      color: #ffffff;
    }

    /* Custom scrollbar for sidebar */
    .sidebar-scroll::-webkit-scrollbar {
      width: 5px;
    }

    .sidebar-scroll::-webkit-scrollbar-track {
      background: #1f2937;
    }

    .sidebar-scroll::-webkit-scrollbar-thumb {
      background: #4b5563;
      border-radius: 10px;
    }

    .sidebar-scroll::-webkit-scrollbar-thumb:hover {
      background: #6b7280;
    }
  </style>
</head>

<body class="bg-gray-50 text-gray-800 antialiased h-screen flex overflow-hidden">
  <!-- Sidebar -->
  <aside id="sidebarMenu"
    class="fixed inset-y-0 left-0 z-50 w-56 admin-sidebar-bg text-gray-900 transition-all duration-300 transform -translate-x-full md:relative md:translate-x-0 flex flex-col shadow-2xl group/sidebar">
    <!-- Collapse Button (Desktop) -->
    <button id="sidebarCollapseBtn"
      class="hidden md:flex absolute -right-4 top-1/2 -translate-y-1/2 admin-key-btn w-8 h-8 rounded-full items-center justify-center shadow-lg z-50 border border-white">
      <i class="bi bi-chevron-left text-sm transition-transform duration-300" id="collapseIcon"></i>
    </button>
    <!-- Logo -->
    <!-- Logo -->
    <!-- Logo -->
    <div id="logoArea" style="height: 64px;" class="flex items-center px-4 border-b admin-sidebar-border">
      <a href="/admin" class="flex items-center justify-center group w-full">
        <% if(siteSettings && siteSettings.logo_url) { %>
          <div
            class="w-full flex items-center justify-center transition-all duration-300 overflow-hidden logo-container bg-white rounded-xl shadow-sm p-1"
            style="height: 44px;" id="logoContainer">
            <img src="<%= siteSettings.logo_url %>" alt="<%= siteSettings.company_name %>"
              class="h-full object-contain mx-auto">
          </div>
          <% } else { %>
            <span id="logoText"
              class="text-xl font-bold tracking-tight text-gray-900 group-hover:text-blue-600 transition-colors whitespace-nowrap overflow-hidden text-center">
              <%= (siteSettings && siteSettings.company_name) ? siteSettings.company_name : 'Admin Pro' %>
            </span>
            <% } %>
      </a>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 overflow-y-auto sidebar-scroll py-2 px-4 space-y-0">
      <% if (typeof adminMenus !== 'undefined' && adminMenus && adminMenus.length) { %>
        <% adminMenus.forEach(function(menu) { 
             const activeClass = (menu.path === '/admin')
               ? (path === '/admin' ? 'active text-white' : '')
               : (path.startsWith(menu.path) ? 'active text-white' : '');
        %>
          <a href="<%= menu.path %>"
            class="sidebar-link flex items-center px-4 py-1 rounded-xl text-sm font-medium text-gray-700 hover:text-blue-900 mb-0 <%= activeClass %>">
            <% if (menu.icon_class) { %>
              <i class="<%= menu.icon_class %> mr-4 text-lg opacity-80"></i>
            <% } %>
            <span class="menu-text"><%= menu.name %></span>
          </a>
        <% }) %>
      <% } %>
    </nav>

    <!-- User Profile (Bottom Sidebar) -->
    <div id="bottomProfile" class="admin-sidebar-bottom px-4"
      style="padding-top: 7px; padding-bottom: 7px;">
      <div class="flex items-center gap-3">
        <div
          class="w-10 h-10 rounded-full bg-gradient-to-r from-purple-500 to-indigo-500 flex items-center justify-center text-white font-bold text-sm shadow-md flex-shrink-0">
          <%= user && user.username ? user.username.substring(0, 2).toUpperCase() : 'AD' %>
        </div>
        <div class="flex-1 min-w-0 menu-text">
          <p class="text-sm font-medium text-gray-900 truncate">
            <%= user ? user.username : 'Administrator' %>
          </p>
          <p class="text-xs text-gray-600 truncate">
            <% let roleName='관리자' ; if(user && user.role==='super_admin' ) roleName='최고관리자' ; else if(user &&
              user.role==='customer_admin' ) roleName='회원관리자' ; else if(user && user.role==='content_admin' )
              roleName='컨텐츠관리자' ; %>
              <%= roleName %>
          </p>
        </div>
        <a href="/admin/logout" class="p-2 text-gray-600 hover:text-blue-900 transition-colors" title="로그아웃">
          <i class="bi bi-box-arrow-right text-lg"></i>
        </a>
      </div>
    </div>
  </aside>

  <!-- Overlay -->
  <div id="sidebarOverlay"
    class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-40 md:hidden hidden transition-opacity opacity-0"></div>

  <!-- Main Content Wrapper -->
  <div class="flex-1 flex flex-col h-full relative overflow-hidden bg-gray-50/50">
    <!-- Top Header -->
    <header
      class="h-16 bg-white/80 backdrop-blur-md border-b border-gray-100 flex items-center justify-between px-6 z-30 sticky top-0">
      <div class="flex items-center gap-4">
        <button id="sidebarToggle"
          class="md:hidden p-2 -ml-2 text-gray-500 hover:text-blue-600 focus:outline-none transition-colors">
          <i class="bi bi-list text-2xl"></i>
        </button>

        <!-- Breadcrumbs or Page Title -->
        <div>
          <h1 class="text-xl font-bold text-gray-800 tracking-tight">
            <%= typeof title !=='undefined' ? title : 'Overview' %>
          </h1>
          <p class="text-xs text-gray-500 mt-0.5 font-medium">
            <%= typeof subtitle !== 'undefined' ? subtitle : '관리자 패널에 오신 것을 환영합니다.' %>
          </p>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <button
          class="w-10 h-10 rounded-full bg-gray-50 hover:bg-gray-100 flex items-center justify-center text-gray-500 hover:text-blue-600 transition-all duration-200 relative">
          <i class="bi bi-bell"></i>
          <span class="absolute top-2.5 right-2.5 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
        </button>

        <a href="/" target="_blank"
          class="flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-gray-600 text-sm font-medium rounded-lg hover:border-blue-500 hover:text-blue-600 hover:shadow-sm transition-all duration-200">
          <i class="bi bi-box-arrow-up-right"></i>
          <span class="hidden sm:inline">사이트 바로가기</span>
        </a>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8 scroll-smooth">
      <!-- Content Container -->
      <div class="max-w-7xl mx-auto pb-10">
        <div
          class="admin-main-content bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8 min-h-[calc(100vh-180px)] transition-all duration-500 ease-out transform opacity-100 translate-y-0 relative">
          <%- body %>
        </div>
      </div>
    </main>
  </div>

    <!-- 공통 숫자 포맷팅 스크립트 -->
  <script src="/js/number-format.js"></script>
  <script>
    // Sidebar Logic with smooth transitions
    const sidebarToggle = document.getElementById("sidebarToggle");
    const sidebarCollapseBtn = document.getElementById("sidebarCollapseBtn");
    const sidebarMenu = document.getElementById("sidebarMenu");
    const sidebarOverlay = document.getElementById("sidebarOverlay");
    const logoText = document.getElementById("logoText");
    const logoContainer = document.getElementById("logoContainer");
    const logoArea = document.getElementById("logoArea");
    const menuTexts = document.querySelectorAll(".menu-text"); // Add class to spans
    const bottomProfile = document.getElementById("bottomProfile");

    let isCollapsed = false;

    function toggleSidebarWidth() {
      isCollapsed = !isCollapsed;
      if (isCollapsed) {
        sidebarMenu.classList.remove("w-56");
        sidebarMenu.classList.add("w-20");
        if (logoText) {
          logoText.classList.add("hidden");
        }
        if (logoContainer) {
          logoContainer.classList.add("hidden");
        }
        if (logoArea) {
          logoArea.classList.add("hidden");
        }
        menuTexts.forEach(el => el.classList.add("hidden"));
        if (bottomProfile) {
          bottomProfile.classList.add("hidden");
        }
        // Icon margin fix if needed
      } else {
        sidebarMenu.classList.remove("w-20");
        sidebarMenu.classList.add("w-56");
        if (logoText) {
          logoText.classList.remove("hidden");
        }
        if (logoContainer) {
          logoContainer.classList.remove("hidden");
        }
        if (logoArea) {
          logoArea.classList.remove("hidden");
        }
        setTimeout(() => {
          if (!isCollapsed) menuTexts.forEach(el => el.classList.remove("hidden"));
        }, 150);
        if (bottomProfile) {
          bottomProfile.classList.remove("hidden");
        }
      }
    }

    if (sidebarCollapseBtn) {
      sidebarCollapseBtn.addEventListener("click", toggleSidebarWidth);
    }

    function openSidebar() {
      sidebarMenu.classList.remove("-translate-x-full");
      sidebarOverlay.classList.remove("hidden");
      // small delay to allow display:block to apply before opacity transition
      setTimeout(() => {
        sidebarOverlay.classList.remove("opacity-0");
      }, 10);
    }

    function closeSidebar() {
      sidebarMenu.classList.add("-translate-x-full");
      sidebarOverlay.classList.add("opacity-0");
      setTimeout(() => {
        sidebarOverlay.classList.add("hidden");
      }, 300);
    }

    sidebarToggle.addEventListener("click", (e) => {
      e.stopPropagation();
      openSidebar();
    });

    sidebarOverlay.addEventListener("click", closeSidebar);
  </script>
  <!-- Add simple fade-in animation for content -->
  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    main>div {
      animation: fadeIn 0.4s ease-out forwards;
    }
  </style>
</body>

</html>
