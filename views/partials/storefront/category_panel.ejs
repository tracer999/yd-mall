<%
  /*
   * PC GNB 카테고리 드롭다운 패널 (§12 디자인 개선)
   *
   * 좌측 1뎁스 세로 리스트. 각 항목은 **썸네일 + 이름 + 간략 설명**으로 구성한다.
   *   - logo_image_path 가 있으면 썸네일, 없으면 이름 이니셜 원형 placeholder.
   *   - description 이 있으면 이름 아래 한 줄(말줄임), 없으면 그 줄만 생략.
   *   - 이미지/설명이 비어도 카테고리 노출 자체는 유지한다(NULL-safe).
   *
   * 자식이 있는 노드에만 우측 서브패널(2·3뎁스)을 hover 로 띄운다.
   * 2뎁스 데이터가 없으면 우측 컬럼을 만들지 않아 깔끔한 리스트로 보인다.
   *
   * locals: categoryTree (navigationService.getCategoryTree 결과, 최대 3뎁스)
   */
  const _tree = (typeof categoryTree !== 'undefined' && categoryTree) ? categoryTree : [];
  const hasChildren = (n) => n.children && n.children.length > 0;
  const anyChildren = _tree.some(hasChildren);
  const initial = (s) => (s || '·').trim().charAt(0);
%>

<% if (_tree.length === 0) { %>
  <p class="p-5 text-sm text-gray-400">등록된 카테고리가 없습니다.</p>
<% } else { %>
  <%# 서브패널의 기준은 이 컨테이너다. <li> 를 기준으로 잡으면 목록 하단 항목에 hover 했을 때
      서브패널이 패널 아래로 넘쳐 나간다. %>
  <div class="relative flex <%= anyChildren ? 'min-h-[420px]' : '' %>">

    <%# 1뎁스 — 항상 세로 리스트(썸네일 + 이름 + 설명) %>
    <ul class="w-80 shrink-0 py-2 <%= anyChildren ? 'border-r border-gray-100 bg-gray-50/40' : '' %>">
      <% _tree.forEach(function (node) { %>
        <li class="group/cat">
          <a href="/products/category/<%= node.id %>"
             class="flex items-center gap-3 px-4 py-2.5 text-gray-700
                    hover:bg-white hover:text-[var(--gh-primary)] transition-colors">
            <%# 썸네일 (없으면 이니셜 원형) %>
            <span class="shrink-0 w-11 h-11 rounded-lg overflow-hidden bg-white border border-gray-100 flex items-center justify-center">
              <% if (node.logo_image_path) { %>
                <img src="<%= node.logo_image_path %>" alt="<%= node.name %>" class="w-full h-full object-cover">
              <% } else { %>
                <span class="text-base font-bold text-[var(--gh-primary)]/70"><%= initial(node.name) %></span>
              <% } %>
            </span>
            <%# 이름 + 설명 %>
            <span class="min-w-0 flex-1">
              <span class="flex items-center gap-1">
                <span class="truncate text-sm font-semibold group-hover/cat:text-[var(--gh-primary)]"><%= node.name %></span>
                <% if (hasChildren(node)) { %>
                  <i class="bi bi-chevron-right text-xs text-gray-300 group-hover/cat:text-[var(--gh-primary)]"></i>
                <% } %>
              </span>
              <% if (node.description) { %>
                <span class="block truncate text-xs text-gray-400 mt-0.5"><%= node.description %></span>
              <% } %>
            </span>
          </a>

          <%# 2뎁스 — 자식이 있을 때만. hover 로 우측에 펼친다.
              위치 기준은 바깥 컨테이너(.relative)라 언제나 패널 상단에 맞춰 열린다. %>
          <% if (hasChildren(node)) { %>
            <div class="hidden group-hover/cat:block absolute left-80 top-0 bottom-0 z-10 w-[560px]
                        bg-white pl-6 pr-5 py-4">
              <div class="flex items-center gap-2 mb-3">
                <% if (node.logo_image_path) { %>
                  <img src="<%= node.logo_image_path %>" alt="" class="w-6 h-6 rounded object-cover">
                <% } %>
                <p class="text-sm font-bold text-gray-800"><%= node.name %></p>
              </div>
              <% if (node.description) { %>
                <p class="mb-3 text-xs text-gray-400"><%= node.description %></p>
              <% } %>
              <ul class="grid grid-cols-2 gap-x-6 gap-y-0.5">
                <% node.children.forEach(function (child) { %>
                  <li>
                    <a href="/products/category/<%= child.id %>"
                       class="block px-2 py-1.5 text-sm text-gray-600 rounded hover:bg-gray-50 hover:text-[var(--gh-primary)]">
                      <%= child.name %>
                    </a>
                    <%# 3뎁스 %>
                    <% if (child.children && child.children.length) { %>
                      <ul class="ml-2 pl-2 border-l border-gray-100">
                        <% child.children.forEach(function (leaf) { %>
                          <li>
                            <a href="/products/category/<%= leaf.id %>"
                               class="block px-2 py-1 text-xs text-gray-500 rounded hover:text-[var(--gh-primary)]">
                              <%= leaf.name %>
                            </a>
                          </li>
                        <% }); %>
                      </ul>
                    <% } %>
                  </li>
                <% }); %>
              </ul>
            </div>
          <% } %>
        </li>
      <% }); %>
    </ul>

    <%# 자식이 하나도 없으면 우측 영역을 아예 만들지 않는다(빈 컬럼 방지). %>
  </div>
<% } %>
