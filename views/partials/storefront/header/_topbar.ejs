<%
  /*
   * 헤더 톱바 — 프로모션 배너(최대 3) + 알림 문구(1). 헤더 최상단, PC·모바일 공용.
   *
   * res.locals.topbar 가 null 이면(= 등록된 배너·알림이 하나도 없으면) 아무것도 렌더하지 않는다.
   * 관리자: /admin/header-settings 의 '톱바(배너·알림)' 섹션.
   *
   * 배너 크기는 **개수로 정한다** — 1개는 크게 한 폭, 2개는 절반씩, 3개는 1/3씩.
   * 개수와 무관하게 같은 높이를 쓰면 3개일 때 톱바가 페이지를 잡아먹는다.
   *
   * 배너 내용의 우선순위: **이미지 1순위, 대체 텍스트가 폴백**.
   *   1) 이미지가 있으면 이미지를 낸다.
   *   2) 이미지가 없으면 대체 텍스트를 '텍스트 배너'(이미지 배너와 같은 칸·같은 높이의 카드)로 낸다.
   *   3) 이미지가 있는데 로드에 실패하면(404·차단 등) 클라이언트에서 텍스트 배너로 갈아끼운다.
   *      서버는 로드 성공 여부를 알 수 없으므로 폴백 마크업을 미리 숨겨서 함께 내려보낸다.
   */
  const _tb = (typeof topbar !== 'undefined') ? topbar : null;
%>
<% if (_tb) { %>
    <%
      const _n = _tb.banners.length;
      const _grid = { 1: 'grid-cols-1', 2: 'grid-cols-2', 3: 'grid-cols-3' }[_n] || 'grid-cols-1';
      // 개수별 높이 — 많아질수록 낮게. 모바일은 한 단계 더 낮다.
      const _h = { 1: 'h-20 md:h-28', 2: 'h-14 md:h-20', 3: 'h-11 md:h-16' }[_n] || '';
      // 텍스트 배너의 글자 크기도 칸 크기를 따라간다 — 3단에 큰 글씨를 넣으면 잘린다.
      const _ts = { 1: 'text-[15px] md:text-xl', 2: 'text-[13px] md:text-base', 3: 'text-[11px] md:text-sm' }[_n] || 'text-sm';
    %>

    <script>
      /*
       * 이미지 배너 로드 실패 → 텍스트 배너 폴백.
       * onerror 는 마크업 파싱 직후에도 터질 수 있으므로 핸들러를 **배너보다 먼저** 정의한다.
       */
      window.ydTopbarImageFailed = window.ydTopbarImageFailed || function (img) {
        var cell = img.closest('[data-tb-slot]');
        img.remove();
        if (!cell) return;
        var fallback = cell.querySelector('[data-tb-fallback]');
        if (fallback) { fallback.style.display = ''; return; }
        cell.style.display = 'none';   // 이미지도 못 쓰고 대체 텍스트도 없으면 빈 칸을 남기지 않는다
      };
    </script>
    <div id="yd-topbar" data-version="<%= _tb.version %>"
         class="relative bg-[var(--gh-primary-dark)] text-white">

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <% if (_n) { %>
                <div class="grid <%= _grid %> gap-2 py-2">
                    <% _tb.banners.forEach(function (b) { %>
                        <%
                          const _img = b.image_url || '';
                          const _text = b.message || '';
                          const _isLink = !!b.link_url;
                        %>
                        <div data-tb-slot class="<%= _h %>">
                            <%# 링크 유무만 다르고 안쪽은 같다 — group 은 텍스트 배너의 hover 연출에 쓴다. %>
                            <% if (_isLink) { %>
                                <a href="<%= b.link_url %>" <%- Number(b.new_window) ? 'target="_blank" rel="noopener noreferrer"' : '' %>
                                   class="group block w-full h-full">
                            <% } else { %>
                                <div class="group block w-full h-full">
                            <% } %>

                            <% if (_img) { %>
                                <img src="<%= _img %>" alt="<%= _text %>" loading="lazy"
                                     onerror="window.ydTopbarImageFailed(this)"
                                     class="w-full h-full object-cover rounded-md">
                            <% } %>

                            <% if (_text) { %>
                                <%#
                                  텍스트 배너 — 이미지 배너와 같은 자리를 채우는 카드로 보여야 한다.
                                  톱바 바탕과 같은 색이면 '배너'가 아니라 '떠 있는 문구'로 읽히므로,
                                  반투명 흰색 레이어 + 안쪽 링 + 광원으로 한 겹 띄운다.
                                  이미지가 있을 때는 폴백이라 숨겨 둔다(인라인 style 이라야 클래스에 안 밀린다).
                                %>
                                <div data-tb-fallback <%- _img ? 'style="display:none"' : '' %>
                                     class="relative w-full h-full flex items-center justify-center overflow-hidden rounded-md px-3
                                            bg-gradient-to-br from-white/20 via-white/10 to-white/[0.04]
                                            ring-1 ring-inset ring-white/25 transition-colors
                                            group-hover:from-white/30 group-hover:ring-white/40">
                                    <span aria-hidden="true"
                                          class="pointer-events-none absolute -top-8 -right-6 w-24 h-24 rounded-full bg-white/15 blur-2xl"></span>
                                    <span class="relative inline-flex items-center gap-1.5 font-semibold tracking-tight text-center <%= _ts %>">
                                        <%#
                                          line-clamp 은 display 를 바꾼다 — 바깥 inline-flex 를 덮지 않도록 텍스트에만 건다.
                                          break-keep: 좁은 폭에서 한글이 어절 중간에 끊기지 않게(‘쿠 / 폰’).
                                        %>
                                        <span class="line-clamp-2 break-keep"><%= _text %></span>
                                        <% if (_isLink) { %>
                                            <i class="bi bi-arrow-right text-[0.85em] opacity-70 transition-transform group-hover:translate-x-0.5"></i>
                                        <% } %>
                                    </span>
                                </div>
                            <% } %>

                            <% if (_isLink) { %></a><% } else { %></div><% } %>
                        </div>
                    <% }); %>
                </div>
            <% } %>

            <% if (_tb.notice) { %>
                <%# 알림 문구 — 배너와 함께 쓰면 배너 아래 한 줄. 닫기 버튼 자리(pr-10)를 비워 둔다. %>
                <div class="flex items-center justify-center py-2 pr-8 text-center text-[13px] <%= _n ? 'border-t border-white/15' : '' %>">
                    <% if (_tb.notice.link_url) { %>
                        <a href="<%= _tb.notice.link_url %>" <%- Number(_tb.notice.new_window) ? 'target="_blank" rel="noopener noreferrer"' : '' %>
                           class="inline-flex items-center gap-1.5 hover:underline">
                            <i class="bi bi-megaphone"></i><span><%= _tb.notice.message %></span>
                            <i class="bi bi-chevron-right text-[11px] opacity-80"></i>
                        </a>
                    <% } else { %>
                        <span class="inline-flex items-center gap-1.5">
                            <i class="bi bi-megaphone"></i><span><%= _tb.notice.message %></span>
                        </span>
                    <% } %>
                </div>
            <% } %>
        </div>

        <button type="button" id="yd-topbar-close" aria-label="상단 알림 닫기"
                class="absolute top-1.5 right-1.5 md:right-3 flex items-center justify-center w-7 h-7 rounded-full text-white/80 hover:text-white hover:bg-white/15 transition-colors">
            <i class="bi bi-x-lg text-xs"></i>
        </button>
    </div>

    <script>
      /*
       * 닫기 — 같은 콘텐츠(version)를 다시 보여 주지 않는다. 배너·문구가 바뀌면 version 이 바뀌므로
       * 이전에 닫은 사용자에게도 새 톱바는 다시 뜬다(닫기가 영구 차단이 되면 안 된다).
       * 스크립트는 요소 바로 뒤에서 동기 실행된다 — 이미 닫은 바가 한 번 깜빡이지 않게 하려는 것.
       */
      (function () {
        var KEY = 'yd-topbar-dismissed';
        var bar = document.getElementById('yd-topbar');
        if (!bar) return;
        var version = bar.getAttribute('data-version');

        var dismissed = null;
        try { dismissed = window.localStorage.getItem(KEY); } catch (e) { /* 사파리 프라이빗 등 */ }
        if (dismissed === version) { bar.remove(); return; }

        var btn = document.getElementById('yd-topbar-close');
        if (btn) btn.addEventListener('click', function () {
          try { window.localStorage.setItem(KEY, version); } catch (e) { /* 저장 실패해도 닫기는 된다 */ }
          bar.remove();
        });
      })();
    </script>
<% } %>
