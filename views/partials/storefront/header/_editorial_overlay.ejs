<%
  /*
   * 에디토리얼 오버레이 헤더 — header_layout_type='editorial_overlay_v1' (nav_mode='split')
   *
   * 투명 헤더가 풀블리드 히어로 위에 겹친다(body.yd-overlay-header). 스크롤이 히어로를 지나면
   * 흰 배경으로 굳는다(하단 inline script). 데이터 계약은 다른 스킨과 동일하게 상위 locals 를 상속:
   *   siteSettings · user · isAdmin · cartCount · gnbMenus · categoryButton · categoryTree · currentPath
   *
   * 카테고리 버튼/패널/백드롭은 기본형과 **같은 id** 를 써서 기존 토글 스크립트를 그대로 재사용한다.
   */
  const _cfg = (typeof nav !== 'undefined' && nav && nav.config) ? nav.config : {};
  const _gnb = (typeof gnbMenus !== 'undefined' ? gnbMenus : []);
  const _catBtn = (typeof categoryButton !== 'undefined') ? categoryButton : null;
  const _company = (siteSettings && siteSettings.company_name) || '와이디몰';

  /*
   * 통합형(nav_mode='unified') — 카테고리 버튼 없이 카테고리 1뎁스가 GNB 항목이 되고 하위는 children.
   * 이 스킨은 테마3에서 split·unified 양쪽에 쓰이므로(presets.js 의 테마3 예외) 두 경우를 모두 낸다.
   *   - PC: 여기 중앙 nav 가 메뉴 전체를 낸다. 하위가 있으면 마우스 오버 드롭다운(햄버거 아님).
   *   - 모바일: 우측 [☰] 드로어(md:hidden).
   * split 이면 children 이 항상 비어 있어 드롭다운 분기 자체가 렌더되지 않는다 — 기존 동작 그대로.
   */
  const _unified = String(_cfg.nav_mode) === 'unified';
  const _pcKids = (m) => (m.children || []).filter((c) => Number(c.pcVisible) !== 0);
  /* unified 는 navigationService.buildUnified 가 이미 max_gnb_items 를 적용했다 — 여기서 또 자르면
     카테고리까지 함께 잘려 PC 메뉴가 사라진다. split 만 기존대로 방어적으로 자른다. */
  const _pcGnb = (() => {
    const list = _gnb.filter((m) => Number(m.pcVisible) !== 0);
    return _unified ? list : list.slice(0, Number(_cfg.max_gnb_items) || 8);
  })();
%>
<header class="yd-ed-hdr absolute top-0 left-0 right-0 z-50" data-solid-after="80">
  <div class="max-w-[80rem] mx-auto px-5 lg:px-10">
    <div class="flex items-center h-20">
      <!-- Logo (left) -->
      <div class="flex-1 min-w-0">
        <a href="/" class="inline-flex items-center gap-2 no-underline">
          <% if (siteSettings && siteSettings.logo_url) { %>
            <img src="<%= siteSettings.logo_url %>" alt="<%= _company %>" class="h-9 w-auto yd-ed-logo-img">
          <% } else { %>
            <span class="yd-ed-logo text-2xl lg:text-[1.7rem] leading-none tracking-tight"><%= _company %></span>
          <% } %>
        </a>
      </div>

      <!-- Center nav (PC) -->
      <%#
        self-stretch — 항목이 헤더 높이(h-20)를 꽉 채워야 드롭다운 패널(top-full)이 헤더 하단에 딱 붙는다.
        틈이 생기면 링크 → 패널로 마우스를 옮기는 사이 hover 가 끊긴다.
      %>
      <nav class="hidden md:flex items-center self-stretch gap-7 yd-ed-nav" aria-label="주 메뉴">
        <% if (_catBtn) { %>
          <div class="relative" id="gnb-cat-wrap">
            <button type="button" id="gnb-cat-btn" aria-expanded="false"
              class="yd-ed-navlink inline-flex items-center gap-1.5 text-sm font-medium">
              <i class="bi bi-grid text-base"></i><span><%= _catBtn.name %></span>
            </button>
            <div id="gnb-cat-panel"
              class="hidden absolute left-1/2 -translate-x-1/2 top-full mt-3 z-50 max-w-[92vw] bg-white text-gray-800 border border-gray-200 shadow-xl rounded-lg overflow-visible">
              <%- include('../category_panel') %>
            </div>
          </div>
        <% } %>
        <% _pcGnb.forEach(function (m) {
             var active = m.href && m.href !== '#' && (typeof currentPath !== 'undefined') && currentPath === m.href;
             var kids = _pcKids(m); %>
          <div class="yd-ed-item relative flex items-center h-full">
            <a href="<%= m.href %>" <%- m.newWindow ? 'target="_blank" rel="noopener noreferrer"' : '' %>
               class="yd-ed-navlink relative text-sm font-medium <%= active ? 'is-active' : '' %>">
              <%= m.name %>
              <% if (m.badgeType) { %><span class="absolute -top-1 -right-2 w-1.5 h-1.5 rounded-full bg-[var(--gh-accent)]"></span><% } %>
            </a>

            <%# 하위메뉴 드롭다운 — 있을 때만. 투명 헤더 위라 패널은 흰 배경·어두운 글자로 되돌린다. %>
            <% if (kids.length) { %>
              <div class="yd-ed-panel absolute left-0 top-full z-40 min-w-[180px] rounded-b-lg border border-gray-100 border-t-0 bg-white shadow-xl py-2">
                <ul>
                  <% kids.forEach(function (c) { %>
                    <li>
                      <a href="<%= c.href %>" class="block px-4 py-2 text-sm text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 whitespace-nowrap">
                        <%= c.name %>
                      </a>
                      <% var grand = _pcKids(c); %>
                      <% if (grand.length) { %>
                        <ul class="pb-1">
                          <% grand.forEach(function (g) { %>
                            <li>
                              <a href="<%= g.href %>" class="block pl-7 pr-4 py-1.5 text-xs text-gray-400 hover:text-[var(--gh-primary)] whitespace-nowrap">
                                <%= g.name %>
                              </a>
                            </li>
                          <% }); %>
                        </ul>
                      <% } %>
                    </li>
                  <% }); %>
                </ul>
              </div>
            <% } %>
          </div>
        <% }); %>
      </nav>

      <%#
        우측 아이콘 — 장바구니 · 사람 · 검색 · [☰] 순(참조 구조 docs/사이트개선/capture/thema2_mo.png).
        검색과 햄버거는 드로어를 연다: 검색은 드로어 안 검색폼에 포커스까지 준다(./_drawer 스크립트).
        입력창을 헤더에도 두면 드로어 안 폼과 두 벌이 되므로 진입점만 둔다.
      %>
      <div class="flex-1 flex items-center justify-end gap-4 sm:gap-5 yd-ed-actions">
        <a href="<%= user ? '/mypage' : '/auth/login' %>" aria-label="<%= user ? '마이쇼핑' : '로그인' %>" class="yd-ed-ico"><i class="bi bi-person text-xl"></i></a>
        <a href="/cart" aria-label="장바구니" class="yd-ed-ico relative">
          <i class="bi bi-bag text-lg"></i>
          <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
            <span class="absolute -top-1.5 -right-1.5 bg-[var(--gh-accent)] text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full"><%= cartCount %></span>
          <% } %>
        </a>
        <% if (Number(_cfg.use_search_bar) !== 0) { %>
          <button type="button" id="yd-dw-search" aria-label="검색" class="yd-ed-ico"><i class="bi bi-search text-lg"></i></button>
        <% } %>
        <% if (isAdmin) { %>
          <a href="/admin" aria-label="관리자모드" class="yd-ed-ico yd-ed-ico--pc hidden md:inline-flex"><i class="bi bi-gear text-lg"></i></a>
        <% } %>
        <%# 햄버거 — PC 는 가운데 메뉴가 있으므로 모바일에서만. 없으면 모바일에 메뉴 진입점이 사라진다. %>
        <button type="button" id="yd-dw-open" aria-expanded="false" aria-controls="yd-drawer" aria-label="전체 메뉴 열기"
                class="yd-ed-ico yd-ed-ico--mo md:hidden"><i class="bi bi-list text-2xl"></i></button>
      </div>
    </div>
  </div>
</header>

<%# 전체 메뉴 드로어 — 드로어형 스킨과 공용. <header> 바깥이어야 백드롭이 헤더를 덮지 않는다. %>
<%- include('./_drawer') %>

<%# 카테고리 드롭다운 백드롭 — 기본형과 동일(헤더 바깥). 기존 토글 스크립트가 같은 id 를 잡는다. %>
<div id="gnb-cat-backdrop" class="hidden fixed inset-0 z-40 bg-black/20" aria-hidden="true"></div>

<style>
  /* 투명 → 스크롤 후 흰 배경으로 굳는다 */
  .yd-ed-hdr { transition: background-color .3s ease, box-shadow .3s ease, color .3s ease; }
  .yd-ed-hdr, .yd-ed-hdr .yd-ed-navlink, .yd-ed-hdr .yd-ed-ico, .yd-ed-hdr .yd-ed-logo { color: #fff; }
  .yd-ed-logo { font-family: var(--yd-font-display, serif); font-weight: 600; }
  .yd-ed-navlink { position: relative; opacity: .92; transition: opacity .2s ease; text-decoration: none; }
  .yd-ed-navlink:hover, .yd-ed-navlink.is-active { opacity: 1; }
  .yd-ed-navlink.is-active::after { content: ''; position: absolute; left: 0; right: 0; bottom: -6px; height: 1px; background: currentColor; }
  .yd-ed-ico { display: inline-flex; opacity: .92; text-decoration: none; }
  .yd-ed-ico:hover { opacity: 1; }

  /*
   * 아이콘의 기기별 노출 — Tailwind 유틸(md:hidden / hidden md:inline-flex)만으로는 안 된다.
   * 위 `.yd-ed-ico { display: inline-flex }` 와 `.md\:hidden { display: none }` 은 특이도가 같고(0,1,0)
   * 이 <style> 이 문서상 뒤에 와서 항상 이긴다 → PC 에 햄버거가 그대로 남고(요구사항 위반),
   * 모바일에는 관리자 아이콘이 남았다. 특이도를 한 단계 올린 미디어쿼리로 확실히 끊는다.
   */
  @media (max-width: 767.98px) { .yd-ed-ico.yd-ed-ico--pc { display: none; } }
  @media (min-width: 768px)    { .yd-ed-ico.yd-ed-ico--mo { display: none; } }

  /*
   * PC 하위메뉴 드롭다운 — 마우스 오버·키보드 포커스에서만 펼친다(1뎁스는 상시 노출).
   * 드로어형 스킨(_compact_drawer.ejs .yd-gnb__panel)과 같은 규칙이되, 이 헤더는 투명 상태에서
   * 흰 글자 + text-shadow 를 자손에 상속시키므로 패널 안에서 그걸 되돌린다(흰 배경에 흰 글자 방지).
   */
  .yd-ed-panel { display: none; }
  .yd-ed-item:hover .yd-ed-panel,
  .yd-ed-item:focus-within .yd-ed-panel { display: block; }
  .yd-ed-hdr .yd-ed-panel,
  .yd-ed-hdr.is-solid .yd-ed-panel,
  body.yd-overlay-header .yd-ed-hdr:not(.is-solid) .yd-ed-panel { color: #374151; text-shadow: none; }
  /* 히어로 위 흰 글자 가독성 */
  body.yd-overlay-header .yd-ed-hdr:not(.is-solid) { text-shadow: 0 1px 10px rgba(0,0,0,.35); }
  /* 굳은 상태 */
  .yd-ed-hdr.is-solid { background: #fff; box-shadow: 0 1px 0 rgba(0,0,0,.06); text-shadow: none; }
  .yd-ed-hdr.is-solid, .yd-ed-hdr.is-solid .yd-ed-navlink, .yd-ed-hdr.is-solid .yd-ed-ico, .yd-ed-hdr.is-solid .yd-ed-logo { color: #14110d; }

  /*
   * 풀블리드 히어로가 없는 페이지(상품목록·상세·마이페이지…) — 겹칠 대상이 없다.
   * 투명·absolute 로 두면 흰 배경에 흰 글자라 헤더가 통째로 사라지고 본문이 그 밑으로 파고든다.
   * → 처음부터 흰 배경 sticky 로 둔다(레이아웃이 body.yd-overlay-header 를 안 붙인 경우).
   */
  body:not(.yd-overlay-header) .yd-ed-hdr {
    position: sticky;
    background: #fff;
    box-shadow: 0 1px 0 rgba(0,0,0,.06);
    text-shadow: none;
  }
  body:not(.yd-overlay-header) .yd-ed-hdr,
  body:not(.yd-overlay-header) .yd-ed-hdr .yd-ed-navlink,
  body:not(.yd-overlay-header) .yd-ed-hdr .yd-ed-ico,
  body:not(.yd-overlay-header) .yd-ed-hdr .yd-ed-logo { color: #14110d; }
</style>
<script>
  (function () {
    var h = document.querySelector('.yd-ed-hdr');
    if (!h) return;
    var after = Number(h.getAttribute('data-solid-after')) || 80;
    function onScroll() { h.classList.toggle('is-solid', window.scrollY > after); }
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>
