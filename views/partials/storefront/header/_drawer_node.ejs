<%
  /*
   * 드로어 메뉴 노드 1개 (재귀) — 드로어형 스킨 전용
   *
   * locals: node = { name, href, kind, badgeType, newWindow, pcVisible, mobileVisible, children[] }, depth (1 = 최상위)
   *
   * 자식이 있으면 **항목명 자체가 아코디언 토글**이고(누르면 하위가 펼쳐진다),
   * 해당 메뉴로 이동하는 링크는 행 끝의 [>] 버튼이다. 둘은 분리된 요소다 —
   * 하나로 합치면 상위 카테고리로 갈 방법이 사라진다.
   * 자식이 없으면 항목명이 그대로 링크다.
   *
   * PC/모바일 노출은 서버가 거르지 않는다(같은 DOM 을 두 폭에서 함께 쓴다).
   * pc_visible=0 → md 이상에서 숨김, mobile_visible=0 → md 미만에서 숨김. 둘 다 0 이면 렌더하지 않는다.
   */
  const _pc = node.pcVisible !== 0;
  const _mo = node.mobileVisible !== 0;
  const _kids = (node.children || []).filter((c) => c.pcVisible !== 0 || c.mobileVisible !== 0);
  const _active = (typeof currentPath !== 'undefined') && node.href && node.href !== '#' && currentPath === node.href;
  const _linkable = node.href && node.href !== '#';
  // 뎁스별 들여쓰기(px). 1뎁스는 드로어 좌측 패딩만 쓴다.
  const _indent = (depth - 1) * 12;
  const _cls = `yd-dw__link ${depth === 1 ? 'yd-dw__link--top' : 'yd-dw__link--sub'} ${_active ? 'is-active' : ''}`;
%>
<% if (_pc || _mo) { %>
<li class="<%= _pc ? '' : 'md:hidden' %> <%= _mo ? '' : 'hidden md:block' %>">
    <div class="yd-dw__row" style="padding-left: <%= _indent %>px">
        <% if (_kids.length) { %>
            <%# 자식이 있으면 항목명이 아코디언 토글. JS 가 aria-expanded 와 행 다음의 <ul> hidden 을 뒤집는다. %>
            <button type="button" class="<%= _cls %> yd-dw__name" aria-expanded="false">
                <span><%= node.name %></span>
                <% if (node.badgeType) { %>
                    <span class="yd-dw__badge <%= node.badgeType === 'HOT' ? 'is-hot' : (node.badgeType === 'SALE' ? 'is-sale' : 'is-new') %>"><%= node.badgeType %></span>
                <% } %>
                <i class="bi bi-chevron-down yd-dw__caret" aria-hidden="true"></i>
            </button>

            <%# 해당 메뉴로 실제 이동하는 유일한 진입점. 링크가 없는 그룹 노드('#')면 내지 않는다. %>
            <% if (_linkable) { %>
                <a href="<%= node.href %>" <%- node.newWindow ? 'target="_blank" rel="noopener noreferrer"' : '' %>
                   class="yd-dw__go" aria-label="<%= node.name %> 바로가기">
                    <i class="bi bi-chevron-right" aria-hidden="true"></i>
                </a>
            <% } %>
        <% } else { %>
            <a href="<%= node.href %>" <%- node.newWindow ? 'target="_blank" rel="noopener noreferrer"' : '' %>
               class="<%= _cls %>">
                <span><%= node.name %></span>
                <% if (node.badgeType) { %>
                    <span class="yd-dw__badge <%= node.badgeType === 'HOT' ? 'is-hot' : (node.badgeType === 'SALE' ? 'is-sale' : 'is-new') %>"><%= node.badgeType %></span>
                <% } %>
            </a>
        <% } %>
    </div>

    <% if (_kids.length) { %>
        <ul class="yd-dw__sub hidden">
            <% _kids.forEach(function (child) { %>
                <%- include('./_drawer_node', { node: child, depth: depth + 1 }) %>
            <% }); %>
        </ul>
    <% } %>
</li>
<% } %>
