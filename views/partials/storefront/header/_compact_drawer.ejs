<%
  /*
   * 드로어형 헤더 스킨 — header_layout_type='compact_drawer_v1' (nav_mode='unified')
   *
   *  ┌──────────────────────────────────┐   ┌─────────────────────┐
   *  │ [☰]      [로고]        🔍 👤 🛒  │   │ JOIN LOGIN MY PAGE  │  ← 드로어(좌측 슬라이드)
   *  └──────────────────────────────────┘   │ [검색 ▸           ] │
   *                                          │ 오늘출발        +   │
   *                                          │ 베스트 50           │
   *                                          │ 건강기능식품    +   │  ← [+] 로 2·3뎁스 아코디언
   *                                          │ …                   │
   *                                          │ ─────────────────── │
   *                                          │ 고객센터 1644-4358  │
   *                                          └─────────────────────┘
   *
   * 메뉴 데이터는 기본형 스킨과 같은 소스에서 온다 — navigationService.buildUnified 가 만든
   * 트리(카테고리 1뎁스 + 기능/커스텀 메뉴, 각 항목에 children). 메뉴 관리·미리보기 화면은 그대로 쓰고,
   * 관리자가 Header 설정에서 스킨을 바꿔도 메뉴 구성은 그대로 따라온다.
   *
   * 드로어는 PC·모바일 공용이다(하나의 DOM). 기기별 노출은 pc_visible/mobile_visible 로
   * _drawer_node.ejs 가 CSS 클래스로 가른다 — 서버가 기기 필터를 하지 않는 기존 원칙 그대로.
   */
  const _headerUtil = (code) => {
    const list = (typeof headerUtilMenus !== 'undefined' && Array.isArray(headerUtilMenus)) ? headerUtilMenus : [];
    return list.find((m) => m.featureCode === code) || null;
  };
  const _gnb = (typeof gnbMenus !== 'undefined' && Array.isArray(gnbMenus)) ? gnbMenus : [];
  const _cfg = (typeof nav !== 'undefined' && nav && nav.config) ? nav.config : {};
  const _useSearch = Number(_cfg.use_search_bar) !== 0;   // PC 는 상단 공통부의 검색바, 모바일은 드로어 안 검색폼
  const _cs = _headerUtil('HEADER_CS');

  /*
   * PC GNB — 한 줄 인라인 메뉴. 카테고리 1뎁스와 일반 메뉴가 **같은 줄**에 순서대로 놓이고,
   * 하위 뎁스는 마우스 오버 드롭다운으로만 나온다(1뎁스만 상시 노출).
   * 서버는 기기 필터를 하지 않으므로(같은 HTML) 여기서 pcVisible 로 고른다 — 드로어(모바일)는
   * 같은 _gnb 를 그대로 쓴다. 즉 PC·모바일이 같은 순서를 공유한다.
   */
  const _pcGnb = _gnb.filter((m) => Number(m.pcVisible) !== 0);
  const _isCat = (m) => m.kind === 'category';
  const _pcKids = (m) => (m.children || []).filter((c) => Number(c.pcVisible) !== 0);

  /*
   * 드로어 섹션 분리 — 참조 디자인처럼 '카테고리'와 '일반/시스템 메뉴'를 별도 섹션으로 낸다.
   * 데이터는 한 트리(_gnb)에서 오지만 kind 로 가른다(category vs 기능·커스텀 메뉴).
   * 각 그룹 안의 상대 순서(관리자가 잡은 sort_order)는 그대로 유지된다.
   */
  const _catNodes  = _gnb.filter((m) => _isCat(m));
  const _menuNodes = _gnb.filter((m) => !_isCat(m));

  const _isLoggedIn = (typeof user !== 'undefined') && !!user;
  const _memberName = _isLoggedIn ? (user.name || user.nickname || user.username || '회원') : '';
  const _cartCount  = (typeof cartCount !== 'undefined' && Number(cartCount) > 0) ? Number(cartCount) : 0;

  /*
   * 알림·배너 슬롯 — 값이 있을 때만 낸다(빈 박스를 내지 않는다). 지금은 소스가 없어 렌더되지 않지만,
   * 관리자가 site_settings 에 아래 키를 넣으면(또는 컨트롤러가 drawerNotice 로컬을 넘기면) 자동 노출된다.
   *   drawer_notice        : 알림 문구(공지·이벤트 한 줄)
   *   drawer_banner_image  : 메뉴 배너 이미지 URL
   *   drawer_banner_link   : 배너 클릭 시 이동 URL
   */
  const _dwNotice = (typeof drawerNotice !== 'undefined' && drawerNotice)
        ? drawerNotice
        : ((siteSettings && siteSettings.drawer_notice) || '');
  const _dwBanner     = (siteSettings && siteSettings.drawer_banner_image) || '';
  const _dwBannerLink = (siteSettings && siteSettings.drawer_banner_link) || '';
  const _bizHours     = (siteSettings && siteSettings.business_hours) || '';
%>
    <!-- Header (드로어형 / compact_drawer_v1) -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100 shadow-sm">

        <%#
          GNB 위쪽 공통부(상단바 + 로고/검색바/유저 액션) — 기본형 스킨과 **같은 마크업**을 쓴다.
          스킨을 바꿔도 PC 헤더 상단은 동일해야 한다는 요구. 모바일은 아래 자체 바가 담당하므로 pcOnly.
        %>
        <%- include('./_pc_top', { pcOnly: true, useSearch: _useSearch }) %>

        <%# 모바일 바 — 햄버거 · 로고 · 장바구니. PC 에서는 위 공통부가 대신한다. %>
        <div class="md:hidden max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 h-16">

                <button type="button" id="yd-dw-open" aria-expanded="false" aria-controls="yd-drawer" aria-label="전체 메뉴 열기"
                        class="flex items-center justify-center w-10 h-10 -ml-2 rounded-full text-gray-800 hover:bg-gray-50 transition-colors">
                    <i class="bi bi-list text-2xl"></i>
                </button>

                <!-- 로고 (모바일 중앙) -->
                <a href="/" class="flex items-center justify-center gap-2 min-w-0">
                    <% if (siteSettings.logo_url) { %>
                        <img class="h-8 w-auto" src="<%= siteSettings.logo_url %>"
                             alt="<%= siteSettings.company_name || '와이디몰' %>">
                    <% } else { %>
                        <span class="gh-serif text-xl font-bold text-[var(--gh-primary-dark)] tracking-tight truncate">
                            <%= siteSettings.company_name || '와이디몰' %>
                        </span>
                    <% } %>
                </a>

                <%#
                  나머지 유틸(로그인·마이쇼핑·고객센터)은 드로어 안 '모바일 유틸'에 둔다 — 좁은 화면에서
                  아이콘을 다 밀어 넣으면 로고가 찌그러진다. 장바구니만 예외로 남긴다(구매 동선의 마지막 진입점).
                %>
                <div class="flex items-center justify-end">
                    <a href="/cart" aria-label="장바구니" title="장바구니"
                       class="relative flex items-center justify-center w-10 h-10 -mr-2 rounded-full text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 transition-colors">
                        <i class="bi bi-bag text-xl"></i>
                        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
                            <span class="absolute top-0.5 right-0 bg-[var(--gh-accent)] text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full">
                                <%= cartCount %>
                            </span>
                        <% } %>
                    </a>
                </div>
            </div>
        </div>

        <%#
          PC 인라인 GNB — 카테고리 1뎁스 + 일반 메뉴가 한 줄에 순서대로. 하위 뎁스는 오버 드롭다운.
          카테고리 묶음과 일반 메뉴 묶음 사이에는 세로 구분선을 넣는다(종류가 바뀌는 지점에서만).
          컨테이너 폭은 상단 공통부와 같은 max-w-7xl 로 맞춘다(좌측 정렬이 어긋나면 안 된다).
        %>
        <nav class="hidden md:block border-t border-gray-100" aria-label="주 메뉴">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <ul class="flex items-center gap-6 h-11">
                    <% _pcGnb.forEach(function (m, i) { %>
                        <% if (i > 0 && _isCat(_pcGnb[i - 1]) !== _isCat(m)) { %>
                            <li aria-hidden="true" class="h-3.5 w-px bg-gray-200 -mx-2"></li>
                        <% } %>
                        <% const kids = _pcKids(m); %>
                        <li class="yd-gnb__item relative h-full flex items-center">
                            <a href="<%= m.href %>" <%= Number(m.newWindow) ? 'target="_blank" rel="noopener"' : '' %>
                               class="flex items-center gap-1 text-[15px] whitespace-nowrap text-gray-800 hover:text-[var(--gh-primary)] transition-colors">
                                <%= m.name %>
                                <% if (m.badgeType) { %>
                                    <span class="yd-dw__badge is-<%= String(m.badgeType).toLowerCase() %>"><%= m.badgeType %></span>
                                <% } %>
                            </a>

                            <% if (kids.length) { %>
                                <div class="yd-gnb__panel absolute left-0 top-full z-40 min-w-[180px] rounded-b-lg border border-gray-100 border-t-0 bg-white shadow-lg py-2">
                                    <ul>
                                        <% kids.forEach(function (c) { %>
                                            <li>
                                                <a href="<%= c.href %>" class="block px-4 py-2 text-sm text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 whitespace-nowrap">
                                                    <%= c.name %>
                                                </a>
                                                <% const grand = _pcKids(c); %>
                                                <% if (grand.length) { %>
                                                    <ul class="pb-1">
                                                        <% grand.forEach(function (g) { %>
                                                            <li>
                                                                <a href="<%= g.href %>" class="block pl-7 pr-4 py-1.5 text-xs text-gray-400 hover:text-[var(--gh-primary)] whitespace-nowrap">
                                                                    <%= g.name %>
                                                                </a>
                                                            </li>
                                                        <% }); %>
                                                    </ul>
                                                <% } %>
                                            </li>
                                        <% }); %>
                                    </ul>
                                </div>
                            <% } %>
                        </li>
                    <% }); %>
                    <% if (!_pcGnb.length) { %>
                        <li class="text-sm text-gray-300">등록된 메뉴가 없습니다.</li>
                    <% } %>
                </ul>
            </div>
        </nav>
    </header>

    <%#
      드로어 + 백드롭은 <header> **바깥**에 둔다. header 가 z-50 으로 stacking context 를 만들기 때문에
      안에 두면 fixed 백드롭이 헤더까지 덮는다(기본형 스킨의 카테고리 백드롭이 같은 이유로 밖에 있다).
    %>
    <div id="yd-dw-backdrop" class="hidden fixed inset-0 z-[60] bg-black/40" aria-hidden="true"></div>

    <%#
      열림/닫힘은 Tailwind 유틸(-translate-x-full)이 아니라 아래 .yd-dw CSS 로 한다.
      Tailwind v4 의 translate 유틸은 `transform` 이 아니라 **`translate` 속성**을 쓰기 때문에,
      transform 으로 여는 규칙과 서로 덮지 못해 드로어가 화면 밖에 머문다.
    %>
    <aside id="yd-drawer" class="yd-dw fixed top-0 left-0 z-[70] h-full w-[320px] max-w-[86vw] bg-white shadow-2xl flex flex-col"
           role="dialog" aria-modal="true" aria-label="전체 메뉴" aria-hidden="true">

        <%# ── 1. 회원 헤더: 로그인 상태 + 닫기 ─────────────────────────────── %>
        <div class="yd-dw__head">
            <p class="yd-dw__greet">
                <% if (_isLoggedIn) { %>
                    <strong><%= _memberName %></strong>님, 환영합니다.
                <% } else { %>
                    로그인이 필요합니다.
                <% } %>
            </p>
            <button type="button" id="yd-dw-close" aria-label="메뉴 닫기" class="yd-dw__close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <%# ── 2. 회원 액션 3분할 (로그인/회원가입/마이쇼핑 · 로그인 시 홈/마이쇼핑/로그아웃) ── %>
        <nav class="yd-dw__auth" aria-label="회원 메뉴">
            <% if (_isLoggedIn) { %>
                <a href="/" class="yd-dw__authbtn">홈</a>
                <a href="/mypage" class="yd-dw__authbtn">마이쇼핑</a>
                <a href="/auth/logout" class="yd-dw__authbtn">로그아웃</a>
            <% } else { %>
                <a href="/auth/login" class="yd-dw__authbtn">로그인</a>
                <a href="/auth/signup" class="yd-dw__authbtn">회원가입</a>
                <a href="/mypage" class="yd-dw__authbtn">마이쇼핑</a>
            <% } %>
        </nav>

        <%# ── 3. 쇼핑 요약 타일 (관심상품/장바구니/주문조회). 카운트는 실데이터가 있는 장바구니만 배지로 ── %>
        <nav class="yd-dw__stats" aria-label="쇼핑 요약">
            <a href="/mypage/likes" class="yd-dw__stat"><i class="bi bi-heart"></i><span>관심상품</span></a>
            <a href="/cart" class="yd-dw__stat">
                <span class="yd-dw__staticon">
                    <i class="bi bi-bag"></i>
                    <% if (_cartCount > 0) { %><em class="yd-dw__dot"><%= _cartCount %></em><% } %>
                </span>
                <span>장바구니</span>
            </a>
            <a href="/mypage/orders" class="yd-dw__stat"><i class="bi bi-receipt"></i><span>주문조회</span></a>
        </nav>

        <!-- 검색 (use_search_bar=0 이면 통째로 빠진다) -->
        <% if (_useSearch) { %>
            <form action="/search" method="get" role="search" class="yd-dw__search">
                <div class="flex items-center gap-2 border-b border-gray-300 pb-1.5">
                    <input type="text" name="q" autocomplete="off" placeholder="검색어를 입력해주세요"
                           class="flex-1 min-w-0 bg-transparent text-sm text-gray-800 placeholder:text-gray-400 focus:outline-none">
                    <button type="submit" aria-label="검색" class="text-gray-500 hover:text-[var(--gh-primary)]">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>
        <% } %>

        <%# ── 스크롤 영역: 알림/배너 슬롯 + 카테고리 섹션 + 메뉴 섹션 ─────────── %>
        <div class="yd-dw__scroll flex-1 overflow-y-auto">

            <%# 4. 알림·배너 슬롯 — 값이 있을 때만. (source: drawerNotice / siteSettings.drawer_*) %>
            <% if (_dwBanner || _dwNotice) { %>
                <div class="yd-dw__notice">
                    <% if (_dwBanner) { %>
                        <a href="<%= _dwBannerLink || '#' %>" class="yd-dw__banner"<%- _dwBannerLink ? '' : ' aria-disabled="true"' %>>
                            <img src="<%= _dwBanner %>" alt="메뉴 배너" loading="lazy">
                        </a>
                    <% } %>
                    <% if (_dwNotice) { %>
                        <p class="yd-dw__noticetext"><i class="bi bi-megaphone" aria-hidden="true"></i><span><%= _dwNotice %></span></p>
                    <% } %>
                </div>
            <% } %>

            <%# 5. 카테고리 섹션 (하위 뎁스는 [+] 아코디언) %>
            <% if (_catNodes.length) { %>
                <section class="yd-dw__section" aria-label="카테고리">
                    <h2 class="yd-dw__sectitle">카테고리</h2>
                    <ul class="yd-dw__list">
                        <% _catNodes.forEach(function (m) { %>
                            <%- include('./_drawer_node', { node: m, depth: 1 }) %>
                        <% }); %>
                    </ul>
                </section>
            <% } %>

            <%# 6. 일반/시스템 메뉴 섹션 (기획전·이벤트·공지 등 기능·커스텀 메뉴) %>
            <% if (_menuNodes.length) { %>
                <section class="yd-dw__section" aria-label="메뉴">
                    <h2 class="yd-dw__sectitle">메뉴</h2>
                    <ul class="yd-dw__list">
                        <% _menuNodes.forEach(function (m) { %>
                            <%- include('./_drawer_node', { node: m, depth: 1 }) %>
                        <% }); %>
                    </ul>
                </section>
            <% } %>

            <% if (!_gnb.length) { %>
                <p class="yd-dw__empty">등록된 메뉴가 없습니다.</p>
            <% } %>
        </div>

        <%# ── 7. 고객센터 (하단 고정) — 값이 있을 때만. 입금계좌는 두지 않는다 ─── %>
        <% if (siteSettings.contact_phone || siteSettings.contact_email || _bizHours || _cs) { %>
            <div class="yd-dw__cs">
                <p class="yd-dw__cstitle">고객센터</p>
                <% if (siteSettings.contact_phone) { %>
                    <a href="tel:<%= siteSettings.contact_phone %>" class="yd-dw__tel"><%= siteSettings.contact_phone %></a>
                <% } %>
                <% if (_bizHours) { %>
                    <p class="yd-dw__hours"><%= _bizHours %></p>
                <% } %>
                <% if (_cs || siteSettings.contact_email) { %>
                    <div class="yd-dw__cslinks">
                        <% if (_cs) { %><a href="<%= _cs.href %>"><%= _cs.name %></a><% } %>
                        <% if (siteSettings.contact_email) { %><a href="mailto:<%= siteSettings.contact_email %>"><%= siteSettings.contact_email %></a><% } %>
                    </div>
                <% } %>
            </div>
        <% } %>

        <%#
          몰 선택 셀렉트는 스토어프론트에서 내지 않는다(고객에게 몰을 고르게 하지 않는다).
          전환은 `?mall=<code>` 쿼리로 여전히 되고 세션에 고정된다 — 관리자 미리보기·QA 용 경로다.
        %>
    </aside>

    <style>
      /* PC GNB 드롭다운 — 마우스 오버·키보드 포커스에서만 펼친다(1뎁스는 상시 노출) */
      .yd-gnb__panel { display: none; }
      .yd-gnb__item:hover .yd-gnb__panel,
      .yd-gnb__item:focus-within .yd-gnb__panel { display: block; }

      .yd-dw { transform: translateX(-100%); transition: transform .3s cubic-bezier(.16,1,.3,1); }
      .yd-dw.is-open { transform: translateX(0); }
      @media (prefers-reduced-motion: reduce) { .yd-dw { transition: none; } }

      /* 1. 회원 헤더 — 로그인 상태 + 닫기 */
      .yd-dw__head { display: flex; align-items: center; justify-content: space-between; gap: .5rem; padding: 1rem 1.25rem .5rem; }
      .yd-dw__greet { font-size: .9375rem; color: #374151; }
      .yd-dw__greet strong { color: #111827; font-weight: 700; }
      .yd-dw__close {
        flex: 0 0 auto; width: 2.25rem; height: 2.25rem; margin-right: -.25rem;
        display: flex; align-items: center; justify-content: center;
        border-radius: 9999px; color: #9ca3af; transition: color .15s, background-color .15s;
      }
      .yd-dw__close:hover { color: #374151; background: #f9fafb; }

      /* 2. 회원 액션 3분할 (로그인/회원가입/마이쇼핑) */
      .yd-dw__auth { margin: 0 1.25rem; display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid #e5e7eb; border-radius: .5rem; overflow: hidden; }
      .yd-dw__authbtn { padding: .625rem .25rem; text-align: center; font-size: .8125rem; color: #374151; border-left: 1px solid #e5e7eb; transition: color .15s, background-color .15s; }
      .yd-dw__authbtn:first-child { border-left: 0; }
      .yd-dw__authbtn:hover { background: #f9fafb; color: var(--gh-primary); }

      /* 3. 쇼핑 요약 타일 (관심상품/장바구니/주문조회) */
      .yd-dw__stats { margin: .75rem 1.25rem 0; display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid #f3f4f6; }
      .yd-dw__stat { display: flex; flex-direction: column; align-items: center; gap: .3125rem; padding: .75rem .25rem; font-size: 11px; color: #6b7280; transition: color .15s; }
      .yd-dw__stat i { font-size: 1.25rem; color: #4b5563; transition: color .15s; }
      .yd-dw__stat:hover, .yd-dw__stat:hover i { color: var(--gh-primary); }
      .yd-dw__staticon { position: relative; display: inline-flex; }
      .yd-dw__dot {
        position: absolute; top: -.375rem; right: -.5rem; min-width: 1rem; height: 1rem; padding: 0 .1875rem;
        display: flex; align-items: center; justify-content: center;
        background: var(--gh-accent); color: #fff; font-size: 9px; font-weight: 800; font-style: normal; border-radius: 9999px;
      }

      /* 검색 폼 */
      .yd-dw__search { padding: 1rem 1.25rem; }

      /* 4. 알림·배너 슬롯 */
      .yd-dw__notice { padding: 0 1.25rem 1rem; }
      .yd-dw__banner { display: block; border-radius: .5rem; overflow: hidden; }
      .yd-dw__banner img { display: block; width: 100%; height: auto; }
      .yd-dw__noticetext {
        display: flex; align-items: flex-start; gap: .375rem; margin-top: .5rem;
        padding: .625rem .75rem; background: #f9fafb; border-radius: .5rem; font-size: .8125rem; color: #4b5563;
      }
      .yd-dw__noticetext i { color: var(--gh-primary); margin-top: .125rem; }

      /* 5·6. 섹션 (카테고리 / 메뉴) */
      .yd-dw__section { padding: .25rem 1.25rem .5rem; }
      .yd-dw__section + .yd-dw__section { border-top: 1px solid #f3f4f6; margin-top: .25rem; padding-top: .5rem; }
      .yd-dw__sectitle { font-size: .75rem; font-weight: 700; letter-spacing: .02em; color: #9ca3af; padding: .5rem 0 .125rem; }
      .yd-dw__empty { padding: 1.5rem 1.25rem; font-size: .875rem; color: #9ca3af; }

      /* 7. 고객센터 (하단) */
      .yd-dw__cs { border-top: 1px solid #e5e7eb; padding: 1rem 1.25rem 1.25rem; }
      .yd-dw__cstitle { font-size: .75rem; font-weight: 700; color: #9ca3af; }
      .yd-dw__tel { display: block; margin-top: .25rem; font-size: 1.5rem; font-weight: 800; letter-spacing: -.01em; color: #111827; }
      .yd-dw__tel:hover { color: var(--gh-primary); }
      .yd-dw__hours { margin-top: .375rem; font-size: .75rem; line-height: 1.5; color: #6b7280; white-space: pre-line; }
      .yd-dw__cslinks { margin-top: .5rem; display: flex; flex-wrap: wrap; gap: .75rem; }
      .yd-dw__cslinks a { font-size: .75rem; color: #6b7280; transition: color .15s; }
      .yd-dw__cslinks a:hover { color: var(--gh-primary); }

      .yd-dw__row { display: flex; align-items: center; justify-content: space-between; gap: .5rem; }

      .yd-dw__link { flex: 1 1 auto; min-width: 0; display: flex; align-items: center; gap: .375rem; padding: .625rem 0; text-align: left; }
      .yd-dw__link--top { font-size: .9375rem; color: #1f2937; }
      .yd-dw__link--sub { font-size: .875rem; color: #6b7280; }
      .yd-dw__link:hover { color: var(--gh-primary); }
      .yd-dw__link.is-active { color: var(--gh-primary); font-weight: 700; }

      /* 하위 목록은 좌측 라인으로 계층을 보인다(들여쓰기만으로는 3뎁스에서 구분이 흐려진다) */
      .yd-dw__sub { border-left: 1px solid #f3f4f6; margin-left: .125rem; padding-left: .5rem; }

      /* 항목명 = 아코디언 토글. 캐럿은 접힘 ▾ / 펼침 ▴ 로 회전한다 */
      .yd-dw__caret { font-size: .75rem; color: #9ca3af; transition: transform .2s; }
      .yd-dw__name[aria-expanded="true"] .yd-dw__caret { transform: rotate(180deg); }
      @media (prefers-reduced-motion: reduce) { .yd-dw__caret { transition: none; } }

      /* 행 끝의 [>] — 하위가 있는 메뉴에서 해당 메뉴로 가는 유일한 진입점 */
      .yd-dw__go {
        flex: 0 0 auto; width: 2rem; height: 2rem;
        display: flex; align-items: center; justify-content: center;
        color: #9ca3af; border-radius: 9999px; transition: color .15s, background-color .15s;
      }
      .yd-dw__go:hover { color: var(--gh-primary); background: #f9fafb; }

      .yd-dw__badge {
        font-size: 9px; font-weight: 800; line-height: 1;
        padding: 2px 3px; border-radius: 3px; color: #fff;
      }
      .yd-dw__badge.is-new  { background: var(--gh-primary); }
      .yd-dw__badge.is-hot  { background: #ef4444; }
      .yd-dw__badge.is-sale { background: #f59e0b; }

      /* 드로어가 열린 동안 본문 스크롤을 잠근다 */
      body.yd-dw-locked { overflow: hidden; }
    </style>

    <script>
      // PC 검색은 상단 공통부(_pc_top)의 검색바가 담당한다 — 모바일 검색은 드로어 안 폼.
      (function () {
        var drawer  = document.getElementById('yd-drawer');
        var openBtn = document.getElementById('yd-dw-open');
        var closeBtn= document.getElementById('yd-dw-close');
        var backdrop= document.getElementById('yd-dw-backdrop');
        if (!drawer || !openBtn) return;

        function setOpen(open) {
          drawer.classList.toggle('is-open', open);
          drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
          if (backdrop) backdrop.classList.toggle('hidden', !open);
          openBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
          document.body.classList.toggle('yd-dw-locked', open);
          if (open && closeBtn) closeBtn.focus();
          else openBtn.focus();
        }

        openBtn.addEventListener('click', function () { setOpen(true); });
        if (closeBtn) closeBtn.addEventListener('click', function () { setOpen(false); });
        if (backdrop) backdrop.addEventListener('click', function () { setOpen(false); });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && drawer.classList.contains('is-open')) setOpen(false);
        });

        // 아코디언 — 항목명(<button.yd-dw__name>)을 누르면 그 행 다음의 <ul.yd-dw__sub> 를 펼친다.
        // 해당 메뉴로 이동하는 링크는 행 끝의 [>](a.yd-dw__go) 다: 상위 카테고리로 갈 방법이 사라지면 안 된다.
        drawer.addEventListener('click', function (e) {
          var btn = e.target.closest('.yd-dw__name');
          if (!btn) return;
          var sub = btn.parentElement.nextElementSibling;
          if (!sub || !sub.classList.contains('yd-dw__sub')) return;
          var open = sub.classList.toggle('hidden') === false;
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
      })();
    </script>
