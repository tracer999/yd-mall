<%
  /*
   * 드로어형 헤더 스킨 — header_layout_type='compact_drawer_v1' (nav_mode='unified')
   *
   *  ┌──────────────────────────────────┐   ┌─────────────────────┐
   *  │ [☰]      [로고]        🔍 👤 🛒  │   │ JOIN LOGIN MY PAGE  │  ← 드로어(좌측 슬라이드)
   *  └──────────────────────────────────┘   │ [검색 ▸           ] │
   *                                          │ 오늘출발        +   │
   *                                          │ 베스트 50           │
   *                                          │ 건강기능식품    +   │  ← [+] 로 2·3뎁스 아코디언
   *                                          │ …                   │
   *                                          │ ─────────────────── │
   *                                          │ 고객센터 1644-4358  │
   *                                          └─────────────────────┘
   *
   * 메뉴 데이터는 기본형 스킨과 같은 소스에서 온다 — navigationService.buildUnified 가 만든
   * 트리(카테고리 1뎁스 + 기능/커스텀 메뉴, 각 항목에 children). 메뉴 관리·미리보기 화면은 그대로 쓰고,
   * 관리자가 Header 설정에서 스킨을 바꿔도 메뉴 구성은 그대로 따라온다.
   *
   * 드로어는 PC·모바일 공용이다(하나의 DOM). 기기별 노출은 pc_visible/mobile_visible 로
   * _drawer_node.ejs 가 CSS 클래스로 가른다 — 서버가 기기 필터를 하지 않는 기존 원칙 그대로.
   */
  const _gnb = (typeof gnbMenus !== 'undefined' && Array.isArray(gnbMenus)) ? gnbMenus : [];
  const _cfg = (typeof nav !== 'undefined' && nav && nav.config) ? nav.config : {};
  const _useSearch = Number(_cfg.use_search_bar) !== 0;   // PC 는 상단 공통부의 검색바, 모바일은 드로어 안 검색폼

  /*
   * PC GNB — 한 줄 인라인 메뉴. 카테고리 1뎁스와 일반 메뉴가 **같은 줄**에 순서대로 놓이고,
   * 하위 뎁스는 마우스 오버 드롭다운으로만 나온다(1뎁스만 상시 노출).
   * 서버는 기기 필터를 하지 않으므로(같은 HTML) 여기서 pcVisible 로 고른다 — 드로어(모바일)는
   * 같은 _gnb 를 그대로 쓴다. 즉 PC·모바일이 같은 순서를 공유한다.
   */
  const _pcGnb = _gnb.filter((m) => Number(m.pcVisible) !== 0);
  const _isCat = (m) => m.kind === 'category';
  const _pcKids = (m) => (m.children || []).filter((c) => Number(c.pcVisible) !== 0);

  /* 드로어 안(회원·검색·카테고리/메뉴 섹션·고객센터)에 필요한 값은 ./_drawer 가 스스로 계산한다. */
%>
    <!-- Header (드로어형 / compact_drawer_v1) -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100 shadow-sm">

        <%#
          GNB 위쪽 공통부(상단바 + 로고/검색바/유저 액션) — 기본형 스킨과 **같은 마크업**을 쓴다.
          스킨을 바꿔도 PC 헤더 상단은 동일해야 한다는 요구. 모바일은 아래 자체 바가 담당하므로 pcOnly.
        %>
        <%- include('./_pc_top', { pcOnly: true, useSearch: _useSearch }) %>

        <%# 모바일 바 — 햄버거 · 로고 · 장바구니. PC 에서는 위 공통부가 대신한다. %>
        <div class="md:hidden max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 h-16">

                <button type="button" id="yd-dw-open" aria-expanded="false" aria-controls="yd-drawer" aria-label="전체 메뉴 열기"
                        class="flex items-center justify-center w-10 h-10 -ml-2 rounded-full text-gray-800 hover:bg-gray-50 transition-colors">
                    <i class="bi bi-list text-2xl"></i>
                </button>

                <!-- 로고 (모바일 중앙) -->
                <a href="/" class="flex items-center justify-center gap-2 min-w-0">
                    <% if (siteSettings.logo_url) { %>
                        <img class="h-8 w-auto" src="<%= siteSettings.logo_url %>"
                             alt="<%= siteSettings.company_name || '와이디몰' %>">
                    <% } else { %>
                        <span class="gh-serif text-xl font-bold text-[var(--gh-primary-dark)] tracking-tight truncate">
                            <%= siteSettings.company_name || '와이디몰' %>
                        </span>
                    <% } %>
                </a>

                <%#
                  나머지 유틸(로그인·마이쇼핑·고객센터)은 드로어 안 '모바일 유틸'에 둔다 — 좁은 화면에서
                  아이콘을 다 밀어 넣으면 로고가 찌그러진다. 장바구니만 예외로 남긴다(구매 동선의 마지막 진입점).
                %>
                <div class="flex items-center justify-end">
                    <a href="/cart" aria-label="장바구니" title="장바구니"
                       class="relative flex items-center justify-center w-10 h-10 -mr-2 rounded-full text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 transition-colors">
                        <i class="bi bi-bag text-xl"></i>
                        <%# 0 이어도 렌더 — 갱신은 ydSetCartCount 가 data-cart-badge 를 잡아 한다 %>
                        <% const _cdCart = Number(typeof cartCount !== 'undefined' ? cartCount : 0) || 0; %>
                        <span data-cart-badge style="<%= _cdCart > 0 ? '' : 'display:none' %>"
                              class="absolute top-0.5 right-0 bg-[var(--gh-accent)] text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full"><%= _cdCart %></span>
                    </a>
                </div>
            </div>
        </div>

        <%#
          PC 인라인 GNB — 카테고리 1뎁스 + 일반 메뉴가 한 줄에 순서대로. 하위 뎁스는 오버 드롭다운.
          카테고리 묶음과 일반 메뉴 묶음 사이에는 세로 구분선을 넣는다(종류가 바뀌는 지점에서만).
          컨테이너 폭은 상단 공통부와 같은 max-w-7xl 로 맞춘다(좌측 정렬이 어긋나면 안 된다).
        %>
        <nav class="hidden md:block border-t border-gray-100" aria-label="주 메뉴">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <ul class="flex items-center gap-6 h-11">
                    <% _pcGnb.forEach(function (m, i) { %>
                        <% if (i > 0 && _isCat(_pcGnb[i - 1]) !== _isCat(m)) { %>
                            <li aria-hidden="true" class="h-3.5 w-px bg-gray-200 -mx-2"></li>
                        <% } %>
                        <% const kids = _pcKids(m); %>
                        <li class="yd-gnb__item relative h-full flex items-center<%= kids.length ? ' has-sub' : '' %>">
                            <a href="<%= m.href %>" <%= Number(m.newWindow) ? 'target="_blank" rel="noopener"' : '' %>
                               class="yd-gnb__link flex items-center gap-1 text-[15px] whitespace-nowrap text-gray-800">
                                <%= m.name %>
                                <% if (kids.length) { %>
                                    <i class="bi bi-chevron-down yd-gnb__caret" aria-hidden="true"></i>
                                <% } %>
                                <% if (m.badgeType) { %>
                                    <span class="yd-dw__badge is-<%= String(m.badgeType).toLowerCase() %>"><%= m.badgeType %></span>
                                <% } %>
                            </a>

                            <% if (kids.length) { %>
                                <%- include('./_gnb_dropdown', { kids: kids, pcKids: _pcKids, panelClass: 'yd-gnb__panel' }) %>
                            <% } %>
                        </li>
                    <% }); %>
                    <% if (!_pcGnb.length) { %>
                        <li class="text-sm text-gray-300">등록된 메뉴가 없습니다.</li>
                    <% } %>
                </ul>
            </div>
        </nav>
    </header>

    <%#
      드로어(백드롭 + 본체 + 스크립트) — 에디토리얼 스킨과 **공용**이라 ./_drawer 로 뽑아 뒀다.
      <header> 바깥이어야 한다: header 가 z-50 으로 stacking context 를 만들어, 안에 두면
      fixed 백드롭이 헤더까지 덮는다(기본형 스킨의 카테고리 백드롭이 같은 이유로 밖에 있다).
      여는 버튼(id=yd-dw-open)은 위 모바일 바에 있다.
    %>
    <%- include('./_drawer') %>

    <style>
      /*
       * PC GNB 1뎁스 — 하단 인디케이터가 가운데에서 좌우로 자란다. 색만 바뀌던 예전보다
       * 어느 항목에 있는지가 분명하고, 아래에서 열리는 패널과 한 덩어리로 읽힌다.
       */
      .yd-gnb__link { transition: color .18s ease; }
      /* 인디케이터는 링크가 아니라 <li> 에 붙인다 — 링크는 세로 중앙 정렬이라 그 기준으로 잡으면
         GNB 줄 아래(nav 바깥)로 삐져나온다. <li> 는 h-full 이라 바닥이 정확히 GNB 하단이다. */
      .yd-gnb__item::after {
        content: '';
        position: absolute;
        left: 0; right: 0; bottom: 0;
        height: 2px;
        background: var(--gh-primary, #2f6b46);
        transform: scaleX(0);
        transition: transform .28s cubic-bezier(.22, 1, .36, 1);
      }
      .yd-gnb__item:hover .yd-gnb__link,
      .yd-gnb__item:focus-within .yd-gnb__link { color: var(--gh-primary, #2f6b46); }
      .yd-gnb__item:hover::after,
      .yd-gnb__item:focus-within::after { transform: scaleX(1); }

      /* 하위가 있다는 표시. 열리면 뒤집힌다 — 패널이 이 항목에서 나왔음을 잇는다. */
      .yd-gnb__caret {
        font-size: 10px;
        opacity: .45;
        transition: transform .28s cubic-bezier(.22, 1, .36, 1), opacity .18s ease;
      }
      .yd-gnb__item:hover .yd-gnb__caret,
      .yd-gnb__item:focus-within .yd-gnb__caret { opacity: 1; transform: rotate(180deg); }

      @media (prefers-reduced-motion: reduce) {
        .yd-gnb__link, .yd-gnb__item::after, .yd-gnb__caret { transition-duration: .01ms !important; }
      }
    </style>

    <%# 드롭다운 패널의 모양·모션·위치 보정 — 에디토리얼 스킨과 공용 %>
    <%- include('./_gnb_dropdown_style') %>
