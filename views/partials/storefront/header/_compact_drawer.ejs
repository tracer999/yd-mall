<%
  /*
   * 드로어형 헤더 스킨 — header_layout_type='compact_drawer_v1' (nav_mode='unified')
   *
   *  ┌──────────────────────────────────┐   ┌─────────────────────┐
   *  │ [☰]      [로고]        🔍 👤 🛒  │   │ JOIN LOGIN MY PAGE  │  ← 드로어(좌측 슬라이드)
   *  └──────────────────────────────────┘   │ [검색 ▸           ] │
   *                                          │ 오늘출발        +   │
   *                                          │ 베스트 50           │
   *                                          │ 건강기능식품    +   │  ← [+] 로 2·3뎁스 아코디언
   *                                          │ …                   │
   *                                          │ ─────────────────── │
   *                                          │ 고객센터 1644-4358  │
   *                                          └─────────────────────┘
   *
   * 메뉴 데이터는 기본형 스킨과 같은 소스에서 온다 — navigationService.buildUnified 가 만든
   * 트리(카테고리 1뎁스 + 기능/커스텀 메뉴, 각 항목에 children). 메뉴 관리·미리보기 화면은 그대로 쓰고,
   * 관리자가 Header 설정에서 스킨을 바꿔도 메뉴 구성은 그대로 따라온다.
   *
   * 드로어는 PC·모바일 공용이다(하나의 DOM). 기기별 노출은 pc_visible/mobile_visible 로
   * _drawer_node.ejs 가 CSS 클래스로 가른다 — 서버가 기기 필터를 하지 않는 기존 원칙 그대로.
   */
  const _headerUtil = (code) => {
    const list = (typeof headerUtilMenus !== 'undefined' && Array.isArray(headerUtilMenus)) ? headerUtilMenus : [];
    return list.find((m) => m.featureCode === code) || null;
  };
  const _gnb = (typeof gnbMenus !== 'undefined' && Array.isArray(gnbMenus)) ? gnbMenus : [];
  const _cfg = (typeof nav !== 'undefined' && nav && nav.config) ? nav.config : {};
  const _useSearch = Number(_cfg.use_search_bar) !== 0;   // 모바일은 드로어 안, PC 는 헤더 검색 아이콘
  const _cs = _headerUtil('HEADER_CS');

  /*
   * PC GNB — 한 줄 인라인 메뉴. 카테고리 1뎁스와 일반 메뉴가 **같은 줄**에 순서대로 놓이고,
   * 하위 뎁스는 마우스 오버 드롭다운으로만 나온다(1뎁스만 상시 노출).
   * 서버는 기기 필터를 하지 않으므로(같은 HTML) 여기서 pcVisible 로 고른다 — 드로어(모바일)는
   * 같은 _gnb 를 그대로 쓴다. 즉 PC·모바일이 같은 순서를 공유한다.
   */
  const _pcGnb = _gnb.filter((m) => Number(m.pcVisible) !== 0);
  const _isCat = (m) => m.kind === 'category';
  const _pcKids = (m) => (m.children || []).filter((c) => Number(c.pcVisible) !== 0);
%>
    <!-- Header (드로어형 / compact_drawer_v1) -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 h-16">

                <!-- 햄버거 — 모바일 전용. PC 는 아래 인라인 GNB 가 메뉴를 다 보여주므로 드로어를 열 이유가 없다. -->
                <button type="button" id="yd-dw-open" aria-expanded="false" aria-controls="yd-drawer" aria-label="전체 메뉴 열기"
                        class="md:hidden flex items-center justify-center w-10 h-10 -ml-2 rounded-full text-gray-800 hover:bg-gray-50 transition-colors">
                    <i class="bi bi-list text-2xl"></i>
                </button>

                <!-- 로고 (모바일 중앙 / PC 좌측) -->
                <a href="/" class="flex items-center justify-center md:justify-start gap-2 min-w-0">
                    <% if (siteSettings.logo_url) { %>
                        <img class="h-8 w-auto" src="<%= siteSettings.logo_url %>"
                             alt="<%= siteSettings.company_name || '와이디몰' %>">
                    <% } else { %>
                        <span class="gh-serif text-xl font-bold text-[var(--gh-primary-dark)] tracking-tight truncate">
                            <%= siteSettings.company_name || '와이디몰' %>
                        </span>
                    <% } %>
                </a>

                <%#
                  유틸 아이콘 — PC 는 여기(헤더 상단), 모바일은 드로어 안(아래 '모바일 유틸')에 둔다.
                  좁은 화면에서 아이콘 4~5개를 헤더에 밀어 넣으면 로고가 찌그러진다.
                  장바구니만 예외로 모바일에서도 헤더에 남긴다 — 구매 동선의 마지막 진입점이라 한 번에 닿아야 한다.
                %>
                <div class="flex items-center gap-1 justify-end">
                    <%# PC 검색 — 아이콘을 누르면 헤더 아래로 검색줄이 펼쳐진다(모바일은 드로어 안 검색폼이 담당). %>
                    <% if (_useSearch) { %>
                        <button type="button" id="yd-pc-search-btn" aria-expanded="false" aria-controls="yd-pc-search" aria-label="검색"
                                class="hidden md:flex items-center justify-center w-10 h-10 rounded-full text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 transition-colors">
                            <i class="bi bi-search text-xl"></i>
                        </button>
                    <% } %>
                    <% if (user) { %>
                        <a href="/mypage" aria-label="마이쇼핑" title="마이쇼핑"
                           class="hidden md:flex items-center justify-center w-10 h-10 rounded-full text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 transition-colors">
                            <i class="bi bi-person text-xl"></i>
                        </a>
                        <a href="/auth/logout" aria-label="로그아웃" title="로그아웃"
                           class="hidden md:flex items-center justify-center w-10 h-10 rounded-full text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 transition-colors">
                            <i class="bi bi-box-arrow-right text-xl"></i>
                        </a>
                    <% } else { %>
                        <%# 이 몰은 OAuth 전용이라 가입·로그인 진입점이 같다(/auth/login). 아이콘만 구분한다. %>
                        <a href="/auth/login" aria-label="회원가입" title="회원가입"
                           class="hidden md:flex items-center justify-center w-10 h-10 rounded-full text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 transition-colors">
                            <i class="bi bi-person-plus text-xl"></i>
                        </a>
                        <a href="/auth/login" aria-label="로그인" title="로그인"
                           class="hidden md:flex items-center justify-center w-10 h-10 rounded-full text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 transition-colors">
                            <i class="bi bi-person text-xl"></i>
                        </a>
                    <% } %>

                    <% if (_cs) { %>
                        <a href="<%= _cs.href %>" aria-label="<%= _cs.name %>" title="<%= _cs.name %>"
                           class="hidden md:flex items-center justify-center w-10 h-10 rounded-full text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 transition-colors">
                            <i class="bi bi-headset text-xl"></i>
                        </a>
                    <% } %>

                    <a href="/cart" aria-label="장바구니" title="장바구니"
                       class="relative flex items-center justify-center w-10 h-10 -mr-2 rounded-full text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 transition-colors">
                        <i class="bi bi-bag text-xl"></i>
                        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
                            <span class="absolute top-0.5 right-0 bg-[var(--gh-accent)] text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full">
                                <%= cartCount %>
                            </span>
                        <% } %>
                    </a>
                </div>
            </div>
        </div>

        <%# PC 검색줄 — 기본 접힘. 아이콘으로 토글한다. %>
        <% if (_useSearch) { %>
            <div id="yd-pc-search" class="hidden md:block border-t border-gray-100">
                <form action="/search" method="get" role="search" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
                    <div class="flex items-center gap-2 border-b border-gray-300 pb-1.5">
                        <input type="text" name="q" autocomplete="off" placeholder="검색어를 입력해주세요"
                               class="flex-1 min-w-0 bg-transparent text-sm text-gray-800 placeholder:text-gray-400 focus:outline-none">
                        <button type="submit" aria-label="검색" class="text-gray-500 hover:text-[var(--gh-primary)]">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        <% } %>

        <%#
          PC 인라인 GNB — 카테고리 1뎁스 + 일반 메뉴가 한 줄에 순서대로. 하위 뎁스는 오버 드롭다운.
          카테고리 묶음과 일반 메뉴 묶음 사이에는 세로 구분선을 넣는다(종류가 바뀌는 지점에서만).
        %>
        <nav class="hidden md:block border-t border-gray-100" aria-label="주 메뉴">
            <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
                <ul class="flex items-center gap-6 h-11">
                    <% _pcGnb.forEach(function (m, i) { %>
                        <% if (i > 0 && _isCat(_pcGnb[i - 1]) !== _isCat(m)) { %>
                            <li aria-hidden="true" class="h-3.5 w-px bg-gray-200 -mx-2"></li>
                        <% } %>
                        <% const kids = _pcKids(m); %>
                        <li class="yd-gnb__item relative h-full flex items-center">
                            <a href="<%= m.path %>" <%= Number(m.newWindow) ? 'target="_blank" rel="noopener"' : '' %>
                               class="flex items-center gap-1 text-[15px] whitespace-nowrap text-gray-800 hover:text-[var(--gh-primary)] transition-colors">
                                <%= m.name %>
                                <% if (m.badgeType) { %>
                                    <span class="yd-dw__badge is-<%= String(m.badgeType).toLowerCase() %>"><%= m.badgeType %></span>
                                <% } %>
                            </a>

                            <% if (kids.length) { %>
                                <div class="yd-gnb__panel absolute left-0 top-full z-40 min-w-[180px] rounded-b-lg border border-gray-100 border-t-0 bg-white shadow-lg py-2">
                                    <ul>
                                        <% kids.forEach(function (c) { %>
                                            <li>
                                                <a href="<%= c.path %>" class="block px-4 py-2 text-sm text-gray-600 hover:text-[var(--gh-primary)] hover:bg-gray-50 whitespace-nowrap">
                                                    <%= c.name %>
                                                </a>
                                                <% const grand = _pcKids(c); %>
                                                <% if (grand.length) { %>
                                                    <ul class="pb-1">
                                                        <% grand.forEach(function (g) { %>
                                                            <li>
                                                                <a href="<%= g.path %>" class="block pl-7 pr-4 py-1.5 text-xs text-gray-400 hover:text-[var(--gh-primary)] whitespace-nowrap">
                                                                    <%= g.name %>
                                                                </a>
                                                            </li>
                                                        <% }); %>
                                                    </ul>
                                                <% } %>
                                            </li>
                                        <% }); %>
                                    </ul>
                                </div>
                            <% } %>
                        </li>
                    <% }); %>
                    <% if (!_pcGnb.length) { %>
                        <li class="text-sm text-gray-300">등록된 메뉴가 없습니다.</li>
                    <% } %>
                </ul>
            </div>
        </nav>
    </header>

    <%#
      드로어 + 백드롭은 <header> **바깥**에 둔다. header 가 z-50 으로 stacking context 를 만들기 때문에
      안에 두면 fixed 백드롭이 헤더까지 덮는다(기본형 스킨의 카테고리 백드롭이 같은 이유로 밖에 있다).
    %>
    <div id="yd-dw-backdrop" class="hidden fixed inset-0 z-[60] bg-black/40" aria-hidden="true"></div>

    <%#
      열림/닫힘은 Tailwind 유틸(-translate-x-full)이 아니라 아래 .yd-dw CSS 로 한다.
      Tailwind v4 의 translate 유틸은 `transform` 이 아니라 **`translate` 속성**을 쓰기 때문에,
      transform 으로 여는 규칙과 서로 덮지 못해 드로어가 화면 밖에 머문다.
    %>
    <aside id="yd-drawer" class="yd-dw fixed top-0 left-0 z-[70] h-full w-[300px] max-w-[85vw] bg-white shadow-2xl flex flex-col"
           role="dialog" aria-modal="true" aria-label="전체 메뉴" aria-hidden="true">

        <!-- 닫기 -->
        <div class="flex items-center justify-end px-5 pt-4 pb-1">
            <button type="button" id="yd-dw-close" aria-label="메뉴 닫기"
                    class="flex items-center justify-center w-9 h-9 -mr-1 rounded-full text-gray-400 hover:text-gray-700 hover:bg-gray-50">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <%#
          모바일 유틸 — PC 는 헤더 상단에 같은 항목을 아이콘으로 갖고 있으므로 md 이상에서는 숨긴다.
          두 벌을 동시에 노출하면 같은 링크가 화면에 두 번 나온다.
        %>
        <%# 항목 수가 로그인 여부·고객센터 ON/OFF 로 4~5개 사이에서 변한다. 열 수를 고정하면 마지막 하나가
            혼자 다음 줄로 떨어진다 → auto-fit 으로 한 줄에 채운다. %>
        <nav class="md:hidden yd-dw__utils px-4 pb-3" aria-label="회원 메뉴">
            <%# 하단 시스템바를 이 스킨에서는 내지 않으므로(main_layout), 그 진입점(홈·마이·장바구니)을 여기서 받는다. %>
            <a href="/" class="yd-dw__util"><i class="bi bi-house"></i><span>홈</span></a>
            <% if (user) { %>
                <a href="/mypage" class="yd-dw__util"><i class="bi bi-person"></i><span>마이쇼핑</span></a>
                <a href="/auth/logout" class="yd-dw__util"><i class="bi bi-box-arrow-right"></i><span>로그아웃</span></a>
            <% } else { %>
                <a href="/auth/login" class="yd-dw__util"><i class="bi bi-person-plus"></i><span>회원가입</span></a>
                <a href="/auth/login" class="yd-dw__util"><i class="bi bi-person"></i><span>로그인</span></a>
            <% } %>

            <% if (_cs) { %>
                <a href="<%= _cs.href %>" class="yd-dw__util"><i class="bi bi-headset"></i><span><%= _cs.name %></span></a>
            <% } %>

            <a href="/cart" class="yd-dw__util">
                <span class="relative">
                    <i class="bi bi-bag"></i>
                    <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
                        <span class="absolute -top-1 -right-2 bg-[var(--gh-accent)] text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full"><%= cartCount %></span>
                    <% } %>
                </span>
                <span>장바구니</span>
            </a>
        </nav>

        <!-- 검색 (use_search_bar=0 이면 통째로 빠진다) -->
        <% if (_useSearch) { %>
            <form action="/search" method="get" role="search" class="px-5 pb-4">
                <div class="flex items-center gap-2 border-b border-gray-300 pb-1.5">
                    <input type="text" name="q" autocomplete="off" placeholder="검색어를 입력해주세요"
                           class="flex-1 min-w-0 bg-transparent text-sm text-gray-800 placeholder:text-gray-400 focus:outline-none">
                    <button type="submit" aria-label="검색" class="text-gray-500 hover:text-[var(--gh-primary)]">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>
        <% } %>

        <!-- 메뉴 (카테고리 + 기능/커스텀. 하위 뎁스는 [+] 아코디언) -->
        <nav class="flex-1 overflow-y-auto px-5 pb-4" aria-label="주 메뉴">
            <ul class="yd-dw__list">
                <% _gnb.forEach(function (m) { %>
                    <%- include('./_drawer_node', { node: m, depth: 1 }) %>
                <% }); %>
            </ul>
            <% if (!_gnb.length) { %>
                <p class="py-6 text-sm text-gray-400">등록된 메뉴가 없습니다.</p>
            <% } %>
        </nav>

        <!-- 하단 고객센터 — 값이 있을 때만 낸다(빈 블록을 내지 않는다) -->
        <% if (siteSettings.contact_phone || siteSettings.contact_email) { %>
            <div class="border-t border-gray-200 px-5 py-4">
                <p class="text-sm font-bold text-gray-800">고객센터</p>
                <% if (siteSettings.contact_phone) { %>
                    <a href="tel:<%= siteSettings.contact_phone %>" class="block mt-1 text-2xl font-extrabold text-gray-900 tracking-tight">
                        <%= siteSettings.contact_phone %>
                    </a>
                <% } %>
                <% if (siteSettings.contact_email) { %>
                    <a href="mailto:<%= siteSettings.contact_email %>" class="block mt-1 text-xs text-gray-500 hover:text-[var(--gh-primary)]">
                        <%= siteSettings.contact_email %>
                    </a>
                <% } %>
            </div>
        <% } %>

        <%#
          몰 선택 셀렉트는 스토어프론트에서 내지 않는다(고객에게 몰을 고르게 하지 않는다).
          전환은 `?mall=<code>` 쿼리로 여전히 되고 세션에 고정된다 — 관리자 미리보기·QA 용 경로다.
          관리자 화면(admin_layout)의 몰 셀렉트는 그대로다.
        %>
    </aside>

    <style>
      /* PC GNB 드롭다운 — 마우스 오버·키보드 포커스에서만 펼친다(1뎁스는 상시 노출) */
      .yd-gnb__panel { display: none; }
      .yd-gnb__item:hover .yd-gnb__panel,
      .yd-gnb__item:focus-within .yd-gnb__panel { display: block; }

      .yd-dw { transform: translateX(-100%); transition: transform .3s cubic-bezier(.16,1,.3,1); }
      .yd-dw.is-open { transform: translateX(0); }
      @media (prefers-reduced-motion: reduce) { .yd-dw { transition: none; } }

      /* 모바일 유틸 아이콘 (PC 는 헤더 상단이 담당) — 4~5개를 한 줄에 균등 배치 */
      .yd-dw__utils { display: grid; grid-auto-flow: column; grid-auto-columns: 1fr; gap: .25rem; }
      .yd-dw__util {
        display: flex; flex-direction: column; align-items: center; gap: .25rem;
        padding: .5rem .25rem; border-radius: .5rem;
        font-size: 11px; color: #4b5563; text-align: center;
      }
      .yd-dw__util i { font-size: 1.125rem; }
      .yd-dw__util:hover { color: var(--gh-primary); background: #f9fafb; }

      .yd-dw__row { display: flex; align-items: center; justify-content: space-between; gap: .5rem; }

      .yd-dw__link { flex: 1 1 auto; min-width: 0; display: flex; align-items: center; gap: .375rem; padding: .625rem 0; }
      .yd-dw__link--top { font-size: .9375rem; color: #1f2937; }
      .yd-dw__link--sub { font-size: .875rem; color: #6b7280; }
      .yd-dw__link:hover { color: var(--gh-primary); }
      .yd-dw__link.is-active { color: var(--gh-primary); font-weight: 700; }

      /* 하위 목록은 좌측 라인으로 계층을 보인다(들여쓰기만으로는 3뎁스에서 구분이 흐려진다) */
      .yd-dw__sub { border-left: 1px solid #f3f4f6; margin-left: .125rem; padding-left: .5rem; }

      .yd-dw__toggle {
        flex: 0 0 auto; width: 2rem; height: 2rem;
        display: flex; align-items: center; justify-content: center;
        color: #9ca3af; border-radius: 9999px; transition: color .15s, background-color .15s;
      }
      .yd-dw__toggle:hover { color: #374151; background: #f9fafb; }
      /* 펼침 상태는 아이콘을 + → − 로 바꾼다(아이콘 폰트 교체 대신 회전으로 처리하면 x 가 된다) */
      .yd-dw__toggle[aria-expanded="true"] .bi-plus::before { content: "\f2ea"; }  /* bi-dash */

      .yd-dw__badge {
        font-size: 9px; font-weight: 800; line-height: 1;
        padding: 2px 3px; border-radius: 3px; color: #fff;
      }
      .yd-dw__badge.is-new  { background: var(--gh-primary); }
      .yd-dw__badge.is-hot  { background: #ef4444; }
      .yd-dw__badge.is-sale { background: #f59e0b; }

      /* 드로어가 열린 동안 본문 스크롤을 잠근다 */
      body.yd-dw-locked { overflow: hidden; }
    </style>

    <script>
      // PC 검색줄 토글 (모바일 검색은 드로어 안 폼이 담당한다)
      (function () {
        var btn = document.getElementById('yd-pc-search-btn');
        var box = document.getElementById('yd-pc-search');
        if (!btn || !box) return;
        btn.addEventListener('click', function () {
          var open = box.classList.toggle('hidden') === false;
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          if (open) { var f = box.querySelector('input[name="q"]'); if (f) f.focus(); }
        });
      })();

      (function () {
        var drawer  = document.getElementById('yd-drawer');
        var openBtn = document.getElementById('yd-dw-open');
        var closeBtn= document.getElementById('yd-dw-close');
        var backdrop= document.getElementById('yd-dw-backdrop');
        if (!drawer || !openBtn) return;

        function setOpen(open) {
          drawer.classList.toggle('is-open', open);
          drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
          if (backdrop) backdrop.classList.toggle('hidden', !open);
          openBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
          document.body.classList.toggle('yd-dw-locked', open);
          if (open && closeBtn) closeBtn.focus();
          else openBtn.focus();
        }

        openBtn.addEventListener('click', function () { setOpen(true); });
        if (closeBtn) closeBtn.addEventListener('click', function () { setOpen(false); });
        if (backdrop) backdrop.addEventListener('click', function () { setOpen(false); });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && drawer.classList.contains('is-open')) setOpen(false);
        });

        // 아코디언 — 토글 버튼의 다음 형제(<ul.yd-dw__sub>)를 펼친다.
        // 항목명(<a>)은 링크로 남겨 둔다: 상위 카테고리로 이동할 방법이 사라지면 안 된다.
        drawer.addEventListener('click', function (e) {
          var btn = e.target.closest('.yd-dw__toggle');
          if (!btn) return;
          var sub = btn.parentElement.nextElementSibling;
          if (!sub || !sub.classList.contains('yd-dw__sub')) return;
          var open = sub.classList.toggle('hidden') === false;
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          btn.setAttribute('aria-label', btn.getAttribute('aria-label').replace(open ? '열기' : '닫기', open ? '닫기' : '열기'));
        });
      })();
    </script>
