<%
  /*
   * 모바일 하단 시스템 내비게이션 + 카테고리 전체 레이어
   *
   * 구조(CJ온스타일형):
   *   [헤더] 로고 + 검색 + 장바구니        ← header.ejs
   *   [GNB]  일반 메뉴 가로 슬라이딩        ← header.ejs (.yd-mgnb)
   *   [본문]
   *   [하단바] 홈 · 카테고리 · 장바구니 · 마이   ← 이 파일 (md:hidden, fixed)
   *
   * 카테고리 레이어는 PC 패널과 같은 **단계별 드릴다운**이다.
   *   1뎁스 탭 → 2뎁스만 보인다
   *   2뎁스 탭 → 그 2뎁스의 3뎁스가 보인다(자식이 없으면 상품목록으로 이동)
   *   하단에는 현재 선택한 1뎁스의 이미지 + 간략 설명이 뜬다(PC 패널의 프로모션 칸과 같은 자리).
   *
   * PC 의 category_panel.ejs 를 재사용하지 않는 이유: 그쪽은 CSS hover 캐스케이드라
   * 터치 기기에서 열리지 않는다. 여기서는 탭(클릭)으로 전환한다.
   *
   * 세 뎁스를 모두 서버에서 렌더하고 JS 로 보이기만 바꾼다(패널 스택).
   * 뒤로가기는 헤더의 ← 버튼이다.
   *
   * 하단 바가 fixed 이므로 본문 마지막 줄을 가린다 → main_layout 이 body 에
   * padding-bottom: var(--yd-mbnav-h) 를 준다. 바 높이를 바꾸면 그 값도 함께 바꾼다.
   *
   * 항목은 하드코딩이다. feature_menu(position='mobile_quick') 로 뺄 수 있으나
   * 해당 행이 0건이고 관리 요구도 아직 없다.
   *
   * locals: categoryTree, malls, mallId, cartCount, user, currentPath
   */
  const _tree = (typeof categoryTree !== 'undefined' && categoryTree) ? categoryTree : [];
  const _cart = (typeof cartCount !== 'undefined' && cartCount) ? Number(cartCount) : 0;
  const _path = (typeof currentPath !== 'undefined') ? currentPath : '';
  const _user = (typeof user !== 'undefined') ? user : null;
  const isOn = (href) => _path === href;
  const hasKids = (n) => Array.isArray(n.children) && n.children.length > 0;
%>

<!-- 카테고리 전체 레이어 (탭으로 열림) — 화면을 통째로 덮는다(바텀시트 아님) -->
<div id="yd-cat-layer" class="md:hidden fixed inset-0 z-[60] hidden" role="dialog" aria-modal="true" aria-label="카테고리">
    <%# 시트가 화면을 다 덮으므로 딤은 등장하는 찰나에만 비친다. 바깥 클릭 닫기 대상이 없어졌지만
        JS 가 dim 을 참조하므로 엘리먼트는 남긴다(닫기는 헤더 X · ESC · 뒤로가기). %>
    <div id="yd-cat-dim" class="absolute inset-0 bg-black/40"></div>

    <div class="yd-cat-sheet absolute inset-0 flex flex-col overflow-hidden bg-white"
         style="padding-top: env(safe-area-inset-top);">
        <header class="flex h-16 shrink-0 items-center gap-1 border-b border-gray-100 px-2">
            <button type="button" id="yd-cat-back" aria-label="뒤로" class="hidden p-2.5 text-gray-600 active:text-[var(--gh-primary)]">
                <i class="bi bi-chevron-left text-xl"></i>
            </button>
            <div class="min-w-0 flex-1 px-2">
                <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--gh-primary)]">All Categories</p>
                <h2 id="yd-cat-title" class="truncate text-[19px] font-extrabold tracking-tight text-gray-900">카테고리</h2>
            </div>
            <button type="button" id="yd-cat-close" aria-label="닫기"
                    class="grid h-10 w-10 shrink-0 place-items-center rounded-full border border-gray-200 text-gray-500 active:bg-gray-900 active:text-white">
                <i class="bi bi-x-lg text-base"></i>
            </button>
        </header>

        <%#
          몰 선택 셀렉트는 스토어프론트에서 제거했다(헤더 Top Bar 에서도 뺐다).
          고객에게 몰을 고르게 하지 않는다. 전환은 `?mall=<code>` 쿼리 → 세션 고정으로 계속 가능하고,
          관리자 화면의 몰 셀렉트는 그대로다(middleware/mallContext.js).
        %>

        <div class="flex-1 overflow-y-auto overscroll-contain">
            <% if (!_tree.length) { %>
                <p class="p-8 text-center text-gray-400 text-sm">등록된 카테고리가 없습니다.</p>
            <% } %>

            <!-- 1뎁스 -->
            <ul id="yd-cat-d1" class="yd-cat-panel divide-y divide-gray-100">
                <% _tree.forEach(function (n1, i) { %>
                    <li class="yd-cat-row">
                        <%# 화면을 다 쓰므로 행을 키우고 번호를 붙여 스캔하기 쉽게 한다. %>
                        <% if (hasKids(n1)) { %>
                            <button type="button" class="yd-cat-drill flex w-full items-center gap-3 px-4 py-4 text-left active:bg-gray-50"
                                    data-target="d2-<%= n1.id %>" data-title="<%= n1.name %>" data-root="<%= n1.id %>">
                                <span class="w-6 shrink-0 text-[11px] font-bold tabular-nums text-gray-300"><%= String(i + 1).padStart(2, '0') %></span>
                                <span class="min-w-0 flex-1 truncate text-[16px] font-bold text-gray-900"><%= n1.name %></span>
                                <i class="bi bi-chevron-right shrink-0 text-gray-300"></i>
                            </button>
                        <% } else { %>
                            <a href="/products?categoryId=<%= n1.id %>"
                               class="flex items-center gap-3 px-4 py-4 active:bg-gray-50">
                                <span class="w-6 shrink-0 text-[11px] font-bold tabular-nums text-gray-300"><%= String(i + 1).padStart(2, '0') %></span>
                                <span class="min-w-0 flex-1 truncate text-[16px] font-bold text-gray-900"><%= n1.name %></span>
                                <i class="bi bi-arrow-right shrink-0 text-xs text-gray-300"></i>
                            </a>
                        <% } %>
                    </li>
                <% }); %>
            </ul>

            <!-- 2뎁스 패널들 -->
            <% _tree.filter(hasKids).forEach(function (n1) { %>
                <div id="d2-<%= n1.id %>" class="yd-cat-panel hidden" data-parent="d1" data-root="<%= n1.id %>">
                    <a href="/products?categoryId=<%= n1.id %>"
                       class="block px-4 py-3 text-sm font-semibold text-[var(--gh-primary)] border-b border-gray-100">
                        <%= n1.name %> 전체보기
                    </a>
                    <ul class="divide-y divide-gray-100">
                        <% n1.children.forEach(function (n2) { %>
                            <li>
                                <% if (hasKids(n2)) { %>
                                    <button type="button" class="yd-cat-drill w-full flex items-center justify-between px-4 py-3.5 text-left"
                                            data-target="d3-<%= n2.id %>" data-title="<%= n2.name %>" data-root="<%= n1.id %>">
                                        <span class="text-gray-800"><%= n2.name %></span>
                                        <i class="bi bi-chevron-right text-gray-400"></i>
                                    </button>
                                <% } else { %>
                                    <a href="/products?categoryId=<%= n2.id %>" class="block px-4 py-3.5 text-gray-800"><%= n2.name %></a>
                                <% } %>
                            </li>
                        <% }); %>
                    </ul>
                </div>
            <% }); %>

            <!-- 3뎁스 패널들 -->
            <% _tree.filter(hasKids).forEach(function (n1) {
                 n1.children.filter(hasKids).forEach(function (n2) { %>
                    <div id="d3-<%= n2.id %>" class="yd-cat-panel hidden" data-parent="d2-<%= n1.id %>" data-root="<%= n1.id %>">
                        <a href="/products?categoryId=<%= n2.id %>"
                           class="block px-4 py-3 text-sm font-semibold text-[var(--gh-primary)] border-b border-gray-100">
                            <%= n2.name %> 전체보기
                        </a>
                        <ul class="divide-y divide-gray-100">
                            <% n2.children.forEach(function (n3) { %>
                                <li><a href="/products?categoryId=<%= n3.id %>" class="block px-4 py-3.5 text-gray-700"><%= n3.name %></a></li>
                            <% }); %>
                        </ul>
                    </div>
            <% }); }); %>
        </div>

        <%# 하단 프로모션 — 현재 선택한 1뎁스의 이미지 + 설명 (PC 패널의 프로모션 칸과 같은 역할).
            1뎁스 화면에서는 보여줄 대상이 없으므로 숨긴다. %>
        <div id="yd-cat-promo" class="hidden shrink-0 border-t border-gray-100 bg-gray-50 px-4 py-3"
             style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom));">
            <div class="flex items-center gap-3">
                <img id="yd-cat-promo-img" src="" alt="" class="w-16 h-16 rounded-lg object-cover bg-white border border-gray-200 hidden">
                <div class="min-w-0">
                    <p id="yd-cat-promo-name" class="font-semibold text-gray-900 text-sm truncate"></p>
                    <p id="yd-cat-promo-desc" class="text-xs text-gray-500 line-clamp-2"></p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
  /* 전체 화면 레이어의 등장 — JS 는 .hidden 만 토글하므로, 그 해제 자체를 트리거로 삼는다. */
  #yd-cat-layer:not(.hidden) .yd-cat-sheet { animation: ydCatSheetIn .28s cubic-bezier(.16,1,.3,1) both; }
  #yd-cat-layer:not(.hidden) #yd-cat-dim   { animation: ydCatDimIn .28s ease both; }
  @keyframes ydCatSheetIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }
  @keyframes ydCatDimIn   { from { opacity: 0; } to { opacity: 1; } }

  /* 행이 순차로 밀려 올라온다. 1뎁스 목록에서만(드릴다운한 패널은 즉시 보여야 답답하지 않다). */
  #yd-cat-layer:not(.hidden) .yd-cat-row { animation: ydCatSheetIn .3s cubic-bezier(.16,1,.3,1) both; }
  #yd-cat-layer:not(.hidden) .yd-cat-row:nth-child(1) { animation-delay: .04s; }
  #yd-cat-layer:not(.hidden) .yd-cat-row:nth-child(2) { animation-delay: .07s; }
  #yd-cat-layer:not(.hidden) .yd-cat-row:nth-child(3) { animation-delay: .10s; }
  #yd-cat-layer:not(.hidden) .yd-cat-row:nth-child(4) { animation-delay: .13s; }
  #yd-cat-layer:not(.hidden) .yd-cat-row:nth-child(5) { animation-delay: .16s; }
  #yd-cat-layer:not(.hidden) .yd-cat-row:nth-child(n+6) { animation-delay: .19s; }

  @media (prefers-reduced-motion: reduce) {
    #yd-cat-layer:not(.hidden) :is(.yd-cat-sheet, #yd-cat-dim, .yd-cat-row) { animation: none; }
  }
</style>

<%# 1뎁스 이미지·설명을 JS 에 넘긴다(카테고리 수가 많아도 이 표는 1뎁스뿐이라 작다) %>
<script type="application/json" id="yd-cat-promo-data">
<%- JSON.stringify(_tree.reduce(function (acc, n) {
      acc[n.id] = { name: n.name, img: n.logo_image_path || '', desc: n.description || '' };
      return acc;
    }, {})) %>
</script>

<!-- 하단 시스템 바 -->
<nav class="md:hidden fixed bottom-0 inset-x-0 z-50 bg-white border-t border-gray-200"
     style="padding-bottom: env(safe-area-inset-bottom);" aria-label="시스템 메뉴">
    <ul class="grid grid-cols-4 h-16">
        <li>
            <a href="/" class="h-full flex flex-col items-center justify-center gap-0.5 <%= isOn('/') ? 'text-[var(--gh-primary)]' : 'text-gray-500' %>">
                <i class="bi <%= isOn('/') ? 'bi-house-fill' : 'bi-house' %> text-xl"></i>
                <span class="text-[11px]">홈</span>
            </a>
        </li>
        <li>
            <button type="button" id="yd-cat-open" class="w-full h-full flex flex-col items-center justify-center gap-0.5 text-gray-500">
                <i class="bi bi-grid text-xl"></i>
                <span class="text-[11px]">카테고리</span>
            </button>
        </li>
        <li>
            <a href="/cart" class="relative h-full flex flex-col items-center justify-center gap-0.5 <%= isOn('/cart') ? 'text-[var(--gh-primary)]' : 'text-gray-500' %>">
                <i class="bi <%= isOn('/cart') ? 'bi-bag-fill' : 'bi-bag' %> text-xl"></i>
                <span class="text-[11px]">장바구니</span>
                <% if (_cart > 0) { %>
                    <span class="absolute top-2 right-[26%] bg-[var(--gh-accent)] text-white text-[10px] font-bold min-w-4 h-4 px-1 flex items-center justify-center rounded-full">
                        <%= _cart %>
                    </span>
                <% } %>
            </a>
        </li>
        <li>
            <a href="<%= _user ? '/mypage' : '/auth/login' %>"
               class="h-full flex flex-col items-center justify-center gap-0.5 <%= isOn('/mypage') ? 'text-[var(--gh-primary)]' : 'text-gray-500' %>">
                <% if (_user && _user.picture) { %>
                    <img src="<%= _user.picture %>" alt="" class="w-6 h-6 rounded-full object-cover border border-gray-200">
                <% } else { %>
                    <i class="bi <%= isOn('/mypage') ? 'bi-person-fill' : 'bi-person' %> text-xl"></i>
                <% } %>
                <span class="text-[11px]"><%= _user ? '마이' : '로그인' %></span>
            </a>
        </li>
    </ul>
</nav>

<script>
(function () {
    var layer = document.getElementById('yd-cat-layer');
    if (!layer) return;

    var openBtn  = document.getElementById('yd-cat-open');
    var closeBtn = document.getElementById('yd-cat-close');
    var backBtn  = document.getElementById('yd-cat-back');
    var dim      = document.getElementById('yd-cat-dim');
    var title    = document.getElementById('yd-cat-title');

    var promo     = document.getElementById('yd-cat-promo');
    var promoImg  = document.getElementById('yd-cat-promo-img');
    var promoName = document.getElementById('yd-cat-promo-name');
    var promoDesc = document.getElementById('yd-cat-promo-desc');

    var PROMO = {};
    try { PROMO = JSON.parse(document.getElementById('yd-cat-promo-data').textContent); } catch (e) {}

    var scroller = layer.querySelector('.overflow-y-auto');
    var stack = ['d1'];   // 현재 패널 스택. 맨 뒤가 보이는 패널.

    function show(id) {
        layer.querySelectorAll('.yd-cat-panel').forEach(function (p) { p.classList.add('hidden'); });
        var el = (id === 'd1') ? document.getElementById('yd-cat-d1') : document.getElementById(id);
        if (el) el.classList.remove('hidden');
        if (scroller) scroller.scrollTop = 0;

        var atRoot = (id === 'd1');
        backBtn.classList.toggle('hidden', atRoot);
        if (atRoot) { title.textContent = '카테고리'; promo.classList.add('hidden'); }
    }

    function setPromo(rootId) {
        var d = PROMO[rootId];
        // 이미지도 설명도 없으면 이름만 남는데, 그 이름은 헤더 제목과 중복이다 → 영역 자체를 숨긴다.
        if (!d || (!d.img && !d.desc)) { promo.classList.add('hidden'); return; }
        promoName.textContent = d.name;
        promoDesc.textContent = d.desc || '';
        if (d.img) { promoImg.src = d.img; promoImg.alt = d.name; promoImg.classList.remove('hidden'); }
        else { promoImg.classList.add('hidden'); }
        promo.classList.remove('hidden');
    }

    function open()  { layer.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
    function close() { layer.classList.add('hidden'); document.body.style.overflow = ''; stack = ['d1']; show('d1'); }

    if (openBtn)  openBtn.addEventListener('click', open);
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (dim)      dim.addEventListener('click', close);
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !layer.classList.contains('hidden')) close(); });

    // 1뎁스 → 2뎁스 → 3뎁스 드릴다운
    layer.querySelectorAll('.yd-cat-drill').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var target = btn.getAttribute('data-target');
            var root   = btn.getAttribute('data-root');
            if (!document.getElementById(target)) return;
            stack.push(target);
            show(target);
            title.textContent = btn.getAttribute('data-title') || '카테고리';
            setPromo(root);
        });
    });

    backBtn.addEventListener('click', function () {
        if (stack.length <= 1) return;
        stack.pop();
        var cur = stack[stack.length - 1];
        show(cur);
        if (cur !== 'd1') {
            var el = document.getElementById(cur);
            var root = el && el.getAttribute('data-root');
            // 되돌아간 패널의 제목은 그 패널을 연 버튼의 라벨이다
            var opener = layer.querySelector('.yd-cat-drill[data-target="' + cur + '"]');
            title.textContent = opener ? (opener.getAttribute('data-title') || '카테고리') : '카테고리';
            if (root) setPromo(root);
        }
    });
})();
</script>
