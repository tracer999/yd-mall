<%
  /*
   * 메뉴 쇼케이스 — GNB 메뉴 페이지 상단에 얹는 캐러셀.
   *
   * main_layout 이 본문(body) 위에서 렌더한다(컨트롤러 무관, middleware/menuShowcase 가 주입).
   * locals: menuShowcase = { kind:'product'|'banner', title, items, perView, menuCode }
   *
   * sections/_carousel_base.ejs 와 마크업 계약이 다르다(1개씩 슬라이드 + peek + 자동재생 +
   * 진행바/카운터). base 를 확장하면 product/brand/deal 캐러셀 3곳에 파급되므로 분리했다.
   */
  const _s = menuShowcase;
  const _items = _s.items || [];
  const _perView = Number(_s.perView) || 3;
%>
<% if (_items.length > 0) { %>
<style>
  /* peek — 트랙 좌우 여백만큼 이전/다음 카드가 걸쳐 보인다. scroll-padding 으로 스냅 위치를 맞춘다. */
  .yd-showcase {
    --yd-sc-gap: 1.25rem;
    --yd-sc-peek: 2.5rem;
    --yd-sc-per: 2;
  }
  @media (min-width: 1024px) {
    .yd-showcase { --yd-sc-per: <%= _perView %>; --yd-sc-peek: 4rem; }
  }
  .yd-showcase__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc(
      (100% - var(--yd-sc-peek) * 2 - var(--yd-sc-gap) * (var(--yd-sc-per) - 1)) / var(--yd-sc-per)
    );
    gap: var(--yd-sc-gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding-inline: var(--yd-sc-peek);
    scroll-padding-inline-start: var(--yd-sc-peek);
  }
  .yd-showcase__track::-webkit-scrollbar { display: none; }
  .yd-showcase__track > * { scroll-snap-align: start; }

  /* 화살표 — 샘플처럼 카드 위에 겹쳐 띄운다 */
  .yd-showcase__nav {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 2;
    width: 44px; height: 44px; border-radius: 9999px;
    background: rgba(255,255,255,.92); border: 1px solid var(--gh-border);
    box-shadow: 0 2px 12px rgba(0,0,0,.12);
    display: none; align-items: center; justify-content: center;
    color: #4b5563; transition: color .15s, border-color .15s, opacity .15s;
  }
  .yd-showcase__nav:hover { color: var(--gh-primary); border-color: var(--gh-primary); }
  .yd-showcase__nav:disabled { opacity: .3; cursor: default; }
  .yd-showcase__nav--prev { left: .25rem; }
  .yd-showcase__nav--next { right: .25rem; }
  @media (min-width: 768px) { .yd-showcase__nav { display: inline-flex; } }

  /* 하단 진행바 + 카운터 + 일시정지 */
  .yd-showcase__bar { height: 2px; background: #e5e7eb; flex: 1; overflow: hidden; }
  .yd-showcase__bar > span {
    display: block; height: 100%; width: 0;
    background: #111827; transition: width .3s ease, transform .3s ease;
  }
  .yd-showcase__count { font-variant-numeric: tabular-nums; }

  /* 배너 카드 — 이미지 위에 제목을 얹는다(샘플 레이아웃) */
  .yd-showcase__banner { position: relative; display: block; border-radius: .75rem; overflow: hidden; }
  .yd-showcase__banner img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .yd-showcase__banner figcaption {
    position: absolute; left: 0; right: 0; bottom: 0; padding: 1rem 1.25rem;
    background: linear-gradient(to top, rgba(0,0,0,.55), rgba(0,0,0,0));
    color: #fff; font-weight: 700; font-size: 1.05rem; line-height: 1.35;
  }
</style>

<section class="yd-showcase py-8 bg-white border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if (_s.title) { %>
      <h2 class="text-2xl font-extrabold text-gray-900 mb-5"><%= _s.title %></h2>
    <% } %>

    <div class="relative" data-yd-showcase>
      <button type="button" class="yd-showcase__nav yd-showcase__nav--prev" data-yd-sc-prev aria-label="이전">
        <i class="bi bi-chevron-left"></i>
      </button>
      <button type="button" class="yd-showcase__nav yd-showcase__nav--next" data-yd-sc-next aria-label="다음">
        <i class="bi bi-chevron-right"></i>
      </button>

      <div class="yd-showcase__track" data-yd-sc-track>
        <% if (_s.kind === 'product') { %>
          <% _items.forEach(product => { %>
            <div><%- include('../product_card', { product }) %></div>
          <% }); %>
        <% } else { %>
          <% _items.forEach(banner => { %>
            <div>
              <a href="<%= banner.link_url || '#' %>" class="yd-showcase__banner aspect-[4/3]">
                <picture>
                  <% if (banner.mobile_image_url) { %>
                    <source media="(max-width: 639px)" srcset="<%= banner.mobile_image_url %>">
                  <% } %>
                  <img src="<%= banner.image_url %>" alt="<%= banner.title || '' %>" loading="lazy">
                </picture>
                <% if (banner.title) { %><figcaption><%= banner.title %></figcaption><% } %>
              </a>
            </div>
          <% }); %>
        <% } %>
      </div>

      <div class="mt-5 flex items-center gap-4">
        <div class="yd-showcase__bar"><span data-yd-sc-bar></span></div>
        <span class="yd-showcase__count text-xs text-gray-500" data-yd-sc-count>1/<%= _items.length %></span>
        <button type="button" class="text-gray-400 hover:text-gray-700 text-xs w-6 h-6 border border-gray-200 rounded flex items-center justify-center"
                data-yd-sc-toggle aria-label="자동재생 일시정지">
          <i class="bi bi-pause-fill"></i>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
/* 메뉴 쇼케이스 캐러셀 — 1개씩 슬라이드 + 자동재생.
   sections/_carousel_base 와 별개 스크립트다(마크업 계약이 다르다). */
(function () {
  if (window.__ydShowcaseInit) return;
  window.__ydShowcaseInit = true;

  var AUTOPLAY_MS = 4000;

  function init(root) {
    var track = root.querySelector('[data-yd-sc-track]');
    var prev = root.querySelector('[data-yd-sc-prev]');
    var next = root.querySelector('[data-yd-sc-next]');
    var bar = root.querySelector('[data-yd-sc-bar]');
    var count = root.querySelector('[data-yd-sc-count]');
    var toggle = root.querySelector('[data-yd-sc-toggle]');
    if (!track) return;

    var total = track.children.length;
    var timer = null;
    var playing = false;

    /* 카드 1장 이동 거리 */
    function step() {
      var first = track.firstElementChild;
      if (!first) return track.clientWidth;
      var gap = parseFloat(getComputedStyle(track).columnGap || '0') || 0;
      return first.offsetWidth + gap;
    }

    function atEnd() {
      return track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
    }

    function sync() {
      var idx = Math.round(track.scrollLeft / step());
      var shown = Math.min(idx + 1, total);
      if (count) count.textContent = shown + '/' + total;
      if (bar) bar.style.width = ((shown / total) * 100) + '%';
      if (prev) prev.disabled = track.scrollLeft <= 1;
      if (next) next.disabled = atEnd();
    }

    function slide(dir) {
      /* 끝에서 다음 → 처음으로 되감는다(자동재생이 멈추지 않도록) */
      if (dir > 0 && atEnd()) track.scrollTo({ left: 0, behavior: 'smooth' });
      else track.scrollBy({ left: dir * step(), behavior: 'smooth' });
    }

    function play() {
      if (playing || total <= 1) return;
      playing = true;
      timer = setInterval(function () { slide(1); }, AUTOPLAY_MS);
      if (toggle) toggle.innerHTML = '<i class="bi bi-pause-fill"></i>';
    }

    function pause() {
      playing = false;
      clearInterval(timer);
      timer = null;
      if (toggle) toggle.innerHTML = '<i class="bi bi-play-fill"></i>';
    }

    if (prev) prev.addEventListener('click', function () { pause(); slide(-1); });
    if (next) next.addEventListener('click', function () { pause(); slide(1); });
    if (toggle) toggle.addEventListener('click', function () { playing ? pause() : play(); });
    track.addEventListener('scroll', sync, { passive: true });
    window.addEventListener('resize', sync);

    /* 마우스가 올라가 있는 동안은 자동으로 넘기지 않는다 */
    root.addEventListener('mouseenter', function () { if (playing) { clearInterval(timer); timer = null; } });
    root.addEventListener('mouseleave', function () { if (playing && !timer) timer = setInterval(function () { slide(1); }, AUTOPLAY_MS); });

    sync();
    /* 접근성 — 모션 최소화 설정이면 자동재생하지 않는다 */
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) play();
    else pause();
  }

  function initAll() {
    document.querySelectorAll('[data-yd-showcase]').forEach(init);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initAll);
  else initAll();
})();
</script>
<% } %>
