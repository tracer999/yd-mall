<%
  /*
   * 우측 유틸 레일 (P1.5 §4.5.4 / 설계 §7.2 Right Utility)
   *  Login Box · Recent Products · App QR · Membership · Top Button
   *
   * layout_type = 'main_right_utility_v1' 인 페이지에서만 main_layout이 include한다.
   * 섹션들이 전부 full-bleed(<section> + 자체 max-w 컨테이너)이므로 본문 흐름을 건드리지 않도록
   * position:fixed 레일로 구현한다(부록 A CT-7 `utility_rail` 규약과 동일).
   *
   * 필요 로컬: user, cartCount, siteSettings
   * QR/멤버십은 설정값이 있을 때만 노출한다(미설정 시 슬롯 자체를 숨김).
   */
  const _appUrl = (siteSettings && siteSettings.app_download_url) ? String(siteSettings.app_download_url).trim() : '';
  const _appQrImage = (siteSettings && siteSettings.app_qr_image_url) ? String(siteSettings.app_qr_image_url).trim() : '';
  const _membershipUrl = (siteSettings && siteSettings.membership_url) ? String(siteSettings.membership_url).trim() : '';

  /* 골격=코드, 항목=데이터.
     레일 항목은 feature_menu(position='right_rail') 에서 오고, 아이콘/동작만 코드가 고정한다. */
  const _rail = (typeof rightRailMenus !== 'undefined' && Array.isArray(rightRailMenus)) ? rightRailMenus : [];
  const _icons = {
    RAIL_CART: 'bi-bag',
    RAIL_WISHLIST: 'bi-heart',
    RAIL_ORDERS: 'bi-receipt',
    RAIL_RECENT: 'bi-clock-history',
    RAIL_TOP: 'bi-chevron-up',
  };
  /* 배지는 코드별 if 대신 맵 조회로 낸다(middleware/cartData.js 가 채운다).
     모바일 드로어 파셜(_mobile_rail_shortcuts)과 같은 규칙이어야 두 벌로 갈라지지 않는다. */
  const _counts = (typeof railCounts !== 'undefined' && railCounts) ? railCounts : {};
  const _countOf = (code) => Number(_counts[code]) > 0 ? Number(_counts[code]) : 0;
  // TOP 은 레일 최하단 고정이므로 루프에서 분리한다.
  const _topItem = _rail.find(function (m) { return m.featureCode === 'RAIL_TOP'; }) || null;
  const _railItems = _rail.filter(function (m) { return m.featureCode !== 'RAIL_TOP'; });
%>
<%#
  레일 항목이 하나도 없으면 CSS(레거시 #scrollTopBtn 숨김 규칙 포함)까지 통째로 렌더하지 않는다.
  그렇지 않으면 레일 없이 TOP 버튼만 사라진다.
%>
<% if (_rail.length > 0) { %>

<style>
  .yd-rail {
    position: fixed;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 45;
    width: 74px;
    display: none;
    flex-direction: column;
    align-items: stretch;
    background: #fff;
    border: 1px solid var(--gh-border);
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    overflow: visible;
  }
  /* 본문(max-w 1400px)과 겹치지 않는 넓은 화면에서만 노출 */
  @media (min-width: 1600px) {
    .yd-rail { display: flex; }
    /* 레일에 TOP이 포함되므로 레거시 플로팅 TOP 버튼은 숨긴다(중복 방지).
       scrollTopBtn은 JS가 inline style로 display를 제어하므로 !important 필요.
       (히어로 내부 레일은 CT-7 에서 완전 제거됨) */
    #scrollTopBtn { display: none !important; }
  }

  /* 레일 헤더 — '바로접속' ON/OFF. 장식이 아니라 실제로 레일 본문을 접는다. */
  .yd-rail__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    padding: 8px 4px;
    border-bottom: 1px solid #f1f2f4;
    background: none;
    border-left: 0; border-right: 0; border-top: 0;
    width: 100%;
    cursor: pointer;
  }
  .yd-rail__head-label { font-size: 11px; font-weight: 700; color: #4b5563; letter-spacing: -.02em; }
  .yd-rail__head-state { font-size: 11px; font-weight: 800; color: var(--gh-accent); }
  .yd-rail[data-collapsed="true"] .yd-rail__body { display: none; }
  .yd-rail[data-collapsed="true"] .yd-rail__head-state { color: #9ca3af; }

  .yd-rail__body { display: flex; flex-direction: column; }

  .yd-rail__item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 10px 4px;
    color: #4b5563;
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: color .15s, background-color .15s;
  }
  .yd-rail__item + .yd-rail__item { border-top: 1px solid #f1f2f4; }
  .yd-rail__item:hover { color: var(--gh-primary); background: var(--gh-primary-soft); }
  .yd-rail__item i { font-size: 20px; line-height: 1; }
  .yd-rail__label { font-size: 10px; font-weight: 600; letter-spacing: -.02em; white-space: nowrap; }

  .yd-rail__badge {
    position: absolute;
    top: 4px;
    right: 12px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    border-radius: 9999px;
    background: var(--gh-accent);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .yd-rail__top { border-top: 1px solid #f1f2f4; color: #6b7280; }

  .yd-rail__qr { padding: 10px 6px; border-top: 1px solid #f1f2f4; text-align: center; }
  .yd-rail__qr img { width: 58px; height: 58px; display: block; margin: 0 auto 4px; }

  /* 최근 본 상품 패널 */
  .yd-recent {
    position: absolute;
    right: 82px;
    top: 0;
    width: 200px;
    max-height: 340px;
    overflow-y: auto;
    background: #fff;
    border: 1px solid var(--gh-border);
    border-radius: 12px;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
    padding: 12px;
  }
  .yd-recent[hidden] { display: none; }
  .yd-recent__title { font-size: 12px; font-weight: 700; color: #374151; margin-bottom: 8px; }
  .yd-recent__empty { font-size: 12px; color: #9ca3af; padding: 12px 0; text-align: center; }
  .yd-recent__item { display: flex; gap: 8px; align-items: center; padding: 6px 0; text-decoration: none; color: #374151; }
  .yd-recent__item + .yd-recent__item { border-top: 1px solid #f6f7f8; }
  .yd-recent__item img { width: 40px; height: 40px; object-fit: contain; border: 1px solid #f1f2f4; border-radius: 6px; background: #fff; }
  .yd-recent__name { font-size: 11px; line-height: 1.3; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  .yd-recent__item:hover .yd-recent__name { color: var(--gh-primary); }

  /* 레일에 직접 노출하는 최근 본 상품 썸네일 (참조몰: capture/image7.png).
     localStorage 기반이라 서버가 알 수 없다 → 항목이 있을 때만 JS 가 이 블록을 드러낸다. */
  .yd-rail__recent { padding: 8px 6px; border-top: 1px solid #f1f2f4; }
  .yd-rail__recent[hidden] { display: none; }
  .yd-rail__recent-title { font-size: 10px; font-weight: 700; color: #6b7280; text-align: center; margin-bottom: 6px; }
  .yd-rail__recent-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 3px; }
  .yd-rail__recent-grid a { display: block; border: 1px solid #f1f2f4; border-radius: 4px; overflow: hidden; background: #fff; }
  .yd-rail__recent-grid img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; display: block; }
  .yd-rail__recent-grid a:hover { border-color: var(--gh-primary); }
</style>

<aside class="yd-rail" aria-label="바로가기 유틸리티" data-collapsed="false">
  <!-- 레일 헤더: 바로접속 ON/OFF (상태는 localStorage 에 남는다) -->
  <button type="button" class="yd-rail__head" id="yd-rail-toggle" aria-expanded="true" aria-controls="yd-rail-body">
    <span class="yd-rail__head-label">바로접속</span>
    <span class="yd-rail__head-state" id="yd-rail-state">ON</span>
  </button>

  <div class="yd-rail__body" id="yd-rail-body">
  <!-- Login Box (시스템 고정) -->
  <% if (user) { %>
    <a href="/mypage" class="yd-rail__item" title="마이쇼핑">
      <i class="bi bi-person-circle" aria-hidden="true"></i>
      <span class="yd-rail__label">마이쇼핑</span>
    </a>
  <% } else { %>
    <a href="/auth/login" class="yd-rail__item" title="로그인">
      <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
      <span class="yd-rail__label">로그인</span>
    </a>
  <% } %>

  <% _railItems.forEach(function (m) {
       const icon = _icons[m.featureCode] || 'bi-dot';
       if (m.featureCode === 'RAIL_RECENT') { %>
    <button type="button" class="yd-rail__item" id="yd-recent-btn" aria-expanded="false" aria-controls="yd-recent-panel" title="<%= m.name %>">
      <i class="bi <%= icon %>" aria-hidden="true"></i>
      <span class="yd-rail__label"><%= m.name %></span>
    </button>
    <%# 썸네일 미리보기 — 아이콘 바로 아래에 붙인다(그 라벨이 제목 역할).
        실제 항목이 있을 때만 JS 가 드러낸다. 아이콘 클릭 = 전체 목록 패널. %>
    <div class="yd-rail__recent" id="yd-rail-recent" hidden>
      <div class="yd-rail__recent-grid" id="yd-rail-recent-grid"></div>
    </div>
  <%   } else { %>
    <a href="<%= m.href %>" class="yd-rail__item" title="<%= m.name %>">
      <i class="bi <%= icon %>" aria-hidden="true"></i>
      <span class="yd-rail__label"><%= m.name %></span>
      <%# 뱃지는 0 이어도 렌더한다 — 0 → 1 갱신 시 붙일 DOM 이 있어야 한다(ydSetCartCount) %>
      <% if (m.featureCode === 'RAIL_CART') { const _rc = _countOf('RAIL_CART'); %>
        <span class="yd-rail__badge" data-cart-badge style="<%= _rc > 0 ? '' : 'display:none' %>"><%= _rc %></span>
      <% } else if (_countOf(m.featureCode) > 0) {
             /* 찜·주문내역은 이 페이지에서 바뀌지 않는다(갱신 훅 없이 정적 렌더). */
             const _rn = _countOf(m.featureCode); %>
        <span class="yd-rail__badge"><%= _rn > 99 ? '99+' : _rn %></span>
      <% } %>
    </a>
  <%   }
     }); %>

  <!-- 멤버십 숏컷 (설정 시에만) -->
  <% if (_membershipUrl) { %>
    <a href="<%= _membershipUrl %>" class="yd-rail__item" title="멤버십">
      <i class="bi bi-award" aria-hidden="true"></i>
      <span class="yd-rail__label">멤버십</span>
    </a>
  <% } %>

  <!-- 앱 다운로드 QR (site_settings 에 QR 이미지가 등록된 경우에만 노출) -->
  <% if (_appQrImage) { %>
    <div class="yd-rail__qr">
      <img src="<%= _appQrImage %>" alt="앱 다운로드 QR" loading="lazy" width="58" height="58">
      <span class="yd-rail__label">앱다운</span>
    </div>
  <% } else if (_appUrl) { %>
    <a href="<%= _appUrl %>" class="yd-rail__item" title="앱 다운로드">
      <i class="bi bi-qr-code" aria-hidden="true"></i>
      <span class="yd-rail__label">앱다운</span>
    </a>
  <% } %>

  <!-- TOP (레일 최하단 고정) -->
  <% if (_topItem) { %>
    <button type="button" class="yd-rail__item yd-rail__top" id="yd-rail-top" title="<%= _topItem.name %>">
      <i class="bi bi-chevron-up" aria-hidden="true"></i>
      <span class="yd-rail__label"><%= _topItem.name %></span>
    </button>
  <% } %>
  </div><!-- /.yd-rail__body -->

  <!-- 최근 본 상품 패널 (아이콘 클릭 시 전체 목록) -->
  <div class="yd-recent" id="yd-recent-panel" hidden>
    <p class="yd-recent__title">최근 본 상품</p>
    <div id="yd-recent-list"></div>
  </div>
</aside>

<script>
(function () {
  // 몰별로 키를 나눈다 — 상품 상세(detail.ejs)·홈 섹션(recent_product.ejs)과 같은 규칙이어야 한다.
  var STORAGE_KEY = 'yd_recent_products:<%= Number(mallId) || 1 %>';

  function readRecent() {
    try {
      var raw = localStorage.getItem(STORAGE_KEY);
      var list = raw ? JSON.parse(raw) : [];
      return Array.isArray(list) ? list : [];
    } catch (e) { return []; }
  }

  function esc(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  function renderRecent() {
    var list = readRecent();
    var box = document.getElementById('yd-recent-list');
    if (!box) return;
    if (list.length === 0) {
      box.innerHTML = '<p class="yd-recent__empty">최근 본 상품이 없습니다.</p>';
      return;
    }
    box.innerHTML = list.slice(0, 10).map(function (p) {
      return '<a class="yd-recent__item" href="' + esc(p.url) + '">'
           + '<img src="' + esc(p.image || '/images/placeholder.png') + '" alt="' + esc(p.name) + '">'
           + '<span class="yd-recent__name">' + esc(p.name) + '</span>'
           + '</a>';
    }).join('');
  }

  var btn = document.getElementById('yd-recent-btn');
  var panel = document.getElementById('yd-recent-panel');
  if (btn && panel) {
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var willOpen = panel.hasAttribute('hidden');
      if (willOpen) { renderRecent(); panel.removeAttribute('hidden'); }
      else { panel.setAttribute('hidden', ''); }
      btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
    });
    document.addEventListener('click', function (e) {
      if (!panel.contains(e.target) && e.target !== btn) {
        panel.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') { panel.setAttribute('hidden', ''); btn.setAttribute('aria-expanded', 'false'); }
    });
  }

  var topBtn = document.getElementById('yd-rail-top');
  if (topBtn) topBtn.addEventListener('click', function () { window.scrollTo({ top: 0, behavior: 'smooth' }); });

  // 레일에 직접 노출하는 최근 본 상품 썸네일 (최대 4개, 2x2).
  // 항목이 없으면 블록 자체를 숨긴다 — 빈 껍데기를 보여주지 않는다.
  (function renderRailThumbs() {
    var box = document.getElementById('yd-rail-recent');
    var grid = document.getElementById('yd-rail-recent-grid');
    if (!box || !grid) return;
    var list = readRecent().slice(0, 4);
    if (list.length === 0) { box.setAttribute('hidden', ''); return; }
    grid.innerHTML = list.map(function (p) {
      return '<a href="' + esc(p.url) + '" title="' + esc(p.name) + '">'
           + '<img src="' + esc(p.image || '/images/placeholder.png') + '" alt="' + esc(p.name) + '" loading="lazy">'
           + '</a>';
    }).join('');
    box.removeAttribute('hidden');
  })();

  // '바로접속' ON/OFF — 실제로 레일 본문을 접고 상태를 기억한다.
  (function railToggle() {
    var RAIL_KEY = 'yd_rail_collapsed';
    var rail = document.querySelector('.yd-rail');
    var btn = document.getElementById('yd-rail-toggle');
    var state = document.getElementById('yd-rail-state');
    if (!rail || !btn || !state) return;

    function apply(collapsed) {
      rail.setAttribute('data-collapsed', collapsed ? 'true' : 'false');
      btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
      state.textContent = collapsed ? 'OFF' : 'ON';
    }
    var saved = false;
    try { saved = localStorage.getItem(RAIL_KEY) === '1'; } catch (e) {}
    apply(saved);

    btn.addEventListener('click', function () {
      var next = rail.getAttribute('data-collapsed') !== 'true';
      apply(next);
      try { localStorage.setItem(RAIL_KEY, next ? '1' : '0'); } catch (e) {}
    });
  })();
})();
</script>

<% } %>
