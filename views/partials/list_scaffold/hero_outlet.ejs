<%
  /*
   * 아울렛 히어로 (스캐폴드 슬롯 A + B)
   *   A: 최대 할인율 배너
   *   B: 할인율 구간 필터(30/50/70%↑)
   *
   * locals: maxDiscount (number|null), currentMinDiscount (number)
   * 구간은 URL 로 전환한다(?minDiscount=N). 서버 렌더 + 앵커, JS 없이 동작.
   */
  const _max = (typeof maxDiscount !== 'undefined' && maxDiscount) ? Math.round(maxDiscount) : 0;
  const _cur = (typeof currentMinDiscount !== 'undefined') ? Number(currentMinDiscount) : 0;
  const _ranges = [
    { v: 0,  label: '전체' },
    { v: 30, label: '30%↑' },
    { v: 50, label: '50%↑' },
    { v: 70, label: '70%↑' },
  ];
%>
<div class="mb-6 rounded-2xl px-6 py-5 flex items-center gap-3 text-white"
     style="background: linear-gradient(135deg, #ef4444, #b91c1c);">
  <i class="bi bi-tags-fill text-2xl"></i>
  <div>
    <div class="text-lg font-extrabold leading-tight">아울렛</div>
    <div class="text-xs opacity-90">
      <% if (_max > 0) { %>최대 <strong class="text-base"><%= _max %>%</strong> 할인 · 재고 소진 특가<% } else { %>재고 소진 특가<% } %>
    </div>
  </div>
</div>

<div class="flex flex-wrap gap-2 text-sm mb-5">
  <% _ranges.forEach(function (r) {
       const active = _cur === r.v;
       const href = r.v > 0 ? ('/outlet?minDiscount=' + r.v) : '/outlet';
  %>
    <a href="<%= href %>"
       class="px-3.5 py-1.5 rounded-full border transition-colors <%= active
         ? 'bg-[var(--gh-primary)] text-white border-[var(--gh-primary)] font-semibold shadow-sm'
         : 'bg-white text-gray-600 border-gray-200 hover:border-gray-300' %>"><%= r.label %></a>
  <% }); %>
</div>
