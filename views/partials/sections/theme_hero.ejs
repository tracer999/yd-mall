<%
  /*
   * 테마 히어로 래퍼 — 축이 둘이고 서로 독립이다(리졸버 theme_hero.js 참고).
   *
   *   layout(배치·테마)  split_feature | full_width | full_bleed
   *   source(콘텐츠)     product_showcase | full_banner
   *
   * locals: layout, source, mainSlides, feature(우측 카드 or null)
   *
   * 배치는 "어디에 어떻게 놓을지"만, 콘텐츠는 "무엇을 넣을지"만 정한다. 그래서 6가지 조합이
   * 모두 성립한다 — 테마를 바꿔도 등록해 둔 배너·상품이 사라지지 않는다.
   *
   * Swiper 초기화(.mySwiperDesktop/.mySwiperMobile)는 user/index.ejs 의 initHeroSwiper 가 담당.
   */
  var _LEGACY = { showcase: 'split_feature', banner: 'full_width', editorial: 'full_bleed' };
  var _rawLayout = (typeof layout !== 'undefined' && layout) ? layout : 'full_width';
  var _layout = _LEGACY[_rawLayout] || _rawLayout;
  var _source = (typeof source !== 'undefined' && source) ? source : 'full_banner';
  var _isProduct = _source === 'product_showcase';
  var _slides = (typeof mainSlides !== 'undefined' && mainSlides) ? mainSlides : [];
  var _feature = (typeof feature !== 'undefined') ? feature : null;

  // 슬라이드 한 행을 클릭 링크로 — 상품 슬라이드와 배너 행 양쪽을 받는다.
  var _href = function (s) {
    if (s.link_url) return s.link_url;
    if (s.slug && String(s.slug).trim()) return '/products/' + encodeURIComponent(s.slug);
    if (s.product_id) return '/products/view/' + s.product_id;
    return '#';
  };
  var _img = function (s) { return s.image_url || s.main_image || '/images/placeholder.png'; };
  // 풀블리드는 상품/배너 어느 쪽이든 "제목 + 작은 라벨"만 쓴다. 필드명이 달라 여기서 흡수한다.
  var _title = function (s) { return s.headline || s.overlay_title || s.product_name || ''; };
  var _eyebrow = function (s) { return s.label || s.overlay_subtitle || ''; };

  // 이미지 배너 행 → hero_banner 가 기대하는 모양
  var _toBanners = function (rows) {
    return rows.map(function (b) {
      return {
        media: null,
        image_url: b.image_url,
        mobile_image_url: b.mobile_image_url || b.image_url,
        title: b.title || '',
        link_url: b.link_url || '',
        overlay_title: b.overlay_title || '',
        overlay_subtitle: b.overlay_subtitle || '',
        overlay_button_text: b.overlay_button_text || '',
        overlay_button_color: b.overlay_button_color || '',
        overlay_align: b.overlay_align || 'LEFT'
      };
    });
  };
%>

<% if (_layout === 'split_feature') { %>
  <%# 테마1 — 좌 히어로 + 우 상품 카드. 좌측 내용만 콘텐츠 종류에 따라 갈린다. %>
  <section class="bg-white">
    <div class="max-w-[1400px] mx-auto px-4 py-4">
      <div class="flex gap-3">
        <div class="flex-1 min-w-0">
          <% if (_isProduct) { %>
            <%- include('./hero_showcase_main', { mainSlides: _slides }) %>
          <% } else { %>
            <% var _b = _toBanners(_slides); %>
            <%- include('./hero_banner', { heroBanners: _b, mobileHeroBanners: _b }) %>
          <% } %>
        </div>
        <%- include('./hero_feature_card', { feature: _feature }) %>
      </div>
    </div>
  </section>

<% } else if (_layout === 'full_bleed') { %>
  <%# 테마3 — 풀블리드 슬라이드 + 오버레이 텍스트 + 하단 마퀴. 상품·배너 어느 쪽이든 같은 마크업. %>
  <section class="yd-ed-hero relative w-full overflow-hidden bg-black">
    <div class="swiper mySwiperDesktop yd-ed-swiper">
      <div class="swiper-wrapper">
        <% _slides.forEach(function (s, _i) { %>
          <div class="swiper-slide relative">
            <div class="yd-ed-stage relative w-full">
              <%# 배너 행에는 영상 컬럼이 없다 — media 를 null 로 줘서 이미지로 렌더한다. %>
              <%- include('./hero_media', {
                    media: (_isProduct ? s : null), img: _img(s), alt: _title(s),
                    cls: 'absolute inset-0 w-full h-full object-cover', mobile: false, eager: _i === 0 }) %>
              <div class="yd-ed-scrim absolute inset-0"></div>
              <div class="relative z-10 h-full flex items-end">
                <div class="w-full max-w-[80rem] mx-auto px-6 lg:px-10 pb-20 lg:pb-28">
                  <div class="max-w-2xl">
                    <% if (_eyebrow(s)) { %>
                      <span class="yd-ed-eyebrow block text-white/80 text-base md:text-xl tracking-[0.25em] uppercase mb-4"><%= _eyebrow(s) %></span>
                    <% } %>
                    <h2 class="yd-ed-title text-white font-normal leading-[1.05]"><%= _title(s) %></h2>
                    <a href="<%= _href(s) %>" class="yd-ed-cta mt-8 inline-flex items-center gap-2 px-8 py-3.5 text-sm font-semibold tracking-wide">
                      <span>자세히 보기</span>
                      <i class="bi bi-arrow-right"></i>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="swiper-pagination swiper-pagination-desktop"></div>
      <div class="swiper-button-next swiper-button-next-desktop"><i class="bi bi-chevron-right"></i></div>
      <div class="swiper-button-prev swiper-button-prev-desktop"><i class="bi bi-chevron-left"></i></div>
    </div>

    <%# 하단 마퀴 — 관리자('테마 히어로' 섹션 설정)에서 입력한 문구를 흐르게 한다. %>
    <%
      var _mqOn = (typeof marqueeEnabled !== 'undefined') ? marqueeEnabled : true;
      var _mqItems = (typeof marqueeItems !== 'undefined' && marqueeItems && marqueeItems.length)
        ? marqueeItems : ['전 상품 무료배송', '신규 회원 15% 쿠폰', '당일 출고'];
      var _mqSpeed = (typeof marqueeSpeed !== 'undefined' && marqueeSpeed) ? marqueeSpeed : 28;

      // nbsp(U+00A0)·middot(U+00B7)를 문자 코드로 직접 구성 — 간격 유지 + 이중 이스케이프 회피.
      var _mqSep = String.fromCharCode(160, 160, 183, 160, 160);
      var _mqSeg = _mqItems.join(_mqSep) + _mqSep;
    %>
    <% if (_mqOn) { %>
      <div class="yd-ed-marquee" aria-hidden="true">
        <div class="yd-ed-marquee__track" style="animation-duration: <%= _mqSpeed %>s;">
          <%# 짝수(8)회 반복 → translateX(-50%) 지점이 반복 경계와 맞아 이음매 없이 흐른다. %>
          <% for (var i = 0; i < 8; i++) { %>
            <span class="yd-ed-marquee__item"><%= _mqSeg %></span>
          <% } %>
        </div>
      </div>
    <% } %>
  </section>

  <script>
    /* 모션 최소화를 켠 사용자에게는 배너 영상을 자동재생하지 않는다. CSS 로는 재생을 못 막는다. */
    (function () {
      if (!window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      document.querySelectorAll('video[data-hero-video]').forEach(function (v) {
        v.removeAttribute('autoplay');
        v.pause();
      });
    })();
  </script>

  <style>
    /* user/index.ejs 가 .mySwiperDesktop 을 모바일에서 숨기지만, 에디토리얼은 단일 스와이퍼라
       모든 폭에서 보여야 한다. 더 높은 특이성 + !important 로 표시를 강제한다. */
    .yd-ed-hero .yd-ed-swiper { display: block !important; width: 100%; }
    /* 풀블리드 무대 — 데스크톱은 뷰포트를 거의 채우고, 모바일은 세로 비율을 키운다. */
    .yd-ed-hero .yd-ed-stage { height: 88vh; min-height: 520px; max-height: 900px; }
    @media (max-width: 640px) { .yd-ed-hero .yd-ed-stage { height: 82vh; min-height: 460px; } }
    .yd-ed-scrim { background: linear-gradient(to top, rgba(0,0,0,.60) 0%, rgba(0,0,0,.15) 45%, rgba(0,0,0,.05) 100%); }
    <%#
      헤드라인 — 확정 40px(데스크톱). 상한을 40px 로 두어 창을 아무리 넓혀도 그 이상 커지지 않는다
      (상품명이 그대로 들어와 길어지는 일이 많아 커지면 3줄 이상으로 꺾인다).
      3.2vw 는 1250px 에서 40px 에 닿으므로 일반적인 데스크톱은 전부 정확히 40px.
      좁아지면 30px 까지만 줄어든다(모바일 가독성 하한).
    %>
    .yd-ed-title { font-family: var(--yd-font-display, serif); font-size: clamp(1.875rem, 3.2vw, 2.5rem); }
    .yd-ed-eyebrow { font-family: var(--yd-font-family); }
    .yd-ed-cta {
      background: #fff; color: #111; border-radius: 9999px;
      transition: transform .2s ease, background .2s ease, color .2s ease;
    }
    .yd-ed-cta:hover { transform: translateY(-2px); background: #111; color: #fff; }
    /* 마퀴 스트립 */
    .yd-ed-marquee { overflow: hidden; background: var(--gh-secondary, #f4f1ec); border-top: 1px solid rgba(0,0,0,.06); }
    .yd-ed-marquee__track { display: inline-flex; white-space: nowrap; padding: 14px 0; animation: yd-ed-scroll 28s linear infinite; }
    .yd-ed-marquee__item { font-family: var(--yd-font-display, serif); font-size: 1.05rem; color: #4b463f; letter-spacing: .02em; }
    @keyframes yd-ed-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    @media (prefers-reduced-motion: reduce) { .yd-ed-marquee__track { animation: none; } }
    /* Swiper 화살표/도트는 hero_banner 와 톤을 맞춘다 */
    .yd-ed-swiper .swiper-button-next::after, .yd-ed-swiper .swiper-button-prev::after { display: none; }
    .yd-ed-swiper .swiper-button-next, .yd-ed-swiper .swiper-button-prev {
      width: 46px; height: 46px; margin-top: -23px; border-radius: 9999px;
      background: rgba(255,255,255,.18); border: 1px solid rgba(255,255,255,.5);
      -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px); color: #fff;
    }
    /*
     * 화살표 위치. 우측 유틸 레일(.yd-rail — position:fixed, right:16px, width:74px, z-index:45)은
     * ≥1600px 에서만 뜬다. 레일이 화살표보다 위에 그려져 클릭까지 먹으므로,
     * 같은 지점에서 오른쪽 화살표를 레일 바깥으로 민다. (hero_banner.ejs 와 동일 규칙)
     */
    .yd-ed-swiper .swiper-button-prev-desktop { left: 32px; }
    .yd-ed-swiper .swiper-button-next-desktop { right: 32px; }
    @media (min-width: 1600px) {
      .yd-ed-swiper .swiper-button-next-desktop { right: 122px; }
    }
    .yd-ed-swiper .swiper-pagination { bottom: 20px; }
    .yd-ed-swiper .swiper-pagination-bullet { width: 8px; height: 8px; background: rgba(255,255,255,.55); opacity: 1; }
    .yd-ed-swiper .swiper-pagination-bullet-active { background: #fff; }
  </style>

<% } else { %>
  <%# 테마2 — 전체폭. 우측 카드가 없는 배치라 콘텐츠만 갈아 끼운다. %>
  <% if (_isProduct) { %>
    <section class="bg-white">
      <div class="max-w-[1400px] mx-auto px-4 py-4">
        <%- include('./hero_showcase_main', { mainSlides: _slides }) %>
      </div>
    </section>
  <% } else { %>
    <% var _b2 = _toBanners(_slides); %>
    <%- include('./hero_banner', { heroBanners: _b2, mobileHeroBanners: _b2 }) %>
  <% } %>
<% } %>
