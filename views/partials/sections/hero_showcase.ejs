<%
  /*
   * 히어로 상품 쇼케이스 — 슬라이더 + 우측 피처 카드를 한 줄로 묶는 얇은 래퍼.
   *
   * locals:
   *   mainSlides : 중앙 슬라이더용 슬라이드 배열
   *   feature    : 우측 피처 카드 슬라이드 또는 null
   *
   * 실제 마크업은 두 파샬에 있다 — 배치(테마)와 콘텐츠(상품/배너)가 분리되면서
   * 슬라이더 본체(hero_showcase_main)와 피처 카드(hero_feature_card)를 테마별로
   * 따로 조합해야 하기 때문이다. 이 파일은 레거시 hero 섹션(mainController)이
   * 예전처럼 한 방에 부를 수 있도록 남겨 둔 조합 지점이다.
   */
%>
<% if ((mainSlides || []).length > 0) { %>
<section class="bg-white">
  <div class="max-w-[1400px] mx-auto px-4 py-4">
    <div class="flex gap-3">
      <div class="flex-1 min-w-0">
        <%- include('./hero_showcase_main', { mainSlides: mainSlides }) %>
      </div>
      <%- include('./hero_feature_card', { feature: (typeof feature !== 'undefined' ? feature : null) }) %>
    </div>
  </div>
</section>
<% } %>
