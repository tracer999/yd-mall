<%
  /*
   * 프로모션 배너 섹션 (CT-5)
   * 데이터소스: banners.group_key (bannerService.getByGroup)
   *
   * locals (config_json):
   *   title        : 섹션 제목 (없으면 헤더 생략)
   *   banners      : 배너 배열 (리졸버 주입)
   *   groupKey     : 배너 그룹 키
   *   layout       : 'rect' (가로 직사각) | 'vertical' (세로형)  기본 rect
   *   columns      : PC 열 수 (기본 2)
   *   sectionClass : <section> 클래스
   *
   * 링크가 없는 배너는 <a> 대신 <div> 로 렌더한다.
   * 모바일 이미지가 있으면 <picture> 로 분기한다.
   */
  const _items = banners || [];
  const _layout = (typeof layout !== 'undefined' && layout === 'vertical') ? 'vertical' : 'rect';
  const _cols = (typeof columns !== 'undefined' && columns) ? Number(columns) : 2;
  const _sectionClass = (typeof sectionClass !== 'undefined' && sectionClass) ? sectionClass : 'py-10 bg-white';
  const _title = (typeof title !== 'undefined' && title) ? title : '';
%>
<% if (_items.length > 0) { %>
<section class="<%= _sectionClass %>">
  <style>
    .yd-promo__grid { display: grid; gap: 1rem; grid-template-columns: 1fr; }
    @media (min-width: 768px) {
      .yd-promo__grid { grid-template-columns: repeat(var(--yd-promo-cols), minmax(0, 1fr)); }
    }
    .yd-promo__item {
      display: block; overflow: hidden; border-radius: 1rem;
      border: 1px solid #eef0f2; background: #fff;
      transition: box-shadow .15s, transform .15s;
    }
    a.yd-promo__item:hover { box-shadow: 0 10px 28px rgba(0,0,0,.10); transform: translateY(-2px); }
    .yd-promo__item img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .yd-promo__item--rect img { aspect-ratio: 16 / 6; }
    .yd-promo__item--vertical img { aspect-ratio: 3 / 4; }
    .yd-promo__caption { padding: .75rem 1rem; }
  </style>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if (_title) { %>
      <div class="text-center mb-6">
        <h2 class="text-2xl font-extrabold text-gray-900"><%= _title %></h2>
      </div>
    <% } %>

    <div class="yd-promo__grid" style="--yd-promo-cols: <%= _cols %>">
      <% _items.forEach(function (b) {
           const hasLink = b.link_url && String(b.link_url).trim(); %>
        <% if (hasLink) { %>
          <a href="<%= b.link_url %>" class="yd-promo__item yd-promo__item--<%= _layout %>">
        <% } else { %>
          <div class="yd-promo__item yd-promo__item--<%= _layout %>">
        <% } %>

          <% if (b.mobile_image_url) { %>
            <picture>
              <source media="(max-width: 767px)" srcset="<%= b.mobile_image_url %>">
              <img src="<%= b.image_url %>" alt="<%= b.title || '프로모션 배너' %>" loading="lazy">
            </picture>
          <% } else { %>
            <img src="<%= b.image_url %>" alt="<%= b.title || '프로모션 배너' %>" loading="lazy">
          <% } %>

          <%# 제목(작게) + 배너 문구(크게, 최대 3줄). 둘 다 비면 캡션 자체를 그리지 않는다. %>
          <% if (b.title || b.overlay_subtitle) { %>
            <div class="yd-promo__caption">
              <%- include('../banner_copy', { copy: b.overlay_subtitle, heading: b.title, variant: 'caption' }) %>
            </div>
          <% } %>

        <% if (hasLink) { %></a><% } else { %></div><% } %>
      <% }); %>
    </div>
  </div>
</section>
<% } %>
