<%
  /*
   * 카테고리별 베스트 섹션.
   * locals.categoryGroups = [{ id, name, products: [...] }]
   *   최상위(1뎁스) 카테고리마다 한 행. 각 행이 독립 캐러셀이다.
   *   상품 카드는 공용 product_card 파셜 재사용.
   *
   * 예전에는 행을 그냥 overflow-x-auto 로 흘려서 모바일에 브라우저 스크롤바가 노출되고
   * PC 에는 좌우 이동 수단이 아예 없었다. 다른 캐러셀 섹션(product_carousel·deal_carousel)이
   * 쓰는 _carousel_base 계약으로 통일한다 — PC 화살표 / 모바일 스와이프 + 도트.
   */
%>
<% if (typeof categoryGroups !== 'undefined' && categoryGroups && categoryGroups.length > 0) { %>
<section class="py-12 bg-white" id="category-section">
  <%- include('./_carousel_base') %>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-extrabold text-gray-900 mb-8 text-center">
      <%= (typeof title !== 'undefined' && title) ? title : '카테고리별 베스트' %>
    </h2>

    <% categoryGroups.forEach(function (g) { %>
      <div class="mb-10 last:mb-0" data-yd-carousel>
        <div class="flex items-end justify-between mb-4 gap-4">
          <h3 class="text-lg sm:text-xl font-bold text-gray-900"><%= g.name %></h3>

          <div class="flex items-center gap-2 shrink-0">
            <a href="/products/category/<%= g.id %>"
               class="text-sm text-gray-500 hover:text-[var(--gh-primary)] inline-flex items-center gap-1">
              더보기 <i class="bi bi-chevron-right text-xs"></i>
            </a>
            <%# 화살표는 _carousel_base 가 PC(≥1024px)에서만 띄운다. 모바일은 스와이프 + 도트. %>
            <button type="button" class="yd-carousel__nav" data-yd-prev aria-label="<%= g.name %> 이전 상품">
              <i class="bi bi-chevron-left"></i>
            </button>
            <button type="button" class="yd-carousel__nav" data-yd-next aria-label="<%= g.name %> 다음 상품">
              <i class="bi bi-chevron-right"></i>
            </button>
          </div>
        </div>

        <div class="yd-carousel__track" data-yd-track style="--yd-per-view: 5">
          <% g.products.forEach(function (p) { %>
            <div><%- include('../product_card', { product: p, opts: { imageHeightClass: 'h-44' } }) %></div>
          <% }); %>
        </div>
      </div>
    <% }); %>
  </div>
</section>
<% } %>
