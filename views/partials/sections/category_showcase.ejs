<%
  /*
   * 카테고리별 베스트 섹션.
   * locals.categoryGroups = [{ id, name, products: [...] }]
   *   최상위(1뎁스) 카테고리마다 한 행. 데스크톱은 그리드, 모바일은 가로 스크롤.
   *   상품 카드는 공용 product_card 파셜 재사용.
   */
%>
<% if (typeof categoryGroups !== 'undefined' && categoryGroups && categoryGroups.length > 0) { %>
<section class="py-12 bg-white" id="category-section">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-extrabold text-gray-900 mb-8 text-center">
      <%= (typeof title !== 'undefined' && title) ? title : '카테고리별 베스트' %>
    </h2>

    <% categoryGroups.forEach(function (g) { %>
      <div class="mb-10 last:mb-0">
        <div class="flex items-end justify-between mb-4">
          <h3 class="text-lg sm:text-xl font-bold text-gray-900"><%= g.name %></h3>
          <a href="/products/category/<%= g.id %>"
             class="text-sm text-gray-500 hover:text-[var(--gh-primary)] inline-flex items-center gap-1 shrink-0">
            더보기 <i class="bi bi-chevron-right text-xs"></i>
          </a>
        </div>

        <!-- 모바일: 가로 스크롤(flex) / 데스크톱: 그리드 -->
        <div class="flex sm:grid sm:grid-cols-3 lg:grid-cols-5 gap-4
                    overflow-x-auto sm:overflow-visible pb-2 sm:pb-0
                    -mx-4 px-4 sm:mx-0 sm:px-0 snap-x">
          <% g.products.forEach(function (p) { %>
            <div class="flex-none w-[42%] min-[420px]:w-[36%] sm:w-auto snap-start">
              <%- include('../product_card', { product: p, opts: { imageHeightClass: 'h-44' } }) %>
            </div>
          <% }); %>
        </div>
      </div>
    <% }); %>
  </div>
</section>
<% } %>
