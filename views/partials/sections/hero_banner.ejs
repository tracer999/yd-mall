<%
  /*
   * 히어로 배너 (PC/모바일 Swiper). locals: heroBanners, mobileHeroBanners. Swiper 초기화 스크립트는 페이지에서 유지.
   *
   * 배너 문구(오버레이) — banners.overlay_* 컬럼. 이미지 위에 큰 제목 + 추가 문구(최대 2줄) + 이동 버튼을 얹는다.
   * 셋 다 비어 있으면 아무것도 그리지 않는다(기존 이미지 전용 배너와 동작이 같다).
   */
  const _lines = (v) => String(v || '').split('\n').map(s => s.trim()).filter(Boolean).slice(0, 2);
  const _hasOverlay = (b) => !!(b.overlay_title || b.overlay_subtitle || b.overlay_button_text);

  // 버튼 글자색 — 배경 밝기로 자동 결정한다. 운영자가 밝은 색을 고르면 흰 글자가 안 보인다.
  const _btnBg = (b) => (/^#[0-9a-fA-F]{6}$/.test(String(b.overlay_button_color || '')) ? b.overlay_button_color : '#1a7f37');
  const _btnFg = (b) => {
    const hex = _btnBg(b).slice(1);
    const [r, g, bl] = [0, 2, 4].map(i => parseInt(hex.slice(i, i + 2), 16));
    // ITU-R BT.601 상대 휘도. 0.6 을 넘으면(밝은 버튼) 검정 글자라야 읽힌다.
    return (0.299 * r + 0.587 * g + 0.114 * bl) / 255 > 0.6 ? '#111827' : '#ffffff';
  };
  const _alignBox = { LEFT: 'items-start text-left', CENTER: 'items-center text-center mx-auto', RIGHT: 'items-end text-right ml-auto' };
  const _align = (b) => _alignBox[b.overlay_align] || _alignBox.LEFT;
%>
<section class="relative bg-white overflow-hidden">
  <% if (heroBanners.length > 0) { %>
    <div class="swiper mySwiperDesktop group hidden sm:block">
      <div class="swiper-wrapper">
        <% heroBanners.forEach(banner => { %>
          <div class="swiper-slide relative cursor-pointer"
               data-href="<%= banner.link_url || '#' %>"
               onclick="window.location.href=this.getAttribute('data-href')">
            <div class="w-full relative aspect-[1920/600]">
              <img src="<%= banner.image_url %>" alt="<%= banner.title %>" class="w-full h-full object-cover block">

              <% if (_hasOverlay(banner)) { %>
                <%# 문구는 본문 폭(max-w-6xl) 안에 둔다 — 전체폭 이미지에 그냥 붙이면 넓은 화면에서 가장자리로 밀린다. %>
                <div class="absolute inset-0 flex items-center pointer-events-none">
                  <div class="max-w-6xl w-full mx-auto px-6 lg:px-8">
                    <div class="yd-hero-ov flex flex-col gap-4 max-w-xl <%= _align(banner) %>">
                      <% if (banner.overlay_title) { %>
                        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-tight tracking-tight">
                          <%= banner.overlay_title %>
                        </h2>
                      <% } %>
                      <% if (banner.overlay_subtitle) { %>
                        <p class="text-sm md:text-base text-white/90 leading-relaxed">
                          <% _lines(banner.overlay_subtitle).forEach(function (line, i) { %>
                            <% if (i) { %><br><% } %><%= line %>
                          <% }); %>
                        </p>
                      <% } %>
                      <% if (banner.overlay_button_text) { %>
                        <%# 슬라이드 전체가 링크지만 버튼은 따로 눌려야 한다 → pointer-events 복구. %>
                        <a href="<%= banner.link_url || '#' %>"
                           class="pointer-events-auto inline-flex items-center justify-center px-7 py-3 rounded-md text-sm md:text-base font-semibold shadow-sm transition-transform hover:-translate-y-0.5"
                           style="background-color: <%= _btnBg(banner) %>; color: <%= _btnFg(banner) %>;">
                          <%= banner.overlay_button_text %>
                        </a>
                      <% } %>
                    </div>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="swiper-pagination swiper-pagination-desktop"></div>
      <div class="swiper-button-next swiper-button-next-desktop hidden group-hover:block text-white/70 hover:text-white" style="text-shadow:0 1px 3px rgba(0,0,0,0.5);"></div>
      <div class="swiper-button-prev swiper-button-prev-desktop hidden group-hover:block text-white/70 hover:text-white" style="text-shadow:0 1px 3px rgba(0,0,0,0.5);"></div>
    </div>
    <% if (mobileHeroBanners.length > 0) { %>
      <div class="swiper mySwiperMobile group block sm:hidden">
        <div class="swiper-wrapper">
          <% mobileHeroBanners.forEach(banner => { %>
            <div class="swiper-slide relative cursor-pointer"
                 data-href="<%= banner.link_url || '#' %>"
                 onclick="window.location.href=this.getAttribute('data-href')">
              <div class="w-full relative aspect-[390/422] bg-white">
                <img src="<%= banner.mobile_image_url %>" alt="<%= banner.title %>"
                     class="w-full h-full object-contain block">

                <% if (_hasOverlay(banner)) { %>
                  <div class="absolute inset-0 flex items-center pointer-events-none px-6">
                    <div class="yd-hero-ov flex flex-col gap-3 w-full <%= _align(banner) %>">
                      <% if (banner.overlay_title) { %>
                        <h2 class="text-2xl font-extrabold text-white leading-tight tracking-tight"><%= banner.overlay_title %></h2>
                      <% } %>
                      <% if (banner.overlay_subtitle) { %>
                        <p class="text-xs text-white/90 leading-relaxed">
                          <% _lines(banner.overlay_subtitle).forEach(function (line, i) { %>
                            <% if (i) { %><br><% } %><%= line %>
                          <% }); %>
                        </p>
                      <% } %>
                      <% if (banner.overlay_button_text) { %>
                        <a href="<%= banner.link_url || '#' %>"
                           class="pointer-events-auto inline-flex items-center justify-center px-5 py-2.5 rounded-md text-sm font-semibold shadow-sm"
                           style="background-color: <%= _btnBg(banner) %>; color: <%= _btnFg(banner) %>;">
                          <%= banner.overlay_button_text %>
                        </a>
                      <% } %>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
        <div class="swiper-pagination swiper-pagination-mobile"></div>
        <div class="swiper-button-next swiper-button-next-mobile text-white/80 hover:text-white" style="text-shadow:0 1px 3px rgba(0,0,0,0.5);"></div>
        <div class="swiper-button-prev swiper-button-prev-mobile text-white/80 hover:text-white" style="text-shadow:0 1px 3px rgba(0,0,0,0.5);"></div>
      </div>
    <% } else { %>
      <div class="flex sm:hidden w-full h-[50vh] max-h-[50vh] bg-[var(--gh-secondary)] flex-col items-center justify-center text-center px-4">
        <h1 class="text-3xl font-bold text-[var(--gh-primary-dark)] mb-3">와이디몰</h1>
        <p class="text-gray-600 text-base max-w-xl">모바일 배너를 등록하면 이 영역에 노출됩니다.</p>
      </div>
    <% } %>
  <% } else { %>
    <div class="w-full h-[50vh] sm:h-auto sm:aspect-[1920/600] bg-[var(--gh-secondary)] flex flex-col items-center justify-center text-center px-4">
      <h1 class="text-3xl md:text-5xl font-bold text-[var(--gh-primary-dark)] mb-4">와이디몰</h1>
      <p class="text-gray-600 text-lg md:text-xl max-w-2xl">자연에서 온 순수한 재료로 만드는 건강한 식탁.<br>지금 배너를 등록하여 메인 화면을 꾸며보세요.</p>
    </div>
  <% } %>
</section>

<style>
  /* 사진 위 흰 글자의 가독성 — 배경이 밝은 이미지일 수 있으므로 그림자로 확보한다(스크림을 깔면 이미지가 죽는다). */
  .yd-hero-ov h2 { text-shadow: 0 2px 12px rgba(0, 0, 0, .45); }
  .yd-hero-ov p  { text-shadow: 0 1px 8px rgba(0, 0, 0, .45); }

  /*
   * 좌우 이동 화살표.
   *   - Swiper 기본값(10px)은 화면 끝에 붙어 배너 밖으로 나간 것처럼 보인다 → 안쪽으로 들인다.
   *   - 우측 유틸 레일(.yd-rail — right:16px, width:74px)은 ≥1600px 에서만 뜬다. 그 폭 안에 화살표가
   *     들어가면 레일과 겹치므로, 같은 지점에서 오른쪽 화살표를 레일 바깥으로 더 민다.
   */
  .mySwiperDesktop .swiper-button-prev-desktop { left: 48px; }
  .mySwiperDesktop .swiper-button-next-desktop { right: 48px; }
  @media (min-width: 1600px) {
    .mySwiperDesktop .swiper-button-next-desktop { right: 122px; }
  }
</style>
