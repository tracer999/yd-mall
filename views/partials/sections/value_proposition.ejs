<%
  /* 특장점(Value Proposition) 섹션. locals: kakaoUrl */
  var _kakaoUrl = (typeof kakaoUrl !== 'undefined' && kakaoUrl) ? kakaoUrl : '#';
%>
<section class="pt-10 pb-8 md:pt-24 md:pb-10 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8 md:mb-12">
      <h2 class="text-base text-[var(--gh-primary)] font-semibold tracking-wide">믿고 사는 건강식품</h2>
      <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl">와이디몰을<br class="sm:hidden"> 선택하는 이유</p>
    </div>
    <!-- PC 뷰 -->
    <div class="hidden md:grid grid-cols-3 gap-8 text-center">
      <div class="p-8 flex flex-col items-center">
        <img src="/images/icons/icon01.png" alt="정품 아이콘" class="w-24 h-24 mb-6 object-contain">
        <h3 class="text-xl font-bold text-gray-900 mb-3">엄선한 정품 건강식품</h3>
        <p class="text-gray-500 text-sm leading-relaxed flex-grow">검증된 정품 건강식품만<br>믿고 구매하실 수 있습니다.</p>
        <a href="/products" class="inline-flex items-center justify-center mt-6 w-52 py-2.5 text-sm font-medium rounded-lg transition-all group text-[var(--gh-primary)] border border-[var(--gh-primary)] bg-transparent hover:bg-[var(--gh-primary)] hover:text-white no-underline">
          전체 상품 보기 <i class="bi bi-chevron-right ml-1.5 text-xs group-hover:translate-x-1 transition-transform"></i>
        </a>
      </div>
      <div class="p-8 flex flex-col items-center">
        <img src="/images/icons/icon02.png" alt="브랜드 아이콘" class="w-24 h-24 mb-6 object-contain">
        <h3 class="text-xl font-bold text-gray-900 mb-3">다양한 브랜드 보유</h3>
        <p class="text-gray-500 text-sm leading-relaxed flex-grow">검증된 건강식품 브랜드와<br>트렌드 제품을한곳에서 만나보세요.</p>
        <a href="/brands" class="inline-flex items-center justify-center mt-6 w-52 py-2.5 text-sm font-medium rounded-lg transition-all group text-[var(--gh-primary)] border border-[var(--gh-primary)] bg-transparent hover:bg-[var(--gh-primary)] hover:text-white no-underline">
          브랜드 전체보기 <i class="bi bi-chevron-right ml-1.5 text-xs group-hover:translate-x-1 transition-transform"></i>
        </a>
      </div>
      <div class="p-8 flex flex-col items-center">
        <img src="/images/icons/icon03.png" alt="가격 아이콘" class="w-24 h-24 mb-6 object-contain">
        <h3 class="text-xl font-bold text-gray-900 mb-3">합리적인 가격</h3>
        <p class="text-gray-500 text-sm leading-relaxed flex-grow">합리적인 가격과 다양한 혜택으로<br>건강한 쇼핑을 도와드립니다.</p>
        <a href="<%= _kakaoUrl %>" target="_blank" data-kakao-source="main_feature" data-kakao-label="메인 특장점 문의하기" class="inline-flex items-center justify-center mt-6 w-52 py-2.5 text-sm font-medium rounded-lg transition-all group text-[var(--gh-primary)] border border-[var(--gh-primary)] bg-transparent hover:bg-[var(--gh-primary)] hover:text-white no-underline">
          문의하기 <i class="bi bi-chevron-right ml-1.5 text-xs group-hover:translate-x-1 transition-transform"></i>
        </a>
      </div>
    </div>

    <!-- 모바일 뷰 -->
    <div class="grid grid-cols-1 gap-4 md:hidden">
      <a href="/products" class="p-4 flex items-center gap-4 border border-gray-200 rounded-xl no-underline hover:bg-gray-50 transition-colors">
        <img src="/images/icons/icon01.png" alt="정품 아이콘" class="w-12 h-12 object-contain flex-shrink-0">
        <div class="text-left flex-1 min-w-0">
          <h3 class="text-sm font-bold text-gray-900 mb-0.5">엄선한 정품 건강식품</h3>
          <p class="text-gray-500 text-xs leading-relaxed">검증된 정품 건강식품만 믿고 구매하실 수 있습니다.</p>
        </div>
        <i class="bi bi-chevron-right text-gray-400 text-lg flex-shrink-0"></i>
      </a>
      <a href="/brands" class="p-4 flex items-center gap-4 border border-gray-200 rounded-xl no-underline hover:bg-gray-50 transition-colors">
        <img src="/images/icons/icon02.png" alt="브랜드 아이콘" class="w-12 h-12 object-contain flex-shrink-0">
        <div class="text-left flex-1 min-w-0">
          <h3 class="text-sm font-bold text-gray-900 mb-0.5">다양한 브랜드 보유</h3>
          <p class="text-gray-500 text-xs leading-relaxed">검증된 건강식품 브랜드와 트렌드 제품을 한 곳에서 만나보세요.</p>
        </div>
        <i class="bi bi-chevron-right text-gray-400 text-lg flex-shrink-0"></i>
      </a>
      <a href="<%= _kakaoUrl %>" target="_blank" data-kakao-source="main_feature" data-kakao-label="메인 특장점 문의하기" class="p-4 flex items-center gap-4 border border-gray-200 rounded-xl no-underline hover:bg-gray-50 transition-colors">
        <img src="/images/icons/icon03.png" alt="가격 아이콘" class="w-12 h-12 object-contain flex-shrink-0">
        <div class="text-left flex-1 min-w-0">
          <h3 class="text-sm font-bold text-gray-900 mb-0.5">합리적인 가격</h3>
          <p class="text-gray-500 text-xs leading-relaxed">합리적인 가격과 다양한 혜택으로 건강한 쇼핑을 도와드립니다.</p>
        </div>
        <i class="bi bi-chevron-right text-gray-400 text-lg flex-shrink-0"></i>
      </a>
    </div>
  </div>
</section>
