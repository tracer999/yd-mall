<%
  /*
   * 카테고리별 신상품 — 탭 + 그리드
   * 데이터소스: 리졸버 new_by_category (신상품이 있는 NORMAL 최상위 카테고리만)
   *
   * locals:
   *   title  : 섹션 제목
   *   tabs   : [{ id, name, products: [...] }] (리졸버 주입)
   *
   * 탭 전환은 CSS 클래스 토글만 한다 — 데이터는 이미 서버가 다 실어 보냈다.
   */
  const _tabs = tabs || [];
  const _title = (typeof title !== 'undefined' && title) ? title : '카테고리별 신상품';
  const _uid = 'nbc' + Math.random().toString(36).slice(2, 8);
%>
<% if (_tabs.length > 0) { %>
<section class="py-12 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-5 text-center"><%= _title %></h2>

    <div class="flex gap-2 overflow-x-auto pb-3 mb-5 border-b border-gray-200" role="tablist">
      <% _tabs.forEach(function (t, i) { %>
        <button type="button" role="tab"
          class="nbc-tab whitespace-nowrap px-4 py-2 text-sm font-medium rounded-full border transition-colors <%= i === 0 ? 'bg-gray-900 text-white border-gray-900' : 'bg-white text-gray-600 border-gray-300 hover:border-gray-400' %>"
          data-uid="<%= _uid %>" data-target="<%= _uid %>-<%= t.id %>"
          aria-selected="<%= i === 0 ? 'true' : 'false' %>">
          <%= t.name %>
        </button>
      <% }); %>
    </div>

    <% _tabs.forEach(function (t, i) { %>
      <div id="<%= _uid %>-<%= t.id %>" class="nbc-panel <%= i === 0 ? '' : 'hidden' %>" data-uid="<%= _uid %>">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4 lg:gap-6">
          <% t.products.forEach(function (product) { %>
            <%- include('../product_card', { product: product, opts: { showTopBadge: true, showPriceBadge: true, showDistBadge: false } }) %>
          <% }); %>
        </div>
        <div class="mt-5 text-center">
          <a href="/products?filter=new&categoryId=<%= t.id %>"
             class="inline-block px-5 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-full hover:border-gray-500 transition-colors no-underline">
            <%= t.name %> 신상품 더보기
          </a>
        </div>
      </div>
    <% }); %>
  </div>

  <script>
    (function () {
      var uid = '<%= _uid %>';
      document.querySelectorAll('.nbc-tab[data-uid="' + uid + '"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          document.querySelectorAll('.nbc-tab[data-uid="' + uid + '"]').forEach(function (b) {
            var on = b === btn;
            b.setAttribute('aria-selected', on ? 'true' : 'false');
            b.classList.toggle('bg-gray-900', on);
            b.classList.toggle('text-white', on);
            b.classList.toggle('border-gray-900', on);
            b.classList.toggle('bg-white', !on);
            b.classList.toggle('text-gray-600', !on);
            b.classList.toggle('border-gray-300', !on);
          });
          document.querySelectorAll('.nbc-panel[data-uid="' + uid + '"]').forEach(function (p) {
            p.classList.toggle('hidden', p.id !== btn.dataset.target);
          });
        });
      });
    })();
  </script>
</section>
<% } %>
