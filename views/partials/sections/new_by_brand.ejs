<%
  /*
   * 브랜드별 신상품 — 브랜드 로고 + 그 브랜드의 신상품 가로 스크롤
   * 데이터소스: 리졸버 new_by_brand (신상품을 가진 브랜드만)
   *
   * locals:
   *   title  : 섹션 제목
   *   groups : [{ id, name, logo, isNewBrand, newCount, products: [...] }] (리졸버 주입)
   */
  const _groups = groups || [];
  const _title = (typeof title !== 'undefined' && title) ? title : '브랜드별 신상품';
%>
<% if (_groups.length > 0) { %>
<section class="py-12 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-6"><%= _title %></h2>

    <div class="space-y-10">
      <% _groups.forEach(function (g) { %>
        <div>
          <div class="flex items-center justify-between mb-4">
            <a href="/products/brand/<%= g.id %>" class="flex items-center gap-3 no-underline group">
              <div class="h-11 w-11 rounded-full bg-white border border-gray-200 flex items-center justify-center overflow-hidden shrink-0">
                <% if (g.logo) { %>
                  <img src="<%= g.logo %>" alt="<%= g.name %>" class="max-h-full max-w-full object-contain">
                <% } else { %>
                  <span class="text-xs font-bold text-gray-400"><%= g.name.slice(0, 2) %></span>
                <% } %>
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <span class="text-base font-bold text-gray-900 group-hover:text-[color:var(--gh-primary)] transition-colors"><%= g.name %></span>
                  <% if (g.isNewBrand) { %>
                    <span class="px-2 py-0.5 text-[11px] font-semibold rounded-full bg-emerald-100 text-emerald-700">신규 입점</span>
                  <% } %>
                </div>
                <div class="text-xs text-gray-500">신상품 <%= g.newCount %>개</div>
              </div>
            </a>
            <a href="/products/brand/<%= g.id %>"
               class="text-sm text-gray-500 hover:text-gray-800 no-underline whitespace-nowrap">
              더보기 <i class="bi bi-chevron-right text-xs"></i>
            </a>
          </div>

          <%# 모바일에서는 가로 스크롤, PC 에서는 그리드 %>
          <div class="flex gap-3 sm:gap-4 overflow-x-auto pb-2 lg:grid lg:grid-cols-6 lg:overflow-visible">
            <% g.products.forEach(function (product) { %>
              <div class="w-40 shrink-0 lg:w-auto">
                <%- include('../product_card', { product: product, opts: { showTopBadge: true, showPriceBadge: false, showDistBadge: false } }) %>
              </div>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>
