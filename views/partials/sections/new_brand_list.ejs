<%
  /*
   * 신규 입점 브랜드 — 로고·브랜드명·입점일·대표 상품
   * 데이터소스: 리졸버 new_brand_list (categories.onboarded_at 기준)
   *
   * locals:
   *   title  : 섹션 제목
   *   brands : [{ id, name, logo, description, onboardedAt, products: [...] }] (리졸버 주입)
   */
  const _brands = brands || [];
  const _title = (typeof title !== 'undefined' && title) ? title : '신규 입점 브랜드';
  const _fmt = (d) => {
    if (!d) return '';
    const dt = new Date(d);
    return `${dt.getFullYear()}.${String(dt.getMonth() + 1).padStart(2, '0')}.${String(dt.getDate()).padStart(2, '0')}`;
  };
%>
<% if (_brands.length > 0) { %>
<section class="py-12 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <%# 제목 중앙 정렬(다른 섹션과 통일). 좌우 1fr 트랙으로 전체보기 링크가 제목을 밀지 않게 한다. %>
    <div class="grid grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center mb-6 gap-4">
      <span aria-hidden="true"></span>
      <h2 class="text-xl md:text-2xl font-bold text-gray-900 text-center">
        <span class="mr-1">✨</span><%= _title %>
      </h2>
      <a href="/brands" class="text-sm text-gray-500 hover:text-gray-800 no-underline whitespace-nowrap justify-self-end">
        전체 브랜드 <i class="bi bi-chevron-right text-xs"></i>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <% _brands.forEach(function (b) { %>
        <div class="border border-gray-200 rounded-2xl p-4 hover:shadow-md transition-shadow bg-white">
          <a href="/products/brand/<%= b.id %>" class="flex items-center gap-3 no-underline mb-3">
            <div class="h-12 w-12 rounded-full bg-gray-50 border border-gray-200 flex items-center justify-center overflow-hidden shrink-0">
              <% if (b.logo) { %>
                <img src="<%= b.logo %>" alt="<%= b.name %>" class="max-h-full max-w-full object-contain">
              <% } else { %>
                <span class="text-xs font-bold text-gray-400"><%= b.name.slice(0, 2) %></span>
              <% } %>
            </div>
            <div class="min-w-0">
              <div class="text-sm font-bold text-gray-900 truncate"><%= b.name %></div>
              <div class="text-xs text-emerald-600 font-medium"><%= _fmt(b.onboardedAt) %> 입점</div>
            </div>
          </a>

          <% if (b.description) { %>
            <p class="text-xs text-gray-500 mb-3 line-clamp-2"><%= b.description %></p>
          <% } %>

          <% if (b.products && b.products.length) { %>
            <div class="grid grid-cols-3 gap-1.5">
              <% b.products.forEach(function (p) { %>
                <a href="<%= (p.slug && p.slug.trim()) ? '/products/' + encodeURIComponent(p.slug) : '/products/view/' + p.id %>"
                   class="block aspect-square rounded-lg overflow-hidden bg-gray-100 no-underline" title="<%= p.name %>">
                  <% if (p.main_image) { %>
                    <img src="<%= p.main_image %>" alt="<%= p.name %>" class="w-full h-full object-cover hover:scale-105 transition-transform">
                  <% } %>
                </a>
              <% }); %>
            </div>
          <% } %>
        </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>
