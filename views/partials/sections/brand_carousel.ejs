<%
  /*
   * 베스트 브랜드 — 브랜드별 상품 리스트
   * 데이터소스: 리졸버 brand_carousel (categories WHERE type='BRAND' × 이 몰 상품)
   *
   * locals (config_json):
   *   title        : 섹션 제목
   *   brands       : 브랜드 배열 (리졸버 주입)
   *                  — { id, name, logo_image_path, product_count, products: [...] }
   *   maxCount       : 최대 노출 브랜드 수 (기본 8)
   *   columnsPerView : 브랜드 상품줄의 PC 뷰당 표시 수 (기본 6)
   *   moreLink       : '더 보기' 링크 (기본 /brands)
   *   sectionClass   : <section> 클래스
   *
   * 브랜드는 세로로 나열하고, 각 브랜드의 상품줄만 스와이프 캐러셀(_carousel_base)로 넘긴다.
   * PC 는 좌우 화살표, 모바일은 터치 슬라이드 + 도트. 로고가 없는 브랜드는 브랜드명 앞 2글자로 폴백한다.
   */
  const _max = (typeof maxCount !== 'undefined' && maxCount) ? Number(maxCount) : 8;
  const _items = (brands || []).slice(0, _max);
  const _title = (typeof title !== 'undefined' && title) ? title : '베스트 브랜드';
  const _more = (typeof moreLink !== 'undefined') ? moreLink : '/brands';
  const _sectionClass = (typeof sectionClass !== 'undefined' && sectionClass) ? sectionClass : 'py-12 bg-gray-50';
  const _perView = (typeof columnsPerView !== 'undefined' && columnsPerView) ? Number(columnsPerView) : 6;
%>
<% if (_items.length > 0) { %>
<section class="<%= _sectionClass %>">
  <%- include('./_carousel_base') %>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-8 gap-4">
      <h2 class="text-2xl font-extrabold text-gray-900"><%= _title %></h2>
      <% if (_more) { %>
        <a href="<%= _more %>" class="text-sm text-gray-500 hover:text-gray-800 no-underline whitespace-nowrap shrink-0">
          브랜드 전체보기 <i class="bi bi-chevron-right text-xs"></i>
        </a>
      <% } %>
    </div>

    <div class="space-y-10">
      <% _items.forEach(function (brand) { %>
        <%# 브랜드 1개 = 캐러셀 1개. 상품줄만 스와이프(PC 화살표 · 모바일 터치/도트)한다. %>
        <div data-yd-carousel>
          <div class="flex items-center justify-between mb-4 gap-3">
            <a href="/products/brand/<%= brand.id %>" class="flex items-center gap-3 no-underline group min-w-0">
              <div class="h-11 w-11 rounded-full bg-white border border-gray-200 flex items-center justify-center overflow-hidden shrink-0">
                <% if (brand.logo_image_path) { %>
                  <img src="<%= brand.logo_image_path %>" alt="<%= brand.name %>" class="max-h-full max-w-full object-contain" loading="lazy">
                <% } else { %>
                  <span class="text-xs font-bold text-gray-400"><%= brand.name.slice(0, 2) %></span>
                <% } %>
              </div>
              <div class="min-w-0">
                <span class="text-base font-bold text-gray-900 group-hover:text-[color:var(--gh-primary)] transition-colors"><%= brand.name %></span>
                <% if (brand.product_count) { %>
                  <div class="text-xs text-gray-500">상품 <%= brand.product_count %>개</div>
                <% } %>
              </div>
            </a>
            <div class="flex items-center gap-2 shrink-0">
              <button type="button" class="yd-carousel__nav" data-yd-prev aria-label="이전 상품">
                <i class="bi bi-chevron-left"></i>
              </button>
              <button type="button" class="yd-carousel__nav" data-yd-next aria-label="다음 상품">
                <i class="bi bi-chevron-right"></i>
              </button>
              <a href="/products/brand/<%= brand.id %>"
                 class="text-sm text-gray-500 hover:text-gray-800 no-underline whitespace-nowrap">
                더보기 <i class="bi bi-chevron-right text-xs"></i>
              </a>
            </div>
          </div>

          <div class="yd-carousel__track" data-yd-track style="--yd-per-view: <%= _perView %>">
            <% brand.products.forEach(function (product) { %>
              <div>
                <%- include('../product_card', { product: product, opts: { showTopBadge: true, showPriceBadge: false, showDistBadge: false } }) %>
              </div>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>
