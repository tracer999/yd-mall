<%
  /*
   * 상품 쇼케이스 슬라이더 본체 (좌/중앙 영역만) — 우측 피처 카드는 hero_feature_card 소관.
   *
   * locals: mainSlides (hero_slide slot=MAIN + 상품 조인, 또는 베스트 자동 구성분)
   *
   * 배치(테마)와 콘텐츠(상품/배너)가 분리되면서, 이 슬라이더는 두 곳에서 쓰인다:
   *   테마1(split_feature) — 좌측 컬럼에 넣고 우측에 피처 카드
   *   테마2(full_width)    — 컬럼 없이 전체폭
   * 그래서 바깥 <section>·컨테이너를 갖지 않는다. 감싸는 쪽이 정한다.
   *
   * Swiper 번들은 페이지에서 로드되므로 하단에서 DOM 준비 후 초기화한다.
   */
  const won = n => Number(n || 0).toLocaleString();
  const slideHref = s => s.link_url
    ? s.link_url
    : (s.slug && String(s.slug).trim() ? `/products/${encodeURIComponent(s.slug)}` : (s.product_id ? `/products/view/${s.product_id}` : '#'));
  const slideImg = s => s.image_url || s.main_image || '/images/placeholder.png';
  const slideTitle = s => s.headline || s.product_name || '';
  // 썸네일 라벨: 슬라이드 label('[베스트]' → '베스트')을 우선한다.
  // provider 를 쓰면 단일 공급사 몰에서 모든 썸네일이 같은 글자가 된다.
  const slideTag = s => String(s.label || '').replace(/^\[|\]$/g, '').trim() || s.provider || slideTitle(s);
  const _slides = mainSlides || [];
%>
<style>
  .hero-thumbs .swiper-slide { opacity: .55; transition: opacity .2s; }
  .hero-thumbs .swiper-slide-thumb-active { opacity: 1; }
  .hero-thumbs .swiper-slide-thumb-active .hero-thumb-ring { border-color: var(--gh-primary); }
  .hero-main .swiper-slide { height: auto; }
</style>

<div class="hero-main swiper relative rounded-2xl overflow-hidden bg-[var(--gh-light)] border border-gray-100">
  <div class="swiper-wrapper">
    <% _slides.forEach(s => { %>
      <div class="swiper-slide">
        <div class="flex items-center gap-4 sm:gap-6 px-12 sm:px-16 py-6 sm:py-10 min-h-[300px] sm:min-h-[380px]">
          <div class="flex-1 min-w-0">
            <% if (s.label) { %>
              <span class="inline-block text-[var(--gh-primary)] font-bold text-xs sm:text-sm mb-2"><%= s.label %></span>
            <% } %>
            <a href="<%= slideHref(s) %>" class="block no-underline">
              <h2 class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900 leading-snug line-clamp-2 hover:text-[var(--gh-primary-dark)] transition-colors">
                <%= slideTitle(s) %>
              </h2>
            </a>
            <div class="mt-3 sm:mt-4 flex items-end gap-2 flex-wrap">
              <% if (s.discount_rate > 0) { %>
                <span class="text-xl sm:text-2xl font-extrabold text-[var(--gh-primary)]"><%= s.discount_rate %>%</span>
              <% } %>
              <span class="text-2xl sm:text-3xl font-extrabold text-gray-900"><%= won(s.price) %><span class="text-base sm:text-lg font-bold">원</span></span>
            </div>
            <% if (s.original_price && s.original_price > s.price) { %>
              <span class="text-gray-400 line-through text-xs sm:text-sm"><%= won(s.original_price) %>원</span>
            <% } %>
            <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] sm:text-xs text-gray-500">
              <span class="inline-flex items-center gap-1"><i class="bi bi-truck"></i> 무료배송</span>
              <span class="text-gray-300">·</span>
              <span class="inline-flex items-center gap-1"><i class="bi bi-credit-card"></i> 무이자</span>
            </div>
            <a href="<%= slideHref(s) %>"
               class="mt-5 sm:mt-6 inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--gh-primary)] text-white text-sm font-bold no-underline shadow-sm hover:bg-[var(--gh-primary-dark)] transition-colors">
              자세히 보기 <i class="bi bi-chevron-right text-xs"></i>
            </a>
          </div>
          <a href="<%= slideHref(s) %>" class="shrink-0 block">
            <div class="w-32 h-32 sm:w-52 sm:h-52 lg:w-64 lg:h-64 rounded-full overflow-hidden bg-white shadow-lg ring-4 ring-white">
              <img src="<%= slideImg(s) %>" alt="<%= slideTitle(s) %>" class="w-full h-full object-cover object-center">
            </div>
          </a>
        </div>
      </div>
    <% }); %>
  </div>
  <button type="button" class="hero-prev absolute left-2 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white/80 hover:bg-white shadow hidden sm:flex items-center justify-center text-gray-600">
    <i class="bi bi-chevron-left"></i>
  </button>
  <button type="button" class="hero-next absolute right-2 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white/80 hover:bg-white shadow hidden sm:flex items-center justify-center text-gray-600">
    <i class="bi bi-chevron-right"></i>
  </button>
</div>

<!-- 썸네일 캐러셀 (메인 연동) -->
<div class="hero-thumbs swiper mt-3">
  <div class="swiper-wrapper">
    <% _slides.forEach(s => { %>
      <div class="swiper-slide cursor-pointer">
        <div class="flex flex-col items-center gap-1 py-1">
          <div class="hero-thumb-ring w-14 h-14 sm:w-16 sm:h-16 rounded-full overflow-hidden border-2 border-transparent bg-white">
            <img src="<%= slideImg(s) %>" alt="<%= slideTitle(s) %>" class="w-full h-full object-cover">
          </div>
          <span class="text-[11px] text-gray-600 truncate max-w-[4.5rem] text-center"><%= slideTag(s) %></span>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<script>
// Swiper 번들은 페이지 하단에서 로드되므로, 로드 완료 후(DOMContentLoaded) 초기화한다.
(function () {
  function initHeroShowcase() {
    if (typeof Swiper === 'undefined') { return; }
    /*
     * 썸네일은 슬라이드 최대 수(7)를 한 화면에 다 보여준다.
     * 예전엔 데스크톱에서 5개만 보여, 7개를 등록해도 "5개만 등록됐다"로 오해하기 쉬웠다
     * (스크롤하면 나오지만 더 있다는 표시가 없었다).
     */
    var thumbs = new Swiper('.hero-thumbs', {
      slidesPerView: 4, spaceBetween: 8, watchSlidesProgress: true,
      breakpoints: { 640: { slidesPerView: 6 }, 1024: { slidesPerView: 7 } }
    });
    new Swiper('.hero-main', {
      loop: false,
      autoplay: { delay: 5000, disableOnInteraction: false },
      navigation: { nextEl: '.hero-next', prevEl: '.hero-prev' },
      thumbs: { swiper: thumbs }
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroShowcase);
  } else {
    initHeroShowcase();
  }
})();
</script>
