<%
  /*
   * 캐러셀 공용 에셋 (CT-1 / CT-2 공유)
   *
   * PC   : CSS scroll-snap 가로 스크롤 + 좌우 화살표.
   * 모바일: 자유 스크롤을 막고(overflow hidden) 터치 드래그를 JS 가 받아
   *         한 스와이프 = 한 페이지로 넘기는 슬라이드. 하단 도트 인디케이터 제공.
   * 외부 라이브러리 없음.
   *
   * 마크업 계약:
   *   [data-yd-carousel]           래퍼
   *     [data-yd-track]            트랙 (style="--yd-per-view: N")
   *     [data-yd-prev] [data-yd-next]  화살표 버튼
   *   도트는 스크립트가 트랙 뒤에 삽입한다.
   *
   * 여러 섹션이 include 하면 <style> 이 중복 출력되지만 동일 규칙이라 무해하고,
   * <script> 는 window.__ydCarouselInit 가드로 1회만 바인딩된다.
   */
%>
<style>
  .yd-carousel__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - 1.25rem) / 2);   /* 모바일 2열 */
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .yd-carousel__track::-webkit-scrollbar { display: none; }
  .yd-carousel__track > * { scroll-snap-align: start; }

  /* 모바일: 브라우저 관성 스크롤 대신 JS 슬라이드가 위치를 제어한다 */
  @media (max-width: 1023px) {
    .yd-carousel__track {
      overflow-x: hidden;
      scroll-snap-type: none;
      scroll-behavior: auto;
      touch-action: pan-y;
    }
    .yd-carousel__track.is-sliding { transition: none; }
  }

  @media (min-width: 1024px) {
    .yd-carousel__track {
      grid-auto-columns: calc((100% - (var(--yd-per-view) - 1) * 1.25rem) / var(--yd-per-view));
    }
  }
  .yd-carousel__nav {
    width: 40px; height: 40px; border-radius: 9999px;
    background: #fff; border: 1px solid var(--gh-border);
    box-shadow: 0 2px 10px rgba(0,0,0,.08);
    display: none; align-items: center; justify-content: center;
    color: #4b5563; transition: color .15s, border-color .15s;
  }
  .yd-carousel__nav:hover { color: var(--gh-primary); border-color: var(--gh-primary); }
  .yd-carousel__nav:disabled { opacity: .35; cursor: default; }
  @media (min-width: 1024px) { .yd-carousel__nav { display: inline-flex; } }

  .yd-carousel__dots { display: none; }
  @media (max-width: 1023px) {
    .yd-carousel__dots {
      display: flex; justify-content: center; align-items: center;
      gap: 6px; margin-top: 1rem;
    }
    .yd-carousel__dot {
      width: 6px; height: 6px; border-radius: 9999px;
      background: #d1d5db; border: 0; padding: 0;
      transition: width .2s ease, background-color .2s ease;
    }
    .yd-carousel__dot.is-active { width: 18px; background: var(--gh-primary); }
  }
</style>

<script>
/* 멀티 인스턴스 안전: 섹션이 여러 번 include 돼도 초기화는 1회만.
   DOM 준비 후 모든 [data-yd-carousel] 을 한 번에 바인딩한다. */
(function () {
  if (window.__ydCarouselInit) return;
  window.__ydCarouselInit = true;

  var MOBILE = '(max-width: 1023px)';

  function initAll() {
    document.querySelectorAll('[data-yd-carousel]').forEach(function (root) {
      var track = root.querySelector('[data-yd-track]');
      if (!track) return;
      var prev = root.querySelector('[data-yd-prev]');
      var next = root.querySelector('[data-yd-next]');

      var index = 0;

      function isMobile() { return window.matchMedia(MOBILE).matches; }

      /* 아이템 1개 폭 + gap. 레이아웃 전이면 0 이 나올 수 있으니 호출부에서 가드한다. */
      function step() {
        var first = track.firstElementChild;
        if (!first) return 0;
        var gap = parseFloat(getComputedStyle(track).columnGap || '0') || 0;
        return first.offsetWidth + gap;
      }

      function perView() {
        var s = step();
        if (!s) return 1;
        return Math.max(1, Math.round(track.clientWidth / s));
      }

      function pageCount() {
        return Math.max(1, Math.ceil(track.children.length / perView()));
      }

      function maxScroll() {
        return Math.max(0, track.scrollWidth - track.clientWidth);
      }

      function offsetOf(i) {
        return Math.min(i * step() * perView(), maxScroll());
      }

      function goTo(i, smooth) {
        index = Math.max(0, Math.min(i, pageCount() - 1));
        track.scrollTo({ left: offsetOf(index), behavior: smooth === false ? 'auto' : 'smooth' });
        sync();
      }

      /* 도트 — 모바일에서만 보이지만 DOM 은 항상 만들어 두고 페이지 수 변화에 맞춰 갱신 */
      var dots = document.createElement('div');
      dots.className = 'yd-carousel__dots';
      track.insertAdjacentElement('afterend', dots);

      var dotCount = -1;
      function renderDots() {
        var n = pageCount();
        if (n !== dotCount) {
          dotCount = n;
          dots.innerHTML = '';
          for (var i = 0; i < n; i++) {
            var b = document.createElement('button');
            b.type = 'button';
            b.className = 'yd-carousel__dot';
            b.setAttribute('aria-label', (i + 1) + '번째 페이지로 이동');
            b.dataset.page = String(i);
            dots.appendChild(b);
          }
        }
        Array.prototype.forEach.call(dots.children, function (b, i) {
          b.classList.toggle('is-active', i === index);
          b.setAttribute('aria-current', i === index ? 'true' : 'false');
        });
        dots.style.visibility = n > 1 ? '' : 'hidden';
      }

      dots.addEventListener('click', function (e) {
        var b = e.target.closest('.yd-carousel__dot');
        if (b) goTo(Number(b.dataset.page));
      });

      function sync() {
        if (prev) prev.disabled = track.scrollLeft <= 1;
        if (next) next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 1;
        renderDots();
      }

      /* PC 는 자유 스크롤도 허용하므로 실제 scrollLeft 에서 index 를 역산한다.
         모바일은 드래그 중에도 scrollLeft 가 계속 바뀌므로 역산하면 index 가 두 번
         밀린다(드래그로 1 + touchend 에서 1). 위치는 JS 가 정하니 역산하지 않는다. */
      function syncFromScroll() {
        if (!isMobile()) {
          var s = step() * perView();
          if (s > 0) index = Math.round(track.scrollLeft / s);
        }
        sync();
      }

      if (prev) prev.addEventListener('click', function () { goTo(index - 1); });
      if (next) next.addEventListener('click', function () { goTo(index + 1); });
      track.addEventListener('scroll', syncFromScroll, { passive: true });

      /* ── 모바일 터치 슬라이드 ── */
      var startX = 0, startY = 0, startLeft = 0, startTime = 0;
      var dragging = false, decided = false, horizontal = false;

      track.addEventListener('touchstart', function (e) {
        if (!isMobile() || e.touches.length !== 1) return;
        dragging = true; decided = false; horizontal = false;
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        startLeft = track.scrollLeft;
        startTime = e.timeStamp;
      }, { passive: true });

      track.addEventListener('touchmove', function (e) {
        if (!dragging) return;
        var dx = e.touches[0].clientX - startX;
        var dy = e.touches[0].clientY - startY;

        if (!decided) {
          if (Math.abs(dx) < 6 && Math.abs(dy) < 6) return;   // 아직 방향 판정 불가
          decided = true;
          horizontal = Math.abs(dx) > Math.abs(dy);
          if (!horizontal) { dragging = false; return; }      // 세로 스크롤은 브라우저에 양보
        }
        e.preventDefault();                                   // 가로 드래그는 우리가 처리
        track.scrollLeft = startLeft - dx;
      }, { passive: false });

      function endDrag(e) {
        if (!dragging || !horizontal) { dragging = false; return; }
        dragging = false;
        /* touchcancel 은 changedTouches 가 비어 있을 수 있다 */
        var touch = e.changedTouches && e.changedTouches.length ? e.changedTouches[0] : null;
        var dx = (touch ? touch.clientX : startX) - startX;
        var dt = Math.max(1, e.timeStamp - startTime);
        var flick = Math.abs(dx) / dt > 0.4;                  // 빠른 플릭은 짧게 밀어도 넘긴다
        var far = Math.abs(dx) > track.clientWidth * 0.2;
        if ((flick || far) && dx !== 0) goTo(index + (dx < 0 ? 1 : -1));
        else goTo(index);                                     // 임계 미달 → 원위치
      }

      track.addEventListener('touchend', endDrag, { passive: true });
      track.addEventListener('touchcancel', endDrag, { passive: true });

      window.addEventListener('resize', function () {
        dotCount = -1;                                        // 뷰당 개수가 바뀌면 페이지 수도 바뀐다
        goTo(index, false);
      });

      sync();
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initAll);
  else initAll();
})();
</script>
