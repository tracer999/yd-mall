<%
  /*
   * 히어로 슬라이드 미디어 한 칸 — 이미지 또는 비디오를 그린다.
   *
   * locals:
   *   media  : hero_slide 행(media_type · video_*_url · poster_url · autoplay …). 없으면 이미지로 그린다.
   *   img    : 이미지로 그릴 때 쓸 경로(호출부가 이미 폴백을 적용한 값)
   *   alt    : 대체 텍스트
   *   cls    : <img>/<video> 에 그대로 붙일 클래스
   *   mobile : 모바일 스와이퍼인가(기본 false)
   *   eager  : 첫 슬라이드인가 — LCP 대상이라 eager + fetchpriority=high (기본 false)
   *
   * 왜 media 가 없어도 되나:
   *   이 파트를 include 하는 hero_banner 는 전역 banners 테이블(영상 컬럼 없음)도 그린다.
   *   media 가 비면 img 경로 하나만 보고 그린다.
   *
   * 배너(media 없음)에 올린 영상:
   *   banners 에는 미디어 종류 컬럼이 없어 영상도 image_url/mobile_image_url 에 경로로 담긴다.
   *   그래서 img 가 영상 확장자면 <video> 로 그린다(isVideoUrl — shared/mediaType.js).
   *   hero_slide 의 영상 분기와 섞지 않는 이유: 그쪽은 poster 를 이미지 컬럼에서 가져오는데,
   *   배너는 그 이미지 자리가 곧 영상이라 poster 로 쓰면 깨진다.
   *
   * 모바일 폴백 순서 (migrate_hero_slide_media.sql 원칙 4 — 데이터·배터리):
   *   모바일 전용 영상 → 모바일 이미지 → 데스크톱 영상 → 이미지
   */
  var _m = (typeof media !== 'undefined' && media) ? media : null;
  var _isMobile = (typeof mobile !== 'undefined') ? !!mobile : false;
  var _cls = (typeof cls !== 'undefined' && cls) ? cls : '';
  var _alt = (typeof alt !== 'undefined' && alt) ? alt : '';
  var _eager = (typeof eager !== 'undefined') ? !!eager : false;

  var _hasDesktopVideo = !!(_m && _m.media_type === 'VIDEO' && (_m.video_webm_url || _m.video_mp4_url));
  var _hasMobileVideo = !!(_m && _m.media_type === 'VIDEO' && (_m.mobile_video_webm_url || _m.mobile_video_mp4_url));

  // 이 칸을 영상으로 그릴지, 그린다면 어떤 소스를 쓸지
  var _useVideo = false, _webm = null, _mp4 = null;
  if (_isMobile) {
    if (_hasMobileVideo) {
      _useVideo = true; _webm = _m.mobile_video_webm_url; _mp4 = _m.mobile_video_mp4_url;
    } else if (!(_m && _m.mobile_image_url) && _hasDesktopVideo) {
      _useVideo = true; _webm = _m.video_webm_url; _mp4 = _m.video_mp4_url;
    }
  } else if (_hasDesktopVideo) {
    _useVideo = true; _webm = _m.video_webm_url; _mp4 = _m.video_mp4_url;
  }

  /*
   * poster 는 영상과 **같은 비율**이어야 한다. 모바일은 세로 영상이므로 가로 poster_url 을 쓰면
   * 로드 직전 한 프레임이 어긋난다 → 모바일 이미지(보통 세로 포스터)를 먼저 쓴다.
   */
  var _poster = _isMobile
    ? ((_m && (_m.mobile_image_url || _m.poster_url || _m.image_url)) || img)
    : ((_m && (_m.poster_url || _m.image_url)) || img);

  // 이미지로 그릴 때 실제로 쓸 경로. 이 경로가 영상이면(배너에 영상을 올린 경우) <video> 로 낸다.
  var _imgSrc = (_isMobile && _m && _m.mobile_image_url) ? _m.mobile_image_url : img;
  var _srcIsVideo = !_useVideo && typeof isVideoUrl === 'function' && isVideoUrl(_imgSrc);
%>
<% if (_useVideo) { %>
  <%#
    playsinline 이 없으면 iOS 가 영상을 전체화면으로 띄워 배너가 아니라 플레이어가 된다.
    autoplay 는 muted 없이 브라우저가 막는다(검은 화면) — DB CHECK 로도 강제되지만 여기서도 함께 낸다.
  %>
  <video
    class="<%= _cls %>"
    <% if (_poster) { %>poster="<%= _poster %>"<% } %>
    <% if (_m.autoplay) { %>autoplay<% } %>
    <% if (_m.muted || _m.autoplay) { %>muted<% } %>
    <% if (_m.loop_play) { %>loop<% } %>
    playsinline
    preload="<%= _m.preload || 'metadata' %>"
    data-hero-video
    aria-label="<%= _alt %>">
    <%# 브라우저가 위에서부터 고른다 — 같은 화질이면 WebM 이 작다. %>
    <% if (_webm) { %><source src="<%= _webm %>" type="video/webm"><% } %>
    <% if (_mp4) { %><source src="<%= _mp4 %>" type="video/mp4"><% } %>
    <%# <video> 자체를 못 그리는 환경의 최후 폴백 %>
    <img src="<%= _poster || img %>" alt="<%= _alt %>" class="<%= _cls %>">
  </video>
<% } else if (_srcIsVideo) { %>
  <%#
    배너에 올린 영상. poster 로 쓸 이미지가 따로 없으므로(그 칸이 곧 영상이다) poster 는 생략한다.
    소리 없이 자동 반복 — 배너 자리라 재생 컨트롤을 두지 않는다(슬라이드 전체가 링크다).
    data-hero-video 는 '모션 최소화' 사용자에게 자동재생을 끄는 스크립트가 잡는 표식이다.
  %>
  <video class="<%= _cls %>" autoplay muted loop playsinline
         preload="metadata" data-hero-video aria-label="<%= _alt %>"
         src="<%= _imgSrc %>"></video>
<% } else { %>
  <%#
    히어로는 화면 최상단이라 lazy 를 걸지 않는다. 캐러셀의 2·3번째 슬라이드는 가로로 밀려 있을 뿐
    화면 안이라, lazy 를 걸면 넘겼을 때 아직 안 받아온 빈 칸이 보일 수 있다.
    첫 슬라이드만 LCP 대상이므로 우선순위를 높인다.
  %>
  <img src="<%= _imgSrc %>"
       alt="<%= _alt %>"
       class="<%= _cls %>"
       <% if (_eager) { %>fetchpriority="high"<% } %>>
<% } %>
