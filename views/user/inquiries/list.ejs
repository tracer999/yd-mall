<div class="py-8 bg-gray-50 min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-3xl font-extrabold text-gray-900">나의 문의 내역</h2>
            <a href="/inquiries/write" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                <i class="bi bi-pencil-square mr-2"></i>문의하기
            </a>
        </div>
        
        <div class="bg-white rounded-lg shadow overflow-hidden">
                <!-- Desktop View (Table) -->
                <div class="hidden md:block overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-16">번호</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">제목</th>
                                <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-32">상태</th>
                                <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-32">날짜</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% inquiries.forEach((inquiry, index) => { %>
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                                        <%= inquiries.length - index %>
                                    </td>
                                    <td class="px-6 py-4">
                                        <a href="/inquiries/<%= inquiry.id %>" class="text-sm font-medium text-gray-900 hover:text-blue-600 hover:underline">
                                            <%= inquiry.title %>
                                        </a>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                        <% if(inquiry.is_answered) { %>
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                답변완료
                                            </span>
                                        <% } else { %>
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                                답변대기
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                                        <%= inquiry.created_at.toISOString().split('T')[0] %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <!-- Mobile View (Cards) -->
                <div class="md:hidden space-y-4 p-4">
                    <% inquiries.forEach((inquiry, index) => { %>
                        <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm">
                            <div class="flex justify-between items-start mb-2">
                                <span class="text-xs text-gray-500">No. <%= inquiries.length - index %></span>
                                <span class="text-xs text-gray-400"><%= inquiry.created_at.toISOString().split('T')[0] %></span>
                            </div>
                            <h3 class="text-base font-bold text-gray-900 mb-2">
                                <a href="/inquiries/<%= inquiry.id %>" class="hover:text-blue-600">
                                    <%= inquiry.title %>
                                </a>
                            </h3>
                            <div class="flex items-center justify-between mt-3">
                                <% if(inquiry.is_answered) { %>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        답변완료
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                        답변대기
                                    </span>
                                <% } %>
                                <a href="/inquiries/<%= inquiry.id %>" class="text-sm text-blue-600 font-medium">상세보기 &rarr;</a>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <% if(inquiries.length === 0) { %>
                    <div class="p-12 text-center text-gray-500">
                        <div class="flex flex-col items-center justify-center">
                            <i class="bi bi-inbox text-4xl mb-3 text-gray-300"></i>
                            <p>문의 내역이 없습니다.</p>
                        </div>
                    </div>
                <% } %>
        </div>
    </div>
</div>
