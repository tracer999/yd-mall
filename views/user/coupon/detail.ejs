<%
  /*
   * 쿠폰 소개 상세 `/coupon/:id`
   * 버튼 상태·혜택 문구·그룹은 서버(couponController)가 판정한 값을 그대로 쓴다.
   */
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');
  const day = (v) => (v ? new Date(v).toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' }) : null);
  const c = coupon;
  const remaining = c.issue_limit != null ? Math.max(0, Number(c.issue_limit) - Number(c.issued_count)) : null;
  const targetNames = [].concat(targets.categories.map((t) => t.name), targets.brands.map((t) => t.name));
%>

<div class="max-w-2xl mx-auto px-4 sm:px-6 py-8">

  <a href="/coupon" class="inline-block mb-4 text-sm text-gray-500 hover:text-gray-700 no-underline">← 쿠폰 목록</a>

  <% if (message) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800"><%= message %></div>
  <% } %>
  <% if (error) { %>
    <div class="mb-5 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800"><%= error %></div>
  <% } %>

  <div class="border border-gray-200 rounded-2xl overflow-hidden bg-white">

    <!-- 히어로 이미지 -->
    <% if (c.thumbnail_url) { %>
      <div class="w-full aspect-[16/9] bg-gray-50">
        <img src="<%= c.thumbnail_url %>" alt="<%= c.name %>" class="w-full h-full object-cover">
      </div>
    <% } %>

    <div class="p-6">
      <p class="text-3xl font-extrabold text-gray-900"><%= c.benefit %></p>
      <h1 class="mt-2 text-lg font-bold text-gray-800"><%= c.name %></h1>
      <% if (c.summary) { %>
        <p class="mt-1 text-sm text-gray-500"><%= c.summary %></p>
      <% } %>

      <!-- 요약 정보 -->
      <dl class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-y-2 gap-x-4 text-sm">
        <div class="flex gap-2">
          <dt class="w-20 shrink-0 text-gray-400">최소주문</dt>
          <dd class="text-gray-700"><%= c.min_order_amount ? won(c.min_order_amount) + '원 이상' : '없음' %></dd>
        </div>
        <div class="flex gap-2">
          <dt class="w-20 shrink-0 text-gray-400">사용기간</dt>
          <dd class="text-gray-700">
            <% if (c.valid_days) { %>받은 날부터 <%= c.valid_days %>일<% } else if (day(c.valid_to)) { %>~ <%= day(c.valid_to) %><% } else { %>제한 없음<% } %>
          </dd>
        </div>
        <% if (targetNames.length) { %>
          <div class="flex gap-2 sm:col-span-2">
            <dt class="w-20 shrink-0 text-gray-400">적용대상</dt>
            <dd class="text-gray-700"><%= targetNames.join(', ') %></dd>
          </div>
        <% } %>
        <% if (remaining != null) { %>
          <div class="flex gap-2 sm:col-span-2">
            <dt class="w-20 shrink-0 text-gray-400">수량</dt>
            <dd class="text-gray-700">선착순 <%= won(c.issue_limit) %>명 · <%= won(remaining) %> 남음</dd>
          </div>
        <% } %>
      </dl>

      <!-- 액션 -->
      <div class="mt-6">
        <% if (c.buttonState === 'code_required') { %>
          <a href="/coupon#coupon-code" class="block w-full text-center py-3 rounded-xl bg-gray-100 text-gray-600 text-sm font-semibold no-underline hover:bg-gray-200">
            쿠폰 코드를 입력해 받으세요
          </a>
        <% } else if (c.buttonState === 'login') { %>
          <a href="/auth/login" class="block w-full text-center py-3 rounded-xl bg-[var(--gh-primary)] text-white text-sm font-semibold no-underline hover:bg-[var(--gh-primary-dark)]">
            로그인하고 받기
          </a>
        <% } else if (c.buttonState === 'available') { %>
          <form method="POST" action="/coupon/<%= c.id %>/claim">
            <input type="hidden" name="redirect" value="detail">
            <button type="submit" class="w-full py-3 rounded-xl bg-[var(--gh-primary)] text-white text-sm font-semibold hover:bg-[var(--gh-primary-dark)]">
              쿠폰 받기
            </button>
          </form>
        <% } else { %>
          <button type="button" disabled class="w-full py-3 rounded-xl bg-gray-100 text-gray-400 text-sm font-semibold cursor-not-allowed">
            <%= c.buttonState === 'claimed' ? '받은 쿠폰입니다' : (c.buttonState === 'sold_out' ? '선착순 마감' : '종료되었습니다') %>
          </button>
        <% } %>
      </div>
    </div>

    <!-- 상세 본문 -->
    <% if (c.detail_content) { %>
      <div class="px-6 py-6 border-t border-gray-100">
        <div class="prose prose-sm max-w-none text-gray-700"><%- c.detail_content %></div>
      </div>
    <% } %>

    <!-- 유의사항 -->
    <% if (c.notice) { %>
      <div class="px-6 py-5 border-t border-gray-100 bg-gray-50">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">유의사항</h3>
        <div class="prose prose-sm max-w-none text-xs text-gray-500"><%- c.notice %></div>
      </div>
    <% } %>
  </div>
</div>
