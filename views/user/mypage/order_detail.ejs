<%- include('./_shell_start') %>

    <% if (typeof claimMsg !== 'undefined' && claimMsg) { %>
        <div class="mb-4 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800"><%= claimMsg %></div>
    <% } %>
    <% if (typeof claimError !== 'undefined' && claimError) { %>
        <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800"><%= claimError %></div>
    <% } %>

    <%
      /*
       * 주문 단위 상태 띠.
       * 부분 취소·부분 반품은 주문이 살아 있어 상태 뱃지만 보면 "정상 주문"으로 읽힌다.
       * 결제 상태(PARTIAL_REFUNDED)를 근거로 한 줄 알려 준다.
       */
      const ORDER_STATUS_KO = { PENDING:'입금 대기', PAID:'결제 완료', PREPARING:'상품 준비중',
                                SHIPPED:'배송중', DELIVERED:'배송 완료', CANCELLED:'취소', REFUNDED:'환불 완료' };
      const isPartialRefunded = order.payment_status === 'PARTIAL_REFUNDED';
    %>
    <% if (isPartialRefunded) { %>
        <div class="mb-4 px-4 py-3 rounded-lg bg-amber-50 border border-amber-200 text-sm text-amber-900">
            <b>이 주문은 일부 상품이 취소·반품되었습니다.</b>
            아래 상품 목록에서 처리된 상품에 표시가 붙어 있으며, 나머지 상품은 그대로 배송됩니다.
        </div>
    <% } %>

    <div class="bg-white rounded-lg shadow border border-gray-100 mb-6">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex flex-wrap justify-between items-center gap-2">
            <div class="flex items-center gap-2">
                <h3 class="text-lg font-bold text-gray-800">주문 상세 정보</h3>
                <span class="px-2.5 py-1 text-xs font-semibold rounded-full
                    <%= order.status === 'PENDING' ? 'bg-yellow-100 text-yellow-800' :
                        order.status === 'PAID' ? 'bg-blue-100 text-blue-800' :
                        order.status === 'DELIVERED' ? 'bg-green-100 text-green-800' :
                        ['CANCELLED','REFUNDED'].includes(order.status) ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800' %>">
                    <%= ORDER_STATUS_KO[order.status] || order.status %>
                </span>
                <% if (isPartialRefunded) { %>
                    <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-amber-100 text-amber-800">부분 취소</span>
                <% } %>
            </div>
            <span class="text-sm text-gray-500">주문번호: <%= order.order_number || order.id %></span>
        </div>
        <div class="p-6">
            <div class="flex flex-col md:flex-row gap-6">
                <div class="flex-1">
                    <h4 class="font-semibold text-gray-700 mb-2">배송지 정보</h4>
                    <p class="text-gray-600">
                        <%= order.receiver_name %>
                    </p>
                    <p class="text-gray-600">
                        <%= order.receiver_phone %>
                    </p>
                    <p class="text-gray-600">(<%= order.receiver_zipcode %>) <%= order.receiver_address %>
                                <%= order.receiver_detailed_address %>
                    </p>
                    <% if (order.shipping_message) { %>
                        <p class="text-gray-500 text-sm mt-1">배송메모: <%= order.shipping_message %>
                        </p>
                        <% } %>
                </div>
                <div class="flex-1">
                    <h4 class="font-semibold text-gray-700 mb-2">결제 정보</h4>
                    <div class="flex justify-between mb-1">
                        <span class="text-gray-600">상품금액</span>
                        <span>
                            <%= Number(order.subtotal_amount).toLocaleString() %>원
                        </span>
                    </div>
                    <% if (order.coupon_discount> 0) { %>
                        <div class="flex justify-between mb-1 text-red-600">
                            <span>쿠폰 할인</span>
                            <span>-<%= Number(order.coupon_discount).toLocaleString() %>원</span>
                        </div>
                        <% } %>
                            <% if (order.point_used> 0) { %>
                                <div class="flex justify-between mb-1 text-red-600">
                                    <span>포인트 사용</span>
                                    <span>-<%= Number(order.point_used).toLocaleString() %>원</span>
                                </div>
                                <% } %>
                                    <div class="flex justify-between mb-1">
                                        <span class="text-gray-600">배송비</span>
                                        <span>
                                            <% if (Number(order.shipping_fee) > 0) { %>
                                                +<%= Number(order.shipping_fee).toLocaleString() %>원
                                            <% } else { %>
                                                무료
                                            <% } %>
                                        </span>
                                    </div>
                                    <% if (Number(order.shipping_discount) > 0) { %>
                                        <div class="flex justify-between mb-1 text-red-600">
                                            <span>배송비 할인</span>
                                            <span>-<%= Number(order.shipping_discount).toLocaleString() %>원</span>
                                        </div>
                                    <% } %>
                                    <div class="flex justify-between mt-2 pt-2 border-t font-bold text-lg">
                                        <span>총 결제금액</span>
                                        <span class="text-[var(--gh-primary)]">
                                            <%= Number(order.total_amount).toLocaleString() %>원
                                        </span>
                                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow border border-gray-100">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
            <h3 class="text-lg font-bold text-gray-800">주문 상품</h3>
        </div>
        <div class="divide-y divide-gray-100">
            <%
              /*
               * 상품별 처리 상태.
               * 주문이 통째로 취소된 경우(전건 클레임)는 상품 기록이 없으므로 주문 상태로 판정한다.
               * 부분 취소한 상품이 정상 주문처럼 보이면 고객이 "취소가 안 됐다"고 받아들인다.
               */
              const orderCancelled = ['CANCELLED', 'REFUNDED'].includes(order.status);
              const CLAIM_LABEL = { CANCEL: '취소', RETURN: '반품', EXCHANGE: '교환' };
            %>
            <% items.forEach(item=> {
                 const claimedQty = orderCancelled ? Number(item.quantity) : Number(item.claimed_qty || 0);
                 const claimType = item.claim_type || 'CANCEL';
                 const pending = !orderCancelled && item.claim_pending;
                 const fully = claimedQty >= Number(item.quantity) && claimedQty > 0;
                 const partly = claimedQty > 0 && !fully;
            %>
                <div class="p-6 flex gap-4 items-center <%= fully && !pending ? 'bg-gray-50' : '' %>">
                    <div class="w-20 h-20 bg-gray-100 rounded-md overflow-hidden flex-shrink-0 <%= fully && !pending ? 'opacity-50' : '' %>">
                        <% if (item.thumbnail_image) { %>
                            <img src="<%= item.thumbnail_image %>" alt="<%= item.product_name %>"
                                class="w-full h-full object-cover">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center text-gray-400 text-xs">No
                                    Image</div>
                                <% } %>
                    </div>
                    <div class="flex-1">
                        <h4 class="font-medium <%= fully && !pending ? 'text-gray-400 line-through' : 'text-gray-900' %>">
                            <% if (item.slug) { %>
                                <a href="/products/<%= item.slug %>" class="hover:text-[var(--gh-primary)]">
                                    <%= item.product_name %>
                                </a>
                                <% } else { %>
                                    <%= item.product_name %>
                                        <% } %>
                        </h4>
                        <% if (claimedQty > 0) { %>
                            <div class="mt-1">
                                <% if (pending) { %>
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 text-xs font-semibold">
                                        <%= CLAIM_LABEL[claimType] %> 신청 중<%= partly ? ' (' + claimedQty + '개)' : '' %>
                                    </span>
                                    <span class="ml-1 text-xs text-gray-500">담당자 확인 후 처리됩니다</span>
                                <% } else { %>
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-red-100 text-red-700 text-xs font-semibold">
                                        <%= CLAIM_LABEL[claimType] %><%= claimType === 'EXCHANGE' ? ' 처리' : '됨' %><%= partly ? ' (' + claimedQty + '개)' : '' %>
                                    </span>
                                <% } %>
                            </div>
                        <% } %>
                        <div class="text-sm text-gray-500 mt-1">
                            <%= Number(item.product_price).toLocaleString() %>원 / <%= item.quantity %>개
                            <% if (partly) { %>
                                <span class="text-gray-400">· 남은 수량 <%= item.remaining_qty %>개</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="font-bold <%= fully && !pending ? 'text-gray-400 line-through' : 'text-gray-900' %>">
                            <%= Number(item.total_price).toLocaleString() %>원
                        </div>
                        <% if (order.status==='DELIVERED' && item.slug && !fully) { %>
                            <a href="/products/<%= item.slug %>#review"
                                class="inline-block mt-2 px-3 py-1 border border-gray-300 rounded text-xs text-gray-600 hover:bg-gray-50 transition">리뷰
                                작성</a>
                            <% } %>
                    </div>
                </div>
                <% }) %>
        </div>
    </div>

    <%
      /*
       * 적립 안내 — 버튼을 누르기 **전에** 얼마를 받는지 알려 준다.
       * 금액이 없으면 고객은 [구매확정] 을 눌러야 할 이유를 모른다(적립은 확정 시점에 나간다).
       * 배송완료 이후에만 뜬다.
       */
      const rw = (typeof reward !== 'undefined' && reward) ? reward : null;
      const showReward = rw && order.status === 'DELIVERED'
                         && (rw.confirm > 0 || rw.alreadyConfirmed > 0 || (rw.reviewCount > 0 && rw.reviewText > 0));
      const wonR = (n) => Number(n || 0).toLocaleString('ko-KR');
    %>
    <% if (showReward) { %>
        <div class="mt-6 rounded-xl border border-[var(--gh-primary)]/30 bg-[var(--gh-primary)]/5 px-5 py-4">
            <p class="text-sm font-bold text-gray-900 mb-2">
                <i class="bi bi-coin text-[var(--gh-primary)] mr-1"></i>
                <% if (rw.confirm > 0) { %>
                    이 주문으로 <span class="text-[var(--gh-primary)]"><%= wonR(rw.confirm + (rw.reviewCount > 0 ? rw.reviewPhoto * rw.reviewCount : 0)) %>P</span> 까지 받으실 수 있습니다
                <% } else if (rw.reviewCount > 0 && rw.reviewPhoto > 0) { %>
                    리뷰를 쓰면 <span class="text-[var(--gh-primary)]"><%= wonR(rw.reviewPhoto * rw.reviewCount) %>P</span> 까지 받으실 수 있습니다
                <% } else { %>
                    적립 안내
                <% } %>
            </p>
            <ul class="space-y-1.5 text-sm text-gray-700">
                <% if (rw.confirm > 0) { %>
                    <li class="flex items-start gap-2">
                        <span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-[var(--gh-primary)] text-white text-[11px] font-bold">1</span>
                        <span>
                            <b>구매확정</b>을 누르면 <b class="text-[var(--gh-primary)]"><%= wonR(rw.confirm) %>P</b> 가 바로 적립됩니다.
                            <span class="block text-xs text-gray-500 mt-0.5">확정 후에는 반품·교환을 신청할 수 없으니 상품을 확인한 뒤 눌러 주세요.</span>
                        </span>
                    </li>
                <% } else if (rw.alreadyConfirmed > 0) { %>
                    <li class="flex items-start gap-2">
                        <span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-gray-300 text-white text-[11px] font-bold"><i class="bi bi-check"></i></span>
                        <span>구매확정으로 <b><%= wonR(rw.alreadyConfirmed) %>P</b> 를 적립해 드렸습니다.</span>
                    </li>
                <% } %>
                <% if (rw.reviewCount > 0 && (rw.reviewText > 0 || rw.reviewPhoto > 0)) { %>
                    <li class="flex items-start gap-2">
                        <span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-[var(--gh-primary)] text-white text-[11px] font-bold"><%= rw.confirm > 0 ? '2' : '1' %></span>
                        <span>
                            <b>리뷰</b>를 쓰면 상품 1개당
                            <b class="text-[var(--gh-primary)]"><%= wonR(rw.reviewText) %>P</b><% if (rw.reviewPhoto > rw.reviewText) { %>,
                            <b class="text-[var(--gh-primary)]">사진을 올리면 <%= wonR(rw.reviewPhoto) %>P</b><% } %> 를 드립니다.
                            <span class="block text-xs text-gray-500 mt-0.5">
                                지금 <b><%= rw.reviewCount %>개</b> 상품에 쓸 수 있습니다
                                <% if (rw.reviewPhoto > 0) { %>(최대 <%= wonR(rw.reviewPhoto * rw.reviewCount) %>P)<% } %> ·
                                <a href="/mypage/reviews" class="underline">리뷰 쓰러 가기</a>
                            </span>
                        </span>
                    </li>
                <% } %>
            </ul>
        </div>
    <% } %>

    <div class="mt-6 text-center">
        <a href="/mypage/orders"
            class="inline-block px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">목록으로
            돌아가기</a>
        <% if (shipment && shipment.tracking_number) { %>
            <button type="button"
                onclick="trackShipment('<%= shipment.courier_company %>', '<%= shipment.tracking_number %>')"
                class="inline-block px-6 py-2 ml-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">배송
                조회</button>
            <% } %>
                <%
                  // 취소(출고 전) vs 반품(출고 후). claim_status 가 진행 중이면 버튼을 감춘다.
                  const canCancel = ['PENDING', 'PAID', 'PREPARING'].includes(order.status) && order.claim_status === 'NONE';
                  // 구매확정한 주문은 반품·교환을 받지 않는다(claimService 와 같은 규칙).
                  const canReturn = ['SHIPPED', 'DELIVERED'].includes(order.status)
                                    && order.claim_status === 'NONE' && !order.confirmed_at;
                  const isReturn = canReturn;
                %>
                <%
                  /* 구매확정 — 배송완료 뒤에만, 아직 확정하지 않았고 처리 중인 신청도 없을 때. */
                  const canConfirm = order.status === 'DELIVERED' && !order.confirmed_at
                                     && order.claim_status !== 'REQUESTED';
                %>
                <% if (canConfirm) { %>
                    <%
                      // 버튼에도 금액을 적는다 — 안내를 못 보고 지나쳐도 여기서 알 수 있다.
                      const confirmPoint = (typeof reward !== 'undefined' && reward) ? reward.confirm : 0;
                      const confirmMsg = confirmPoint > 0
                        ? `구매를 확정할까요?\\n\\n${Number(confirmPoint).toLocaleString()}P 가 적립됩니다.\\n확정 후에는 반품·교환을 신청할 수 없습니다.`
                        : '구매를 확정할까요?\\n\\n확정 후에는 반품·교환을 신청할 수 없습니다.';
                    %>
                    <form action="/mypage/orders/<%= order.id %>/confirm" method="POST" class="inline"
                          onsubmit="return confirm('<%= confirmMsg %>');">
                        <button type="submit"
                            class="inline-block px-6 py-2 ml-2 rounded-lg bg-[var(--gh-primary)] text-white font-medium hover:opacity-90 transition">
                            구매확정<% if (confirmPoint > 0) { %> <span class="font-bold">+<%= Number(confirmPoint).toLocaleString() %>P</span><% } %>
                        </button>
                    </form>
                <% } %>
                <% if (order.confirmed_at) { %>
                    <span class="inline-block px-6 py-2 ml-2 border border-green-200 bg-green-50 rounded-lg text-green-700">
                        <i class="bi bi-check-circle"></i> 구매확정 완료
                    </span>
                <% } %>
                <% if (canCancel || canReturn) { %>
                    <%
                      /* 팝업 대신 전용 화면으로 보낸다 — 신청은 상품을 보며 고르는 일이라
                         좁은 모달보다 한 화면에서 다루는 편이 낫다. */
                    %>
                    <a href="/mypage/orders/<%= order.id %>/claim"
                        class="inline-block px-6 py-2 ml-2 border border-red-300 bg-red-50 rounded-lg text-red-700 hover:bg-red-100 transition no-underline">
                        <%= isReturn ? '반품 · 교환 신청' : '주문 취소' %></a>
                <% } else if (order.claim_status && order.claim_status !== 'NONE') { %>
                    <span class="inline-block px-6 py-2 ml-2 border border-gray-200 bg-gray-50 rounded-lg text-gray-500">
                        <%= { REQUESTED:'취소·반품 처리 중', APPROVED:'승인됨', COMPLETED:'처리 완료', REJECTED:'반려됨' }[order.claim_status] || '' %>
                    </span>
                <% } %>
    </div>

    <script>
        function trackShipment(courier, trackingNumber) {
            let url = '';
            // 택배사 이름은 DB에 저장된 값과 정확히 일치해야 합니다.
            switch (courier) {
                case 'CJ대한통운':
                    url = `https://www.doortodoor.co.kr/parcel/doortodoor.do?fsp_action=PARC_ACT_002&fsp_cmd=retrieveInvNoact&invc_no=${trackingNumber}`;
                    break;
                case '우체국택배':
                    url = `https://service.epost.go.kr/trace.RetrieveDomRmgTrace.comm?sid1=${trackingNumber}`;
                    break;
                case '한진택배':
                    url = `https://www.hanjin.co.kr/kor/gbl/Hanjin_Gbl_MS.asp?w_num=${trackingNumber}`;
                    break;
                case '롯데택배':
                    url = `https://www.lotteglogis.com/home/reservation/tracking/linkView?InvNo=${trackingNumber}`;
                    break;
                case '로젠택배':
                    url = `https://www.ilogen.com/web/personal/trace/${trackingNumber}`;
                    break;
                default:
                    alert(`지원하지 않는 택배사(${courier})입니다. 송장번호: ${trackingNumber}`);
                    return;
            }
            if (url) {
                window.open(url, 'trackingPopup', 'width=800,height=700,scrollbars=yes');
            }
        }
    </script>
        </div>
        <%- include('./_shell_end') %>