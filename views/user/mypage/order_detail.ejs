<%- include('./_shell_start') %>

    <% if (typeof claimMsg !== 'undefined' && claimMsg) { %>
        <div class="mb-4 px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-sm text-green-800"><%= claimMsg %></div>
    <% } %>
    <% if (typeof claimError !== 'undefined' && claimError) { %>
        <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800"><%= claimError %></div>
    <% } %>

    <div class="bg-white rounded-lg shadow border border-gray-100 mb-6">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
            <h3 class="text-lg font-bold text-gray-800">주문 상세 정보</h3>
            <span class="text-sm text-gray-500">주문번호: <%= order.order_number || order.id %></span>
        </div>
        <div class="p-6">
            <div class="flex flex-col md:flex-row gap-6">
                <div class="flex-1">
                    <h4 class="font-semibold text-gray-700 mb-2">배송지 정보</h4>
                    <p class="text-gray-600">
                        <%= order.receiver_name %>
                    </p>
                    <p class="text-gray-600">
                        <%= order.receiver_phone %>
                    </p>
                    <p class="text-gray-600">(<%= order.receiver_zipcode %>) <%= order.receiver_address %>
                                <%= order.receiver_detailed_address %>
                    </p>
                    <% if (order.shipping_message) { %>
                        <p class="text-gray-500 text-sm mt-1">배송메모: <%= order.shipping_message %>
                        </p>
                        <% } %>
                </div>
                <div class="flex-1">
                    <h4 class="font-semibold text-gray-700 mb-2">결제 정보</h4>
                    <div class="flex justify-between mb-1">
                        <span class="text-gray-600">상품금액</span>
                        <span>
                            <%= Number(order.subtotal_amount).toLocaleString() %>원
                        </span>
                    </div>
                    <% if (order.coupon_discount> 0) { %>
                        <div class="flex justify-between mb-1 text-red-600">
                            <span>쿠폰 할인</span>
                            <span>-<%= Number(order.coupon_discount).toLocaleString() %>원</span>
                        </div>
                        <% } %>
                            <% if (order.point_used> 0) { %>
                                <div class="flex justify-between mb-1 text-red-600">
                                    <span>포인트 사용</span>
                                    <span>-<%= Number(order.point_used).toLocaleString() %>원</span>
                                </div>
                                <% } %>
                                    <div class="flex justify-between mb-1">
                                        <span class="text-gray-600">배송비</span>
                                        <span>
                                            <% if (Number(order.shipping_fee) > 0) { %>
                                                +<%= Number(order.shipping_fee).toLocaleString() %>원
                                            <% } else { %>
                                                무료
                                            <% } %>
                                        </span>
                                    </div>
                                    <% if (Number(order.shipping_discount) > 0) { %>
                                        <div class="flex justify-between mb-1 text-red-600">
                                            <span>배송비 할인</span>
                                            <span>-<%= Number(order.shipping_discount).toLocaleString() %>원</span>
                                        </div>
                                    <% } %>
                                    <div class="flex justify-between mt-2 pt-2 border-t font-bold text-lg">
                                        <span>총 결제금액</span>
                                        <span class="text-[var(--gh-primary)]">
                                            <%= Number(order.total_amount).toLocaleString() %>원
                                        </span>
                                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow border border-gray-100">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
            <h3 class="text-lg font-bold text-gray-800">주문 상품</h3>
        </div>
        <div class="divide-y divide-gray-100">
            <% items.forEach(item=> { %>
                <div class="p-6 flex gap-4 items-center">
                    <div class="w-20 h-20 bg-gray-100 rounded-md overflow-hidden flex-shrink-0">
                        <% if (item.thumbnail_image) { %>
                            <img src="<%= item.thumbnail_image %>" alt="<%= item.product_name %>"
                                class="w-full h-full object-cover">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center text-gray-400 text-xs">No
                                    Image</div>
                                <% } %>
                    </div>
                    <div class="flex-1">
                        <h4 class="font-medium text-gray-900">
                            <% if (item.slug) { %>
                                <a href="/products/<%= item.slug %>" class="hover:text-[var(--gh-primary)]">
                                    <%= item.product_name %>
                                </a>
                                <% } else { %>
                                    <%= item.product_name %>
                                        <% } %>
                        </h4>
                        <div class="text-sm text-gray-500 mt-1">
                            <%= Number(item.product_price).toLocaleString() %>원 / <%= item.quantity %>개
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="font-bold text-gray-900">
                            <%= Number(item.total_price).toLocaleString() %>원
                        </div>
                        <% if (order.status==='DELIVERED' && item.slug) { %>
                            <a href="/products/<%= item.slug %>#review"
                                class="inline-block mt-2 px-3 py-1 border border-gray-300 rounded text-xs text-gray-600 hover:bg-gray-50 transition">리뷰
                                작성</a>
                            <% } %>
                    </div>
                </div>
                <% }) %>
        </div>
    </div>

    <div class="mt-6 text-center">
        <a href="/mypage/orders"
            class="inline-block px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">목록으로
            돌아가기</a>
        <% if (shipment && shipment.tracking_number) { %>
            <button type="button"
                onclick="trackShipment('<%= shipment.courier_company %>', '<%= shipment.tracking_number %>')"
                class="inline-block px-6 py-2 ml-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">배송
                조회</button>
            <% } %>
                <%
                  // 취소(출고 전) vs 반품(출고 후). claim_status 가 진행 중이면 버튼을 감춘다.
                  const canCancel = ['PENDING', 'PAID', 'PREPARING'].includes(order.status) && order.claim_status === 'NONE';
                  const canReturn = ['SHIPPED', 'DELIVERED'].includes(order.status) && order.claim_status === 'NONE';
                  const isReturn = canReturn;
                %>
                <% if (canCancel || canReturn) { %>
                    <button type="button" onclick="openCancelModal()"
                        class="inline-block px-6 py-2 ml-2 border border-red-300 bg-red-50 rounded-lg text-red-700 hover:bg-red-100 transition">
                        <%= isReturn ? '반품 · 교환 신청' : '주문 취소' %></button>

                    <div id="cancelModal"
                        class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50"
                        style="display: none;">
                        <div class="relative top-10 mx-auto p-5 border w-[26rem] max-w-[95vw] shadow-lg rounded-md bg-white">
                            <div class="mt-3 text-center">
                                <h3 class="text-lg leading-6 font-medium text-gray-900"><%= isReturn ? '반품 · 교환 신청' : '주문 취소' %></h3>
                                <% if (isReturn) { %>
                                    <p class="mt-1 text-xs text-gray-500">단순 변심은 왕복 배송비가 부과됩니다. 불량·오배송은 무료입니다.</p>
                                <% } %>
                                <div class="mt-2 px-2 py-3">
                                    <form id="cancelForm" action="/mypage/orders/<%= order.id %>/cancel" method="POST">
                                        <input type="hidden" name="reasonType" id="reasonType" value="CHANGE_OF_MIND">

                                        <% if (isReturn) { %>
                                            <div class="mb-4 text-left">
                                                <label class="block text-gray-700 text-sm font-bold mb-2">신청 종류</label>
                                                <div class="flex gap-2">
                                                    <label class="flex-1 flex items-center gap-2 border rounded px-3 py-2 cursor-pointer text-sm has-[:checked]:border-red-400 has-[:checked]:bg-red-50">
                                                        <input type="radio" name="claim_type" value="RETURN" checked> 반품 <span class="text-xs text-gray-400">(환불)</span>
                                                    </label>
                                                    <label class="flex-1 flex items-center gap-2 border rounded px-3 py-2 cursor-pointer text-sm has-[:checked]:border-blue-400 has-[:checked]:bg-blue-50">
                                                        <input type="radio" name="claim_type" value="EXCHANGE"> 교환 <span class="text-xs text-gray-400">(재발송)</span>
                                                    </label>
                                                </div>
                                                <p class="mt-1 text-xs text-gray-400">교환은 같은 상품을 다시 보내 드리며 환불은 없습니다.</p>
                                            </div>
                                        <% } %>

                                        <%
                                          // 신청 가능한 수량이 남은 품목만 고르게 한다.
                                          const pickable = items.filter((it) => Number(it.remaining_qty) > 0);
                                        %>
                                        <% if (pickable.length) { %>
                                            <div class="mb-4 text-left">
                                                <label class="block text-gray-700 text-sm font-bold mb-2">신청할 상품</label>
                                                <div class="space-y-1.5 max-h-52 overflow-y-auto border rounded p-2">
                                                    <% pickable.forEach(function (it) { %>
                                                        <div class="flex items-center gap-2 text-sm">
                                                            <span class="flex-1 truncate text-gray-700" title="<%= it.product_name %>">
                                                                <%= it.product_name %>
                                                                <% if (it.option_snapshot) { %><span class="text-gray-400 text-xs">[<%= it.option_snapshot %>]</span><% } %>
                                                            </span>
                                                            <select name="item_qty[<%= it.id %>]" class="border rounded py-1 px-2 text-sm w-20">
                                                                <% for (let q = 0; q <= Number(it.remaining_qty); q++) { %>
                                                                    <option value="<%= q %>" <%= q === Number(it.remaining_qty) ? 'selected' : '' %>><%= q %>개</option>
                                                                <% } %>
                                                            </select>
                                                        </div>
                                                    <% }); %>
                                                </div>
                                                <p class="mt-1 text-xs text-gray-400">
                                                    일부만 신청할 수 있습니다. 수량을 <b>0</b>으로 두면 그 상품은 제외됩니다.
                                                    <% if (isReturn) { %>배송비는 남은 상품이 있는 동안에는 환불되지 않습니다.<% } %>
                                                </p>
                                            </div>
                                        <% } %>
                                        <div class="mb-4 text-left">
                                            <label class="block text-gray-700 text-sm font-bold mb-2" for="cancelReasonSelect"><%= isReturn ? '반품' : '취소' %> 사유</label>
                                            <select id="cancelReasonSelect"
                                                class="shadow border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none"
                                                onchange="onReasonChange(this)">
                                                <% if (isReturn) { %>
                                                    <option value="CHANGE_OF_MIND|단순변심">단순 변심</option>
                                                    <option value="DEFECT|상품 불량">상품 불량</option>
                                                    <option value="WRONG_DELIVERY|오배송">오배송</option>
                                                    <option value="OTHER|기타">기타 (직접입력)</option>
                                                <% } else { %>
                                                    <option value="CHANGE_OF_MIND|단순변심">단순변심</option>
                                                    <option value="CHANGE_OF_MIND|주문실수">주문실수</option>
                                                    <option value="OTHER|배송지연">배송지연</option>
                                                    <option value="OTHER|기타">기타 (직접입력)</option>
                                                <% } %>
                                            </select>
                                        </div>
                                        <div id="etcReasonContainer" class="mb-4 text-left hidden">
                                            <label class="block text-gray-700 text-sm font-bold mb-2" for="cancelReasonDetail">상세 사유</label>
                                            <textarea id="cancelReasonDetail"
                                                class="shadow border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none"
                                                placeholder="사유를 입력해주세요."></textarea>
                                        </div>
                                        <input type="hidden" name="reason" id="finalReason">
                                        <div class="flex gap-2 justify-center mt-4">
                                            <button type="button" onclick="closeCancelModal()"
                                                class="px-4 py-2 bg-gray-200 text-gray-800 text-base font-medium rounded-md hover:bg-gray-300">닫기</button>
                                            <button type="button" onclick="submitCancel()"
                                                class="px-4 py-2 bg-red-600 text-white text-base font-medium rounded-md hover:bg-red-700"><%= isReturn ? '신청하기' : '취소 확정' %></button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } else if (order.claim_status && order.claim_status !== 'NONE') { %>
                    <span class="inline-block px-6 py-2 ml-2 border border-gray-200 bg-gray-50 rounded-lg text-gray-500">
                        <%= { REQUESTED:'취소·반품 처리 중', APPROVED:'승인됨', COMPLETED:'처리 완료', REJECTED:'반려됨' }[order.claim_status] || '' %>
                    </span>
                <% } %>
    </div>

    <script>
        function openCancelModal() {
            document.getElementById('cancelModal').style.display = 'block';
        }

        function closeCancelModal() {
            document.getElementById('cancelModal').style.display = 'none';
        }

        // 옵션 값은 "REASON_TYPE|표시라벨" 형식이다. 유형은 서버가 귀책 판정에 쓴다.
        function onReasonChange(select) {
            const [type, label] = select.value.split('|');
            document.getElementById('reasonType').value = type;
            document.getElementById('etcReasonContainer').classList.toggle('hidden', type !== 'OTHER');
        }

        function submitCancel() {
            const select = document.getElementById('cancelReasonSelect');
            const detail = document.getElementById('cancelReasonDetail');
            const finalInput = document.getElementById('finalReason');
            if (!select.value) { alert('사유를 선택해주세요.'); return; }

            const [type, label] = select.value.split('|');
            let reason = label;
            if (type === 'OTHER') {
                if (!detail.value.trim()) { alert('상세 사유를 입력해주세요.'); return; }
                reason = detail.value.trim();
            }
            document.getElementById('reasonType').value = type;
            finalInput.value = reason;

            // 상품 수량을 전부 0으로 두고 보내면 아무것도 신청되지 않는다. 보내기 전에 막는다.
            const qtySelects = document.querySelectorAll('#cancelForm select[name^="item_qty"]');
            if (qtySelects.length) {
                const total = Array.from(qtySelects).reduce((s, el) => s + Number(el.value || 0), 0);
                if (total === 0) { alert('신청할 상품의 수량을 1개 이상 선택해주세요.'); return; }
            }
            document.getElementById('cancelForm').submit();
        }

        function trackShipment(courier, trackingNumber) {
            let url = '';
            // 택배사 이름은 DB에 저장된 값과 정확히 일치해야 합니다.
            switch (courier) {
                case 'CJ대한통운':
                    url = `https://www.doortodoor.co.kr/parcel/doortodoor.do?fsp_action=PARC_ACT_002&fsp_cmd=retrieveInvNoact&invc_no=${trackingNumber}`;
                    break;
                case '우체국택배':
                    url = `https://service.epost.go.kr/trace.RetrieveDomRmgTrace.comm?sid1=${trackingNumber}`;
                    break;
                case '한진택배':
                    url = `https://www.hanjin.co.kr/kor/gbl/Hanjin_Gbl_MS.asp?w_num=${trackingNumber}`;
                    break;
                case '롯데택배':
                    url = `https://www.lotteglogis.com/home/reservation/tracking/linkView?InvNo=${trackingNumber}`;
                    break;
                case '로젠택배':
                    url = `https://www.ilogen.com/web/personal/trace/${trackingNumber}`;
                    break;
                default:
                    alert(`지원하지 않는 택배사(${courier})입니다. 송장번호: ${trackingNumber}`);
                    return;
            }
            if (url) {
                window.open(url, 'trackingPopup', 'width=800,height=700,scrollbars=yes');
            }
        }
    </script>
        </div>
        <%- include('./_shell_end') %>