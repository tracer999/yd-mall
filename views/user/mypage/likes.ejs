<%- include('./_shell_start') %>

<%#
  찜 = 상품 + 브랜드. 우측레일 바로가기에서 [찜한 브랜드] 버튼이 빠지고 그 자리에 [주문내역]이
  들어가면서, 브랜드 찜의 진입점이 이 화면의 탭 하나만 남았다.
  두 목록을 모두 서버에서 렌더하고 탭은 CSS 로만 가른다 — 개수가 많지 않고(찜 목록),
  전환할 때마다 왕복하면 스크롤 위치가 튄다.
%>
<div class="bg-white rounded-lg shadow border border-gray-100">
    <div class="border-b border-gray-100 bg-gray-50 px-2 sm:px-4">
        <nav class="flex gap-1" aria-label="찜 목록 종류">
            <button type="button" data-like-tab="product" aria-selected="<%= tab === 'product' %>"
                class="yd-like-tab px-4 py-3 text-sm font-bold border-b-2 transition">
                관심 상품 <span class="text-xs font-semibold"><%= likedProducts.length %></span>
            </button>
            <button type="button" data-like-tab="brand" aria-selected="<%= tab === 'brand' %>"
                class="yd-like-tab px-4 py-3 text-sm font-bold border-b-2 transition">
                찜한 브랜드 <span class="text-xs font-semibold"><%= likedBrands.length %></span>
            </button>
        </nav>
    </div>

    <!-- ── 관심 상품 ─────────────────────────────────────────────── -->
    <section data-like-panel="product" <%= tab === 'product' ? '' : 'hidden' %>>
        <% if (likedProducts.length === 0) { %>
            <div class="p-12 text-center text-gray-500">
                <div class="text-4xl mb-4"><i class="bi bi-heart"></i></div>
                <p class="mb-1 font-medium">관심 상품이 없습니다.</p>
                <p class="text-sm text-gray-400 mb-4">마음에 드는 상품의 하트를 눌러보세요.</p>
                <a href="/products"
                    class="inline-flex items-center gap-2 gh-btn-primary px-5 py-2.5 rounded-lg text-sm font-semibold transition">
                    상품 보러가기
                </a>
            </div>
        <% } else { %>
            <div class="p-4 sm:p-6">
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
                    <% likedProducts.forEach(product => { %>
                        <div class="relative group product-card">
                            <%- include('../../partials/product_card', { product }) %>
                            <button type="button" title="찜 해제"
                                class="unlike-btn absolute top-2 right-2 z-30 w-8 h-8 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center text-red-500 hover:text-red-600 hover:bg-white shadow-sm transition"
                                data-product-id="<%= product.id %>">
                                <i class="bi bi-heart-fill text-sm"></i>
                            </button>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>
    </section>

    <!-- ── 찜한 브랜드 ───────────────────────────────────────────── -->
    <section data-like-panel="brand" <%= tab === 'brand' ? '' : 'hidden' %>>
        <% if (likedBrands.length === 0) { %>
            <div class="p-12 text-center text-gray-500">
                <div class="text-4xl mb-4"><i class="bi bi-bookmark-heart"></i></div>
                <p class="mb-1 font-medium">찜한 브랜드가 없습니다.</p>
                <p class="text-sm text-gray-400 mb-4">관심 있는 브랜드의 하트를 눌러보세요.</p>
                <a href="/brands"
                    class="inline-flex items-center gap-2 gh-btn-primary px-5 py-2.5 rounded-lg text-sm font-semibold transition">
                    브랜드 보러가기
                </a>
            </div>
        <% } else { %>
            <div class="p-4 sm:p-6">
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
                    <% likedBrands.forEach(brand => { %>
                        <div class="relative group brand-card border border-gray-100 rounded-lg overflow-hidden hover:shadow-md transition-shadow bg-white">
                            <a href="/products/brand/<%= brand.id %>" class="block p-4">
                                <div class="h-24 flex items-center justify-center mb-3">
                                    <% if (brand.logo_image_path) { %>
                                        <img src="<%= brand.logo_image_path %>" alt="<%= brand.name %>"
                                            class="max-h-full max-w-full object-contain">
                                    <% } else { %>
                                        <span class="text-lg font-bold text-gray-700"><%= brand.name %></span>
                                    <% } %>
                                </div>
                                <p class="text-sm font-semibold text-gray-800 text-center truncate"><%= brand.name %></p>
                                <p class="mt-0.5 text-xs text-gray-400 text-center">상품 <%= brand.product_count %>개</p>
                            </a>
                            <button type="button" title="찜 해제"
                                class="unlike-brand-btn absolute top-2 right-2 z-30 w-8 h-8 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center text-red-500 hover:text-red-600 hover:bg-white shadow-sm transition"
                                data-brand-id="<%= brand.id %>">
                                <i class="bi bi-heart-fill text-sm"></i>
                            </button>
                        </div>
                    <% }); %>
                </div>
            </div>
        <% } %>
    </section>
</div>

<style>
    /* 탭 상태는 aria-selected 하나로 표현한다(클래스 토글 두 벌을 두지 않는다). */
    .yd-like-tab { border-color: transparent; color: #6b7280; }
    .yd-like-tab[aria-selected="true"] { border-color: var(--gh-primary); color: var(--gh-primary); }
    .yd-like-tab span { color: #9ca3af; }
    .yd-like-tab[aria-selected="true"] span { color: var(--gh-primary); }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    /* ── 탭 전환 ─────────────────────────────────────────────────
       주소도 같이 바꾼다(replaceState) — 새로고침·뒤로가기가 보던 탭을 유지해야 한다. */
    const tabs = document.querySelectorAll('[data-like-tab]');
    const panels = document.querySelectorAll('[data-like-panel]');
    tabs.forEach(btn => {
        btn.addEventListener('click', () => {
            const key = btn.dataset.likeTab;
            tabs.forEach(t => t.setAttribute('aria-selected', String(t === btn)));
            panels.forEach(p => p.hidden = p.dataset.likePanel !== key);
            const url = new URL(location.href);
            if (key === 'brand') url.searchParams.set('tab', 'brand');
            else url.searchParams.delete('tab');
            history.replaceState(null, '', url);
        });
    });

    /* ── 상품 찜 해제 ─────────────────────────────────────────── */
    document.querySelectorAll('.unlike-btn').forEach(button => {
        button.addEventListener('click', async (e) => {
            e.preventDefault();
            if (!confirm('이 상품을 찜 목록에서 삭제하시겠습니까?')) return;

            const card = button.closest('.product-card');
            const productId = button.dataset.productId;

            try {
                const resp = await fetch('/likes/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId })
                });
                if (!resp.ok) throw new Error('Server error');
                const result = await resp.json();

                if (result.success && !result.liked) {
                    card.style.transition = 'opacity 0.3s ease';
                    card.style.opacity = '0';
                    setTimeout(() => {
                        card.remove();
                        // 마지막 한 장이 사라지면 빈 상태 안내를 내야 한다 → 새로고침.
                        if (document.querySelectorAll('.product-card').length === 0) location.reload();
                    }, 300);
                } else {
                    alert(result.message || '삭제에 실패했습니다.');
                }
            } catch (err) {
                alert('찜 해제 중 오류가 발생했습니다.');
            }
        });
    });

    /* ── 브랜드 찜 해제 ───────────────────────────────────────── */
    document.querySelectorAll('.unlike-brand-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const brandId = btn.dataset.brandId;
            try {
                const res = await fetch('/likes/brand/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ brandId: Number(brandId) })
                });
                const result = await res.json();
                if (result.success && !result.liked) {
                    // 브랜드 탭을 보던 중이므로 새로고침 후에도 그 탭으로 돌아와야 한다.
                    location.href = '/mypage/likes?tab=brand';
                } else {
                    alert(result.message || '삭제에 실패했습니다.');
                }
            } catch (err) {
                alert('찜 해제 중 오류가 발생했습니다.');
            }
        });
    });
});
</script>

<%- include('./_shell_end') %>
