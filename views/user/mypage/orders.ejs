<%- include('./_shell_start') %>

    <%
      // 마이페이지 주문 현황 카드에서 넘어온 필터. 지금 무엇만 보고 있는지 알 수 있어야 한다.
      const fKey = (typeof filterKey !== 'undefined') ? filterKey : null;
      const fLabel = (typeof filterLabel !== 'undefined') ? filterLabel : null;
      const STATUS_KO = { PENDING:'입금 대기', PAID:'결제 완료', PREPARING:'상품 준비중',
                          SHIPPED:'배송중', DELIVERED:'배송 완료', CANCELLED:'취소', REFUNDED:'환불 완료' };
      const TABS = [
        { key: null, label: '전체' },
        { key: 'ongoing', label: '주문중' },
        { key: 'shipping', label: '배송중' },
        { key: 'done', label: '배송완료' },
        { key: 'claim', label: '반품/취소' },
      ];
    %>
    <div class="bg-white rounded-lg shadow border border-gray-100">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
            <div class="flex flex-wrap items-center justify-between gap-2">
                <h3 class="text-lg font-bold text-gray-800">주문/배송 조회</h3>
                <a href="/mypage/claims" class="text-xs text-gray-500 hover:text-gray-800">취소·반품 신청 내역 <i class="bi bi-chevron-right"></i></a>
            </div>
            <div class="mt-3 flex flex-wrap gap-1.5">
                <% TABS.forEach(function (t) { %>
                    <a href="/mypage/orders<%= t.key ? '?filter=' + t.key : '' %>"
                       class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium transition <%= fKey === t.key ? 'bg-gray-900 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-100' %>">
                        <%= t.label %>
                    </a>
                <% }); %>
            </div>
        </div>

        <% if (orders.length===0) { %>
            <div class="p-12 text-center text-gray-500">
                <% if (fLabel) { %>
                    <p><b><%= fLabel %></b>인 주문이 없습니다.</p>
                    <a href="/mypage/orders" class="mt-2 inline-block text-sm text-gray-600 underline">전체 주문 보기</a>
                <% } else { %>
                    주문 내역이 없습니다.
                <% } %>
            </div>
            <% } else { %>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-white text-gray-500 text-xs uppercase border-b border-gray-100">
                            <tr>
                                <th class="px-6 py-3 font-medium">주문번호 / 일자</th>
                                <th class="px-6 py-3 font-medium">상품명</th>
                                <th class="px-6 py-3 font-medium">결제금액</th>
                                <th class="px-6 py-3 font-medium">상태</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% orders.forEach(order=> { %>
                                <tr class="hover:bg-gray-50 transition-colors cursor-pointer"
                                    onclick="location.href='/mypage/orders/<%= order.id %>'">
                                    <td class="px-6 py-4">
                                        <div class="font-medium text-gray-900">
                                            <%= order.order_number || order.id %>
                                        </div>
                                        <div class="text-sm text-gray-500">
                                            <%= new Date(order.created_at).toLocaleDateString() %>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-gray-900">
                                        <%= order.product_name_display %>
                                    </td>
                                    <td class="px-6 py-4 text-gray-900 font-medium">
                                        <%= Number(order.total_amount).toLocaleString() %>원
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2.5 py-1 text-xs font-semibold rounded-full
                                    <%= order.status === 'PENDING' ? 'bg-yellow-100 text-yellow-800' :
                                       order.status === 'PAID' ? 'bg-blue-100 text-blue-800' :
                                       order.status === 'DELIVERED' ? 'bg-green-100 text-green-800' :
                                       ['CANCELLED','REFUNDED'].includes(order.status) ? 'bg-red-100 text-red-800' :
                                       'bg-gray-100 text-gray-800' %>">
                                            <%= STATUS_KO[order.status] || order.status %>
                                        </span>
                                        <%
                                          /* 부분 취소·반품은 주문이 살아 있어 위 뱃지만 보면 정상 주문으로 읽힌다.
                                             결제 상태로 한 번 더 알려 준다. */
                                        %>
                                        <% if (order.payment_status === 'PARTIAL_REFUNDED') { %>
                                            <span class="mt-1 inline-block px-2.5 py-1 text-xs font-semibold rounded-full bg-amber-100 text-amber-800">부분 취소</span>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>

                <!-- 페이지네이션 -->
                <% if (totalPages> 1) { %>
                    <div class="px-6 py-4 border-t border-gray-100 flex justify-center">
                        <nav class="flex gap-2">
                            <% for(let i=1; i <=totalPages; i++) { %>
                                <a href="/mypage/orders?<%= fKey ? 'filter=' + fKey + '&' : '' %>page=<%= i %>"
                                    class="px-3 py-1 rounded-md text-sm font-medium <%= currentPage === i ? 'brand-badge shadow-md' : 'bg-white text-gray-700 hover:bg-gray-50 border border-gray-300' %>">
                                    <%= i %>
                                </a>
                                <% } %>
                        </nav>
                    </div>
                    <% } %>
                        <% } %>
    </div>
    <%- include('./_shell_end') %>