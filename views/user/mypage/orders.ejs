<%- include('./_shell_start') %>

    <div class="bg-white rounded-lg shadow border border-gray-100">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
            <h3 class="text-lg font-bold text-gray-800">주문/배송 조회</h3>
        </div>

        <% if (orders.length===0) { %>
            <div class="p-12 text-center text-gray-500">
                주문 내역이 없습니다.
            </div>
            <% } else { %>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-white text-gray-500 text-xs uppercase border-b border-gray-100">
                            <tr>
                                <th class="px-6 py-3 font-medium">주문번호 / 일자</th>
                                <th class="px-6 py-3 font-medium">상품명</th>
                                <th class="px-6 py-3 font-medium">결제금액</th>
                                <th class="px-6 py-3 font-medium">상태</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% orders.forEach(order=> { %>
                                <tr class="hover:bg-gray-50 transition-colors cursor-pointer"
                                    onclick="location.href='/mypage/orders/<%= order.id %>'">
                                    <td class="px-6 py-4">
                                        <div class="font-medium text-gray-900">
                                            <%= order.order_number || order.id %>
                                        </div>
                                        <div class="text-sm text-gray-500">
                                            <%= new Date(order.created_at).toLocaleDateString() %>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-gray-900">
                                        <%= order.product_name_display %>
                                    </td>
                                    <td class="px-6 py-4 text-gray-900 font-medium">
                                        <%= Number(order.total_amount).toLocaleString() %>원
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2.5 py-1 text-xs font-semibold rounded-full
                                    <%= order.status === 'PENDING' ? 'bg-yellow-100 text-yellow-800' :
                                       order.status === 'PAID' ? 'bg-blue-100 text-blue-800' :
                                       order.status === 'DELIVERED' ? 'bg-green-100 text-green-800' :
                                       order.status === 'CANCELLED' ? 'bg-red-100 text-red-800' :
                                       'bg-gray-100 text-gray-800' %>">
                                            <%= order.status %>
                                        </span>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>

                <!-- 페이지네이션 -->
                <% if (totalPages> 1) { %>
                    <div class="px-6 py-4 border-t border-gray-100 flex justify-center">
                        <nav class="flex gap-2">
                            <% for(let i=1; i <=totalPages; i++) { %>
                                <a href="/mypage/orders?page=<%= i %>"
                                    class="px-3 py-1 rounded-md text-sm font-medium <%= currentPage === i ? 'brand-badge shadow-md' : 'bg-white text-gray-700 hover:bg-gray-50 border border-gray-300' %>">
                                    <%= i %>
                                </a>
                                <% } %>
                        </nav>
                    </div>
                    <% } %>
                        <% } %>
    </div>
    <%- include('./_shell_end') %>