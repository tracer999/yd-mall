<%- include('./_shell_start') %>

<div class="space-y-4">
    <% if (typeof membership !== 'undefined' && membership && membership.membership && membership.membership.grade_name) {
         var mg = membership.membership;
         var gcolor = mg.color || '#9ca3af';
         var toNext = membership.amountToNext;
         var nextName = membership.nextGrade ? membership.nextGrade.grade_name : null;
         var nextEntry = membership.nextGrade ? Number(membership.nextGrade.entry_amount_min) : 0;
         var pct = (nextName && nextEntry > 0) ? Math.min(100, Math.round((membership.recognizedAmount / nextEntry) * 100)) : 100;
    %>
    <!-- 멤버십 등급 -->
    <section class="rounded-xl shadow-sm bg-white border border-gray-100 p-5">
        <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-sm font-bold text-white" style="background:<%= gcolor %>">
                    <i class="bi bi-award"></i><%= mg.grade_name %>
                </span>
                <span class="text-xs text-gray-400">멤버십 등급</span>
            </div>
            <a href="/membership" class="text-xs text-gray-500 hover:underline">등급 안내 <i class="bi bi-chevron-right"></i></a>
        </div>
        <div class="flex items-center justify-between text-sm mb-2">
            <span class="text-gray-500">최근 <%= membership.periodMonths %>개월 인정 실적</span>
            <span class="font-semibold text-gray-900"><%= Number(membership.recognizedAmount).toLocaleString() %>원 · <%= membership.recognizedCount %>건</span>
        </div>
        <% if (nextName && toNext !== null && toNext > 0) { %>
        <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden mb-1.5">
            <div class="h-full rounded-full" style="width:<%= pct %>%; background:<%= gcolor %>"></div>
        </div>
        <p class="text-xs text-gray-500"><span class="font-semibold text-gray-700"><%= nextName %></span> 등급까지 <span class="font-semibold" style="color:<%= gcolor %>"><%= Number(toNext).toLocaleString() %>원</span> 남았습니다.</p>
        <% } else if (!nextName) { %>
        <p class="text-xs text-gray-500">최고 등급입니다. 전용 혜택을 누리세요.</p>
        <% } else { %>
        <p class="text-xs text-gray-500"><span class="font-semibold text-gray-700"><%= nextName %></span> 등급 조건을 충족했습니다. 다음 평가에 반영됩니다.</p>
        <% } %>
        <div class="mt-3 flex flex-wrap gap-1.5">
            <% if (Number(mg.discount_rate) > 0) { %><span class="px-2 py-0.5 text-xs rounded bg-gray-100 text-gray-600">상품 <%= Number(mg.discount_rate) %>% 할인</span><% } %>
            <% if (mg.point_rate != null) { %><span class="px-2 py-0.5 text-xs rounded bg-gray-100 text-gray-600">적립 <%= mg.point_rate_mode==='REPLACE'?'':'+' %><%= Number(mg.point_rate) %>%</span><% } %>
            <% if (Number(mg.free_shipping) === 1) { %><span class="px-2 py-0.5 text-xs rounded bg-gray-100 text-gray-600">무료배송</span><% } else if (mg.free_ship_threshold != null) { %><span class="px-2 py-0.5 text-xs rounded bg-gray-100 text-gray-600"><%= Math.round(Number(mg.free_ship_threshold)/10000) %>만원↑ 무료배송</span><% } %>
        </div>
    </section>
    <% } %>

    <!-- 카드 UI: 한 줄 3칸 고정 -->
    <section class="rounded-xl shadow-sm overflow-hidden"
             style="background: var(--gh-primary);">
        <div class="grid"
             style="grid-template-columns: repeat(3, minmax(0, 1fr));">
            <a href="/mypage/likes" class="block px-4 py-5 text-center text-white transition hover:bg-white/10">
                <p class="text-sm font-semibold">찜 상품</p>
                <p class="mt-2 text-2xl font-bold"><%= likesCount || 0 %></p>
                <p class="mt-1 text-xs text-white/70">관심 목록</p>
            </a>
            <a href="/mypage/recent-views" class="block px-4 py-5 text-center text-white border-l border-white/20 transition hover:bg-white/10">
                <p class="text-sm font-semibold">최근 본 상품</p>
                <p class="mt-2 text-2xl font-bold"><%= recentViewedCount || 0 %></p>
                <p class="mt-1 text-xs text-white/70">히스토리</p>
            </a>
            <a href="/mypage/points" class="block px-4 py-5 text-center text-white border-l border-white/20 transition hover:bg-white/10">
                <p class="text-sm font-semibold">보유 포인트</p>
                <p class="mt-2 text-2xl font-bold"><%= (pointsBalance || 0).toLocaleString() %> P</p>
                <p class="mt-1 text-xs text-white/70">포인트 내역</p>
            </a>
        </div>
    </section>

    <%
      /*
       * 주문 현황 — 위 카드와 같은 자리에서 바로 확인하고 눌러 들어간다.
       * 상태 코드를 늘어놓지 않고 고객이 궁금해하는 단위(주문중·배송중·반품/취소)로 묶었다.
       * 배송완료는 "끝난 일"이라 카드로 두지 않고 아래 [전체 주문 내역]에서 본다.
       */
      const os = (typeof orderSummary !== 'undefined' && orderSummary) ? orderSummary : { ongoing: 0, shipping: 0, claim: 0, claimPending: 0 };
    %>
    <section class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
        <div class="flex items-center justify-between px-4 pt-4 pb-1">
            <h2 class="text-sm font-bold text-gray-900">주문 현황</h2>
            <a href="/mypage/orders" class="text-xs text-gray-500 hover:text-gray-800">전체 주문 내역 <i class="bi bi-chevron-right"></i></a>
        </div>
        <div class="grid" style="grid-template-columns: repeat(3, minmax(0, 1fr));">
            <a href="/mypage/orders?filter=ongoing"
               class="group block px-3 py-4 text-center transition hover:bg-gray-50">
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-blue-50 text-blue-600">
                    <i class="bi bi-box-seam"></i>
                </span>
                <p class="mt-2 text-2xl font-bold <%= os.ongoing > 0 ? 'text-gray-900' : 'text-gray-300' %>"><%= os.ongoing %></p>
                <p class="mt-0.5 text-sm font-semibold text-gray-700">주문중</p>
                <p class="mt-0.5 text-[11px] text-gray-400">결제 · 상품 준비</p>
            </a>
            <a href="/mypage/orders?filter=shipping"
               class="group block px-3 py-4 text-center border-l border-gray-100 transition hover:bg-gray-50">
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-amber-50 text-amber-600">
                    <i class="bi bi-truck"></i>
                </span>
                <p class="mt-2 text-2xl font-bold <%= os.shipping > 0 ? 'text-gray-900' : 'text-gray-300' %>"><%= os.shipping %></p>
                <p class="mt-0.5 text-sm font-semibold text-gray-700">배송중</p>
                <p class="mt-0.5 text-[11px] text-gray-400">지금 오는 중</p>
            </a>
            <a href="/mypage/orders?filter=claim"
               class="group block px-3 py-4 text-center border-l border-gray-100 transition hover:bg-gray-50">
                <span class="relative inline-flex h-9 w-9 items-center justify-center rounded-full bg-rose-50 text-rose-600">
                    <i class="bi bi-arrow-counterclockwise"></i>
                    <% if (os.claimPending > 0) { %>
                        <span class="absolute -top-1 -right-1 inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-rose-600 px-1 text-[10px] font-bold text-white"><%= os.claimPending %></span>
                    <% } %>
                </span>
                <p class="mt-2 text-2xl font-bold <%= os.claim > 0 ? 'text-gray-900' : 'text-gray-300' %>"><%= os.claim %></p>
                <p class="mt-0.5 text-sm font-semibold text-gray-700">반품/취소</p>
                <p class="mt-0.5 text-[11px] <%= os.claimPending > 0 ? 'text-rose-600 font-medium' : 'text-gray-400' %>">
                    <%= os.claimPending > 0 ? os.claimPending + '건 처리 중' : '취소 · 반품 · 교환' %>
                </p>
            </a>
        </div>
    </section>
</div>
<%- include('./_shell_end') %>
