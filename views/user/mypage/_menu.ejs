<div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm <%= (typeof sticky !== 'undefined' && sticky) ? 'lg:sticky lg:top-4' : '' %>">
    <h2 class="mb-3 text-base font-bold text-gray-900">마이페이지 메뉴</h2>
    <nav class="space-y-3 text-sm">
        <div>
            <p class="mb-2 px-2 text-xs font-bold tracking-wide text-gray-500">주문 관리</p>
            <a href="/cart" class="block rounded-md px-3 py-2 text-gray-700 transition hover:bg-gray-50">장바구니</a>
            <!-- <a href="/mypage/orders" class="block rounded-md px-3 py-2 transition">주문내역</a> -->
            <!-- <a href="/mypage/orders?status=CANCELLED" class="block rounded-md px-3 py-2 text-gray-700 transition hover:bg-gray-50">취소/환불 내역</a> -->
            <!-- <a href="/mypage/orders?status=SHIPPED" class="block rounded-md px-3 py-2 text-gray-700 transition hover:bg-gray-50">배송조회</a> -->
        </div>

        <div>
            <p class="mb-2 px-2 text-xs font-bold tracking-wide text-gray-500">혜택 관리</p>
            <a href="/mypage/coupons" class="block rounded-md px-3 py-2 transition <%= path && path.startsWith('/mypage/coupons') ? 'brand-chip font-semibold' : 'text-gray-700 hover:bg-gray-50' %>">쿠폰함</a>
            <a href="/mypage/points" class="block rounded-md px-3 py-2 transition <%= path && path.startsWith('/mypage/points') ? 'brand-chip font-semibold' : 'text-gray-700 hover:bg-gray-50' %>">포인트</a>
