<%
    const displayName = (user && (user.nickname || user.name)) ? (user.nickname || user.name) : '회원';
    const isDashboard = path === '/mypage';
    const isSubpage = !isDashboard;
%>
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-8">
    <div class="flex flex-col <%= isDashboard ? 'gap-4' : 'gap-5' %>">
        <% if (isSubpage) { %>
        <div class="lg:hidden">
            <a href="/mypage" class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 hover:text-gray-900 transition">
                <i class="bi bi-chevron-left"></i> 마이페이지로 돌아가기
            </a>
        </div>
        <% } %>
        <section class="rounded-xl border border-gray-200 bg-white p-5 md:p-6 shadow-sm <%= isSubpage ? 'hidden lg:block' : '' %>">
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                <div>
                    <p class="text-lg font-bold text-gray-900 md:text-xl"><%= displayName %> 님</p>
                </div>
                <a href="/mypage/profile" class="inline-flex items-center justify-center rounded-lg gh-btn-primary px-4 py-2 text-sm font-semibold shadow-sm">
                    내 정보 수정하기
                </a>
            </div>
        </section>

        <% if (isDashboard) { %>
            <main class="min-w-0">
        <% } else { %>
            <div class="flex flex-col lg:flex-row gap-5">
                <aside class="hidden lg:block w-full lg:w-64 flex-shrink-0">
                    <%- include('./_menu', { sticky: true }) %>
                </aside>
                <main class="flex-1 min-w-0">
        <% } %>
