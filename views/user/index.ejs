<%
  /*
   * 홈 — 섹션 조립 렌더(P1 SDUI 엔진)
   * 컨트롤러가 displayService.getHomeSections()로 만든 sections를 sort_order대로 렌더한다.
   * 각 section = { type, view(=partials/sections/*), locals }
   * <style>/<script>는 여러 섹션이 공유하는 페이지 크롬으로 여기 유지한다.
   */
  const _sections = sections || [];
%>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
  .mySwiperDesktop { display: none !important; }
  .mySwiperMobile  { display: block !important; }
  @media (min-width: 640px) {
    .mySwiperDesktop { display: block !important; }
    .mySwiperMobile  { display: none !important; }
  }
  .swiper { width: 100%; }
  @keyframes badge-blink {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.06); }
  }
  .status-banner-blink { animation: badge-blink 1.4s infinite ease-in-out; }
  .product-pill-badge {
    border-radius: 9999px;
    padding: 0.25rem 0.6rem;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    box-shadow: 0 1px 4px rgba(0,0,0,0.12);
    white-space: nowrap;
  }
  .badge-channel  { background: var(--gh-primary); color: #fff; }
  .badge-best     { background: #ef4444; color: #fff; }
  .badge-new      { background: #10b981; color: #fff; }
  .badge-recommend{ background: #f59e0b; color: #fff; }
</style>

<!-- ── 팝업 배너(오버레이) ── -->
<%- include('../partials/sections/popup_banner', { popupBanner }) %>

<!-- ── 섹션 조립 렌더 (page_section 순서대로) ── -->
<%/* gateClass = 노출 대상(PC/모바일) 제한. 빈 문자열이면 감싸지 않는다(불필요한 div 금지). */%>
<% _sections.forEach(function (section) { %>
  <% if (section.gateClass) { %><div class="<%= section.gateClass %>"><% } %>
  <% try { %>
    <%- include('../' + section.view, section.locals) %>
  <% } catch (e) { %>
    <% console.error('[home] 섹션 렌더 실패 — 스킵:', section.type, e && e.message); %>
  <% } %>
  <% if (section.gateClass) { %></div><% } %>
<% }); %>

<!-- ── 페이지 스크립트 (여러 섹션 공유) ── -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  /*
   * 전체폭 배너 히어로(full_banner) Swiper — 해당 DOM 이 없으면 no-op.
   * 슬라이드가 1장이면 loop 를 켜지 않는다. Swiper 11 은 loop 에 슬라이드가 모자라면 경고와 함께
   * loop 를 해제하는데, 그 상태에서 autoplay·스와이프가 함께 죽어 "슬라이더가 안 돌아간다"로 보인다.
   * 1장짜리는 아예 정적 배너로 두고 화살표/인디케이터도 감춘다.
   */
  function initHeroSwiper(sel, pagination, next, prev, extra) {
    var el = document.querySelector(sel);
    if (!el) return;

    var count = el.querySelectorAll('.swiper-slide').length;
    if (count < 2) {
      el.querySelectorAll('.swiper-pagination, .swiper-button-next, .swiper-button-prev')
        .forEach(function (n) { n.style.display = 'none'; });
      return;
    }

    var opts = {
      spaceBetween: 0,
      centeredSlides: true,
      loop: true,
      autoplay: { delay: 5000, disableOnInteraction: false },
      pagination: { el: pagination, clickable: true },
      navigation: { nextEl: next, prevEl: prev }
    };
    for (var k in (extra || {})) opts[k] = extra[k];
    var sw = new Swiper(sel, opts);

    // autoHeight 는 초기화 시점의 이미지 높이로 컨테이너를 잡는다. 아직 안 받아온 이미지가 있으면
    // 높이가 0 으로 굳으므로, 로드가 끝날 때마다 다시 계산시킨다.
    el.querySelectorAll('img').forEach(function (img) {
      if (img.complete) return;
      img.addEventListener('load', function () { sw.update(); });
    });
  }

  initHeroSwiper('.mySwiperDesktop', '.swiper-pagination-desktop', '.swiper-button-next-desktop', '.swiper-button-prev-desktop');
  // 모바일은 이미지 원본 높이를 그대로 쓴다(레터박스 흰 여백 제거) → 슬라이드마다 높이가 달라지므로 autoHeight.
  initHeroSwiper('.mySwiperMobile', '.swiper-pagination-mobile', '.swiper-button-next-mobile', '.swiper-button-prev-mobile', { autoHeight: true });
</script>

<!-- ── 팝업 스크립트 ── -->
<% if (popupBanner) { %>
<script>
(function () {
  var overlay = document.getElementById('popup-banner-overlay');
  var closeBtn = document.getElementById('popup-banner-close');
  var hideCheckbox = document.getElementById('popup-banner-hide-today-checkbox');
  var dismissBtn = document.getElementById('popup-banner-dismiss');
  var storageKey = 'popup_skip_<%= popupBanner.id %>';
  function todayKey() {
    var d = new Date(Date.now() - new Date().getTimezoneOffset() * 60000);
    return d.toISOString().slice(0, 10);
  }
  function handleClose() {
    if (hideCheckbox && hideCheckbox.checked) {
      try { localStorage.setItem(storageKey, todayKey()); } catch(e) {}
    }
    if (overlay) overlay.classList.add('hidden');
  }
  function shouldShow() {
    try { return localStorage.getItem(storageKey) !== todayKey(); } catch(e) { return true; }
  }
  if (overlay && shouldShow()) {
    overlay.classList.remove('hidden');
    if (closeBtn) closeBtn.addEventListener('click', handleClose);
    if (dismissBtn) dismissBtn.addEventListener('click', handleClose);
    overlay.addEventListener('click', function(e) { if (e.target === overlay) handleClose(); });
  }
})();
</script>
<% } %>

