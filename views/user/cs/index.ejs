<%
  /*
   * 고객센터 (M8) — capture/image copy.png 구조
   *   좌 LNB : 1:1문의 / 문의내역 / 공지사항 / 자주묻는질문(분류) / 비회원 주문조회 / 대표번호
   *   본문   : FAQ 검색 → 자주묻는 질문 (아코디언) → 공지사항
   *   우측   : 전역 유틸 레일 (main_layout 이 렌더)
   *
   * faqs[].answer 는 컨트롤러에서 이미 새니타이즈된 HTML 이다.
   */
  const _cats = categories || [];
  const _faqs = faqs || [];
  const _notices = notices || [];
  const _activeId = (typeof activeCategoryId !== 'undefined') ? activeCategoryId : null;
  const _kw = (typeof keyword !== 'undefined' && keyword) ? keyword : '';
  const _phone = (siteSettings && siteSettings.contact_phone) || '';
  const _fmt = (d) => {
    const dt = new Date(d);
    return `${dt.getFullYear()}.${String(dt.getMonth() + 1).padStart(2, '0')}.${String(dt.getDate()).padStart(2, '0')}`;
  };
%>

<style>
  .cs-lnb__link { display: block; padding: .5rem .25rem; font-size: .875rem; color: #4b5563; text-decoration: none; transition: color .15s; }
  .cs-lnb__link:hover { color: var(--gh-primary); }
  .cs-lnb__link.is-active { color: var(--gh-primary); font-weight: 700; }
  .cs-lnb__btn {
    display: flex; align-items: center; gap: .5rem; width: 100%;
    padding: .75rem 1rem; border: 1px solid var(--gh-border); border-radius: .5rem;
    background: #fff; color: #374151; font-size: .875rem; font-weight: 600; text-decoration: none;
    transition: border-color .15s, color .15s;
  }
  .cs-lnb__btn:hover { border-color: var(--gh-primary); color: var(--gh-primary); }
  .cs-lnb__title { font-size: .8125rem; font-weight: 700; color: #111827; padding: .5rem .25rem; border-bottom: 1px solid #f1f2f4; margin-bottom: .25rem; }

  .cs-faq__item { border-bottom: 1px solid #f1f2f4; }
  .cs-faq__q {
    width: 100%; display: flex; align-items: center; gap: .75rem; text-align: left;
    padding: 1rem .25rem; background: none; border: none; cursor: pointer;
    font-size: .9375rem; color: #374151; transition: color .15s;
  }
  .cs-faq__q:hover { color: var(--gh-primary); }
  .cs-faq__mark { flex: 0 0 auto; font-weight: 800; color: var(--gh-primary); }
  .cs-faq__cat { flex: 0 0 auto; font-size: .75rem; color: #9ca3af; }
  .cs-faq__chev { margin-left: auto; transition: transform .2s; color: #9ca3af; }
  .cs-faq__item.is-open .cs-faq__chev { transform: rotate(180deg); }
  .cs-faq__a { padding: 0 .25rem 1.25rem 2.25rem; font-size: .875rem; color: #4b5563; line-height: 1.7; }
  .cs-faq__a[hidden] { display: none; }
  .cs-faq__a a { color: var(--gh-primary); text-decoration: underline; }
</style>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex flex-col lg:flex-row gap-8">

    <!-- 좌측 LNB -->
    <aside class="w-full lg:w-56 shrink-0">
      <h1 class="text-2xl font-extrabold text-gray-900 mb-6">고객센터</h1>

      <div class="space-y-2 mb-6">
        <a href="/inquiries" class="cs-lnb__btn"><i class="bi bi-chat-dots"></i> 1:1 문의하기</a>
        <a href="/mypage/activities" class="cs-lnb__btn"><i class="bi bi-list-check"></i> 1:1 문의내역</a>
      </div>

      <div class="mb-6">
        <p class="cs-lnb__title">공지사항</p>
        <a href="/boards/notice" class="cs-lnb__link">공지사항 전체보기</a>
      </div>

      <div class="mb-6">
        <p class="cs-lnb__title">자주묻는질문</p>
        <a href="/cs" class="cs-lnb__link <%= !_activeId && !_kw ? 'is-active' : '' %>">전체</a>
        <% _cats.forEach(function (c) { %>
          <a href="/cs/faq?categoryId=<%= c.id %>"
             class="cs-lnb__link <%= _activeId === c.id ? 'is-active' : '' %>">
            <%= c.name %> <span class="text-gray-300">(<%= c.faq_count %>)</span>
          </a>
        <% }); %>
      </div>

      <div class="mb-6">
        <p class="cs-lnb__title">비회원 주문조회</p>
        <a href="/mypage/orders" class="cs-lnb__link">주문/배송 조회</a>
      </div>

      <% if (_phone) { %>
        <div class="p-4 rounded-lg bg-[var(--gh-secondary)]">
          <p class="text-xs font-semibold text-gray-500 mb-1">고객센터</p>
          <p class="text-xl font-extrabold text-gray-900"><%= _phone %></p>
          <p class="mt-1 text-xs text-gray-500">※ 운영시간은 공지사항을 확인해 주세요.</p>
        </div>
      <% } %>
    </aside>

    <!-- 본문 -->
    <div class="flex-1 min-w-0">

      <!-- FAQ 검색 -->
      <form action="/cs/faq" method="get" class="bg-gray-50 border border-gray-100 rounded-xl p-5 mb-8 flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
        <label for="cs-q" class="text-sm font-bold text-gray-800 shrink-0">FAQ 검색</label>
        <input id="cs-q" type="text" name="q" value="<%= _kw %>" maxlength="100"
               placeholder="검색 후 문의가 해결되지 않으면 1:1 상담을 이용하세요."
               class="flex-1 h-11 rounded-md border border-gray-200 px-4 text-sm brand-focus focus:outline-none">
        <button type="submit" class="h-11 px-6 rounded-md gh-btn-primary text-sm font-semibold shrink-0">검색</button>
      </form>

      <!-- FAQ 목록 -->
      <section class="mb-12">
        <div class="flex items-baseline justify-between mb-2">
          <h2 class="text-xl font-extrabold text-gray-900">
            <% if (_kw) { %>'<%= _kw %>' 검색 결과<% } else if (_activeId) { %>자주묻는질문<% } else { %>자주묻는 질문 BEST 10<% } %>
          </h2>
          <span class="text-sm text-gray-400"><%= _faqs.length %>건</span>
        </div>

        <% if (_faqs.length === 0) { %>
          <div class="py-16 text-center text-gray-400 border-t border-gray-100">
            <p class="mb-1">검색 결과가 없습니다.</p>
            <p class="text-sm">해결되지 않으면 <a href="/inquiries" class="text-[var(--gh-primary)] underline">1:1 문의</a>를 이용해 주세요.</p>
          </div>
        <% } else { %>
          <div class="border-t border-gray-200" data-cs-faq>
            <% _faqs.forEach(function (f) { %>
              <div class="cs-faq__item" data-faq-id="<%= f.id %>">
                <button type="button" class="cs-faq__q" aria-expanded="false">
                  <span class="cs-faq__mark">Q</span>
                  <% if (f.category_name) { %><span class="cs-faq__cat">[<%= f.category_name %>]</span><% } %>
                  <span><%= f.question %></span>
                  <i class="bi bi-chevron-down cs-faq__chev"></i>
                </button>
                <div class="cs-faq__a" hidden><%- f.answer %></div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </section>

      <!-- 공지사항 -->
      <section>
        <div class="flex items-baseline justify-between mb-2">
          <h2 class="text-xl font-extrabold text-gray-900">공지사항</h2>
          <a href="/boards/notice" class="text-sm text-gray-500 hover:text-[var(--gh-primary)]">더보기 <i class="bi bi-plus"></i></a>
        </div>
        <ul class="border-t border-gray-200">
          <% if (_notices.length === 0) { %>
            <li class="py-10 text-center text-gray-400">등록된 공지사항이 없습니다.</li>
          <% } else { %>
            <% _notices.forEach(function (n) { %>
              <li class="border-b border-gray-100">
                <a href="/boards/notice/<%= n.id %>" class="flex items-center justify-between gap-4 py-3.5 text-sm text-gray-700 hover:text-[var(--gh-primary)]">
                  <span class="truncate"><%= n.title %></span>
                  <span class="shrink-0 text-xs text-gray-400"><%= _fmt(n.created_at) %></span>
                </a>
              </li>
            <% }); %>
          <% } %>
        </ul>
      </section>
    </div>
  </div>
</div>

<script>
(function () {
  var root = document.querySelector('[data-cs-faq]');
  if (!root) return;

  root.addEventListener('click', function (e) {
    var btn = e.target.closest('.cs-faq__q');
    if (!btn) return;

    var item = btn.closest('.cs-faq__item');
    var answer = item.querySelector('.cs-faq__a');
    var willOpen = answer.hasAttribute('hidden');

    if (willOpen) {
      answer.removeAttribute('hidden');
      item.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
      // 조회수 증가 (실패해도 UX에 영향 없음)
      fetch('/cs/faq/' + item.dataset.faqId + '/view', { method: 'POST' }).catch(function () {});
    } else {
      answer.setAttribute('hidden', '');
      item.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
    }
  });
})();
</script>
