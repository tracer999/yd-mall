<%
  /*
   * 추천 (고객)
   *
   * 설계: docs/사이트개선/recommend_specialty_design_and_development.md §4-3
   *
   * 화면의 본질은 목록이 아니라 **근거**다. 섹션마다 "왜 이걸 보여주는가"(reason)를
   * 제목 아래 반드시 단다. 근거가 없으면 이 화면은 베스트와 구별되지 않는다.
   *
   * locals: sections[{key,title,reason,products[]}], banners[], currentUser
   * 섹션이 전부 비면 컨트롤러가 준비중 랜딩으로 되돌리므로, 여기 도달하면 최소 1개는 있다.
   */
  const _sections = sections || [];
  const _banners = banners || [];
  const _hasPersonal = _sections.some(s => s.key === 'personal');
%>

<div class="max-w-7xl mx-auto px-4 py-6">

  <% if (_banners.length) { const b = _banners[0]; %>
    <a href="<%= b.link_url || '#' %>" class="block mb-6 rounded-lg overflow-hidden">
      <picture>
        <% if (b.mobile_image_url) { %>
          <source media="(max-width: 767px)" srcset="<%= b.mobile_image_url %>">
        <% } %>
        <img src="<%= b.image_url %>" alt="<%= b.title %>" class="w-full object-cover">
      </picture>
    </a>
  <% } %>

  <h1 class="text-2xl font-bold text-gray-900 mb-1">추천</h1>
  <p class="text-sm text-gray-500 mb-8">최근 본 상품과 MD 큐레이션을 바탕으로 골랐습니다.</p>

  <%# ── 비로그인: 개인화 섹션 자리를 로그인 CTA 로 대체 ──────────────
      베스트 목록을 복제해 채우지 않는다. 그러면 추천 메뉴의 정체성이 사라진다. %>
  <% if (!currentUser && !_hasPersonal) { %>
    <div class="mb-10 rounded-2xl border border-gray-200 bg-gray-50 px-6 py-8 text-center">
      <i class="bi bi-stars text-3xl text-gray-300"></i>
      <p class="mt-3 text-base font-semibold text-gray-900">로그인하면 나에게 맞는 상품을 골라드려요</p>
      <p class="mt-1 text-sm text-gray-500">최근 본 상품을 바탕으로 함께 많이 본 상품을 추천합니다.</p>
      <a href="/auth/login"
         class="mt-5 inline-block px-6 py-2.5 rounded-full text-sm font-semibold text-white no-underline"
         style="background: var(--gh-primary);">로그인하고 맞춤 추천 받기</a>
    </div>
  <% } %>

  <%# ── 섹션 ─────────────────────────────────────────── %>
  <% _sections.forEach(function (s) { %>
    <section class="mb-12">
      <div class="mb-4">
        <h2 class="text-lg sm:text-xl font-bold text-gray-900"><%= s.title %></h2>
        <p class="mt-0.5 text-sm text-gray-500"><%= s.reason %></p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
        <% s.products.forEach(function (product) { %>
          <%- include('../../partials/product_card', { product, opts: { imageHeightClass: 'h-44' } }) %>
        <% }); %>
      </div>
    </section>
  <% }); %>

</div>
