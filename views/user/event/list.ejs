<%
  const FILTERS = [
    { key: 'all',      label: '전체' },
    { key: 'ongoing',  label: '진행중' },
    { key: 'upcoming', label: '예정' },
    { key: 'ended',    label: '종료' },
  ];
  const TYPE_LABELS = {
    NOTICE: '공지', APPLY: '응모', COUPON_PACK: '쿠폰팩',
    ATTENDANCE: '출석체크', PURCHASE: '구매인증',
  };
  const fmt = (d) => d ? new Date(d).toLocaleDateString('ko-KR', { year: '2-digit', month: '2-digit', day: '2-digit' }) : '';
%>

<div class="max-w-screen-xl mx-auto px-4 py-10">
    <header class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">이벤트 &amp; 혜택</h1>
        <p class="mt-2 text-gray-500">참여하고 받아가세요.</p>
    </header>

    <nav class="flex gap-2 mb-8 border-b border-gray-200">
        <% FILTERS.forEach(function(f) { %>
            <a href="/event?phase=<%= f.key %>"
               class="px-4 py-2.5 text-sm font-medium border-b-2 -mb-px transition
                      <%= phase === f.key
                            ? 'border-[var(--gh-primary)] text-[var(--gh-primary)]'
                            : 'border-transparent text-gray-500 hover:text-gray-800' %>">
                <%= f.label %>
            </a>
        <% }); %>
    </nav>

    <% if (!events.length) { %>
        <div class="py-24 text-center">
            <i class="bi bi-gift text-5xl text-gray-300"></i>
            <p class="mt-4 text-gray-500">해당하는 이벤트가 없습니다.</p>
            <a href="/event?phase=all" class="mt-4 inline-block px-5 py-2.5 border border-gray-300 rounded-full text-sm text-gray-700 hover:border-[var(--gh-primary)] hover:text-[var(--gh-primary)] transition">
                전체 이벤트 보기
            </a>
        </div>
    <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% events.forEach(function(e) { %>
                <a href="/event/<%= e.slug %>" class="group block rounded-xl overflow-hidden border border-gray-200 hover:shadow-lg transition <%= e.phase === 'ended' ? 'opacity-60' : '' %>">
                    <div class="aspect-[16/9] bg-gray-100 overflow-hidden">
                        <% if (e.thumbnail_url) { %>
                            <img src="<%= e.thumbnail_url %>" alt="<%= e.title %>"
                                 class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                        <% } else { %>
                            <div class="w-full h-full flex items-center justify-center text-gray-300">
                                <i class="bi bi-gift text-4xl"></i>
                            </div>
                        <% } %>
                    </div>

                    <div class="p-4">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="px-2 py-0.5 rounded text-xs font-semibold bg-gray-100 text-gray-600">
                                <%= TYPE_LABELS[e.event_type] || e.event_type %>
                            </span>
                            <% var pc = e.phase === 'ongoing' ? 'bg-[var(--gh-primary)] text-[var(--gh-primary-contrast)]'
                                       : e.phase === 'upcoming' ? 'bg-purple-100 text-purple-700'
                                       : 'bg-gray-200 text-gray-500'; %>
                            <span class="px-2 py-0.5 rounded text-xs font-semibold <%= pc %>"><%= e.phaseLabel %></span>
                            <% if (e.isFull && e.phase === 'ongoing') { %>
                                <span class="px-2 py-0.5 rounded text-xs font-semibold bg-red-100 text-red-600">마감</span>
                            <% } %>
                        </div>

                        <h2 class="font-bold text-gray-900 line-clamp-2 group-hover:text-[var(--gh-primary)] transition">
                            <%= e.title %>
                        </h2>
                        <% if (e.summary) { %>
                            <p class="mt-1 text-sm text-gray-500 line-clamp-1"><%= e.summary %></p>
                        <% } %>

                        <p class="mt-3 text-xs text-gray-400">
                            <%= fmt(e.start_at) %> ~ <%= e.end_at ? fmt(e.end_at) : '상시' %>
                        </p>
                    </div>
                </a>
            <% }); %>
        </div>
    <% } %>

    <section class="mt-16 pt-10 border-t border-gray-200">
        <h2 class="text-xl font-bold text-gray-900 mb-4">상시 혜택</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <a href="/mypage/coupons" class="p-5 rounded-xl border border-gray-200 hover:border-[var(--gh-primary)] transition">
                <i class="bi bi-ticket-perforated text-2xl text-[var(--gh-primary)]"></i>
                <h3 class="mt-2 font-semibold text-gray-900">신규가입 쿠폰</h3>
                <p class="mt-1 text-sm text-gray-500">가입 즉시 쿠폰을 드립니다.</p>
            </a>
            <a href="/mypage/points" class="p-5 rounded-xl border border-gray-200 hover:border-[var(--gh-primary)] transition">
                <i class="bi bi-coin text-2xl text-[var(--gh-primary)]"></i>
                <h3 class="mt-2 font-semibold text-gray-900">적립금</h3>
                <p class="mt-1 text-sm text-gray-500">구매하고 적립금을 모으세요.</p>
            </a>
            <a href="/deals" class="p-5 rounded-xl border border-gray-200 hover:border-[var(--gh-primary)] transition">
                <i class="bi bi-fire text-2xl text-[var(--gh-primary)]"></i>
                <h3 class="mt-2 font-semibold text-gray-900">오늘특가</h3>
                <p class="mt-1 text-sm text-gray-500">기간 한정 할인 상품.</p>
            </a>
        </div>
    </section>
</div>
