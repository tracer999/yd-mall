<%
  const e = event;
  const TYPE_LABELS = {
    NOTICE: '공지', APPLY: '응모', COUPON_PACK: '쿠폰팩',
    ATTENDANCE: '출석체크', PURCHASE: '구매인증',
  };
  const fmtDT = (d) => d ? new Date(d).toLocaleString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }) : '';
  const fmtD  = (d) => d ? new Date(d).toLocaleDateString('ko-KR') : '';

  // 참여 결과 메시지 (?r=)
  const FLASH = {
    ok:        { cls: 'bg-green-50 text-green-700',  msg: '참여가 완료되었습니다.' },
    duplicate: { cls: 'bg-yellow-50 text-yellow-700', msg: '이미 참여하셨습니다.' },
    full:      { cls: 'bg-red-50 text-red-600',       msg: '선착순이 마감되었습니다.' },
    closed:    { cls: 'bg-gray-100 text-gray-600',    msg: '지금은 참여할 수 없는 이벤트입니다.' },
    login:     { cls: 'bg-blue-50 text-blue-700',     msg: '로그인 후 참여할 수 있습니다.' },
  };
  const f = flash && FLASH[flash] ? FLASH[flash] : null;
%>

<div class="max-w-screen-lg mx-auto px-4 py-8">
    <nav class="mb-6 text-sm text-gray-400">
        <a href="/event" class="hover:text-gray-700">이벤트 &amp; 혜택</a>
        <span class="mx-1">/</span>
        <span class="text-gray-600"><%= e.title %></span>
    </nav>

    <% if (f) { %>
        <div class="mb-6 px-4 py-3 rounded-lg text-sm <%= f.cls %>"><%= f.msg %></div>
    <% } %>

    <header class="mb-6">
        <div class="flex items-center gap-2 mb-3">
            <span class="px-2.5 py-1 rounded text-xs font-semibold bg-gray-100 text-gray-600">
                <%= TYPE_LABELS[e.event_type] || e.event_type %>
            </span>
            <% var pc = e.phase === 'ongoing' ? 'bg-[var(--gh-primary)] text-[var(--gh-primary-contrast)]'
                       : e.phase === 'upcoming' ? 'bg-purple-100 text-purple-700'
                       : 'bg-gray-200 text-gray-500'; %>
            <span class="px-2.5 py-1 rounded text-xs font-semibold <%= pc %>"><%= e.phaseLabel %></span>
        </div>

        <h1 class="text-3xl font-bold text-gray-900"><%= e.title %></h1>
        <% if (e.summary) { %>
            <p class="mt-2 text-gray-500"><%= e.summary %></p>
        <% } %>
        <p class="mt-3 text-sm text-gray-400">
            <i class="bi bi-calendar3"></i>
            <%= fmtDT(e.start_at) %> ~ <%= e.end_at ? fmtDT(e.end_at) : '상시' %>
        </p>
    </header>

    <% if (e.pc_hero_url || e.mobile_hero_url) { %>
        <figure class="mb-8 rounded-xl overflow-hidden bg-gray-100">
            <% if (e.mobile_hero_url) { %>
                <img src="<%= e.mobile_hero_url %>" alt="<%= e.title %>" class="w-full sm:hidden">
            <% } %>
            <% if (e.pc_hero_url) { %>
                <img src="<%= e.pc_hero_url %>" alt="<%= e.title %>"
                     class="w-full <%= e.mobile_hero_url ? 'hidden sm:block' : '' %>">
            <% } %>
        </figure>
    <% } %>

    <% if (e.contentHtml) { %>
        <article class="prose max-w-none mb-10 text-gray-800">
            <%- e.contentHtml %>
        </article>
    <% } %>

    <!-- 참여 영역: 공지형(NOTICE)에는 없다 -->
    <% if (e.participable) { %>
        <section class="mb-10 p-6 rounded-xl border-2 border-gray-100 bg-gray-50 text-center">
            <% if (e.issue_limit) { %>
                <p class="mb-4 text-sm text-gray-500">
                    선착순 <strong class="text-gray-800"><%= e.issue_limit.toLocaleString() %></strong>명 중
                    <strong class="text-gray-800"><%= e.issued_count.toLocaleString() %></strong>명 참여
                    <% if (e.remaining !== null && e.remaining > 0) { %>
                        <span class="text-[var(--gh-primary)]">(<%= e.remaining.toLocaleString() %>명 남음)</span>
                    <% } %>
                </p>
            <% } %>

            <% if (!currentUser && e.login_required) { %>
                <a href="/auth/login?redirect=<%= encodeURIComponent('/event/' + e.slug) %>"
                   class="inline-block px-8 py-3 rounded-full bg-gray-800 text-white font-semibold hover:bg-gray-900 transition">
                    로그인하고 참여하기
                </a>
            <% } else if (participated) { %>
                <button type="button" disabled
                        class="px-8 py-3 rounded-full bg-gray-300 text-white font-semibold cursor-not-allowed">
                    이미 참여하셨습니다
                </button>
            <% } else if (e.phase === 'upcoming') { %>
                <button type="button" disabled
                        class="px-8 py-3 rounded-full bg-gray-300 text-white font-semibold cursor-not-allowed">
                    곧 시작합니다
                </button>
            <% } else if (e.phase === 'ended') { %>
                <button type="button" disabled
                        class="px-8 py-3 rounded-full bg-gray-300 text-white font-semibold cursor-not-allowed">
                    종료된 이벤트입니다
                </button>
            <% } else if (e.isFull) { %>
                <button type="button" disabled
                        class="px-8 py-3 rounded-full bg-gray-300 text-white font-semibold cursor-not-allowed">
                    선착순 마감
                </button>
            <% } else { %>
                <form action="/event/<%= e.slug %>/apply" method="POST">
                    <button type="submit"
                            class="px-10 py-3 rounded-full bg-[var(--gh-primary)] text-[var(--gh-primary-contrast)] font-semibold hover:opacity-90 transition">
                        참여하기
                    </button>
                </form>
            <% } %>

            <% if (e.winner_announce_at) { %>
                <p class="mt-4 text-xs text-gray-400">당첨자 발표 <%= fmtD(e.winner_announce_at) %></p>
            <% } %>
        </section>
    <% } %>

    <% if (e.noticeHtml) { %>
        <section class="p-6 rounded-xl bg-gray-50 border border-gray-100">
            <h2 class="font-semibold text-gray-800 mb-3">유의사항</h2>
            <div class="text-sm text-gray-600 leading-relaxed"><%- e.noticeHtml %></div>
        </section>
    <% } %>

    <div class="mt-10 text-center">
        <a href="/event" class="inline-flex items-center gap-2 px-6 py-2.5 border border-gray-300 rounded-full text-sm text-gray-700 hover:border-[var(--gh-primary)] hover:text-[var(--gh-primary)] transition">
            <i class="bi bi-arrow-left"></i> 이벤트 목록
        </a>
    </div>
</div>
