<%
  /*
   * 베스트/랭킹 (고객)
   *
   * 화면 구조 (2026-07-22 개편)
   *   [쇼케이스]        상단 배너·상품 캐러셀 — 이 뷰가 아니라 main_layout 이 body 위에 렌더한다
   *                     (middleware/menuShowcase → services/menu/menuShowcaseService)
   *   [BEST 10]         전체 랭킹 상위 10 + 순위 번호 + 기간 탭
   *   [카테고리별 BEST] 카테고리마다 한 줄 (최대 10개 + 더보기)
   *   [브랜드별 BEST]   브랜드마다 한 줄 (최대 10개 + 더보기)
   *
   * locals: period, periods{}, top{products,calculatedAt,isEmpty,hasMore}, topLimit,
   *         categoryRows[], brandRows[]
   */
  const _cat = categoryRows || [];
  const _brand = brandRows || [];
  const _hasAnything = !top.isEmpty || _cat.length || _brand.length;
%>

<%- include('./_best_block', {
      heading: 'BEST ' + topLimit,
      lead: '판매와 좋아요를 합산해 매긴 인기 상품 순위입니다.',
      period, periods, top,
      scope: 'top',
      moreUrl: '/best/all?period=' + period,
    }) %>

<%- include('../../partials/storefront/landing_rows', {
      sectionTitle: '카테고리별 BEST',
      sectionDesc: '카테고리마다 지금 가장 잘 나가는 상품입니다.',
      rows: _cat,
      variant: 'category',
      surface: 'gray',
    }) %>

<%- include('../../partials/storefront/landing_rows', {
      sectionTitle: '브랜드별 BEST',
      sectionDesc: '브랜드마다 지금 가장 잘 나가는 상품입니다.',
      rows: _brand,
      variant: 'brand',
      surface: 'white',
    }) %>

<% if (!_hasAnything) { %>
  <%# 상품이 한 건도 없는 몰(갓 찍어낸 상태)에서 빈 화면을 남기지 않는다 %>
  <div class="max-w-7xl mx-auto px-4 py-20 text-center">
    <i class="bi bi-trophy text-5xl text-gray-200"></i>
    <p class="mt-4 text-gray-500">아직 집계된 랭킹이 없습니다.</p>
    <p class="mt-1 text-sm text-gray-400">상품 판매·좋아요가 쌓이면 순위가 표시됩니다.</p>
    <a href="/products" class="mt-6 inline-block px-6 py-2.5 rounded-full bg-gray-900 text-white text-sm font-semibold no-underline">
      전체 상품 보기
    </a>
  </div>
<% } %>
