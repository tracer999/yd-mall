<%
  /*
   * 결제 화면 — 세 갈래다.
   *   1) 실제 결제   : 결제사 키가 있고 가상결제가 꺼져 있을 때 (토스 결제창)
   *   2) 가상결제    : 사이트 설정에서 **가상결제 사용**을 켰을 때 (결제 없이 완료)
   *   3) 진행 불가   : 키도 없고 가상결제도 꺼져 있을 때
   *
   * 예전에는 키가 없으면 "키가 설정되지 않았습니다" 경고와 작은 링크만 두고 멈췄다.
   * 게다가 그 링크는 `NODE_ENV=production` 인 배포 서버에서 **눌러도 아무 일이 없었다**
   * (서버가 NODE_ENV 로 막았다). 그래서 결제를 마쳤다고 생각한 주문이 `대기` 로 쌓였다.
   * 지금은 화면과 서버가 **같은 설정 하나**(virtual_payment_enabled)를 보므로 어긋나지 않는다.
   */
  const testCompleteUrl = '/checkout/complete?orderId=' + encodeURIComponent(order.order_number) + '&test=1'
      + ((order.coupon_discount && order.coupon_discount > 0)
          ? '&coupon_discount=' + order.coupon_discount + (order.user_coupon_id ? '&user_coupon_id=' + order.user_coupon_id : '')
          : '')
      + ((order.point_used && order.point_used > 0) ? '&point_use_amount=' + order.point_used : '');
%>
<div class="max-w-lg mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h1 class="text-xl font-bold text-gray-900 mb-4">결제하기</h1>
    <p class="text-gray-600 mb-6">총 <strong><%= Number(order.total_amount).toLocaleString() %>원</strong></p>

    <%
      /* 가상결제가 켜져 있으면 결제사 키가 있어도 가상으로 처리한다.
         개발 중 키를 넣어 둔 채로도 테스트할 수 있어야 하기 때문이다. */
      const useReal = clientKey && !virtualPayment;
    %>
    <% if (useReal) { %>
        <%# ── 실제 결제 (토스) ─────────────────────────────── %>
        <button type="button" id="paymentBtn" class="w-full max-w-xs mx-auto py-4 rounded-xl bg-[var(--gh-primary)] text-white font-semibold hover:bg-[var(--gh-primary-dark)]">
            결제 진행
        </button>
        <script src="https://js.tosspayments.com/v2/payment"></script>
        <script>
            document.getElementById('paymentBtn').addEventListener('click', function() {
                const clientKey = '<%= clientKey %>';
                const orderId = '<%= order.order_number %>';
                const amount = <%= order.total_amount %>;
                const successUrl = '<%= successUrl %>?paymentKey={paymentKey}&orderId={orderId}&amount={amount}';
                const failUrl = '<%= failUrl %>?reason=cancel';

                const payment = new TossPayments(clientKey);
                payment.requestPayment('CARD', {
                    amount: { value: amount, currency: 'KRW' },
                    orderId: orderId,
                    orderName: '주문 결제',
                    successUrl: successUrl,
                    failUrl: failUrl
                }).catch(function(err) {
                    if (err.code === 'USER_CANCEL') {
                        window.location.href = '<%= failUrl %>?reason=cancel';
                    } else {
                        alert('결제 요청 중 오류가 발생했습니다.');
                    }
                });
            });
        </script>
        <%#
           키가 있을 때는 우회 완료 링크를 두지 않는다.
           실제 결제를 건너뛰고 주문을 완료시킬 수 있는 통로가 되기 때문이다.
        %>
    <% } else if (virtualPayment) { %>
        <%# ── 가상결제 (관리자가 켠 개발·테스트 모드) ─────────── %>
        <div class="mb-6 p-4 bg-blue-50 border border-blue-200 rounded-xl text-blue-900 text-sm text-left">
            <p class="font-semibold"><i class="bi bi-info-circle mr-1"></i>가상결제 모드입니다</p>
            <p class="mt-1.5 leading-relaxed">
                <b>실제 결제 없이 주문이 완료</b>됩니다.
                재고 차감·쿠폰 사용·적립·배송 처리는 실제와 똑같이 진행되며, <b>돈은 청구되지 않습니다.</b>
            </p>
        </div>

        <a href="<%= testCompleteUrl %>"
           class="block w-full max-w-xs mx-auto py-4 rounded-xl bg-[var(--gh-primary)] text-white font-semibold hover:opacity-90 no-underline text-center">
            결제 없이 주문 완료
        </a>
    <% } else { %>
        <%# ── 결제 수단이 없고 가상결제도 꺼져 있다 → 주문을 마칠 방법이 없다 ── %>
        <div class="p-4 bg-amber-50 border border-amber-200 rounded-xl text-amber-900 text-sm text-left">
            <p class="font-semibold">결제를 진행할 수 없습니다</p>
            <p class="mt-1.5 leading-relaxed">
                결제 수단이 설정되지 않았습니다. 잠시 후 다시 시도하시거나 고객센터로 문의해 주세요.
            </p>
        </div>
        <p class="mt-4 text-xs text-gray-400">
            운영자 안내 — <span class="text-gray-500">관리자 &gt; 사이트 설정 &gt; 토스페이먼츠</span> 에서
            결제 키를 넣거나, 개발 중이라면 <b>가상결제 사용</b> 을 켜 주세요.
        </p>
    <% } %>

    <p class="mt-6">
        <a href="/cart" class="text-sm text-gray-400 hover:text-gray-600">장바구니로 돌아가기</a>
    </p>
</div>
