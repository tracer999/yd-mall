<%
const won = (n) => Number(n || 0).toLocaleString('ko-KR');
const d = (v) => (v ? new Date(v).toLocaleDateString('ko-KR') : '-');
%>
<div class="max-w-2xl mx-auto px-4 py-12">
  <% if (!order) { %>
    <div class="text-center">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">주문 정보를 찾을 수 없습니다</h1>
      <p class="text-gray-500 mb-6">주문번호가 올바른지 확인해 주세요.</p>
      <a href="/mypage/orders" class="inline-block px-6 py-3 rounded-lg bg-gray-900 text-white font-semibold no-underline">주문내역으로</a>
    </div>
  <% } else { %>
    <div class="text-center mb-8">
      <div class="mx-auto w-14 h-14 rounded-full bg-blue-100 flex items-center justify-center mb-4">
        <i class="bi bi-clipboard-check text-2xl text-blue-700"></i>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 mb-2">주문이 접수되었습니다</h1>
      <p class="text-gray-500">아직 결제는 이루어지지 않았습니다. 담당자 확인 후 입금 안내를 드립니다.</p>
    </div>

    <div class="rounded-xl border border-blue-200 bg-blue-50 p-4 mb-6">
      <p class="text-sm font-semibold text-blue-900 mb-2">다음 절차</p>
      <ol class="text-sm text-blue-900 space-y-1 list-decimal list-inside">
        <li><strong>주문 접수</strong> — 완료</li>
        <li>담당자 확인 및 승인</li>
        <li>입금 안내 (승인일로부터 <%= settings.paymentDueDays %>일 이내 입금)</li>
        <li>입금 확인 후 출고</li>
      </ol>
      <% if (settings.bankAccountInfo) { %>
        <p class="mt-3 pt-3 border-t border-blue-200 text-sm text-blue-900">
          입금 계좌: <strong><%= settings.bankAccountInfo %></strong>
        </p>
      <% } %>
    </div>

    <div class="bg-white border rounded-xl px-6 py-4 mb-6">
      <dl class="text-sm">
        <div class="flex py-2 border-b border-gray-100">
          <dt class="w-36 text-gray-500">주문번호</dt><dd class="font-semibold text-gray-900"><%= order.order_number %></dd>
        </div>
        <div class="flex py-2 border-b border-gray-100">
          <dt class="w-36 text-gray-500">주문일시</dt><dd class="text-gray-900"><%= new Date(order.created_at).toLocaleString('ko-KR') %></dd>
        </div>
        <div class="flex py-2 border-b border-gray-100">
          <dt class="w-36 text-gray-500">공급가액</dt><dd class="text-gray-900"><%= won(order.supply_amount) %>원</dd>
        </div>
        <div class="flex py-2 border-b border-gray-100">
          <dt class="w-36 text-gray-500">부가세</dt><dd class="text-gray-900"><%= won(order.vat_amount) %>원</dd>
        </div>
        <% if (order.tax_free_amount > 0) { %>
        <div class="flex py-2 border-b border-gray-100">
          <dt class="w-36 text-gray-500">면세 금액</dt><dd class="text-gray-900"><%= won(order.tax_free_amount) %>원</dd>
        </div>
        <% } %>
        <div class="flex py-2 border-b border-gray-100">
          <dt class="w-36 text-gray-500">배송비</dt><dd class="text-gray-900"><%= won(order.shipping_fee) %>원</dd>
        </div>
        <div class="flex py-2 border-b border-gray-100">
          <dt class="w-36 text-gray-500 font-semibold">주문 금액</dt>
          <dd class="text-lg font-bold text-blue-700"><%= won(order.total_amount) %>원</dd>
        </div>
        <% if (order.purchase_order_number) { %>
        <div class="flex py-2 border-b border-gray-100">
          <dt class="w-36 text-gray-500">발주번호</dt><dd class="text-gray-900"><%= order.purchase_order_number %></dd>
        </div>
        <% } %>
        <% if (order.requested_delivery_date) { %>
        <div class="flex py-2 border-b border-gray-100">
          <dt class="w-36 text-gray-500">납기 희망일</dt><dd class="text-gray-900"><%= d(order.requested_delivery_date) %></dd>
        </div>
        <% } %>
        <div class="flex py-2">
          <dt class="w-36 text-gray-500">세금계산서</dt>
          <dd class="text-gray-900"><%= order.tax_invoice_required ? '발행 요청' : '발행 안 함' %></dd>
        </div>
      </dl>
    </div>

    <div class="flex gap-3">
      <a href="/mypage/orders" class="flex-1 text-center px-6 py-3 rounded-lg bg-gray-900 text-white font-semibold no-underline">주문내역 보기</a>
      <a href="/products" class="flex-1 text-center px-6 py-3 rounded-lg border border-gray-300 text-gray-700 font-semibold no-underline">쇼핑 계속하기</a>
    </div>
  <% } %>
</div>
