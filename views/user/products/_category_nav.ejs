<%
/*
 * 카테고리 목록 페이지 상단 내비 (위치 + 하위 카테고리)
 *
 * categoryNav 가 있을 때만 include 한다 (NORMAL 카테고리 경로).
 * 브랜드·테마·전체 경로는 기존 사이드바 레이아웃을 쓴다.
 *
 * 패널 규칙: 자식이 있으면 자식, 리프면 형제(현재 강조).
 *   리프에서 자식을 깔면 패널이 통째로 빈다.
 *
 * 구성 원칙(2026-07 개편):
 *   - '홈' 크럼과 뒤로가기 버튼은 두지 않는다. 헤더 로고와 브라우저 뒤로가기가 이미 그 역할을 한다.
 *   - 경로에는 **조상만** 남기고, 현재 카테고리는 제목(h1)으로 승격한다.
 *     이 페이지에 다른 제목이 없어서(list.ejs 는 개수만 표시) 여기가 사실상 페이지 타이틀이다.
 *   - **배경(흰색)과 하단 구분선은 list.ejs 의 전폭 밴드가 담당한다.** 여기서 또 테두리를 두르면
 *     밴드 안에 카드가 겹쳐 이중 경계가 된다. 이 파일은 밴드 내부의 여백·타이포·칩만 책임진다.
 */
const _nav = categoryNav;
const _brandQs = currentBrand ? ('?brandId=' + encodeURIComponent(currentBrand)) : '';
const _catUrl = (id) => `/products/category/${id}${_brandQs}`;
const _parent = _nav.ancestors.length ? _nav.ancestors[_nav.ancestors.length - 1] : null;

/*
 * panelItems 가 형제 목록인지(= 현재가 리프) 자식 목록인지 구분한다.
 * 형제 모드에서는 칩 맨 앞에 '전체'(= 부모 카테고리 전체 상품)를 하나 더 놓는다.
 * 자식 모드에서는 현재 카테고리 자신이 이미 '전체'이므로 넣지 않는다.
 */
const _isSiblingMode = _nav.panelItems.some((i) => String(i.id) === String(_nav.current.id));
const _showAllChip = _isSiblingMode && !!_parent;
%>

<%# ── PC ─────────────────────────────────────────────────────────────────── %>
<section class="yd-cnav-pc hidden md:block" aria-label="카테고리">
    <div class="yd-cnav-pc__head">
        <% if (_nav.ancestors.length) { %>
            <nav class="yd-cnav-pc__path" aria-label="카테고리 경로">
                <% _nav.ancestors.forEach((node, i) => { %>
                    <% if (i > 0) { %><i class="bi bi-chevron-right yd-cnav-pc__sep" aria-hidden="true"></i><% } %>
                    <a href="<%= _catUrl(node.id) %>" class="yd-cnav-pc__crumb" title="<%= node.name %>"><%= node.name %></a>
                <% }) %>
            </nav>
        <% } %>
        <h1 class="yd-cnav-pc__title"><%= _nav.current.name %></h1>
    </div>

    <%# 칩 줄은 얇은 내부 구분선으로 제목과 갈라 놓는다 — 밴드 자체의 경계선(아래쪽)과 굵기를 달리해 위계를 준다. %>
    <% if (_nav.panelItems.length) { %>
        <ul class="yd-cnav-pc__chips">
            <% if (_showAllChip) { %>
                <li>
                    <a href="<%= _catUrl(_parent.id) %>" class="yd-cnav-pc__chip yd-cnav-pc__chip--all">
                        <i class="bi bi-grid-3x3-gap" aria-hidden="true"></i><span><%= _parent.name %> 전체</span>
                    </a>
                </li>
            <% } %>
            <% _nav.panelItems.forEach((item) => {
                 const _isCurrent = String(item.id) === String(_nav.current.id); %>
                <li>
                    <a href="<%= _catUrl(item.id) %>"
                       class="yd-cnav-pc__chip <%= _isCurrent ? 'is-current' : '' %>"
                       <%= _isCurrent ? 'aria-current="page"' : '' %>
                       title="<%= item.name %>"><%= item.name %></a>
                </li>
            <% }) %>
        </ul>
    <% } %>
</section>

<%# ── 모바일 ───────────────────────────────────────────────────────────────
    같은 구성을 세로로 압축한다. 칩 레일만 -mx-4 로 화면 가장자리까지 흘려
    "옆에 더 있다"를 보이게 하고, 내부 padding 으로 본문 정렬선을 맞춘다. %>
<section class="yd-cnav md:hidden" aria-label="카테고리">
    <div class="yd-cnav__head">
        <% if (_nav.ancestors.length) { %>
            <nav class="yd-cnav__path" aria-label="카테고리 경로">
                <% _nav.ancestors.forEach((node, i) => { %>
                    <% if (i > 0) { %><span class="yd-cnav__sep" aria-hidden="true">/</span><% } %>
                    <a href="<%= _catUrl(node.id) %>" class="yd-cnav__crumb" title="<%= node.name %>"><%= node.name %></a>
                <% }) %>
            </nav>
        <% } %>
        <h1 class="yd-cnav__title"><%= _nav.current.name %></h1>
    </div>

    <% if (_nav.panelItems.length) { %>
        <div class="yd-cnav__rail-wrap" data-cnav-rail-wrap>
            <div class="yd-cnav__rail" data-cnav-rail>
                <% if (_showAllChip) { %>
                    <a href="<%= _catUrl(_parent.id) %>" class="yd-cnav__chip yd-cnav__chip--all">
                        <i class="bi bi-grid-3x3-gap text-[10px]" aria-hidden="true"></i><span>전체</span>
                    </a>
                <% } %>
                <% _nav.panelItems.forEach((item) => {
                     const _isCurrent = String(item.id) === String(_nav.current.id); %>
                    <a href="<%= _catUrl(item.id) %>"
                       class="yd-cnav__chip <%= _isCurrent ? 'is-current' : '' %>"
                       <%= _isCurrent ? 'aria-current="page" data-cnav-current' : '' %>><%= item.name %></a>
                <% }) %>
            </div>
        </div>
    <% } %>
</section>

<style>
  /* ── PC ────────────────────────────────────────────────────────────────
     배경·하단 경계선은 밴드(list.ejs)가 갖는다. 여기서는 여백과 내부 위계만. */
  .yd-cnav-pc { padding: 1.125rem 0 1rem; }

  /* 좌측 액센트 바 — 브랜드 컬러로 "여기가 현재 위치"임을 표시한다 */
  .yd-cnav-pc__head { position: relative; padding-left: .75rem; }
  .yd-cnav-pc__head::before {
    content: "";
    position: absolute; left: 0; top: .15rem; bottom: .15rem;
    width: 3px; border-radius: 3px;
    background: var(--gh-primary);
  }

  /* 경로(조상). 좁아지면 조상 이름만 말줄임된다 — 한 줄 유지. */
  .yd-cnav-pc__path {
    display: flex; align-items: center; min-width: 0;
    margin-bottom: .125rem;
    font-size: .75rem; color: #9ca3af; white-space: nowrap; overflow: hidden;
  }
  .yd-cnav-pc__crumb {
    min-width: 0; overflow: hidden; text-overflow: ellipsis;
    transition: color .15s ease;
  }
  .yd-cnav-pc__crumb:hover { color: #374151; text-decoration: underline; }
  .yd-cnav-pc__sep { flex: 0 0 auto; margin: 0 .375rem; font-size: .625rem; color: #d1d5db; }

  .yd-cnav-pc__title {
    font-size: 1.375rem; font-weight: 800; line-height: 1.3;
    color: #111827; letter-spacing: -.02em;
  }

  /* 제목 ↔ 칩 사이의 내부 구분선. 밴드 하단 경계선(#e5e7eb)보다 옅게 둬 위계를 준다. */
  .yd-cnav-pc__chips {
    display: flex; flex-wrap: wrap; gap: .5rem;
    margin-top: .875rem; padding-top: .875rem;
    border-top: 1px solid #f3f4f6;
  }

  .yd-cnav-pc__chip {
    display: inline-flex; align-items: center; gap: .375rem;
    max-width: 14rem; height: 2rem; padding: 0 .875rem;
    border: 1px solid #e5e7eb; border-radius: 9999px;
    background: #fff; color: #4b5563;
    font-size: .8125rem; line-height: 1; white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis;
    transition: border-color .15s ease, color .15s ease, background-color .15s ease, box-shadow .15s ease;
  }
  .yd-cnav-pc__chip:hover {
    border-color: var(--gh-primary);
    color: var(--gh-primary-dark, var(--gh-primary));
    box-shadow: 0 1px 3px rgba(17, 24, 39, .08);
  }
  .yd-cnav-pc__chip--all { color: #6b7280; background: #f7f8fb; border-color: #e5e7eb; }
  .yd-cnav-pc__chip.is-current {
    background: var(--gh-primary); border-color: var(--gh-primary);
    color: #fff; font-weight: 700;
  }
  .yd-cnav-pc__chip.is-current:hover { color: #fff; }

  /* ── 모바일 ──────────────────────────────────────────────────────────── */
  .yd-cnav { --cnav-gutter: 1rem; padding: .875rem 0 .75rem; }

  .yd-cnav__head { position: relative; padding-left: .625rem; }
  .yd-cnav__head::before {
    content: "";
    position: absolute; left: 0; top: .1rem; bottom: .1rem;
    width: 3px; border-radius: 3px;
    background: var(--gh-primary);
  }

  .yd-cnav__path {
    display: flex; align-items: center; min-width: 0;
    font-size: .6875rem; color: #9ca3af; white-space: nowrap; overflow: hidden;
  }
  /* flex 기본 min-width:auto 때문에 min-width:0 이 없으면 말줄임이 먹지 않는다 */
  .yd-cnav__crumb {
    flex: 0 1 auto; min-width: 0;
    overflow: hidden; text-overflow: ellipsis;
    transition: color .15s ease;
  }
  .yd-cnav__crumb:active { color: #374151; }
  .yd-cnav__sep { flex: 0 0 auto; margin: 0 .25rem; color: #d1d5db; }

  .yd-cnav__title {
    font-size: 1.125rem; font-weight: 800; line-height: 1.3;
    color: #111827; letter-spacing: -.02em;
  }

  /* 레일만 화면 가장자리까지 흘린다(-1rem). 컨테이너 px-4 를 상쇄. */
  .yd-cnav__rail-wrap {
    position: relative;
    margin: .75rem -1rem 0;
    padding-top: .75rem;
    border-top: 1px solid #f3f4f6;
  }
  /* 양끝 페이드 — 넘칠 때만 켠다(스크롤 위치에 따라 JS 가 클래스를 토글).
     밴드 배경이 흰색이므로 흰색에서 투명으로. */
  .yd-cnav__rail-wrap::before,
  .yd-cnav__rail-wrap::after {
    content: ""; position: absolute; top: .75rem; bottom: 0; width: 1.75rem;
    pointer-events: none; opacity: 0; transition: opacity .2s ease; z-index: 1;
  }
  .yd-cnav__rail-wrap::before { left: 0;  background: linear-gradient(90deg, #fff 30%, rgba(255,255,255,0)); }
  .yd-cnav__rail-wrap::after  { right: 0; background: linear-gradient(270deg, #fff 30%, rgba(255,255,255,0)); }
  .yd-cnav__rail-wrap.is-scrolled::before { opacity: 1; }
  .yd-cnav__rail-wrap.has-more::after     { opacity: 1; }

  .yd-cnav__rail {
    display: flex; gap: .375rem;
    padding: .125rem var(--cnav-gutter);
    overflow-x: auto; overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x proximity;
    scroll-padding-inline: var(--cnav-gutter);
    /* 스크롤바는 숨긴다 — 칩 아래 회색 막대가 보이던 원인 */
    scrollbar-width: none; -ms-overflow-style: none;
  }
  .yd-cnav__rail::-webkit-scrollbar { display: none; }

  .yd-cnav__chip {
    flex: 0 0 auto; scroll-snap-align: start;
    display: inline-flex; align-items: center; gap: .25rem;
    height: 2rem; padding: 0 .875rem;
    border: 1px solid #e5e7eb; border-radius: 9999px;
    background: #fff; color: #4b5563;
    font-size: .8125rem; line-height: 1; white-space: nowrap;
    transition: transform .15s ease, border-color .15s ease, color .15s ease, background-color .15s ease;
  }
  .yd-cnav__chip:active { transform: scale(.95); border-color: #d1d5db; }
  .yd-cnav__chip--all { color: #6b7280; background: #f7f8fb; border-color: #e5e7eb; }

  .yd-cnav__chip.is-current {
    background: var(--gh-primary); border-color: var(--gh-primary);
    color: #fff; font-weight: 700;
    box-shadow: 0 4px 10px -4px rgba(17, 24, 39, .35);
  }

  @media (prefers-reduced-motion: reduce) {
    .yd-cnav__chip, .yd-cnav-pc__chip, .yd-cnav__rail-wrap::before, .yd-cnav__rail-wrap::after { transition: none; }
  }
</style>

<script>
  (function () {
    var wrap = document.querySelector('[data-cnav-rail-wrap]');
    if (!wrap) return;
    var rail = wrap.querySelector('[data-cnav-rail]');
    if (!rail) return;

    // 활성 칩을 시야 가운데로. scrollIntoView 는 페이지 세로 스크롤까지 건드리므로 scrollLeft 를 직접 계산한다.
    var current = rail.querySelector('[data-cnav-current]');
    if (current) {
      var target = current.offsetLeft - (rail.clientWidth - current.offsetWidth) / 2;
      rail.scrollLeft = Math.max(0, target);
    }

    function sync() {
      var max = rail.scrollWidth - rail.clientWidth;
      wrap.classList.toggle('is-scrolled', rail.scrollLeft > 4);
      wrap.classList.toggle('has-more', max - rail.scrollLeft > 4);
    }
    sync();
    rail.addEventListener('scroll', sync, { passive: true });
    window.addEventListener('resize', sync);
  })();
</script>
