<%# 상품 필터(facet) 패널 스타일 — 목록과 브랜드관이 함께 쓴다.
    설계: docs/사이트개선/카테고리_브랜드_상품필터_설계.md §8 %>
<style>
    /* ── 필터(facet) 패널 ─────────────────────────────────────────────
       설계: docs/사이트개선/카테고리_브랜드_상품필터_설계.md §8
       레이블 열 + 값 열의 2단 구조. 행마다 얇은 구분선을 둬 스캔이 되게 한다. */
    .facet-panel {
        margin-top: .75rem;
        border: 1px solid #e8eaee;
        border-radius: 12px;
        background: #fff;
        overflow: hidden;
    }

    .facet-row {
        display: flex;
        align-items: flex-start;
        gap: .875rem;
        padding: .625rem .875rem;
        border-top: 1px solid #f1f2f4;
    }
    .facet-row:first-child { border-top: 0; }

    .facet-row__label {
        flex: 0 0 5.5rem;
        padding-top: .3rem;
        font-size: 12px;
        font-weight: 700;
        color: #4b5563;
        letter-spacing: -.01em;
        line-height: 1.3;
    }
    .facet-row__label i { font-style: normal; font-weight: 500; color: #9ca3af; }

    .facet-row__values {
        flex: 1 1 auto;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: .375rem;
        min-width: 0;
    }
    .facet-row__values.is-grid { gap: .3rem; }

    .facet-row__reset {
        margin-left: .25rem;
        font-size: 11px;
        color: #9ca3af;
        text-decoration: underline;
    }
    .facet-row__reset:hover { color: #4b5563; }

    /* 알약 — 기본은 조용하고, 선택되면 확실히 눈에 띈다. */
    .facet-pill {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .3rem .625rem;
        border: 1px solid #e5e7eb;
        border-radius: 9999px;
        background: #fff;
        font-size: 12.5px;
        color: #4b5563;
        text-decoration: none;
        transition: border-color .15s, color .15s, background-color .15s;
    }
    .facet-pill:hover { border-color: #c7cbd1; color: #111827; }
    .facet-pill.is-on {
        background: var(--gh-primary);
        border-color: var(--gh-primary);
        color: #fff;
        font-weight: 600;
    }

    /* 사이즈 격자 — 알약보다 촘촘하게, 숫자 정렬이 되도록 고정폭. */
    .facet-cell {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.75rem;
        padding: .3rem .45rem;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        background: #fff;
        font-size: 12px;
        font-variant-numeric: tabular-nums;
        color: #4b5563;
        text-decoration: none;
        transition: border-color .15s, color .15s, background-color .15s;
    }
    .facet-cell:hover { border-color: #c7cbd1; color: #111827; }
    .facet-cell.is-on {
        background: #111827;
        border-color: #111827;
        color: #fff;
        font-weight: 600;
    }

    /* 색상 스와치 — 선택은 링으로 표시한다(테두리는 밝은 색에서 안 보인다). */
    .facet-sw {
        width: 1.5rem;
        height: 1.5rem;
        border-radius: 9999px;
        background: var(--sw, #fff);
        border: 1px solid rgba(0, 0, 0, .14);
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, .06);
        transition: transform .12s, box-shadow .12s;
        display: inline-block;
    }
    .facet-sw:hover { transform: scale(1.12); }
    .facet-sw.is-on {
        box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--gh-primary);
    }
    .facet-sw.is-multi {
        background: conic-gradient(#ef4444, #f59e0b, #10b981, #3b82f6, #a855f7, #ef4444);
    }

    /* 적용된 조건 — 패널 맨 위에 눈에 띄는 띠로. */
    .facet-chips {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: .375rem;
        padding: .625rem .875rem;
        background: var(--gh-secondary, #f6f8f7);
        border-bottom: 1px solid #e8eaee;
    }
    .facet-chips__lead { font-size: 11.5px; color: #6b7280; margin-right: .125rem; }
    .facet-chips__lead b { color: var(--gh-primary); }
    .facet-chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .25rem .5rem .25rem .5rem;
        border-radius: 9999px;
        background: #fff;
        border: 1px solid #dfe3e8;
        font-size: 12px;
        color: #111827;
        text-decoration: none;
    }
    .facet-chip:hover { border-color: #9ca3af; }
    .facet-chip__k { font-size: 10.5px; color: #9ca3af; }
    .facet-chip__x { color: #9ca3af; font-size: 13px; line-height: 1; }
    .facet-chip:hover .facet-chip__x { color: #ef4444; }
    .facet-chips__clear {
        margin-left: auto;
        font-size: 11.5px;
        color: #6b7280;
        text-decoration: underline;
    }

    /* 가격 직접 입력 */
    .facet-range { display: flex; align-items: center; gap: .375rem; flex-wrap: wrap; }
    .facet-range input[type="number"] {
        width: 6.5rem;
        padding: .3rem .5rem;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        font-size: 12.5px;
        text-align: right;
        font-variant-numeric: tabular-nums;
    }
    .facet-range input[type="number"]:focus {
        outline: none;
        border-color: var(--gh-primary);
        box-shadow: 0 0 0 2px color-mix(in srgb, var(--gh-primary) 18%, transparent);
    }
    .facet-range__dash, .facet-range__won { font-size: 12px; color: #9ca3af; }
    .facet-range button {
        padding: .32rem .75rem;
        border: 1px solid var(--gh-primary);
        border-radius: 6px;
        background: #fff;
        color: var(--gh-primary);
        font-size: 12px;
        font-weight: 600;
        transition: background-color .15s, color .15s;
    }
    .facet-range button:hover { background: var(--gh-primary); color: #fff; }
    .facet-range__reset { font-size: 11px; color: #9ca3af; text-decoration: underline; }

    /* 값 옆 건수 — 보조 정보라 작고 흐리게. 선택되면 같이 반전된다. */
    .facet-cnt {
        margin-left: .3rem;
        font-size: 10.5px;
        color: #9ca3af;
        font-variant-numeric: tabular-nums;
    }
    .facet-pill.is-on .facet-cnt, .facet-cell.is-on .facet-cnt { color: rgba(255, 255, 255, .75); }

    /* 값이 많은 필터(브랜드 등)의 인라인 더보기 */
    .facet-inline-more { display: inline; }
    .facet-inline-more > summary {
        display: inline-block;
        padding: .3rem .55rem;
        border: 1px dashed #d1d5db;
        border-radius: 9999px;
        font-size: 11.5px;
        color: #6b7280;
        cursor: pointer;
        list-style: none;
    }
    .facet-inline-more > summary::-webkit-details-marker { display: none; }
    .facet-inline-more > summary:hover { border-color: #9ca3af; color: #111827; }
    .facet-inline-more[open] > summary { display: none; }
    .facet-inline-more__body { display: contents; }

    /* 상세 필터 더보기 */
    .facet-more { border-top: 1px solid #f1f2f4; }
    .facet-more > summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .5rem .875rem;
        font-size: 12px;
        color: #6b7280;
        cursor: pointer;
        list-style: none;
        user-select: none;
    }
    .facet-more > summary::-webkit-details-marker { display: none; }
    .facet-more > summary:hover { background: #fafbfc; color: #111827; }
    .facet-more > summary b { color: var(--gh-primary); }
    .facet-more > summary i { transition: transform .18s; }
    .facet-more[open] > summary i { transform: rotate(180deg); }
    .facet-more__body { border-top: 1px solid #f1f2f4; }

    @media (max-width: 640px) {
        .facet-row { flex-direction: column; gap: .375rem; padding: .5rem .75rem; }
        .facet-row__label { flex: none; padding-top: 0; }
        .facet-row__values { width: 100%; }
        .facet-range input[type="number"] { width: 5.5rem; }
    }
</style>
