<style>
    @keyframes blink-shine {

        0%,
        100% {
            opacity: 1;
            color: var(--gh-primary-dark);
            text-shadow: 0 0 6px color-mix(in srgb, var(--gh-primary) 40%, transparent);
        }

        50% {
            opacity: 0.65;
            color: var(--gh-primary);
            text-shadow: 0 0 18px color-mix(in srgb, var(--gh-primary) 70%, transparent);
        }
    }

    .animate-blink-shine {
        animation: blink-shine 1.6s infinite ease-in-out;
    }

    .brand-thumb {
        border: 2px solid transparent;
        opacity: 0.6;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
        cursor: pointer;
    }

    .brand-thumb:hover {
        opacity: 0.85;
    }

    .brand-thumb.is-active {
        border-color: var(--gh-primary);
        box-shadow: 0 0 0 3px var(--gh-primary-ring);
        opacity: 1;
    }

    .status-banner {
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
    }

    .status-image-dim {
        filter: grayscale(0.6);
        opacity: 0.7;
    }

    .status-image-overlay {
        background: radial-gradient(circle at center, rgba(0, 0, 0, 0.25) 0, rgba(0, 0, 0, 0.4) 55%, rgba(0, 0, 0, 0.55) 100%);
    }

    .product-pill-badge {
        border-radius: 9999px;
        padding: 0.32rem 0.7rem;
        font-size: 12px;
        font-weight: 700;
        line-height: 1;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
        white-space: nowrap;
    }

    .badge-channel {
        background: var(--gh-primary);
        color: #fff;
    }

    .badge-best {
        background: #ef4444;
        color: #fff;
    }

    .badge-new {
        background: #10b981;
        color: #fff;
    }

    .badge-recommend {
        background: #f59e0b;
        color: #fff;
    }
</style>

<% const productStatus=product.status || 'ON' ; const availableStock=(product.stock !=null && product.stock>= 0) ?
    product.stock : 0;
    const isSoldOut = (productStatus === 'SOLD_OUT') || availableStock <= 0; const isStopped=productStatus==='OFF' ;
        const isComingSoon=productStatus==='COMING_SOON' ; const isRestock=productStatus==='RESTOCK' ;
        const isOutOfStock=isSoldOut; const
        isPurchasable=(productStatus==='ON' ) && !isSoldOut; const
        /* 오프라인전용 뱃지 미사용으로 ONLINE_ONLY만 표시 */
        distributionBadgeText=product.distribution_badge==='ONLINE_ONLY' ? '온라인판매가능' : null;
        const _detailAllBadges = product.product_badge ? product.product_badge.split(',') : [];
        const _detailTopMap = { 'BEST': { text: 'BEST', cls: 'badge-best' }, 'NEW': { text: 'NEW', cls: 'badge-new' }, 'RECOMMEND': { text: '추천', cls: 'badge-recommend' } };
        const _detailPriceMap = { 'DEADLINE_SALE': { text: '기간임박할인', cls: 'badge-deadline' }, 'GREENHUB_SPECIAL': { text: '와이디몰특가', cls: 'badge-greenhub' } };
        /* NEW 는 뱃지 문자열이 아니라 신상품 판정(services/catalog/newArrival)으로 그린다 */
        const _detailTopBadges = _detailAllBadges.filter(b => _detailTopMap[b] && b !== 'NEW');
        if (typeof isNewProduct === 'function' ? isNewProduct(product) : _detailAllBadges.includes('NEW')) _detailTopBadges.unshift('NEW');
        const _detailPriceBadges = _detailAllBadges.filter(b => _detailPriceMap[b]); %>

        <% if (typeof stockError !=='undefined' && stockError) { %>
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
                <div class="mb-4 p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
                    <i class="bi bi-exclamation-circle mr-2"></i>재고가 부족합니다. (최대 <%= stockError %>개)
                </div>
            </div>
            <% } %>
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2">
                    <div class="flex flex-wrap items-center gap-3">
                        <button onclick="history.length > 1 ? history.back() : location.href='/products'" class="inline-flex items-center text-sm font-bold text-gray-700 hover:text-[color:var(--gh-primary-dark)] transition-colors py-1.5 px-2 -ml-2 rounded-lg hover:bg-gray-100">
                            <i class="bi bi-arrow-left text-lg mr-1.5 leading-none"></i>
                            뒤로가기
                        </button>
                        
                        <div class="h-4 w-px bg-gray-300 hidden sm:block"></div>
                        
                        <!-- Breadcrumbs -->
                        <nav class="hidden sm:flex text-sm font-medium text-gray-500" aria-label="Breadcrumb">
                            <ol class="inline-flex items-center space-x-2">
                                <li>
                                    <a href="/" class="hover:text-[color:var(--gh-primary-dark)] transition-colors flex items-center"><i class="bi bi-house-door text-[15px]"></i></a>
                                </li>
                                <li>
                                    <i class="bi bi-chevron-right text-xs text-gray-400"></i>
                                </li>
                                <li>
                                    <a href="/products" class="hover:text-[color:var(--gh-primary-dark)] transition-colors">상품목록</a>
                                </li>
                                <% if (product.category_name) { %>
                                <li>
                                    <i class="bi bi-chevron-right text-xs text-gray-400"></i>
                                </li>
                                <li>
                                    <span class="text-gray-900 font-semibold"><%= product.category_name %></span>
                                </li>
                                <% } %>
                            </ol>
                        </nav>
                    </div>
                </div>

                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 lg:py-10">
                    <div class="flex flex-col lg:flex-row gap-12">

                        <!-- Left: Image Gallery -->
                        <div class="w-full lg:w-1/2 space-y-4">
                            <!-- Main Image Display (Fixed 456x456) -->
                            <div class="w-full flex justify-center">
                                <div
                                    class="w-[456px] h-[456px] bg-white rounded-2xl overflow-hidden border border-gray-100 flex items-center justify-center relative group">
                                    <% const mainImg=product.main_image
                                        || 'https://via.placeholder.com/600x600?text=No+Image' ; %>

                                        <% if (isStopped || isComingSoon || isRestock || isSoldOut) { %>
                                            <div
                                                class="absolute inset-0 flex items-center justify-center pointer-events-none <%= (isSoldOut && !isStopped && !isComingSoon && !isRestock) ? 'status-image-overlay' : '' %>">
                                                <div class="px-4 py-1.5 rounded-lg text-white text-base font-bold status-banner shadow-md backdrop-blur-sm
                                <%= isStopped
                                    ? 'bg-red-600/90'
                                    : (isRestock
                                        ? 'bg-gradient-to-r from-blue-400/90 to-cyan-400/90 text-white animate-blink-shine'
                                        : (isComingSoon
                                            ? 'bg-gradient-to-r from-yellow-400/90 to-orange-400/90 text-white animate-blink-shine'
                                            : 'bg-gray-800/85')) %>">
                                                    <% if (isStopped) { %>
                                                        판매중지
                                                        <% } else if (isRestock) { %>
                                                            재입고예정
                                                        <% } else if (isComingSoon) { %>
                                                            COMING SOON
                                                            <% } else { %>
                                                                SOLD OUT
                                                                <% } %>
                                                </div>
                                            </div>
                                            <% } %>

                                                <img id="mainImage" src="<%= mainImg %>"
                                                    class="w-full h-full object-contain p-4 transition duration-300 <%= (isSoldOut && !isStopped && !isComingSoon && !isRestock) ? 'status-image-dim' : '' %>">
                                </div>
                            </div>

                            <!-- Thumbnails (Centered to match) -->
                            <div class="w-[85%] mx-auto flex gap-3 overflow-x-auto pb-2 scrollbar-hide justify-center">
                                <!-- Main Image Thumbnail -->
                                <button type="button" data-url="<%= mainImg %>"
                                    class="flex-shrink-0 w-20 h-20 rounded-xl overflow-hidden bg-white focus:outline-none transition brand-thumb is-active">
                                    <img src="<%= mainImg %>" class="w-full h-full object-contain p-1 pointer-events-none">
                                </button>

                                <!-- Additional Images -->
                                <% if(product.images && product.images.length> 0) { %>
                                    <% product.images.forEach(img=> { %>
                                        <button type="button" data-url="<%= img.image_url %>"
                                            class="flex-shrink-0 w-20 h-20 rounded-xl overflow-hidden bg-white focus:outline-none transition brand-thumb">
                                            <img src="<%= img.image_url %>" class="w-full h-full object-contain p-1 pointer-events-none">
                                        </button>
                                        <% }) %>
                                            <% } %>
                            </div>
                        </div>

                        <!-- Right: Product Information -->
                        <div class="w-full lg:w-1/2 flex flex-col">

                            <div class="flex justify-between items-start mb-4">
                                <span
                                    class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold brand-chip">
                                    <%= product.category_name %>
                                </span>
                                <div class="flex items-center gap-1 sm:gap-2">
                                    <button
                                        class="text-gray-400 hover:text-[color:var(--gh-primary)] transition-colors p-2"
                                        id="likeBtn" onclick="toggleLike('<%= product.id %>')">
                                        <i
                                            class="bi <%= isLiked ? 'bi-heart-fill brand-text' : 'bi-heart' %> text-2xl"></i>
                                    </button>
                                    <button type="button"
                                        class="text-gray-400 hover:text-[color:var(--gh-primary-dark)] transition-colors p-2"
                                        onclick="toggleShareModal(true)" aria-label="공유하기">
                                        <i class="bi bi-share text-2xl"></i>
                                    </button>
                                </div>
                            </div>

                            <% if (distributionBadgeText || _detailAllBadges.length > 0) { %>
                                <div class="flex flex-wrap items-center gap-2 mb-3">
                                    <% if (distributionBadgeText) { %>
                                        <span class="product-pill-badge badge-channel">
                                            <%= distributionBadgeText %>
                                        </span>
                                    <% } %>
                                    <% _detailAllBadges.forEach(b => { const top = _detailTopMap[b]; const price = _detailPriceMap[b]; const info = top || price; if (info) { %>
                                        <span class="product-pill-badge <%= info.cls %>">
                                            <%= info.text %>
                                        </span>
                                    <% } }) %>
                                </div>
                                <% } %>
                                    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 leading-tight mb-2">
                                        <%= product.name %>
                                    </h1>
                                    <p class="text-gray-500 text-sm mb-6">
                                        <%= product.provider %> <span class="text-gray-400">(상품코드 : <%= product.id %>
                                                    )</span>
                                    </p>

                                    <!-- Short Description -->
                                    <% if(product.short_description) { %>
                                        <div
                                            class="bg-gray-50 rounded-xl p-4 mb-8 text-gray-600 text-sm leading-relaxed border border-gray-100 prose max-w-none">
                                            <%- product.short_description.replace(/\n/g, '<br>' ) %>
                                        </div>
                                        <% } %>

                                            <!-- Price Info -->
                                            <%
                                                const displayPrice = product.price;
                                                const displayListPrice = (product.original_price && product.original_price > displayPrice) ? product.original_price : null;
                                                /*
                                                 * B2B 전용가 (설계 §6.1).
                                                 * b2bInfo 는 승인·미승인 사업자에게만 채워진다. 일반 사용자·비로그인은 null 이라
                                                 * 아래 블록이 통째로 렌더되지 않는다 — 기존 화면과 완전히 동일하다.
                                                 */
                                                const _b2b = locals.b2b || { state: 'NONE', active: false };
                                                const _bi = locals.b2bInfo || null;
                                                const _btax = locals.b2bTax || null;
                                                const _showB2bPrice = _bi && _bi.priceSource !== 'B2C_FALLBACK';
                                                const _pendingBiz = _b2b.state && !['NONE', 'APPROVED'].includes(_b2b.state);
                                            %>

                                                <% if (_showB2bPrice) { %>
                                                    <!-- 기업 전용가 -->
                                                    <div class="w-full mb-6 rounded-xl border-2 border-blue-200 bg-blue-50 p-4">
                                                        <div class="flex items-center justify-between mb-2">
                                                            <span class="text-xs font-bold px-2 py-0.5 rounded bg-blue-600 text-white">기업 전용가</span>
                                                            <% if (_bi.discountRate > 0) { %>
                                                                <span class="text-sm font-bold text-blue-700">일반가 대비 <%= _bi.discountRate %>% ↓</span>
                                                            <% } %>
                                                        </div>
                                                        <div class="text-right">
                                                            <div class="flex items-baseline justify-end gap-2">
                                                                <span class="text-3xl font-bold text-blue-900"><%= Number(_bi.unitPrice).toLocaleString() %>원</span>
                                                            </div>
                                                            <% if (_btax && _b2b.taxDisplay === 'EXCLUSIVE') { %>
                                                                <p class="mt-1 text-sm text-blue-800">
                                                                    공급가 <strong><%= Number(_btax.supply).toLocaleString() %>원</strong>
                                                                    <% if (_btax.vat > 0) { %> + VAT <%= Number(_btax.vat).toLocaleString() %>원<% } else { %> (면세)<% } %>
                                                                </p>
                                                            <% } %>
                                                            <p class="mt-1 text-xs text-gray-500">
                                                                일반 판매가 <span class="line-through"><%= Number(_bi.listPrice).toLocaleString() %>원</span>
                                                            </p>
                                                        </div>

                                                        <% if (_bi.minOrderQty > 1) { %>
                                                            <p class="mt-3 pt-3 border-t border-blue-200 text-sm text-blue-900">
                                                                최소 주문수량 <strong><%= _bi.minOrderQty %>개</strong>
                                                            </p>
                                                        <% } %>
                                                        <p class="mt-2 text-xs text-blue-700">
                                                            대량 주문 단가는 견적으로 협의하실 수 있습니다.
                                                        </p>
                                                    </div>
                                                <% } else if (_pendingBiz) { %>
                                                    <!-- 승인 전 사업자 -->
                                                    <div class="w-full mb-6 rounded-xl border border-amber-200 bg-amber-50 p-4">
                                                        <p class="text-sm text-amber-900">
                                                            기업 전용가는 <strong>사업자 승인 후</strong> 확인하실 수 있습니다.
                                                            <a href="/b2b/status" class="underline underline-offset-2">신청 상태 보기</a>
                                                        </p>
                                                    </div>
                                                <% } %>

                                                <div class="flex flex-col items-end gap-1 w-full text-right mb-8">
                                                    <!-- 정가 (할인 시 취소선) -->
                                                    <% if (displayListPrice) { %>
                                                        <div class="flex items-center justify-end gap-2">
                                                            <span class="text-sm font-medium text-gray-400">정가</span>
                                                            <span class="text-lg font-medium text-gray-400 line-through">
                                                                <%= Number(displayListPrice).toLocaleString() %>원
                                                            </span>
                                                        </div>
                                                    <% } %>
                                                    <!-- 판매가 -->
                                                    <div class="flex items-center justify-end gap-2">
                                                        <% if (product.discount_rate > 0) { %>
                                                            <span class="text-lg font-bold text-[var(--gh-accent)]"><%= product.discount_rate %>%</span>
                                                        <% } %>
                                                        <span class="text-3xl font-bold text-gray-900">
                                                            <%= Number(displayPrice).toLocaleString() %>원
                                                        </span>
                                                    </div>
                                                </div>

                                                <%#
                                                  아울렛 고지 — 구매 버튼 위에 둔다.
                                                  리퍼브·전시·포장훼손 상품을 일반 상품처럼 보여주면 교환·반품 분쟁이 난다.
                                                  '왜 싼가'(사유)와 '어떤 상태인가'(등급·하자)를 구매 전에 반드시 읽히게 한다.
                                                  아울렛 상품이 아니면 outletInfo 가 null 이라 아무것도 그리지 않는다.
                                                  → 설계: docs/사이트개선/outlet_design_and_development.md §4-4
                                                %>
                                                <% if (typeof outletInfo !== 'undefined' && outletInfo) { %>
                                                    <div class="mb-6 rounded-xl border-2 <%= outletInfo.hasDisclosure ? 'border-orange-300 bg-orange-50' : 'border-gray-200 bg-gray-50' %> p-4">
                                                        <div class="flex items-center gap-2 mb-2">
                                                            <span class="px-2 py-0.5 text-xs font-bold text-white rounded bg-gray-900">아울렛</span>
                                                            <span class="text-sm font-bold text-gray-900"><%= outletInfo.typeLabel %></span>
                                                            <% if (outletInfo.condition_grade) { %>
                                                                <span class="px-1.5 py-0.5 text-xs font-bold rounded border border-gray-300 bg-white text-gray-700">
                                                                    <%= outletInfo.condition_grade %>급
                                                                </span>
                                                            <% } %>
                                                        </div>

                                                        <% if (outletInfo.outlet_reason) { %>
                                                            <p class="text-sm text-gray-700 mb-2"><%= outletInfo.outlet_reason %></p>
                                                        <% } %>

                                                        <% if (outletInfo.outlet_type === 'EXPIRY_SOON' && outletInfo.expiry_at) { %>
                                                            <p class="text-sm font-bold text-red-600 mb-2">
                                                                <i class="bi bi-calendar-x"></i>
                                                                유통기한 <%= new Date(outletInfo.expiry_at).toLocaleDateString('ko-KR') %>까지
                                                            </p>
                                                        <% } %>

                                                        <% if (outletInfo.defect_description) { %>
                                                            <div class="mt-2 pt-2 border-t border-orange-200">
                                                                <p class="text-xs font-bold text-orange-800 mb-1">
                                                                    <i class="bi bi-exclamation-triangle-fill"></i> 상품 상태 고지
                                                                </p>
                                                                <p class="text-sm text-orange-900 leading-relaxed"><%= outletInfo.defect_description %></p>
                                                            </div>
                                                        <% } %>

                                                        <p class="mt-2 pt-2 border-t <%= outletInfo.hasDisclosure ? 'border-orange-200' : 'border-gray-200' %> text-xs text-gray-500 leading-relaxed">
                                                            아울렛 상품은 기간 한정 할인이 아니라 <strong>할인 사유가 상품 자체에 있는</strong> 상품입니다.
                                                            <% if (outletInfo.hasDisclosure) { %>
                                                                위 상태를 확인하고 구매해 주세요. 고지된 하자는 교환·반품 사유가 되지 않습니다.
                                                            <% } %>
                                                            <a href="/outlet" class="underline">아울렛 전체보기</a>
                                                        </p>
                                                    </div>
                                                <% } %>

                                                <!-- ===== 구매 패널 (SKU/옵션) ===== -->
                                                <% const _hasOptions = (typeof productOptions !== 'undefined' && productOptions && productOptions.length > 0); %>
                                                <% if (isPurchasable || _hasOptions) { %>
                                                <div id="purchasePanel" class="border border-gray-200 rounded-2xl p-5 mb-6 bg-white"
                                                     data-is-option="<%= _hasOptions ? '1' : '0' %>"
                                                     <% if (_showB2bPrice) { %>data-b2b-price="1"<% } %>>
                                                    <% if (_hasOptions) { %>
                                                        <div class="space-y-3 mb-4">
                                                            <% productOptions.forEach(function(opt, oi){ %>
                                                                <div>
                                                                    <label class="block text-sm font-medium text-gray-700 mb-1"><%= opt.option_name %></label>
                                                                    <select class="opt-select w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" data-oi="<%= oi %>">
                                                                        <option value="">선택하세요</option>
                                                                        <% (opt.values||[]).forEach(function(v){ %>
                                                                            <option value="<%= v.id %>"><%= v.value_name %></option>
                                                                        <% }) %>
                                                                    </select>
                                                                </div>
                                                            <% }) %>
                                                        </div>
                                                        <div id="skuSummary" class="text-sm text-gray-500 mb-4">옵션을 선택하세요.</div>
                                                    <% } %>

                                                    <div class="flex items-baseline justify-between mb-4">
                                                        <span class="text-sm text-gray-500"><%= _showB2bPrice ? '기업 전용가' : '판매가' %></span>
                                                        <span id="panelPrice" class="text-2xl font-bold <%= _showB2bPrice ? 'text-blue-900' : 'text-gray-900' %>"><%= Number((_showB2bPrice ? _bi.unitPrice : product.price) || 0).toLocaleString() %>원</span>
                                                    </div>

                                                    <form id="add-to-cart-form" action="/cart/add" method="post">
                                                        <input type="hidden" name="product_id" value="<%= product.id %>">
                                                        <input type="hidden" name="sku_id" id="selectedSkuId" value="">
                                                        <div class="flex items-center justify-between mb-4">
                                                            <span class="text-sm text-gray-500">수량</span>
                                                            <div class="flex items-center border border-gray-200 rounded-xl overflow-hidden bg-white">
                                                                <button type="button" class="w-9 h-9 flex items-center justify-center text-gray-500 hover:bg-gray-50" onclick="changeOrderQuantity(-1)"><i class="bi bi-dash"></i></button>
                                                                <input id="orderQuantity" name="quantity" type="number"
                                                                       min="<%= _showB2bPrice ? _bi.minOrderQty : 1 %>"
                                                                       value="<%= _showB2bPrice ? _bi.minOrderQty : 1 %>"
                                                                       max="<%= availableStock %>" data-max="<%= availableStock %>"
                                                                       data-min="<%= _showB2bPrice ? _bi.minOrderQty : 1 %>"
                                                                       class="w-14 text-center text-sm border-0 focus:ring-0 focus:outline-none" />
                                                                <button type="button" class="w-9 h-9 flex items-center justify-center text-gray-500 hover:bg-gray-50" onclick="changeOrderQuantity(1)"><i class="bi bi-plus"></i></button>
                                                            </div>
                                                        </div>
                                                        <div class="flex flex-col gap-2">
                                                            <button type="submit" id="addCartBtn" class="w-full py-3 rounded-xl border border-gray-900 text-gray-900 font-semibold hover:bg-gray-50 transition">장바구니 담기</button>
                                                            <button type="button" id="buyNowBtn" onclick="goToCheckout()" class="w-full py-3 rounded-xl <%= _showB2bPrice ? 'bg-blue-700 hover:bg-blue-800' : 'bg-gray-900 hover:bg-gray-700' %> text-white font-semibold transition"><%= _showB2bPrice ? '주문 요청' : '바로구매' %></button>
                                                        </div>
                                                    </form>
                                                </div>
                                                <script id="sku-data" type="application/json"><%- JSON.stringify({ options: (typeof productOptions !== 'undefined' && productOptions) || [], skus: (typeof productSkus !== 'undefined' && productSkus) || [] }).replace(/</g, '\\u003c') %></script>
                                                <script>
                                                (function(){
                                                    var el = document.getElementById('sku-data');
                                                    var panel = document.getElementById('purchasePanel');
                                                    if(!el || !panel || panel.dataset.isOption !== '1') return; // 단일상품은 서버가 대표 SKU 해석
                                                    var data = JSON.parse(el.textContent);
                                                    var selectedSkuInput = document.getElementById('selectedSkuId');
                                                    var priceEl = document.getElementById('panelPrice');
                                                    var summaryEl = document.getElementById('skuSummary');
                                                    var qtyInput = document.getElementById('orderQuantity');
                                                    var addBtn = document.getElementById('addCartBtn');
                                                    var buyBtn = document.getElementById('buyNowBtn');
                                                    var selects = [].slice.call(panel.querySelectorAll('.opt-select'));

                                                    function setEnabled(on){
                                                        [addBtn, buyBtn].forEach(function(b){ if(b){ b.disabled = !on; b.classList.toggle('opacity-40', !on); b.classList.toggle('cursor-not-allowed', !on); } });
                                                    }
                                                    setEnabled(false);

                                                    function resolve(){
                                                        var ids = selects.map(function(s){ return s.value; });
                                                        if(ids.some(function(v){ return !v; })){ summaryEl.textContent='옵션을 선택하세요.'; selectedSkuInput.value=''; setEnabled(false); return; }
                                                        var idset = ids.map(Number);
                                                        var sku = data.skus.find(function(s){
                                                            return s.valueIds && s.valueIds.length===idset.length && idset.every(function(id){ return s.valueIds.indexOf(id)>=0; });
                                                        });
                                                        if(!sku){ summaryEl.textContent='해당 옵션 조합은 판매하지 않습니다.'; selectedSkuInput.value=''; setEnabled(false); return; }
                                                        selectedSkuInput.value = sku.id;
                                                        /*
                                                         * B2B 전용가는 상품 단위로 정한다(1단계). SKU 를 골라도 전용가는 그대로여야 하므로
                                                         * 여기서 덮어쓰지 않는다. 일반 사용자는 data-b2b-price 가 없어 예전처럼 SKU 가로 갱신된다.
                                                         */
                                                        if(priceEl && !panel.dataset.b2bPrice) priceEl.textContent = Number(sku.price).toLocaleString()+'원';
                                                        var stock = Math.max(0, sku.stock||0);
                                                        if(qtyInput){ qtyInput.max = stock; qtyInput.dataset.max = stock; if((parseInt(qtyInput.value,10)||1) > stock) qtyInput.value = stock>0?1:1; }
                                                        if(sku.status==='OFF' || stock<=0){ summaryEl.textContent='선택하신 옵션은 품절입니다.'; setEnabled(false); }
                                                        else { summaryEl.textContent='재고 '+stock.toLocaleString()+'개'; setEnabled(true); }
                                                    }
                                                    selects.forEach(function(s){ s.addEventListener('change', resolve); });
                                                })();
                                                </script>
                                                <% } %>

