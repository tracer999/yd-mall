                                                            <% } %>
                                            </div>
                                            <p class="text-gray-700 leading-relaxed">
                                                <%= review.content %>
                                            </p>
                                        </li>
                                        <% }) %>
                                            <% if(reviews.length===0) { %>
                                                <li class="p-16 text-center text-gray-500 bg-gray-50">
                                                    <i class="bi bi-chat-text text-4xl mb-4 block text-gray-300"></i>
                                                    등록된 리뷰가 없습니다. 첫 리뷰를 작성해보세요!
                                                </li>
                                                <% } %>
                                </ul>
                            </div>

                            <!-- Inquiry Tab -->
                            <div id="inquiry" class="tab-pane hidden">
                                <div
                                    class="text-center py-16 bg-gray-50 rounded-2xl border border-dashed border-gray-300">
                                    <i class="bi bi-question-circle text-4xl text-gray-400 mb-4 block"></i>
                                    <p class="text-gray-600 mb-6 text-lg">상품에 대해 궁금한 점이 있으신가요?</p>
                                    <button
                                        class="px-8 py-3 brand-pill--ghost font-bold rounded-xl transition">문의하기</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 공유 모달 (PC/모바일 공통) -->
                    <div id="shareModal" class="fixed inset-0 flex items-center justify-center z-50 hidden"
                        style="background-color: rgba(15, 23, 42, 0.35);"
                        onclick="if(event.target === this) toggleShareModal(false)">
                        <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm mx-4 p-6">
                            <h3 class="text-base font-semibold text-gray-900 mb-4">공유하기</h3>
                            <div class="space-y-3 text-sm">
                                <button type="button"
                                    class="w-full flex items-center justify-between px-4 py-3 rounded-xl border border-yellow-300 bg-yellow-50 text-yellow-800 font-medium hover:bg-yellow-100"
                                    onclick="shareToKakao()">
                                    <span class="flex items-center gap-2">
                                        <i class="bi bi-chat-fill"></i>
                                        <span>카카오톡으로 공유</span>
                                    </span>
                                    <% if (!(typeof kakaoJsKey !=='undefined' && kakaoJsKey)) { %>
                                        <span class="text-[11px] text-yellow-700">관리자 설정 필요</span>
                                        <% } %>
                                </button>
                                <button type="button"
                                    class="w-full flex items-center justify-between px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-gray-800 font-medium hover:bg-gray-100"
                                    onclick="copyPageUrl()">
                                    <span class="flex items-center gap-2">
                                        <i class="bi bi-link-45deg"></i>
                                        <span>URL 복사</span>
                                    </span>
                                </button>
                            </div>
                            <button type="button" class="mt-4 w-full text-sm text-gray-500 hover:text-gray-700"
                                onclick="toggleShareModal(false)">닫기</button>
