                                                <!-- Main Description -->
                                                <%
                                                    const _ipMasked = (typeof visitorIp !== 'undefined' && visitorIp)
                                                        ? visitorIp.replace(/^(\d+)\.(\d+)\.(\d+)\.(\d+)$/, '$1.xxx.xxx.$4')
                                                        : '';
                                                    const _today = new Date().toISOString().split('T')[0];
                                                    const _wmText = currentUser
                                                        ? `USER-${currentUser.id} ${currentUser.name || ''}`.trim()
                                                        : `GUEST · ${_ipMasked} · ${_today}`;
                                                %>
                                                <!-- 저작권 경고 안내 -->
                                                <div class="flex items-start gap-3 bg-red-50 border-l-4 border-red-500 rounded-r-lg px-4 py-3 mb-4 -mt-8 text-sm">
                                                    <i class="bi bi-exclamation-triangle-fill text-red-500 text-lg flex-shrink-0 mt-0.5"></i>
                                                    <div class="text-red-900 leading-relaxed">
                                                        <strong class="block font-bold mb-1">저작권 및 무단 사용 금지 안내</strong>
                                                        <p class="text-xs sm:text-sm">본 웹사이트에 사용된 모든 상품과 콘텐츠의 이미지, 로고 및 문구에 대한 저작권은 제품의 제조사 및 원판매처에 있습니다.<br>
                                                        <strong class="font-semibold">도용 및 훼손, 재가공, 배포하는 행위를 금합니다.</strong></p>
                                                    </div>
                                                </div>
                                                <div class="bg-white rounded-2xl p-0 sm:p-4 prose max-w-none text-gray-800 watermark-container relative" id="product-description">
                                                    <%- product.description %>
                                                    <div class="watermark-overlay" aria-hidden="true" data-wm-text="<%= _wmText %>"></div>
                                                </div>
                                                <style>
                                                    .watermark-container { position: relative; }
                                                    .watermark-container img { -webkit-user-drag: none; -khtml-user-drag: none; -moz-user-drag: none; -o-user-drag: none; user-drag: none; -webkit-user-select: none; -moz-user-select: none; -ms-user-select: none; user-select: none; pointer-events: none; }
                                                    .watermark-overlay {
                                                        position: absolute; top: 0; left: 0; right: 0; bottom: 0;
                                                        pointer-events: none;
                                                        z-index: 10;
                                                        overflow: hidden;
                                                    }
                                                    .watermark-text {
                                                        position: absolute;
                                                        transform: rotate(-25deg);
                                                        font-size: 18px;
                                                        font-weight: 700;
                                                        color: rgba(255, 255, 255, 0.28);
                                                        mix-blend-mode: difference;
                                                        white-space: nowrap;
                                                        user-select: none;
                                                        letter-spacing: 0.5px;
                                                    }
                                                </style>
                                                <script>
                                                    (function() {
                                                        const wrap = document.getElementById('product-description');
                                                        if (!wrap) return;
                                                        wrap.addEventListener('contextmenu', e => e.preventDefault());
                                                        wrap.addEventListener('dragstart', e => e.preventDefault());
                                                        wrap.addEventListener('selectstart', e => e.preventDefault());

                                                        // 워터마크 동적 배치 (콘텐츠 전체 높이 기준)
                                                        const overlay = wrap.querySelector('.watermark-overlay');
                                                        if (!overlay) return;
                                                        const wmText = overlay.dataset.wmText || '';

                                                        function layoutWatermarks() {
                                                            overlay.innerHTML = '';
                                                            const totalH = wrap.scrollHeight;
                                                            const totalW = wrap.clientWidth;
                                                            const isMobile = totalW < 768;
                                                            const cellW = isMobile ? 280 : 480;
                                                            const cellH = isMobile ? 340 : 400;
                                                            const fontSize = isMobile ? 15 : 18;
                                                            const cols = Math.max(1, Math.floor(totalW / cellW));
                                                            const rows = Math.ceil(totalH / cellH) + 1;
                                                            for (let r = 0; r < rows; r++) {
                                                                for (let c = 0; c < cols; c++) {
                                                                    const span = document.createElement('span');
                                                                    span.className = 'watermark-text';
                                                                    span.textContent = wmText;
                                                                    span.style.fontSize = fontSize + 'px';
                                                                    const offsetX = (r % 2 === 0) ? 0 : cellW / 2;
                                                                    span.style.left = (c * cellW + offsetX) + 'px';
                                                                    span.style.top = (r * cellH) + 'px';
                                                                    overlay.appendChild(span);
                                                                }
                                                            }
                                                        }

                                                        // 이미지 로딩 후 높이 재계산
                                                        layoutWatermarks();
                                                        const imgs = wrap.querySelectorAll('img');
                                                        imgs.forEach(img => {
                                                            if (img.complete) return;
                                                            img.addEventListener('load', layoutWatermarks);
                                                            img.addEventListener('error', layoutWatermarks);
                                                        });
                                                        window.addEventListener('resize', layoutWatermarks);
                                                        setTimeout(layoutWatermarks, 500);
                                                        setTimeout(layoutWatermarks, 1500);
                                                    })();
                                                </script>
                            </div>

                            <!-- Review Tab -->
                            <div id="review" class="tab-pane hidden">
                                <div class="flex justify-between items-center mb-6">
                                    <h5 class="text-2xl font-bold text-gray-900">구매 후기</h5>
