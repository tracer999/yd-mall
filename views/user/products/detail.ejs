                    </div>
                </div>

                <% if (typeof kakaoJsKey !=='undefined' && kakaoJsKey) { %>
                    <script src="https://t1.kakaocdn.net/kakao_js_sdk/2.7.4/kakao.min.js"></script>
                    <script>
                        (function() {
                            function tryInit() {
                                if (window.Kakao && typeof Kakao.init === 'function' && !Kakao.isInitialized()) {
                                    try { Kakao.init('<%= kakaoJsKey %>'); } catch(e) { console.error('Kakao.init error:', e); }
                                }
                            }
                            if (window.Kakao) tryInit();
                            else window.addEventListener('load', tryInit);
                        })();
                    </script>
                    <% } %>

                        <script id="product-data" type="application/json">
                            <%- JSON.stringify({
                                url: seo && seo.url ? seo.url : '',
                                title: seo && seo.title ? seo.title : product.name,
                                description: seo && seo.description ? seo.description : '',
                                image: seo && seo.image ? seo.image : (product.main_image || product.thumbnail_image || ''),
                                kakaoEnabled: (typeof kakaoJsKey !== 'undefined' && !!kakaoJsKey),
                                stock: (product.stock != null && product.stock >= 0) ? product.stock : 0,
                                unitPrice: Number(product.price || 0),
                                item_id: product.slug || String(product.id),
                                item_name: product.name,
                                item_brand: product.provider || null,
                                item_category: product.category_name || null
                            }).replace(/</g, '\\u003c') %>
                        </script>
                        <script>
                            const serverData = JSON.parse(document.getElementById('product-data').textContent);

                            // 카카오 공유용 데이터 정제
                            function sanitizeText(s) {
                                if (!s) return '';
                                return String(s).replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim().substring(0, 200);
                            }
                            function forceHttps(u) {
                                if (!u) return '';
                                return String(u).replace(/^http:\/\//i, 'https://');
                            }
                            const SHARE_DATA = {
                                url: forceHttps(serverData.url),
                                title: sanitizeText(serverData.title).substring(0, 100) || '상품',
                                description: sanitizeText(serverData.description),
                                image: forceHttps(serverData.image),
                                kakaoEnabled: serverData.kakaoEnabled
                            };

                            const PRODUCT_STOCK = serverData.stock;
                            const PRODUCT_UNIT_PRICE = serverData.unitPrice;
                            const PRODUCT_ANALYTICS = {
                                item_id: serverData.item_id,
                                item_name: serverData.item_name,
                                item_brand: serverData.item_brand,
                                item_category: serverData.item_category,
                                currency: 'KRW',
                                price: PRODUCT_UNIT_PRICE
                            };

                            function buildAnalyticsItem(quantity) {
                                const item = Object.assign({}, PRODUCT_ANALYTICS);
                                if (typeof quantity === 'number') {
                                    item.quantity = quantity;
                                }
                                return item;
                            }

                            function sendGa4Event(name, params, callback) {
                                if (typeof window.gtag === 'function') {
                                    const payload = Object.assign({}, params || {});
                                    if (callback) {
                                        payload.event_callback = callback;
                                        payload.event_timeout = 500;
                                    }
                                    window.gtag('event', name, payload);
                                    return true;
                                }
                                if (typeof callback === 'function') {
                                    callback();
                                }
                                return false;
                            }

                            document.addEventListener('DOMContentLoaded', function () {
                                sendGa4Event('view_item', {
                                    currency: 'KRW',
                                    value: PRODUCT_UNIT_PRICE,
                                    items: [buildAnalyticsItem(1)]
                                });

                                const addToCartForm = document.getElementById('add-to-cart-form');
                                if (addToCartForm) {
                                    addToCartForm.addEventListener('submit', function (event) {
                                        if (typeof window.gtag !== 'function') {
                                            return;
                                        }
                                        event.preventDefault();
                                        const quantityInput = document.getElementById('orderQuantity');
                                        const quantity = Math.max(1, parseInt(quantityInput ? quantityInput.value : '1', 10) || 1);
                                        let submitted = false;
                                        const submitForm = () => {
                                            if (!submitted) {
                                                submitted = true;
                                                addToCartForm.submit();
                                            }
                                        };
                                        sendGa4Event('add_to_cart', {
                                            currency: 'KRW',
                                            value: PRODUCT_UNIT_PRICE * quantity,
                                            items: [buildAnalyticsItem(quantity)]
                                        }, submitForm);
                                        setTimeout(submitForm, 700);
                                    });
                                }

                                // 썸네일 클릭 이벤트
                                document.querySelectorAll('.brand-thumb').forEach(function(btn) {
                                    btn.addEventListener('click', function() {
                                        const url = this.getAttribute('data-url');
                                        const mainImg = document.getElementById('mainImage');
                                        if(mainImg && url) {
                                            mainImg.src = url;
                                        }

                                        // 형제 요소들 초기화 및 현재 선택 활성화
                                        if (this.parentElement) {
                                            this.parentElement.querySelectorAll('.brand-thumb').forEach(function(b) {
                                                b.classList.remove('is-active');
                                            });
                                        }
                                        this.classList.add('is-active');
                                    });
                                });
                            });

                            function goToCheckout() {
                                const input = document.getElementById('orderQuantity');
                                if (!input) return;
                                const qty = parseInt(input.value, 10) || 1;
                                const max = parseInt(input.dataset.max || input.max || PRODUCT_STOCK, 10) || PRODUCT_STOCK;
                                if (qty > max) {
                                    alert('재고가 부족합니다. (최대 ' + max + '개)');
                                    input.value = max;
                                    return;
                                }
                                if (qty < 1) {
                                    alert('수량을 1개 이상 선택해 주세요.');
                                    return;
                                }
                                const _skuEl = document.getElementById('selectedSkuId');
                                const _skuParam = (_skuEl && _skuEl.value) ? '&sku_id=' + encodeURIComponent(_skuEl.value) : '';
                                const redirectUrl = '/checkout?product_id=<%= product.id %>&quantity=' + qty + _skuParam;
                                const proceed = () => {
                                    location.href = redirectUrl;
                                };
                                const sent = sendGa4Event('begin_checkout', {
                                    currency: 'KRW',
                                    value: PRODUCT_UNIT_PRICE * qty,
                                    items: [buildAnalyticsItem(qty)]
                                }, proceed);
                                if (!sent) {
                                    proceed();
                                } else {
                                    setTimeout(proceed, 700);
                                }
                            }

                            function changeOrderQuantity(delta) {
                                const input = document.getElementById('orderQuantity');
                                if (!input) return;
                                const max = parseInt(input.dataset.max || input.max || PRODUCT_STOCK, 10) || PRODUCT_STOCK;
                                // B2B 는 MOQ·주문단위가 있다. 일반 상품은 min=1·step=1 이라 동작이 예전과 같다.
                                const min = parseInt(input.dataset.min || 1, 10) || 1;
                                const step = parseInt(input.dataset.step || 1, 10) || 1;
                                let value = parseInt(input.value, 10) || min;
                                value += delta * step;
                                if (value < min) value = min;
                                if (value > max) {
                                    // 상한을 넘으면 주문단위에 맞는 가장 큰 값으로 내린다.
                                    value = min + Math.floor((max - min) / step) * step;
                                    if (value < min) value = min;
                                }
                                input.value = value;
                            }

                            async function toggleLike(productId) {
                                try {
                                    const response = await fetch('/products/like/' + productId, { method: 'POST' });
                                    const data = await response.json();

                                    if (response.status === 401) {
                                        alert('로그인이 필요합니다.');
                                        location.href = '/auth/login';
                                        return;
                                    }

                                    if (data.success) {
                                        const icon = document.querySelector('#likeBtn i');
                                        if (data.liked) {
                                            icon.classList.remove('bi-heart');
                                            icon.classList.add('bi-heart-fill');
                                            icon.classList.add('brand-text');
                                        } else {
                                            icon.classList.remove('bi-heart-fill');
                                            icon.classList.remove('brand-text');
                                            icon.classList.add('bi-heart');
                                        }
                                    }
                                } catch (error) {
                                    console.error('Error:', error);
                                }
                            }

                            // changeMainImage 함수는 DOMContentLoaded 내부 이벤트 리스너로 대체되었습니다.

                            function toggleShareModal(show) {
                                const modal = document.getElementById('shareModal');
                                if (!modal) return;
                                if (show) {
                                    modal.classList.remove('hidden');
                                } else {
                                    modal.classList.add('hidden');
                                }
                            }

                            function shareToKakao() {
                                // 비로그인 시 로그인 페이지로 유도
                                <% if (!currentUser) { %>
                                    if (confirm('카카오톡 공유를 위해 로그인이 필요합니다. 로그인 페이지로 이동하시겠습니까?')) {
                                        location.href = '/auth/login?redirect=' + encodeURIComponent(location.pathname + location.search);
                                    }
                                    return;
                                <% } %>
                                if (!SHARE_DATA.kakaoEnabled || !window.Kakao) {
                                    alert('카카오톡 공유 설정이 아직 완료되지 않았습니다. URL 복사 기능을 이용해 주세요.');
                                    return;
                                }
                                if (!Kakao.isInitialized()) {
                                    try { Kakao.init('<%= typeof kakaoJsKey !== "undefined" ? kakaoJsKey : "" %>'); } catch(e) { console.error(e); }
                                }
                                if (!SHARE_DATA.url) {
                                    alert('공유할 URL 정보를 불러오지 못했습니다.');
                                    return;
                                }

                                // v2는 Kakao.Share, v1은 Kakao.Link
                                const shareApi = (Kakao.Share && Kakao.Share.sendDefault) ? Kakao.Share : (Kakao.Link && Kakao.Link.sendDefault ? Kakao.Link : null);
                                if (!shareApi) {
                                    alert('카카오톡 공유 SDK를 불러오지 못했습니다. 새로고침 후 다시 시도해 주세요.');
                                    return;
                                }

                                const contentObj = {
                                    title: SHARE_DATA.title,
                                    link: {
                                        mobileWebUrl: SHARE_DATA.url,
                                        webUrl: SHARE_DATA.url
                                    }
                                };
                                if (SHARE_DATA.description) contentObj.description = SHARE_DATA.description;
                                if (SHARE_DATA.image) contentObj.imageUrl = SHARE_DATA.image;

                                try {
                                    shareApi.sendDefault({
                                        objectType: 'feed',
                                        content: contentObj,
                                        buttons: [
                                            {
                                                title: '상품 보러가기',
                                                link: {
                                                    mobileWebUrl: SHARE_DATA.url,
                                                    webUrl: SHARE_DATA.url
                                                }
                                            }
                                        ]
                                    });
                                } catch (e) {
                                    console.error('Kakao share error:', e);
                                    alert('카카오톡 공유 중 오류가 발생했습니다: ' + (e.msg || e.message || e));
                                }
                            }

                            async function shopifyGlobalCheckout(variantId) {
                                const btn = document.getElementById('shopifyGlobalBtn');
                                if (!btn) return;
                                const origHtml = btn.innerHTML;
                                btn.disabled = true;
                                btn.innerHTML = '<i class="bi bi-hourglass-split"></i> 연결 중...';
                                try {
                                    // 국가 선택기에서 선택된 값 우선, 없으면 서버 세션 값 사용
                                    const selectEl = document.getElementById('shopify-country-select');
                                    const countryCode = (selectEl && selectEl.value) || null;

                                    const body = { items: [{ variantId, quantity: 1 }] };
                                    if (countryCode) body.countryCode = countryCode;

                                    const resp = await fetch('/shopify/cart', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify(body)
                                    });
                                    const data = await resp.json();
                                    if (data.checkoutUrl) {
                                        window.location.href = data.checkoutUrl;
                                    } else {
                                        throw new Error(data.error || '알 수 없는 오류');
                                    }
                                } catch (e) {
                                    btn.disabled = false;
                                    btn.innerHTML = origHtml;
                                    alert('Shopify 체크아웃 연결 실패: ' + e.message);
                                }
                            }

                            async function copyPageUrl() {
                                if (!SHARE_DATA.url) {
                                    alert('공유할 URL 정보를 불러오지 못했습니다.');
                                    return;
                                }
                                try {
                                    if (navigator.clipboard && navigator.clipboard.writeText) {
                                        await navigator.clipboard.writeText(SHARE_DATA.url);
                                    } else {
                                        throw new Error('Clipboard API not available');
                                    }
                                    alert('상품 링크가 복사되었습니다.');
                                } catch (e) {
                                    try {
                                        const textarea = document.createElement('textarea');
                                        textarea.value = SHARE_DATA.url;
                                        textarea.style.position = 'fixed';
                                        textarea.style.left = '-9999px';
                                        document.body.appendChild(textarea);
                                        textarea.select();
                                        document.execCommand('copy');
                                        document.body.removeChild(textarea);
                                        alert('상품 링크가 복사되었습니다.');
                                    } catch (err) {
                                        alert('복사 기능을 사용할 수 없습니다. 주소창의 URL을 직접 복사해 주세요.');
                                    }
                                }
                                toggleShareModal(false);
                            }

                            // Shopify: 동기화되어 실제 판매 가능한 상품만 "해외 구매하기" 노출 + 현지화 가격 표시
                            // (현지 가격 조회 성공 = Storefront에서 구매 가능 → 섹션 노출 / 실패 = 미동기화·삭제 → 숨김)
                            (function() {
                                const section = document.getElementById('shopify-global-section');
                                const priceEl = document.getElementById('shopify-local-price');
                                const priceText = document.getElementById('shopify-local-price-text');
                                if (!section || !priceEl || !priceText) return;

                                const handle = section.dataset.handle;
                                if (!handle) return;

                                async function loadLocalPrice(country) {
                                    const params = new URLSearchParams({ handle });
                                    if (country) params.set('country', country);
                                    try {
                                        const res = await fetch(`/shopify/price?${params}`);
                                        if (!res.ok) { section.classList.add('hidden'); return; }
                                        const { amount, currencyCode } = await res.json();
                                        const fmt = new Intl.NumberFormat(undefined, {
                                            style: 'currency', currency: currencyCode, minimumFractionDigits: 2
                                        });
                                        priceText.textContent = `해외 가격: ${fmt.format(amount)} (${currencyCode})`;
                                        priceEl.classList.remove('hidden');
                                        section.classList.remove('hidden'); // 판매 가능 → 버튼 노출
                                    } catch (e) {
                                        section.classList.add('hidden');
                                    }
                                }

                                // 국가는 세션(상단 헤더 마켓 선택) 기준 → 서버가 처리
                                loadLocalPrice(null);
                                window.shopifyRefreshLocalPrice = loadLocalPrice;
                            })();

                            // Simple Tab Logic with Sticky Header Support
                            document.querySelectorAll('.tab-btn').forEach(button => {
                                button.addEventListener('click', () => {
                                    // Reset buttons
                                    document.querySelectorAll('.tab-btn').forEach(btn => {
                                        btn.classList.remove('is-active');
                                    });
                                    // Activate current button
                                    button.classList.add('is-active');

                                    // Hide all panes
                                    document.querySelectorAll('.tab-pane').forEach(pane => {
                                        pane.classList.add('hidden');
                                        pane.classList.remove('block');
                                    });
                                    // Show target pane
                                    const target = document.querySelector(button.dataset.target);
                                    target.classList.remove('hidden');
                                    target.classList.add('block');

                                    // Scroll to tab content smoothly if needed (optional)
                                    // window.scrollTo({ top: document.querySelector('.max-w-5xl').offsetTop - 100, behavior: 'smooth' });
                                });
                            });
                        </script>
<%
  /* 최근 본 상품 기록 — 우측 유틸 레일(P1.5 §4.5.4)의 데이터 소스.
     비로그인 포함 클라이언트 localStorage 기반. (로그인 사용자 recent_views 연동은 CT-8) */
  const _detailPath = (product.slug && String(product.slug).trim())
    ? '/products/' + encodeURIComponent(String(product.slug).trim())
    : '/products/view/' + product.id;
  const _js = (v) => JSON.stringify(v == null ? '' : String(v)).replace(/</g, '\u003c');
%>
<script>
(function () {
  var STORAGE_KEY = 'yd_recent_products';
  var MAX = 10;
  var item = {
    id: <%= Number(product.id) %>,
    name: <%- _js(product.name) %>,
    image: <%- _js(product.main_image || '') %>,
    url: <%- _js(_detailPath) %>
  };
  try {
    var raw = localStorage.getItem(STORAGE_KEY);
    var list = raw ? JSON.parse(raw) : [];
    if (!Array.isArray(list)) list = [];
    list = list.filter(function (p) { return p && p.id !== item.id; });
    list.unshift(item);
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list.slice(0, MAX)));
  } catch (e) { /* 저장 실패는 무시 (프라이빗 모드 등) */ }
})();
</script>
