                                        </div>
                                    </div>
                                    <% } %>

                                        <!-- AI Recommendation -->
                                        <% if(product.is_ai_recommendation) { %>
                                            <div
                                                class="bg-gradient-to-r from-[color:var(--gh-secondary)] via-white to-white border brand-border rounded-3xl p-8 relative overflow-hidden mb-12 shadow-sm">
                                                <div
                                                    class="absolute top-0 right-0 -mt-4 -mr-4 text-[color:var(--gh-primary-soft-strong)] opacity-40">
                                                    <i class="bi bi-stars" style="font-size: 10rem;"></i>
                                                </div>
                                                <h3
                                                    class="text-xl font-bold brand-text flex items-center gap-2 mb-6 relative z-10 animate-blink-shine">
                                                    <i class="bi bi-stars brand-text"></i> AI 추천 포인트
