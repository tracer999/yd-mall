                        <div id="tab-contents">
                            <!-- Detail Tab -->
                            <div id="detail" class="tab-pane block space-y-12">

                                <!-- Video Section -->
                                <% if(product.video_url) { %>
                                    <div class="space-y-4 mb-12">
                                        <h3 class="text-xl font-bold text-gray-900 flex items-center gap-2">
                                            <i class="bi bi-play-circle-fill text-red-500"></i> 관련 영상
                                        </h3>
                                        <!-- 16:9 Aspect Ratio Container -->
                                        <div
                                            class="relative w-full pb-[56.25%] bg-black rounded-2xl overflow-hidden shadow-lg">
                                            <% if(product.video_type==='YOUTUBE' ) { %>
                                                <iframe class="absolute top-0 left-0 w-full h-full"
                                                    src="<%= product.video_url.replace('watch?v=', 'embed/') %>"
                                                    frameborder="0" allowfullscreen></iframe>
