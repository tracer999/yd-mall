<%
const won = n => Number(n || 0).toLocaleString('ko-KR');
const dt = v => (v ? new Date(v).toLocaleString('ko-KR') : '-');
const dd = v => (v ? new Date(v).toLocaleDateString('ko-KR') : '-');
const tone = {
  DRAFT:'gray', REQUESTED:'amber', UNDER_REVIEW:'blue', SELLER_PROPOSED:'blue',
  BUYER_COUNTERED:'amber', BUYER_ACCEPTED:'green', SELLER_ACCEPTED:'green',
  REJECTED:'red', EXPIRED:'gray', CONVERTED_TO_ORDER:'green', CANCELLED:'gray',
}[quote.status] || 'gray';
const cls = {
  gray:'bg-gray-100 text-gray-700 border-gray-300', amber:'bg-amber-100 text-amber-800 border-amber-300',
  blue:'bg-blue-100 text-blue-800 border-blue-300', green:'bg-green-100 text-green-800 border-green-300',
  red:'bg-red-100 text-red-800 border-red-300',
}[tone];
// 서버가 고른 가능한 전이만 버튼으로 만든다 — 화면이 규칙을 새로 만들지 않는다.
const canCounter = actions.includes('BUYER_COUNTERED');
const canAccept  = actions.includes('BUYER_ACCEPTED');
const canCancel  = actions.includes('CANCELLED');
const canConvert = actions.includes('CONVERTED_TO_ORDER') && convertible.ok;
%>
<div class="max-w-4xl mx-auto px-4 py-10">
  <a href="/quotes" class="text-sm text-gray-500 hover:text-gray-700 no-underline">&larr; 견적함</a>

  <% if (message) { %><div class="mt-4 rounded-md bg-green-50 border border-green-200 p-3 text-sm text-green-800"><%= message %></div><% } %>
  <% if (error) { %><div class="mt-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800"><%= error %></div><% } %>

  <div class="flex items-center justify-between mt-4 mb-6">
    <div>
      <h1 class="text-2xl font-extrabold text-gray-900"><%= quote.quote_number %></h1>
      <p class="text-sm text-gray-500">v<%= quote.version %> · 요청일 <%= dd(quote.created_at) %> · 유효기간 <%= dd(quote.valid_until) %></p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/quotes/<%= quote.id %>/pdf" target="_blank" rel="noopener"
         class="text-sm px-3 py-2 rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50 no-underline">견적서 PDF</a>
      <span class="text-xs px-2.5 py-1 rounded border <%= cls %>"><%= STATUS[quote.status] %></span>
    </div>
  </div>

  <% if (quote.status === 'CONVERTED_TO_ORDER') { %>
    <div class="mb-6 rounded-xl border border-green-200 bg-green-50 p-4 text-sm text-green-900">
      이 견적은 주문으로 전환되었습니다.
      <a href="/mypage/orders" class="underline underline-offset-2">주문내역에서 확인</a>
    </div>
  <% } %>

  <!-- 품목 -->
  <form action="/quotes/<%= quote.id %>/action" method="POST">
    <input type="hidden" name="action" value="counter">
    <div class="bg-white border rounded-xl overflow-hidden mb-6">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-xs text-gray-600 border-b">
          <tr>
            <th class="text-left px-4 py-3">품목</th>
            <th class="text-right px-4 py-3">정가</th>
            <th class="text-right px-4 py-3">판매자 제안</th>
            <th class="text-right px-4 py-3 w-24">수량</th>
            <th class="text-right px-4 py-3 w-32">희망 단가</th>
            <th class="text-right px-4 py-3">합계</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(function(it) { const eff = effectiveUnitPrice(it); %>
            <tr class="border-b">
              <td class="px-4 py-3">
                <input type="hidden" name="item_id" value="<%= it.id %>">
                <span class="font-medium text-gray-900"><%= it.product_name_snapshot %></span>
                <% if (it.sku_snapshot) { %><p class="text-xs text-gray-400"><%= it.sku_snapshot %></p><% } %>
                <% if (it.item_note) { %><p class="text-xs text-blue-600">판매자 메모: <%= it.item_note %></p><% } %>
              </td>
              <td class="px-4 py-3 text-right text-gray-400 line-through"><%= won(it.catalog_unit_price) %></td>
              <td class="px-4 py-3 text-right font-semibold <%= it.proposed_unit_price != null ? 'text-blue-800' : 'text-gray-300' %>">
                <%= it.proposed_unit_price != null ? won(it.proposed_unit_price) + '원' : '-' %>
              </td>
              <td class="px-4 py-3 text-right">
                <% if (canCounter) { %>
                  <input type="number" name="quantity" value="<%= it.quantity %>" min="1" class="w-full text-right border-gray-300 rounded-md text-sm">
                <% } else { %>
                  <input type="hidden" name="quantity" value="<%= it.quantity %>"><%= won(it.quantity) %>
                <% } %>
              </td>
              <td class="px-4 py-3 text-right">
                <% if (canCounter) { %>
                  <input type="number" name="wish_price" value="<%= it.requested_unit_price != null ? it.requested_unit_price : '' %>" min="0" placeholder="희망가"
                         class="w-full text-right border-gray-300 rounded-md text-sm">
                <% } else { %>
                  <%= it.requested_unit_price != null ? won(it.requested_unit_price) : '-' %>
                <% } %>
              </td>
              <td class="px-4 py-3 text-right font-semibold"><%= won(eff * it.quantity) %>원</td>
            </tr>
          <% }); %>
        </tbody>
      </table>

      <div class="px-4 py-3 bg-gray-50 border-t text-sm space-y-1">
        <div class="flex justify-between"><span class="text-gray-600">공급가액</span><span><%= won(quote.supply_amount) %>원</span></div>
        <div class="flex justify-between"><span class="text-gray-600">부가세</span><span><%= won(quote.vat_amount) %>원</span></div>
        <% if (quote.tax_free_amount > 0) { %><div class="flex justify-between"><span class="text-gray-600">면세</span><span><%= won(quote.tax_free_amount) %>원</span></div><% } %>
        <div class="flex justify-between"><span class="text-gray-600">배송비</span><span><%= won(quote.shipping_amount) %>원</span></div>
        <% if (quote.discount_amount > 0) { %><div class="flex justify-between text-blue-700"><span>할인</span><span>-<%= won(quote.discount_amount) %>원</span></div><% } %>
        <div class="flex justify-between font-bold text-base pt-2 border-t border-gray-200">
          <span>합계</span><span class="text-blue-700"><%= won(quote.final_total) %>원</span>
        </div>
      </div>
    </div>

    <% if (canCounter) { %>
      <div class="bg-white border rounded-xl p-4 mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-1">재제안 메시지</label>
        <textarea name="message" rows="3" class="block w-full border-gray-300 rounded-md text-sm" placeholder="희망 조건을 적어주세요"></textarea>
        <button type="submit" class="mt-3 px-5 py-2.5 rounded-lg bg-amber-500 text-white font-semibold hover:bg-amber-600">재제안 보내기</button>
      </div>
    <% } %>
  </form>

  <!-- 조건 -->
  <div class="bg-white border rounded-xl p-6 mb-6 text-sm">
    <h2 class="font-bold text-gray-900 mb-3">거래 조건</h2>
    <dl class="space-y-2">
      <div class="flex"><dt class="w-32 text-gray-500">결제 조건</dt><dd><%= quote.payment_terms || '선결제(무통장 입금)' %></dd></div>
      <div class="flex"><dt class="w-32 text-gray-500">납기</dt><dd><%= quote.delivery_terms || (quote.requested_delivery_date ? dd(quote.requested_delivery_date) : '협의') %></dd></div>
      <div class="flex"><dt class="w-32 text-gray-500">유효기간</dt><dd><%= dd(quote.valid_until) %></dd></div>
    </dl>
  </div>

  <!-- 협상 메시지 -->
  <div class="bg-white border rounded-xl p-6 mb-6">
    <h2 class="font-bold text-gray-900 mb-3 text-sm">협상 메시지</h2>
    <% if (messages.length === 0) { %>
      <p class="text-sm text-gray-400 mb-4">아직 오간 메시지가 없습니다.</p>
    <% } else { %>
      <div class="space-y-3 mb-4">
        <% messages.forEach(function(m) { %>
          <div class="flex <%= m.sender_type === 'BUYER' ? 'justify-end' : 'justify-start' %>">
            <div class="max-w-[75%] rounded-lg px-3 py-2 text-sm <%= m.sender_type === 'BUYER' ? 'bg-blue-50 text-blue-900' : 'bg-gray-100 text-gray-800' %>">
              <p class="whitespace-pre-line"><%= m.message %></p>
              <p class="text-[11px] text-gray-400 mt-1"><%= m.sender_type === 'BUYER' ? '우리' : '판매자' %> · <%= dt(m.created_at) %></p>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
    <form action="/quotes/<%= quote.id %>/action" method="POST" class="flex gap-2">
      <input type="hidden" name="action" value="message">
      <input type="text" name="message" required placeholder="메시지 입력" class="flex-1 border-gray-300 rounded-md text-sm">
      <button type="submit" class="px-4 py-2 rounded-md border border-gray-300 text-sm hover:bg-gray-50">보내기</button>
    </form>
  </div>

  <!-- 변경 이력 -->
  <div class="bg-white border rounded-xl p-6 mb-6">
    <h2 class="font-bold text-gray-900 mb-3 text-sm">변경 이력</h2>
    <ol class="space-y-2 text-sm">
      <% revisions.forEach(function(r) { %>
        <li class="flex gap-3">
          <span class="text-xs font-mono text-gray-400 shrink-0">v<%= r.revision_number %></span>
          <span class="text-gray-700"><%= r.summary || STATUS[r.status_after] %></span>
          <span class="ml-auto text-xs text-gray-400"><%= dt(r.created_at) %></span>
        </li>
      <% }); %>
    </ol>
  </div>

  <!-- 액션 -->
  <div class="flex flex-wrap gap-3">
    <% if (canAccept) { %>
      <form action="/quotes/<%= quote.id %>/action" method="POST" onsubmit="return confirm('이 조건으로 수락하시겠습니까? 수락 후 단가가 확정됩니다.');">
        <input type="hidden" name="action" value="accept">
        <button type="submit" class="px-6 py-3 rounded-lg bg-green-600 text-white font-bold hover:bg-green-700">견적 수락</button>
      </form>
    <% } %>
    <% if (canCancel) { %>
      <form action="/quotes/<%= quote.id %>/action" method="POST" onsubmit="return confirm('견적을 취소하시겠습니까?');">
        <input type="hidden" name="action" value="cancel">
        <button type="submit" class="px-6 py-3 rounded-lg border border-red-200 bg-red-50 text-red-700 font-semibold hover:bg-red-100">견적 취소</button>
      </form>
    <% } %>
  </div>

  <!-- 주문 전환 -->
  <% if (actions.includes('CONVERTED_TO_ORDER')) { %>
    <div class="mt-6 bg-white border-2 border-blue-200 rounded-xl p-6">
      <h2 class="font-bold text-gray-900 mb-1">주문으로 전환</h2>
      <% if (!convertible.ok) { %>
        <p class="text-sm text-red-700"><%= convertible.error %></p>
      <% } else { %>
        <p class="text-sm text-gray-500 mb-4">
          확정된 견적 단가 그대로 주문이 만들어집니다. 주문 후 담당자 승인과 입금 안내가 이어집니다.
        </p>
        <form action="/quotes/<%= quote.id %>/convert" method="POST" class="space-y-3">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <input type="text" name="receiver_name" value="<%= prefill.receiver_name %>" placeholder="수령인" required class="border-gray-300 rounded-md text-sm">
            <input type="text" name="receiver_phone" value="<%= prefill.receiver_phone %>" placeholder="연락처" required class="border-gray-300 rounded-md text-sm">
          </div>
          <input type="text" name="receiver_zipcode" value="<%= prefill.receiver_zipcode %>" placeholder="우편번호" class="w-40 border-gray-300 rounded-md text-sm">
          <input type="text" name="receiver_address" value="<%= prefill.receiver_address %>" placeholder="주소" required class="block w-full border-gray-300 rounded-md text-sm">
          <input type="text" name="receiver_detailed_address" value="<%= prefill.receiver_detailed_address %>" placeholder="상세주소" class="block w-full border-gray-300 rounded-md text-sm">
          <input type="text" name="shipping_message" placeholder="배송 요청사항" class="block w-full border-gray-300 rounded-md text-sm">
          <button type="submit" class="w-full py-3 rounded-lg bg-blue-700 text-white font-bold hover:bg-blue-800">이 견적으로 주문하기</button>
        </form>
      <% } %>
    </div>
  <% } %>
</div>
