<%
  /*
   * 쇼핑라이브 목록 (§6-1)
   *
   * 방송 중(ON_AIR)이 항상 맨 위다. 서비스가 FIELD() 로 정렬해서 준다.
   * 발행된 라이브가 0건이면 컨트롤러가 준비중 랜딩으로 되돌리므로, 이 화면은 항상 1건 이상이다.
   */
  const won = (n) => Number(n || 0).toLocaleString('ko-KR');
  const fmtDT = (d) => d ? new Date(d).toLocaleString('ko-KR', { dateStyle: 'medium', timeStyle: 'short' }) : '';

  const STATUS_BADGE = {
    ON_AIR:    'bg-red-600 text-white',
    SCHEDULED: 'bg-purple-600 text-white',
    ENDED:     'bg-gray-500 text-white',
  };

  /** 카드 한 장의 가격 표시 — 대표 상품이 없을 수도 있다(관리자가 아직 안 걸었을 때). */
  const cardPrice = (l) => {
    const normal = Number(l.main_normal_price) || Number(l.main_product_price) || 0;
    const sale = Number(l.main_live_price) || Number(l.main_product_price) || 0;
    return { normal, sale, rate: Number(l.main_discount_rate) || 0 };
  };
%>

<div class="max-w-screen-lg mx-auto px-4 py-8">

  <div class="mb-6">
    <h1 class="text-2xl font-extrabold text-gray-900">쇼핑라이브</h1>
    <p class="mt-1 text-sm text-gray-500">방송을 보면서 바로 구매하세요. 방송 한정 특가와 전용 쿠폰을 드립니다.</p>
  </div>

  <%# ── 방송 중 히어로 ── %>
  <% if (hero) { %>
    <a href="<%= hero.detailPath %>" class="block mb-8 group">
      <div class="relative rounded-2xl overflow-hidden bg-gray-900 aspect-video">
        <% const heroImg = hero.pc_hero_image_url || hero.list_thumbnail_url || hero.main_product_image; %>
        <% if (heroImg) { %>
          <img src="<%= heroImg %>" alt="<%= hero.title %>"
               class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition duration-300">
        <% } %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        <span class="absolute top-4 left-4 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-red-600 text-white">
          <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span> LIVE
        </span>

        <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-6">
          <h2 class="text-xl sm:text-2xl font-extrabold text-white line-clamp-2"><%= hero.title %></h2>
          <% if (hero.summary) { %>
            <p class="mt-1 text-sm text-white/80 line-clamp-1"><%= hero.summary %></p>
          <% } %>
          <% if (hero.main_product_name) { %>
            <% const hp = cardPrice(hero); %>
            <div class="mt-3 flex items-center gap-2 text-white">
              <% if (hp.rate > 0) { %>
                <span class="text-lg font-extrabold text-red-400"><%= hp.rate %>%</span>
              <% } %>
              <span class="text-lg font-extrabold"><%= won(hp.sale) %>원</span>
              <% if (hp.rate > 0) { %>
                <span class="text-sm text-white/50 line-through"><%= won(hp.normal) %>원</span>
              <% } %>
              <span class="ml-1 text-sm text-white/70 truncate"><%= hero.main_product_name %></span>
            </div>
          <% } %>
        </div>
      </div>
    </a>
  <% } %>

  <%# ── 필터 ── %>
  <div class="flex items-center gap-2 mb-6 overflow-x-auto">
    <% filters.forEach(function (f) { %>
      <a href="/live?filter=<%= f.value %>"
         class="shrink-0 px-4 py-2 rounded-full text-sm font-medium border transition
                <%= filter === f.value
                    ? 'bg-gray-900 text-white border-gray-900'
                    : 'bg-white text-gray-600 border-gray-200 hover:border-gray-400' %>">
        <%= f.label %>
      </a>
    <% }); %>
  </div>

  <%# ── 목록 ── %>
  <% if (!lives.length) { %>
    <div class="py-20 text-center text-gray-400">
      <i class="bi bi-broadcast text-4xl"></i>
      <p class="mt-3 text-sm">해당하는 방송이 없습니다.</p>
      <a href="/live" class="mt-4 inline-block text-sm text-[var(--gh-primary)] hover:underline">전체 방송 보기</a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% lives.forEach(function (l) { %>
        <% const p = cardPrice(l); %>
        <a href="<%= l.detailPath %>" class="group block bg-white rounded-xl overflow-hidden border border-gray-100 hover:border-gray-300 hover:shadow-md transition">
          <div class="relative aspect-video bg-gray-100 overflow-hidden">
            <% const img = l.list_thumbnail_url || l.main_product_image; %>
            <% if (img) { %>
              <img src="<%= img %>" alt="<%= l.title %>" loading="lazy"
                   class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center text-gray-300">
                <i class="bi bi-broadcast text-3xl"></i>
              </div>
            <% } %>

            <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold <%= STATUS_BADGE[l.status] %>">
              <% if (l.isLive) { %>
                <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span> LIVE
              <% } else { %>
                <%= l.statusLabel %>
              <% } %>
            </span>

            <% if (l.isReplay) { %>
              <span class="absolute top-3 right-3 px-2 py-1 rounded-full text-xs bg-black/60 text-white">
                <i class="bi bi-play-circle"></i> 다시보기
              </span>
            <% } %>
          </div>

          <div class="p-4">
            <h3 class="font-bold text-gray-900 line-clamp-2 group-hover:text-[var(--gh-primary)] transition"><%= l.title %></h3>

            <% if (l.status === 'SCHEDULED') { %>
              <p class="mt-1.5 text-xs text-purple-600">
                <i class="bi bi-clock"></i> <%= fmtDT(l.start_at) %> 시작
              </p>
            <% } else if (l.summary) { %>
              <p class="mt-1.5 text-xs text-gray-500 line-clamp-1"><%= l.summary %></p>
            <% } %>

            <% if (l.main_product_name) { %>
              <div class="mt-3 pt-3 border-t border-gray-100">
                <p class="text-xs text-gray-400 line-clamp-1 mb-1"><%= l.main_product_name %></p>
                <div class="flex items-baseline gap-1.5">
                  <% if (p.rate > 0) { %>
                    <span class="text-base font-extrabold text-red-600"><%= p.rate %>%</span>
                  <% } %>
                  <span class="text-base font-extrabold text-gray-900"><%= won(p.sale) %>원</span>
                  <% if (p.rate > 0) { %>
                    <span class="text-xs text-gray-400 line-through"><%= won(p.normal) %>원</span>
                  <% } %>
                </div>
              </div>
            <% } %>
          </div>
        </a>
      <% }); %>
    </div>

    <%# ── 페이지네이션 ── %>
    <% if (pagination.totalPages > 1) { %>
      <div class="mt-10 flex items-center justify-center gap-1">
        <% for (let i = 1; i <= pagination.totalPages; i++) { %>
          <a href="/live?filter=<%= filter %>&page=<%= i %>"
             class="w-9 h-9 flex items-center justify-center rounded-lg text-sm transition
                    <%= pagination.page === i
                        ? 'bg-gray-900 text-white'
                        : 'text-gray-600 hover:bg-gray-100' %>">
            <%= i %>
          </a>
        <% } %>
      </div>
    <% } %>
  <% } %>
</div>
