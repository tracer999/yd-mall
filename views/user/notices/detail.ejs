<div class="py-12 brand-page-surface min-h-screen">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden"
    >
      <div class="px-8 py-6 border-b border-gray-200 bg-white">
        <h3 class="text-2xl font-bold text-gray-900 mb-2">
          <%= notice.title %>
        </h3>
        <div class="flex items-center text-sm text-gray-500">
          <span><%= notice.created_at.toISOString().split('T')[0] %></span>
          <span class="mx-3 text-gray-300">|</span>
          <span>조회 <%= notice.view_count %></span>
        </div>
      </div>
      <div
        class="p-8 text-gray-800 leading-relaxed min-h-[300px]"
      >
        <%- notice.content %>
      </div>
      <div class="px-8 py-6 bg-gray-50 border-t border-gray-200 text-center">
        <a
          href="/notices"
          class="inline-flex items-center px-6 py-3 border border-gray-300 shadow-sm text-base font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
        >
          목록으로 돌아가기
        </a>
      </div>
    </div>
  </div>
</div>
