<div class="py-12 brand-page-surface min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-extrabold text-gray-900 text-center mb-10">공지사항</h2>
        
        <div class="flex flex-col">
            <!-- Desktop Table -->
            <div class="hidden md:block -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
                <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                    <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-20">번호</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-3/5">제목</th>
                                    <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-32">작성일</th>
                                    <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-24">조회수</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% notices.forEach(notice => { %>
                                    <tr class="<%= notice.importance ? 'bg-red-50 hover:bg-red-100' : 'hover:bg-gray-50' %> transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                                            <% if(notice.importance) { %>
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                    필독
                                                </span>
                                            <% } else { %>
                                                <span class="text-gray-500"><%= notice.id %></span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4">
                                            <a href="/notices/<%= notice.id %>" class="text-sm font-medium text-gray-900 hover:text-blue-600 hover:underline block truncate <%= notice.importance ? 'font-bold' : '' %>">
                                                <%= notice.title %>
                                            </a>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                                            <%= notice.created_at.toISOString().split('T')[0] %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                                            <%= notice.view_count %>
                                        </td>
                                    </tr>
                                <% }) %>
                                <% if(notices.length === 0) { %>
                                    <tr>
                                        <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                                            <div class="flex flex-col items-center justify-center">
                                                <i class="bi bi-megaphone text-4xl mb-3 text-gray-300"></i>
                                                <p>등록된 공지사항이 없습니다.</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Mobile Cards -->
            <div class="md:hidden space-y-4">
                <% notices.forEach(notice => { %>
                    <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm <%= notice.importance ? 'border-l-4 border-l-red-500 bg-red-50' : '' %>">
                        <div class="flex justify-between items-start mb-2">
                             <% if(notice.importance) { %>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
                                    필독
                                </span>
                            <% } else { %>
                                <span class="text-xs text-gray-500">No. <%= notice.id %></span>
                            <% } %>
                            <span class="text-xs text-gray-400"><%= notice.created_at.toISOString().split('T')[0] %></span>
                        </div>
                        <h3 class="text-base font-bold text-gray-900 mb-2">
                            <a href="/notices/<%= notice.id %>" class="hover:text-blue-600 <%= notice.importance ? 'text-red-900' : '' %>">
                                <%= notice.title %>
                            </a>
                        </h3>
                        <div class="flex items-center justify-between mt-3 text-sm text-gray-500">
                            <span>조회수 <%= notice.view_count %></span>
                            <a href="/notices/<%= notice.id %>" class="text-blue-600 font-medium">읽기 &rarr;</a>
                        </div>
                    </div>
                <% }) %>
                <% if(notices.length === 0) { %>
                    <div class="p-8 text-center text-gray-500 bg-white rounded-lg shadow-sm">
                        <i class="bi bi-megaphone text-3xl mb-2 text-gray-300"></i>
                         <p>등록된 공지사항이 없습니다.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
