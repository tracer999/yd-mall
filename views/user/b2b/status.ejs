<%
const tone = {
  green: 'bg-green-50 border-green-200 text-green-800',
  amber: 'bg-amber-50 border-amber-200 text-amber-900',
  red:   'bg-red-50 border-red-200 text-red-800',
  gray:  'bg-gray-50 border-gray-200 text-gray-700',
}[label.tone] || 'bg-gray-50 border-gray-200 text-gray-700';
const badgeTone = {
  green: 'bg-green-100 text-green-800 border-green-400',
  amber: 'bg-amber-100 text-amber-900 border-amber-400',
  red:   'bg-red-100 text-red-800 border-red-400',
  gray:  'bg-gray-100 text-gray-700 border-gray-400',
}[label.tone] || 'bg-gray-100 text-gray-700 border-gray-400';
const row = (k, v) => `<div class="flex py-3 border-b border-gray-100 last:border-0"><dt class="w-36 shrink-0 text-sm text-gray-500">${k}</dt><dd class="text-sm text-gray-900">${v || '-'}</dd></div>`;
%>
<div class="bg-gray-50 py-10 px-4 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-2xl">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-extrabold text-gray-900">사업자 회원 정보</h2>
      <span class="text-xs font-medium px-2.5 py-1 rounded border <%= badgeTone %>"><%= label.badge %></span>
    </div>

    <div class="rounded-md border p-4 mb-6 <%= tone %>">
      <p class="text-sm"><%= label.desc %></p>
      <% if (state === 'REJECTED' && profile.reject_reason) { %>
        <p class="mt-2 text-sm font-medium">사유: <%= profile.reject_reason %></p>
      <% } %>
      <% if (state === 'SUSPENDED' && profile.reject_reason) { %>
        <p class="mt-2 text-sm font-medium">사유: <%= profile.reject_reason %></p>
      <% } %>
    </div>

    <div class="bg-white shadow sm:rounded-lg px-6 py-4">
      <dl>
        <%- row('상호', profile.company_name) %>
        <%- row('사업자등록번호', formatBusinessNumber(profile.business_number)) %>
        <%- row('대표자명', profile.representative_name) %>
        <%- row('업태 / 종목', [profile.business_type, profile.business_category].filter(Boolean).join(' / ')) %>
        <%- row('사업장 주소', [profile.company_zipcode ? '(' + profile.company_zipcode + ')' : '', profile.company_address, profile.company_detailed_address].filter(Boolean).join(' ')) %>
        <%- row('세금계산서 이메일', profile.tax_invoice_email) %>
        <%- row('담당자', [profile.manager_name, profile.manager_phone].filter(Boolean).join(' / ')) %>
        <% if (profile.tier_name) { %><%- row('거래처 등급', profile.tier_name) %><% } %>
        <% if (profile.contract_valid_from || profile.contract_valid_to) { %>
          <%- row('계약 기간', [profile.contract_valid_from, profile.contract_valid_to].map(d => d ? new Date(d).toLocaleDateString('ko-KR') : '제한 없음').join(' ~ ')) %>
        <% } %>
      </dl>
    </div>

    <% if (state === 'APPROVED') { %>
      <div class="mt-6 bg-white shadow sm:rounded-lg px-6 py-4">
        <h3 class="text-sm font-bold text-gray-900 mb-2">기업 거래 안내</h3>
        <ul class="text-sm text-gray-600 space-y-1 list-disc list-inside">
          <li>가격은 <strong>공급가 별도</strong>로 표시됩니다.</li>
          <li>주문은 접수 후 담당자 확인을 거쳐 확정됩니다. 결제는 승인 후 안내드립니다.</li>
          <li>입금 기한은 승인일로부터 <strong><%= settings.paymentDueDays %>일</strong>입니다.</li>
          <% if (settings.bankAccountInfo) { %><li>입금 계좌: <%= settings.bankAccountInfo %></li><% } %>
        </ul>
      </div>
    <% } %>

    <% if (state === 'REJECTED') { %>
      <div class="mt-6 text-center">
        <a href="/b2b/apply"
           class="inline-flex items-center justify-center h-[42px] px-6 text-sm font-semibold rounded-md bg-blue-600 text-white hover:bg-blue-700 no-underline">
          다시 신청하기
        </a>
      </div>
    <% } %>

    <p class="mt-6 text-center text-sm text-gray-500">
      <a href="/mypage" class="underline underline-offset-2 hover:text-gray-700">마이페이지로</a>
    </p>
  </div>
</div>
