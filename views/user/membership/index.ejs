<%
  /*
   * 멤버십 안내 (정적 소개 — 안 A)
   *
   * 등급 산정을 하지 않는다. 주문·회원 데이터가 등급을 계산할 만큼 쌓이지 않아
   * (docs/사이트개선/gnb_menu_design.md §2-9) 제도 소개 페이지로만 운영한다.
   * 실제 등급 시스템(user_grade + 구매액 배치)은 데이터 축적 후 2차(안 B).
   *
   * locals: tiers[] = { code, name, threshold, rate, perks[], accent(bool) }
   *         benefits[] = { icon, title, desc }
   */
  const _tiers = tiers || [];
  const _benefits = benefits || [];
%>

<section class="py-14 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full mb-5"
           style="background: var(--gh-primary-soft); color: var(--gh-primary);">
        <i class="bi bi-award text-2xl"></i>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-3">멤버십</h1>
      <p class="text-base text-gray-500 leading-relaxed">
        구매 실적에 따라 등급이 오르고, 등급마다 적립·배송·전용 혜택이 커집니다.
      </p>
    </div>

    <!-- 등급표 -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-14">
      <% _tiers.forEach(function (t) { %>
        <div class="rounded-2xl border p-6 flex flex-col <%= t.accent ? 'shadow-lg' : '' %>"
             style="<%= t.accent ? 'border-color: var(--gh-primary);' : 'border-color: #e5e7eb;' %>">
          <div class="text-xs font-bold tracking-wide mb-1"
               style="color: <%= t.accent ? 'var(--gh-primary)' : '#9ca3af' %>;"><%= t.code %></div>
          <div class="text-lg font-extrabold text-gray-900 mb-3"><%= t.name %></div>
          <div class="text-sm text-gray-500 mb-4">
            <%= t.threshold %>
          </div>
          <div class="text-2xl font-extrabold mb-4" style="color: var(--gh-primary);">
            적립 <%= t.rate %>
          </div>
          <ul class="mt-auto space-y-2">
            <% (t.perks || []).forEach(function (p) { %>
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <i class="bi bi-check-circle-fill mt-0.5 text-xs" style="color: var(--gh-primary);"></i>
                <span><%= p %></span>
              </li>
            <% }); %>
          </ul>
        </div>
      <% }); %>
    </div>

    <!-- 혜택 안내 -->
    <% if (_benefits.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12">
        <% _benefits.forEach(function (b) { %>
          <div class="text-center px-4">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full mb-3"
                 style="background: var(--gh-primary-soft); color: var(--gh-primary);">
              <i class="bi <%= b.icon %> text-xl"></i>
            </div>
            <div class="font-bold text-gray-900 mb-1"><%= b.title %></div>
            <p class="text-sm text-gray-500 leading-relaxed"><%= b.desc %></p>
          </div>
        <% }); %>
      </div>
    <% } %>

    <div class="rounded-2xl bg-gray-50 p-6 sm:p-8 text-center">
      <p class="text-sm text-gray-500 mb-4">
        등급별 혜택과 적립 정책은 회사 사정에 따라 변경될 수 있습니다.
      </p>
      <a href="/mypage/points" class="gh-btn-primary inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold">
        내 적립금 확인 <i class="bi bi-chevron-right text-xs"></i>
      </a>
    </div>

  </div>
</section>
