<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">브랜드</h1>
        <p class="mt-2 text-sm text-gray-600">브랜드를 선택하면 해당 브랜드 상품으로 이동합니다.</p>
    </div>

    <% if (!brands || brands.length===0) { %>
        <div class="bg-white border border-gray-200 rounded-xl p-10 text-center text-gray-500">
            등록된 브랜드가 없습니다.
        </div>
        <% } else { %>
            <% const _liked = new Set((typeof likedBrandIds !== 'undefined' ? likedBrandIds : []).map(Number)); %>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
                <% brands.forEach(brand=> { const isLiked = _liked.has(Number(brand.id)); %>
                    <div class="relative">
                    <a href="/brands/<%= brand.id %>"
                        class="group flex flex-col items-center justify-start p-3 sm:p-4 h-28 sm:h-32 bg-white border border-gray-200 rounded-2xl hover:border-[var(--gh-primary)] hover:shadow-md transition-all">
                        <% if (brand.logo_image_path) { %>
                            <div class="w-full h-8 sm:h-10 flex items-center justify-center mb-2 mt-1">
                                <img src="<%= brand.logo_image_path %>" alt="<%= brand.name %>"
                                    class="w-auto h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-300">
                            </div>
                            <div
                                class="text-xs sm:text-sm leading-tight font-medium text-gray-600 group-hover:text-[var(--gh-primary)] text-center w-full border-t border-gray-100 pt-2 min-h-[2.25rem] flex items-start justify-center shrink-0">
                                <%= brand.name %>
                            </div>
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center">
                                    <div
                                        class="text-sm sm:text-base font-bold text-gray-800 group-hover:text-[var(--gh-primary)] transition-colors text-center line-clamp-2">
                                        <%= brand.name %>
                                    </div>
                                </div>
                                <% } %>
                    </a>
                    <button type="button"
                        class="brand-like-btn absolute top-1.5 right-1.5 z-10 w-7 h-7 rounded-full bg-white/90 backdrop-blur-sm shadow-sm flex items-center justify-center transition hover:bg-white <%= isLiked ? 'text-red-500' : 'text-gray-300 hover:text-red-400' %>"
                        data-brand-id="<%= brand.id %>" data-liked="<%= isLiked ? '1' : '0' %>"
                        aria-pressed="<%= isLiked ? 'true' : 'false' %>"
                        title="<%= isLiked ? '찜 해제' : '브랜드 찜하기' %>">
                        <i class="bi <%= isLiked ? 'bi-heart-fill' : 'bi-heart' %> text-sm"></i>
                    </button>
                    </div>
                    <% }) %>
            </div>
            <% } %>

<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.brand-like-btn').forEach(function (btn) {
        btn.addEventListener('click', async function (e) {
            e.preventDefault();
            try {
                const res = await fetch('/likes/brand/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ brandId: Number(btn.dataset.brandId) })
                });
                if (res.status === 401 || res.redirected) { location.href = '/auth/login'; return; }
                const result = await res.json();
                if (!result.success) { alert(result.message || '처리에 실패했습니다.'); return; }

                const icon = btn.querySelector('i');
                btn.dataset.liked = result.liked ? '1' : '0';
                btn.setAttribute('aria-pressed', result.liked ? 'true' : 'false');
                btn.title = result.liked ? '찜 해제' : '브랜드 찜하기';
                icon.className = 'bi ' + (result.liked ? 'bi-heart-fill' : 'bi-heart') + ' text-sm';
                btn.classList.toggle('text-red-500', result.liked);
                btn.classList.toggle('text-gray-300', !result.liked);
                btn.classList.toggle('hover:text-red-400', !result.liked);
            } catch (err) {
                location.href = '/auth/login';
            }
        });
    });
});
</script>
</div>
