<%
  /*
   * 브랜드 홈 — 브랜드 전용 허브
   * docs/사이트개선/brand_hub_dev_plan.md §5-1
   *
   * locals: popular, newBrands, rootCategories, activeRoot, catBrands,
   *         weeklyBenefits, listing{brands,total,page,pages}, initialCounts,
   *         initialBuckets, filters{initial,sort}, likedBrandIds
   */
  const liked = new Set((likedBrandIds || []).map(Number));
  const isLiked = (b) => liked.has(Number(b.id));
  const q = (obj) => {
    const p = new URLSearchParams();
    Object.entries(obj).forEach(([k, v]) => { if (v) p.set(k, v); });
    const s = p.toString();
    return s ? `?${s}` : '';
  };
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">

  <%# 전체 공통 브랜드 배너 (배너 관리 > 브랜드 배너 > 전체 공통) — 등록이 없으면 아무것도 그리지 않는다.
      개별 브랜드 배너는 대상이 정해져야 하므로 이 화면에는 걸리지 않는다(상세관 전용). %>
  <% if (typeof brandBanners !== 'undefined' && brandBanners && brandBanners.length) { %>
    <%- include('../products/_category_banner', { banners: brandBanners }) %>
  <% } %>

  <!-- ① 브랜드 검색 -->
  <section class="mb-10">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">브랜드</h1>
    <p class="mt-2 text-sm text-gray-600">브랜드별 상품·신상품·베스트·혜택을 한 번에 확인하세요.</p>

    <div class="relative mt-5 max-w-2xl">
      <i class="bi bi-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
      <input type="text" id="brandSearch" autocomplete="off"
             placeholder="브랜드명·영문명·초성으로 검색 (예: 나이키, NIKE, ㄴㅇㅋ)"
             class="w-full pl-11 pr-4 py-3.5 border border-gray-300 rounded-full text-sm focus:outline-none focus:border-[var(--gh-primary)] focus:ring-2 focus:ring-[var(--gh-primary)]/20">
      <div id="brandSearchResults"
           class="hidden absolute z-30 left-0 right-0 mt-2 bg-white border border-gray-200 rounded-2xl shadow-lg overflow-hidden max-h-96 overflow-y-auto"></div>
    </div>
  </section>

  <!-- ② 이번 주 브랜드 혜택 (슬라이더) — 검색 바로 아래 첫 콘텐츠 블록 -->
  <% if (weeklyBenefits && weeklyBenefits.length) { %>
    <%- include('./_benefit_slider', { weeklyBenefits: weeklyBenefits }) %>
  <% } %>

  <!-- ③ 인기 브랜드 — 브랜드 한 줄 = 해시태그 + 특집전 + 상품 캐러셀 -->
  <% if (showcase && showcase.length) { %>
  <section class="mb-12">
    <div class="flex items-end justify-between mb-6">
      <h2 class="text-xl font-bold text-gray-900">인기 브랜드</h2>
      <a href="<%= q({ sort: 'popular' }) %>#all-brands" class="text-sm text-gray-500 hover:text-[var(--gh-primary)]">전체보기 ›</a>
    </div>
    <% showcase.forEach(function (b) { %>
      <%- include('../../partials/brand/showcase_row', { brand: b, isLiked: isLiked(b) }) %>
    <% }) %>
  </section>
  <% } else if (popular && popular.length) { %>
    <%# 상품이 모자라 캐러셀을 못 만드는 몰(브랜드당 상품 4개 미만)은 기존 로고 타일로 떨어진다 %>
    <section class="mb-12">
      <div class="flex items-end justify-between mb-4">
        <h2 class="text-xl font-bold text-gray-900">인기 브랜드</h2>
        <a href="<%= q({ sort: 'popular' }) %>#all-brands" class="text-sm text-gray-500 hover:text-[var(--gh-primary)]">전체보기 ›</a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 sm:gap-4">
        <% popular.forEach(function (b, i) { %>
          <%- include('../../partials/brand/tile', { brand: b, isLiked: isLiked(b), rank: i + 1 }) %>
        <% }) %>
      </div>
    </section>
  <% } %>

  <!-- ④ 신규 입점 브랜드 -->
  <% if (newBrands && newBrands.length) { %>
  <section class="mb-12">
    <div class="flex items-end justify-between mb-4">
      <h2 class="text-xl font-bold text-gray-900">신규 입점 브랜드</h2>
      <a href="<%= q({ sort: 'new' }) %>#all-brands" class="text-sm text-gray-500 hover:text-[var(--gh-primary)]">전체보기 ›</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 sm:gap-4">
      <% newBrands.forEach(function (b) { %>
        <%- include('../../partials/brand/tile', { brand: b, isLiked: isLiked(b) }) %>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- ⑤ 카테고리별 브랜드 -->
  <% if (rootCategories && rootCategories.length) { %>
  <section class="mb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-4">카테고리별 브랜드</h2>
    <div class="flex gap-2 overflow-x-auto pb-2 mb-5 -mx-1 px-1">
      <% rootCategories.forEach(function (c) { const on = Number(activeRoot) === Number(c.id); %>
        <a href="<%= q({ root: c.id }) %>#cat-brands"
           class="shrink-0 px-4 py-2 rounded-full border text-sm whitespace-nowrap transition
                  <%= on ? 'bg-[var(--gh-primary)] border-[var(--gh-primary)] text-white font-semibold'
                         : 'bg-white border-gray-200 text-gray-700 hover:border-gray-400' %>">
          <%= c.name %> <span class="<%= on ? 'text-white/70' : 'text-gray-400' %>"><%= c.brand_count %></span>
        </a>
      <% }) %>
    </div>
    <div id="cat-brands" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 sm:gap-4">
      <% (catBrands || []).forEach(function (b) { %>
        <%- include('../../partials/brand/tile', { brand: b, isLiked: isLiked(b) }) %>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- ⑥ 전체 브랜드 -->
  <section id="all-brands">
    <div class="flex flex-wrap items-end justify-between gap-3 mb-4">
      <h2 class="text-xl font-bold text-gray-900">
        전체 브랜드 <span class="text-gray-400 font-medium text-base">(<%= Number(listing.total).toLocaleString() %>)</span>
      </h2>
      <div class="flex gap-1.5">
        <% const sorts = [['count','상품많은순'],['popular','인기순'],['name','가나다순'],['new','신규순']]; %>
        <% sorts.forEach(function (s) { const on = filters.sort === s[0]; %>
          <a href="<%= q({ initial: filters.initial, sort: s[0] }) %>#all-brands"
             class="px-3 py-1.5 rounded-full text-xs border transition
                    <%= on ? 'bg-gray-900 border-gray-900 text-white font-semibold'
                           : 'bg-white border-gray-200 text-gray-600 hover:border-gray-400' %>">
            <%= s[1] %>
          </a>
        <% }) %>
      </div>
    </div>

    <!-- 초성 인덱스 -->
    <div class="flex flex-wrap gap-1 mb-6 p-3 bg-gray-50 rounded-xl">
      <a href="<%= q({ sort: filters.sort }) %>#all-brands"
         class="px-2.5 py-1 rounded text-xs font-medium transition
                <%= !filters.initial ? 'bg-gray-900 text-white' : 'text-gray-600 hover:bg-white' %>">전체</a>
      <% initialBuckets.forEach(function (ini) {
           const cnt = initialCounts[ini] || 0;
           const on = filters.initial === ini; %>
        <% if (cnt === 0) { %>
          <span class="px-2.5 py-1 rounded text-xs text-gray-300 cursor-default"><%= ini %></span>
        <% } else { %>
          <a href="<%= q({ initial: ini, sort: filters.sort }) %>#all-brands"
             class="px-2.5 py-1 rounded text-xs font-medium transition
                    <%= on ? 'bg-gray-900 text-white' : 'text-gray-700 hover:bg-white' %>"><%= ini %></a>
        <% } %>
      <% }) %>
    </div>

    <% if (!listing.brands.length) { %>
      <div class="bg-white border border-gray-200 rounded-xl p-10 text-center text-gray-500">
        해당하는 브랜드가 없습니다.
      </div>
    <% } else { %>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 sm:gap-4">
        <% listing.brands.forEach(function (b) { %>
          <%- include('../../partials/brand/tile', { brand: b, isLiked: isLiked(b) }) %>
        <% }) %>
      </div>

      <!-- 페이지네이션 -->
      <% if (listing.pages > 1) {
           const cur = listing.page;
           const from = Math.max(1, cur - 2);
           const to = Math.min(listing.pages, from + 4); %>
        <nav class="flex justify-center items-center gap-1 mt-10">
          <% if (cur > 1) { %>
            <a href="<%= q({ initial: filters.initial, sort: filters.sort, page: cur - 1 }) %>#all-brands"
               class="px-3 py-2 rounded-lg border border-gray-200 text-sm text-gray-600 hover:border-gray-400">‹</a>
          <% } %>
          <% if (from > 1) { %>
            <a href="<%= q({ initial: filters.initial, sort: filters.sort, page: 1 }) %>#all-brands"
               class="px-3 py-2 rounded-lg border border-gray-200 text-sm text-gray-600 hover:border-gray-400">1</a>
            <span class="px-1 text-gray-400">…</span>
          <% } %>
          <% for (let i = from; i <= to; i++) { %>
            <a href="<%= q({ initial: filters.initial, sort: filters.sort, page: i }) %>#all-brands"
               class="px-3 py-2 rounded-lg border text-sm transition
                      <%= i === cur ? 'bg-gray-900 border-gray-900 text-white font-semibold'
                                    : 'border-gray-200 text-gray-600 hover:border-gray-400' %>"><%= i %></a>
          <% } %>
          <% if (to < listing.pages) { %>
            <span class="px-1 text-gray-400">…</span>
            <a href="<%= q({ initial: filters.initial, sort: filters.sort, page: listing.pages }) %>#all-brands"
               class="px-3 py-2 rounded-lg border border-gray-200 text-sm text-gray-600 hover:border-gray-400"><%= listing.pages %></a>
          <% } %>
          <% if (cur < listing.pages) { %>
            <a href="<%= q({ initial: filters.initial, sort: filters.sort, page: cur + 1 }) %>#all-brands"
               class="px-3 py-2 rounded-lg border border-gray-200 text-sm text-gray-600 hover:border-gray-400">›</a>
          <% } %>
        </nav>
      <% } %>
    <% } %>
  </section>
</div>

<%- include('../../partials/brand/like_script') %>

<script>
/*
 * 브랜드 쇼케이스 캐러셀 — 좌우 화살표.
 *
 * 자동 넘김은 하지 않는다. 여러 줄이 동시에 자동으로 움직이면 화면이 산만해지고,
 * 사용자가 읽는 중에 카드가 밀려나간다(혜택 슬라이더는 한 줄뿐이라 자동 넘김이 성립한다).
 *
 * 끝에 닿으면 버튼을 비활성화한다 — 눌러도 안 움직이는 버튼을 남기지 않는다.
 */
(function () {
    document.querySelectorAll('[data-showcase]').forEach(function (root) {
        const track = root.querySelector('[data-track]');
        const prev = root.querySelector('[data-scroll="prev"]');
        const next = root.querySelector('[data-scroll="next"]');
        if (!track || !prev || !next) return;

        const step = function () {
            const card = track.firstElementChild;
            // 카드 2장씩 넘긴다 — 한 장씩이면 답답하고, 한 화면씩이면 맥락이 끊긴다.
            return card ? (card.offsetWidth + 16) * 2 : track.clientWidth;
        };

        const sync = function () {
            const max = track.scrollWidth - track.clientWidth;
            prev.disabled = track.scrollLeft <= 4;
            next.disabled = track.scrollLeft >= max - 4;
        };

        prev.addEventListener('click', function () { track.scrollBy({ left: -step(), behavior: 'smooth' }); });
        next.addEventListener('click', function () { track.scrollBy({ left: step(), behavior: 'smooth' }); });
        track.addEventListener('scroll', sync, { passive: true });
        window.addEventListener('resize', sync);
        sync();
    });
})();

// 브랜드 검색 자동완성 — /brands/search.json
(function () {
    const input = document.getElementById('brandSearch');
    const box = document.getElementById('brandSearchResults');
    if (!input || !box) return;
    let timer = null;

    const render = (rows) => {
        if (!rows.length) {
            box.innerHTML = '<div class="px-4 py-6 text-center text-sm text-gray-500">검색 결과가 없습니다.</div>';
            box.classList.remove('hidden');
            return;
        }
        box.innerHTML = rows.map(function (b) {
            const thumb = b.logo_image_path
                ? '<img src="' + b.logo_image_path + '" alt="" class="w-full h-full object-contain p-1">'
                : (b.repImages && b.repImages[0]
                    ? '<img src="' + b.repImages[0] + '" alt="" class="w-full h-full object-cover">'
                    : '<span class="text-xs font-bold text-gray-300">' + b.name.slice(0, 2) + '</span>');
            const meta = ['상품 ' + Number(b.product_count || 0).toLocaleString() + '개'];
            if (b.topCategoryName) meta.push(b.topCategoryName);
            if (b.benefit_count > 0) meta.push('진행 중 혜택 ' + b.benefit_count + '개');
            return '<a href="/brands/' + b.id + '" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition">'
                 + '<span class="shrink-0 w-11 h-11 rounded-lg bg-gray-50 border border-gray-100 overflow-hidden flex items-center justify-center">' + thumb + '</span>'
                 + '<span class="min-w-0 flex-1">'
                 + '<span class="flex items-center gap-1.5">'
                 + '<span class="text-sm font-semibold text-gray-900 truncate">' + b.name + '</span>'
                 + (b.official_yn ? '<span class="shrink-0 px-1 py-0.5 rounded bg-[var(--gh-primary)] text-white text-[10px]">공식</span>' : '')
                 + (b.name_en ? '<span class="shrink-0 text-xs text-gray-400">' + b.name_en + '</span>' : '')
                 + '</span>'
                 + '<span class="block text-xs text-gray-500 truncate">' + meta.join(' · ') + '</span>'
                 + '</span></a>';
        }).join('');
        box.classList.remove('hidden');
    };

    input.addEventListener('input', function () {
        const kw = input.value.trim();
        clearTimeout(timer);
        if (!kw) { box.classList.add('hidden'); return; }
        timer = setTimeout(async function () {
            try {
                const res = await fetch('/brands/search.json?q=' + encodeURIComponent(kw));
                const data = await res.json();
                render(data.brands || []);
            } catch (e) { box.classList.add('hidden'); }
        }, 200);
    });

    document.addEventListener('click', function (e) {
        if (!box.contains(e.target) && e.target !== input) box.classList.add('hidden');
    });
})();
</script>
