<%
  /*
   * 기획전 목록
   *
   * 발행된 기획전이 0건이면 컨트롤러가 준비중 랜딩으로 되돌리므로, 여기 도달하면 최소 1건은 있다.
   * (단, 2페이지 이후로 넘어가면 빈 목록이 나올 수 있다 — 그때는 안내 문구를 보여준다.)
   *
   * 카테고리 필터와 예정/진행중/종료 상태 필터는 2차 범위다.
   * 지금은 정렬만 제공하고, 진행 상태는 카드의 배지로만 구분한다.
   *
   * 상단 큰 배너는 이 화면이 고르지 않는다. 예전에는 "진행중 기획전 중 첫 번째"를
   * 임의로 골라 크게 걸었는데, 무엇이 걸릴지 운영자가 정할 수 없었다.
   * 지금은 **배너 관리 → 메뉴별 배너 → 기획전**(group_key='menu:EXHIBITION')이 그 자리를
   * 담당한다. 레이아웃이 본문 위(제목보다 위)에 얹지 않도록 컨트롤러가 넘겨받아
   * 여기 — 제목 아래, 목록 위 — 에서 직접 렌더한다.
   */
  const _showcase = (typeof showcase !== 'undefined' && showcase) ? showcase : [];
  const rest = exhibitions || [];
  const _p = pagination;
  const pageUrl = (n) => `/exhibition?sort=${encodeURIComponent(sort)}&page=${n}`;
%>

<div class="bg-white border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900">기획전</h1>
    <p class="mt-2 text-sm sm:text-base text-gray-500">시즌·브랜드·테마별로 엄선한 구성을 만나보세요.</p>
  </div>
</div>

<%# 배너 관리에 등록한 기획전 배너. 자체 컨테이너를 갖는 partial 이라 본문 컨테이너 밖에 둔다. %>
<% if (_showcase.length) { %>
  <%- include('../../partials/storefront/menu_showcase', { menuShowcase: _showcase }) %>
<% } %>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">

  <%# ── 정렬 ────────────────────────────────────────── %>
  <div class="mb-5 flex items-center justify-between gap-4">
    <p class="text-sm text-gray-500">전체 <strong class="text-gray-900"><%= _p.total %></strong>개</p>
    <div class="flex items-center gap-1">
      <% sorts.forEach(function (s) { %>
        <a href="/exhibition?sort=<%= s.value %>"
           class="px-3 py-1.5 text-xs rounded-full no-underline <%= sort === s.value
             ? 'bg-gray-900 text-white font-semibold'
             : 'text-gray-500 hover:bg-gray-100' %>"><%= s.label %></a>
      <% }); %>
    </div>
  </div>

  <%# ── 카드 리스트 ─────────────────────────────────── %>
  <% if (rest.length === 0) { %>
    <div class="py-24 text-center">
      <i class="bi bi-stars text-4xl text-gray-200"></i>
      <p class="mt-4 text-sm text-gray-500">표시할 기획전이 없습니다.</p>
      <a href="/exhibition" class="mt-4 inline-block text-sm text-gray-600 hover:text-gray-900">첫 페이지로</a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% rest.forEach(function (e) { %>
        <%- include('../../partials/exhibition/card', { exhibition: e }) %>
      <% }); %>
    </div>
  <% } %>

  <%# ── 페이지네이션 ────────────────────────────────── %>
  <% if (_p.totalPages > 1) { %>
    <nav class="mt-10 flex items-center justify-center gap-1">
      <% if (_p.page > 1) { %>
        <a href="<%= pageUrl(_p.page - 1) %>"
           class="px-3 py-2 text-sm rounded-md text-gray-500 hover:bg-gray-100 no-underline">
          <i class="bi bi-chevron-left"></i>
        </a>
      <% } %>
      <% for (let n = 1; n <= _p.totalPages; n++) { %>
        <a href="<%= pageUrl(n) %>"
           class="min-w-[38px] text-center px-3 py-2 text-sm rounded-md no-underline <%= n === _p.page
             ? 'bg-gray-900 text-white font-semibold'
             : 'text-gray-600 hover:bg-gray-100' %>"><%= n %></a>
      <% } %>
      <% if (_p.page < _p.totalPages) { %>
        <a href="<%= pageUrl(_p.page + 1) %>"
           class="px-3 py-2 text-sm rounded-md text-gray-500 hover:bg-gray-100 no-underline">
          <i class="bi bi-chevron-right"></i>
        </a>
      <% } %>
    </nav>
  <% } %>

</div>
