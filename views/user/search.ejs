<style>
    .status-banner {
        text-shadow: 0 2px 6px rgba(0, 0, 0, 0.45);
    }
    @keyframes badge-blink {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.06); }
    }
    .status-banner-blink {
        animation: badge-blink 1.4s infinite ease-in-out;
    }
    .status-image-dim {
        filter: grayscale(0.6);
        opacity: 0.7;
    }
    .status-image-overlay {
        background: radial-gradient(circle at center, rgba(0,0,0,0.25) 0, rgba(0,0,0,0.4) 55%, rgba(0,0,0,0.55) 100%);
    }
</style>
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center gap-3 mb-6">
        <button onclick="history.back()" class="sm:hidden flex items-center justify-center w-9 h-9 rounded-full bg-gray-100 hover:bg-gray-200 text-gray-600 transition">
            <i class="bi bi-chevron-left text-lg"></i>
        </button>
        <h1 class="text-2xl font-bold text-gray-900">상품 검색</h1>
    </div>

    <form action="/search" method="GET" class="mb-6">
        <div class="flex gap-2 items-center">
            <input type="text" name="q" value="<%= query || '' %>" minlength="2" autocomplete="off"
                placeholder="검색어를 입력하세요 (2자 이상)"
                class="flex-1 border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--gh-primary)] focus:border-[var(--gh-primary)]" />
            <button type="submit"
                class="px-5 py-2.5 rounded-xl bg-[var(--gh-primary)] text-white text-sm font-semibold hover:bg-[var(--gh-primary-dark)]">
                검색
            </button>
        </div>
        <p class="mt-2 text-xs text-gray-500">엔터 또는 검색 버튼을 눌러 검색합니다. (최대 50개 결과 표시)</p>
    </form>

    <% if (!query || query.trim().length < 2) { %>
        <div class="bg-white border border-dashed border-gray-300 rounded-2xl p-10 text-center text-gray-500">
            <p class="mb-2">검색어를 2자 이상 입력한 후 검색해 주세요.</p>
        </div>
    <% } else { %>
        <div class="flex items-center justify-between mb-4 text-sm text-gray-600">
            <p>"<span class="font-semibold"><%= query.trim() %></span>" 에 대한 검색 결과 <span class="font-semibold"><%= total %></span>개</p>
        </div>

        <% if (!products || products.length === 0) { %>
            <div class="bg-white border border-gray-200 rounded-2xl p-10 text-center">
                <p class="text-lg font-bold text-gray-800 mb-4">원하시는 상품을 찾지 못하셨나요?</p>
                <p class="text-sm text-gray-500 leading-relaxed mb-1">찾으시는 제품이 등록 전일 수 있습니다.</p>
                <p class="text-sm text-gray-500 leading-relaxed mb-1">필요한 상품명이나 이미지를 <span class="font-semibold text-gray-700">카카오톡 고객센터</span>로 남겨주세요.</p>
                <p class="text-sm text-gray-500 leading-relaxed mb-6">담당자가 직접 확인하여 최적의 상품을 제안해 드립니다.</p>
                <% const kakaoUrl = (siteSettings && siteSettings.kakao_channel_url) || '#'; %>
                <a href="<%= kakaoUrl %>" target="_blank" rel="noopener noreferrer"
                    data-kakao-source="search_no_result" data-kakao-label="검색 결과 없음 문의"
                    class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#FEE500] text-[#3C1E1E] text-sm font-bold hover:brightness-95 transition no-underline">
                    <img src="https://developers.kakao.com/assets/img/about/logos/kakaotalksharing/kakaotalk_sharing_btn_small.png" alt="" class="w-5 h-5">
                    카카오톡 문의하기
                </a>
            </div>
        <% } else { %>
            <div class="space-y-3">
                <% products.forEach(p => { %>
                    <% const isTheme = (p.category_type === 'THEME'); %>
                    <% const detailPath = (p.slug && p.slug.trim()) ? `/products/${encodeURIComponent(p.slug)}` : `/products/view/${p.id}`; %>
                    <% 
                        const status = p.status || 'ON';
                        const stock = (p.stock != null && p.stock >= 0) ? p.stock : 0;
                        const isSoldOut = (status === 'SOLD_OUT') || stock <= 0;
                        const isStopped = status === 'OFF';
                        const isComingSoon = status === 'COMING_SOON';
                    %>
                    <a href="<%= detailPath %>" class="block bg-white border border-gray-200 rounded-2xl p-4 hover:border-[var(--gh-primary)] hover:shadow-sm transition flex gap-4">
                        <div class="w-24 h-24 flex-shrink-0 rounded-xl overflow-hidden bg-gray-100 relative">
                            <img src="<%= p.thumbnail_image || p.main_image || 'https://via.placeholder.com/120x120?text=No+Image' %>" alt="" class="w-full h-full object-cover <%= (isSoldOut && !isStopped && !isComingSoon) ? 'status-image-dim' : '' %>" />
                            
                            <% if (isStopped || isComingSoon || isSoldOut) { %>
                                <div class="absolute inset-0 flex items-center justify-center pointer-events-none <%= (isSoldOut && !isStopped && !isComingSoon) ? 'status-image-overlay' : '' %>">
                                    <div class="px-2 py-1 rounded text-white text-[10px] font-bold status-banner shadow-sm backdrop-blur-sm
                                        <%= isStopped
                                            ? 'bg-red-600/90'
                                            : (isComingSoon
                                                ? 'bg-gradient-to-r from-yellow-400/90 to-orange-400/90 text-white status-banner-blink'
                                                : 'bg-gray-800/85') %>">
                                        <% if (isStopped) { %>
                                            판매중지
                                        <% } else if (isComingSoon) { %>
                                            COMING SOON
                                        <% } else { %>
                                            SOLD OUT
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                        <div class="flex-1 min-w-0 flex flex-col justify-between">
                            <div>
                                <div class="flex items-center gap-2 mb-1 text-xs">
                                    <% if (p.category_name) { %>
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full border text-[10px] <%= isTheme ? 'border-purple-200 text-purple-700 bg-purple-50' : 'border-green-200 text-green-700 bg-green-50' %>">
                                            <%= p.category_name %>
                                            <% if (isTheme) { %>
                                                <span class="ml-1 text-[9px] text-purple-500">테마</span>
                                            <% } %>
                                        </span>
                                    <% } %>
                                </div>
                                <p class="text-sm font-medium text-gray-900 mb-0.5 line-clamp-2"><%= p.name %></p>
                                <p class="text-xs text-gray-500 truncate"><%= p.provider || '' %></p>
                            </div>
                            <%
                                const _price = p.price || 0;
                                const _listPrice = (p.original_price && p.original_price > _price) ? p.original_price : null;
                            %>
                            <div class="flex items-end justify-end gap-2 mt-2">
                                <% if (_listPrice) { %>
                                    <span class="text-xs text-gray-400 line-through"><%= Number(_listPrice).toLocaleString() %>원</span>
                                <% } %>
                                <span class="font-bold text-gray-900 text-base"><%= Number(_price).toLocaleString() %>원</span>
                            </div>
                        </div>
                    </a>
                <% }); %>
            </div>
        <% } %>
    <% } %>
</div>
