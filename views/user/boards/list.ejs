<div class="py-12 brand-page-surface min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-extrabold text-gray-900 text-center mb-8">
            <%= title %>
        </h2>

        <div class="mb-8 flex justify-center gap-3">
            <a href="/boards/notice"
                class="px-6 py-2 rounded-full text-sm font-semibold transition-colors duration-200 <%= type === 'notice' ? 'brand-badge shadow-md' : 'bg-white border border-gray-200 text-gray-600 hover:bg-gray-50' %>">공지사항</a>
            <a href="/boards/guide"
                class="px-6 py-2 rounded-full text-sm font-semibold transition-colors duration-200 <%= type === 'guide' ? 'brand-badge shadow-md' : 'bg-white border border-gray-200 text-gray-600 hover:bg-gray-50' %>">상품안내</a>
        </div>

        <div class="flex flex-col mb-8">
            <!-- Desktop Table -->
            <div class="hidden md:block shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col"
                                class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-20">
                                번호</th>
                            <th scope="col"
                                class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                제목</th>
                            <th scope="col"
                                class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-32">
                                작성일</th>
                            <th scope="col"
                                class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-24">
                                조회수</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <% if(posts.length===0) { %>
                            <tr>
                                <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                                    <div class="flex flex-col items-center justify-center">
                                        <i class="bi bi-megaphone text-4xl mb-3 text-gray-300"></i>
                                        <p>등록된 게시물이 없습니다.</p>
                                    </div>
                                </td>
                            </tr>
                            <% } %>
                                <% posts.forEach(post=> { %>
                                    <tr class="<%= post.importance ? 'bg-red-50 hover:bg-red-100' : 'hover:bg-gray-50' %> transition-colors cursor-pointer"
                                        onclick="handleClick('<%= post.id %>')">
                                        <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                                            <% if(post.importance) { %>
                                                <span
                                                    class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                    필독
                                                </span>
                                                <% } else { %>
                                                    <span class="text-gray-500">
                                                        <%= post.id %>
                                                    </span>
                                                    <% } %>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span
                                                class="text-sm font-medium text-gray-900 hover:text-[var(--gh-primary)] hover:underline block truncate <%= post.importance ? 'font-bold' : '' %>">
                                                <%= post.title %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                                            <%= new Date(post.created_at).toLocaleDateString() %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                                            <%= post.view_count %>
                                        </td>
                                    </tr>
                                    <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- Mobile Cards -->
            <div class="md:hidden space-y-4">
                <% if(posts.length===0) { %>
                    <div class="p-8 text-center text-gray-500 bg-white rounded-lg shadow-sm border border-gray-200">
                        <i class="bi bi-megaphone text-3xl mb-2 text-gray-300"></i>
                        <p>등록된 게시물이 없습니다.</p>
                    </div>
                    <% } %>
                        <% posts.forEach(post=> { %>
                            <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm cursor-pointer hover:shadow-md transition-shadow <%= post.importance ? 'border-l-4 border-l-red-500 bg-red-50' : '' %>"
                                onclick="handleClick('<%= post.id %>')">
                                <div class="flex justify-between items-start mb-2">
                                    <% if(post.importance) { %>
                                        <span
                                            class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
                                            필독
                                        </span>
                                        <% } else { %>
                                            <span class="text-xs text-gray-500">No. <%= post.id %></span>
                                            <% } %>
                                                <span class="text-xs text-gray-400">
                                                    <%= new Date(post.created_at).toLocaleDateString() %>
                                                </span>
                                </div>
                                <h3 class="text-base font-bold text-gray-900 mb-2">
                                    <span
                                        class="hover:text-[var(--gh-primary)] <%= post.importance ? 'text-red-900' : '' %>">
                                        <%= post.title %>
                                    </span>
                                </h3>
                                <div class="flex items-center justify-between mt-3 text-sm text-gray-500">
                                    <span>조회수 <%= post.view_count %></span>
                                    <span class="text-[var(--gh-primary)] font-medium">읽기 &rarr;</span>
                                </div>
                            </div>
                            <% }) %>
            </div>
        </div>

        <% if (totalPages> 1) { %>
            <div class="flex justify-center mt-8 gap-2">
                <% for(let i=1; i<=totalPages; i++) { %>
                    <a href="?page=<%= i %>"
                        class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors duration-200 <%= currentPage === i ? 'bg-[var(--gh-primary)] text-white shadow-md' : 'bg-white border border-gray-200 text-gray-600 hover:bg-gray-50' %>">
                        <%= i %>
                    </a>
                    <% } %>
            </div>
            <% } %>
    </div>
</div>

<script>
    const boardType = '<%= type %>';
    const isLoggedIn = '<%= user ? "true" : "false" %>' === 'true';

    function handleClick(id) {
        if (boardType === 'guide') {
            if (isLoggedIn) {
                location.href = `/boards/${boardType}/${id}`;
            } else {
                if (confirm('로그인이 필요한 서비스입니다. 로그인 페이지로 이동하시겠습니까?')) {
                    location.href = '/auth/login';
                }
            }
            return;
        }
        location.href = `/boards/${boardType}/${id}`;
    }
</script>