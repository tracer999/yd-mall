<div class="manual-welcome" style="margin-top: 0.5rem;">
    <h2 style="margin-top: 0; font-size: 1.6rem; color: #0f172a;">매뉴얼 & 가이드</h2>
    <p style="margin: 0.5rem 0 1.25rem; color: #64748b;">
        몰을 처음 만든다면 <strong>몰 빌더 가이드</strong>부터 보세요. 몰을 만든 뒤 운영에 필요한 작업은
        <strong>관리자 매뉴얼</strong>, 고객이 보는 화면은 <strong>쇼핑몰 매뉴얼</strong>에서 설명합니다.
    </p>

    <div style="display: flex; flex-direction: column; gap: 0.9rem;">
        <% sections.forEach(function (item) { %>
            <a href="<%= item.href %>"
               style="display: block; padding: 1rem 1.1rem; border-radius: 0.75rem; background: #f8fafc; border: 1px solid #e2e8f0; text-decoration: none; color: #0f172a; box-shadow: 0 1px 2px rgba(15,23,42,0.03); transition: background 0.15s ease, box-shadow 0.15s ease, transform 0.08s ease;">
                <div style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: #94a3b8; margin-bottom: 0.35rem;">
                    <%= item.key === 'admin' ? 'Operators' : (item.key === 'mall_builder' ? 'Builder' : 'Users') %>
                </div>
                <div style="font-weight: 600; font-size: 1.05rem; margin-bottom: 0.3rem;">
                    <%= item.title %>
                </div>
                <% if (item.description) { %>
                    <div style="font-size: 0.9rem; color: #64748b; line-height: 1.6;">
                        <%= item.description %>
                    </div>
                <% } %>
            </a>
        <% }); %>
    </div>
</div>
